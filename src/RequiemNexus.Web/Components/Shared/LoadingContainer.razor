@if (Loading)
{
    <SkeletonLoader Variant="rows" Count="4" />
}
else
{
    @ChildContent
}

@code {
    /// <summary>Gets or sets a value indicating whether content is loading.</summary>
    [Parameter]
    public bool Loading { get; set; }

    /// <summary>Gets or sets the content to render when not loading.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
