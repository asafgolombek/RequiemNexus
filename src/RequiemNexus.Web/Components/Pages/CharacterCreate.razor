@page "/character/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using RequiemNexus.Data
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.Pages.CharacterCreation
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.Services
@using RequiemNexus.Domain
@using RequiemNexus.Domain.Models
@using RequiemNexus.Web.Helpers
@inject ICharacterService CharacterService
@inject IClanService ClanService
@inject ICharacterMeritService CharacterMeritService
@inject IDisciplineService DisciplineService
@inject ICharacterCreationService CharacterCreationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject RequiemNexus.Web.Services.ToastService ToastService

<PageTitle>Create Character — Requiem Nexus</PageTitle>

<div class="page-container fade-in wizard-container">
    <div class="wizard-header">
        <h2>Embrace a New Kindred</h2>
        <div class="wizard-progress-bar">
            @for(int i = 1; i <= 5; i++)
            {
                <div class="wizard-progress-step @((int)_currentStep >= i ? "active" : "")"></div>
            }
        </div>
        <div class="wizard-step-text">
            Step @((int)_currentStep) of 5
        </div>
    </div>

    <div class="wizard-body">
        @if (_currentStep == CreationStep.BasicInformation)
        {
            <BasicInformationStep Character="_newCharacter" 
                                  AvailableClans="_availableClans" 
                                  OnStateChanged="StateHasChanged" />
        }
        else if (_currentStep == CreationStep.Attributes)
        {
            <AttributesStep Character="_newCharacter" 
                            MentalPointsSpent="MentalPointsSpent" 
                            PhysicalPointsSpent="PhysicalPointsSpent" 
                            SocialPointsSpent="SocialPointsSpent" 
                            TotalAttributePointsSpent="TotalAttributePointsSpent" 
                            IsValid="IsAttributeDistributionValid()" 
                            OnAdjustAttribute="AdjustAttribute" 
                            OnStateChanged="StateHasChanged" />
        }
        else if (_currentStep == CreationStep.Skills)
        {
            <SkillsStep Character="_newCharacter" 
                        MentalSkillsSpent="MentalSkillsSpent" 
                        PhysicalSkillsSpent="PhysicalSkillsSpent" 
                        SocialSkillsSpent="SocialSkillsSpent" 
                        TotalSkillPointsSpent="TotalSkillPointsSpent" 
                        IsValid="IsSkillDistributionValid()" 
                        OnAdjustSkill="AdjustSkill" 
                        OnStateChanged="StateHasChanged" />
        }
        else if (_currentStep == CreationStep.MeritsAndDisciplines)
        {
            <MeritsAndDisciplinesStep Character="_newCharacter" 
                                      AvailableMerits="_availableMerits" 
                                      AvailableDisciplines="_availableDisciplines" 
                                      SelectableDisciplines="_selectableDisciplines"
                                      MeritPointsSpent="MeritPointsSpent" 
                                      DisciplineDotsSpent="DisciplineDotsSpent" 
                                      CreationDisciplineError="@_creationDisciplineError"
                                      IsValid="IsMeritAndDisciplineCountsValid()" 
                                      OnAddMerit="HandleAddMerit" 
                                      OnAdjustMeritRating="AdjustMeritRating" 
                                      OnRemoveMerit="RemoveMerit"
                                      OnMeritsChanged="HandleMeritsChanged"
                                      OnAddDiscipline="HandleAddDiscipline" 
                                      OnAdjustDisciplineDots="AdjustDisciplineDots" 
                                      OnRemoveDiscipline="RemoveDiscipline" 
                                      OnStateChanged="StateHasChanged" />
        }
        else if (_currentStep == CreationStep.ReviewAndEmbrace)
        {
            <ReviewAndEmbraceStep Character="_newCharacter" 
                                  AvailableClans="_availableClans" 
                                  AvailableDisciplines="_availableDisciplines"
                                  MentalPointsSpent="MentalPointsSpent" 
                                  PhysicalPointsSpent="PhysicalPointsSpent" 
                                  SocialPointsSpent="SocialPointsSpent" 
                                  MentalSkillsSpent="MentalSkillsSpent" 
                                  PhysicalSkillsSpent="PhysicalSkillsSpent" 
                                  SocialSkillsSpent="SocialSkillsSpent" 
                                  MeritPointsSpent="MeritPointsSpent" 
                                  DisciplineDotsSpent="DisciplineDotsSpent" />
        }
    </div>

    <div class="wizard-footer">
        <button class="btn-rn-ghost" @onclick="PreviousStep" disabled="@(_currentStep == CreationStep.BasicInformation)">Back</button>

        @if (_currentStep < CreationStep.ReviewAndEmbrace)
        {
            <button class="btn-rn-primary" @onclick="NextStepAsync" disabled="@(!CanProceedToNextStep())">Next Step</button>
        }
        else
        {
            <button class="btn-rn-primary wizard-btn-embrace" @onclick="SaveCharacter" disabled="@_isSaving">@(_isSaving ? "Embrace…" : "Embrace")</button>
        }
    </div>
</div>

@code {

    private CreationStep _currentStep = CreationStep.BasicInformation;
    private readonly Character _newCharacter = new Character();
    private bool _isSaving = false;
    private List<Clan> _availableClans = new List<Clan>();
    private string? _currentUserId;

    private List<Merit> _availableMerits = new List<Merit>();
    private List<Discipline> _availableDisciplines = new List<Discipline>();
    private List<Discipline> _selectableDisciplines = new List<Discipline>();
    private string? _creationDisciplineError;

    private int MentalPointsSpent => TraitMetadata.MentalAttributes.Sum(a => CharacterTraitHelper.GetTraitValue(_newCharacter, a) - 1);
    private int PhysicalPointsSpent => TraitMetadata.PhysicalAttributes.Sum(a => CharacterTraitHelper.GetTraitValue(_newCharacter, a) - 1);
    private int SocialPointsSpent => TraitMetadata.SocialAttributes.Sum(a => CharacterTraitHelper.GetTraitValue(_newCharacter, a) - 1);
    private int TotalAttributePointsSpent => MentalPointsSpent + PhysicalPointsSpent + SocialPointsSpent;

    private int MentalSkillsSpent => TraitMetadata.MentalSkills.Sum(s => CharacterTraitHelper.GetTraitValue(_newCharacter, s));
    private int PhysicalSkillsSpent => TraitMetadata.PhysicalSkills.Sum(s => CharacterTraitHelper.GetTraitValue(_newCharacter, s));
    private int SocialSkillsSpent => TraitMetadata.SocialSkills.Sum(s => CharacterTraitHelper.GetTraitValue(_newCharacter, s));
    private int TotalSkillPointsSpent => MentalSkillsSpent + PhysicalSkillsSpent + SocialSkillsSpent;

    private int MeritPointsSpent => _newCharacter.Merits.Sum(m => m.Rating);
    private int DisciplineDotsSpent => _newCharacter.Disciplines.Sum(d => d.Rating);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        
        if (string.IsNullOrEmpty(_currentUserId))
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _newCharacter.ApplicationUserId = _currentUserId;

        // Seed attribute and skill entity rows on the new character
        CharacterTraitHelper.SeedAttributes(_newCharacter);
        CharacterTraitHelper.SeedSkills(_newCharacter);

        _availableClans = await ClanService.GetAllClansAsync();
        _availableDisciplines = await DisciplineService.GetAllDisciplinesAsync();
    }

    private void AdjustAttribute(string attributeName, int change)
    {
        int currentValue = CharacterTraitHelper.GetTraitValue(_newCharacter, attributeName);
        int newValue = currentValue + change;
        if (newValue >= 1 && newValue <= 5)
        {
            CharacterTraitHelper.SetTraitValue(_newCharacter, attributeName, newValue);
        }
    }

    private void AdjustSkill(string skillName, int change)
    {
        int currentValue = CharacterTraitHelper.GetTraitValue(_newCharacter, skillName);
        int newValue = currentValue + change;
        if (newValue >= 0 && newValue <= 5)
        {
            CharacterTraitHelper.SetTraitValue(_newCharacter, skillName, newValue);
        }
    }

    private void HandleAddMerit(int meritId)
    {
        var merit = _availableMerits.FirstOrDefault(m => m.Id == meritId);
        if (merit == null) return;

        // For merits that can be purchased multiple times, allow adding duplicates
        if (!merit.CanBePurchasedMultipleTimes && _newCharacter.Merits.Any(m => m.MeritId == meritId))
            return;

        int startingRating = MeritRatingHelper.GetMinRating(merit.ValidRatings);

        _newCharacter.Merits.Add(new CharacterMerit { MeritId = meritId, Rating = startingRating, Specification = "" });
    }

    private async Task HandleMeritsChanged()
    {
        _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_newCharacter);
        StateHasChanged();
    }

    private static void AdjustMeritRating(CharacterMerit cm, int change)
    {
        if (cm.Rating + change >= 1 && cm.Rating + change <= 5)
        {
            cm.Rating += change;
        }
    }

    private void RemoveMerit(CharacterMerit cm)
    {
        _newCharacter.Merits.Remove(cm);
    }

    private void HandleAddDiscipline(int disciplineId)
    {
        if (!_newCharacter.Disciplines.Any(d => d.DisciplineId == disciplineId))
        {
            _newCharacter.Disciplines.Add(new CharacterDiscipline { DisciplineId = disciplineId, Rating = 1 });
        }

        RefreshCreationDisciplineValidation();
    }

    private void AdjustDisciplineDots(CharacterDiscipline cd, int change)
    {
        if (cd.Rating + change >= 1 && cd.Rating + change <= 5)
        {
            cd.Rating += change;
        }

        RefreshCreationDisciplineValidation();
    }

    private void RemoveDiscipline(CharacterDiscipline cd)
    {
        _newCharacter.Disciplines.Remove(cd);
        RefreshCreationDisciplineValidation();
    }

    private void RefreshCreationDisciplineValidation()
    {
        _newCharacter.Clan = _availableClans.FirstOrDefault(c => c.Id == _newCharacter.ClanId);
        _selectableDisciplines = _availableDisciplines
            .Where(d => DisciplineAcquisitionGates.GetCharacterCreationBlockingReason(_newCharacter, d) == null)
            .ToList();

        IReadOnlyDictionary<int, Discipline> disciplineMap = _availableDisciplines.ToDictionary(d => d.Id);
        Result<bool> eligibility = CharacterCreationService.ValidateCreationDisciplineEligibility(_newCharacter, disciplineMap);
        Result<bool> dotRule = CharacterCreationService.ValidateCreationDisciplines(_newCharacter);
        _creationDisciplineError = !eligibility.IsSuccess
            ? eligibility.Error
            : (!dotRule.IsSuccess ? dotRule.Error : null);
    }

    private async Task NextStep()
    {
        if (_currentStep < CreationStep.ReviewAndEmbrace)
        {
            if (_currentStep == CreationStep.Skills)
            {
                _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_newCharacter);
            }

            _currentStep++;
            if (_currentStep == CreationStep.MeritsAndDisciplines)
            {
                RefreshCreationDisciplineValidation();
            }
            else if (_currentStep == CreationStep.ReviewAndEmbrace)
            {
                _newCharacter.Clan = _availableClans.FirstOrDefault(c => c.Id == _newCharacter.ClanId);
            }
        }
    }

    private void PreviousStep()
    {
        if (_currentStep > CreationStep.BasicInformation)
        {
            _currentStep--;
            if (_currentStep == CreationStep.MeritsAndDisciplines)
            {
                RefreshCreationDisciplineValidation();
            }
        }
    }

    private async Task NextStepAsync() => await NextStep();

    private bool IsAttributeDistributionValid()
    {
        var points = new List<int> { MentalPointsSpent, PhysicalPointsSpent, SocialPointsSpent };
        points.Sort();
        // Strict 5/4/3 distribution means exactly those numbers when sorted.
        return points[0] == 3 && points[1] == 4 && points[2] == 5;
    }

    private bool IsSkillDistributionValid()
    {
        var points = new List<int> { MentalSkillsSpent, PhysicalSkillsSpent, SocialSkillsSpent };
        points.Sort();
        // Strict 11/7/4 distribution means exactly those numbers when sorted.
        return points[0] == 4 && points[1] == 7 && points[2] == 11;
    }

    private bool IsMeritAndDisciplineCountsValid()
    {
        return MeritPointsSpent == 7 && DisciplineDotsSpent == 3;
    }

    private bool CanLeaveMeritsAndDisciplinesStep()
    {
        return IsMeritAndDisciplineCountsValid() && string.IsNullOrEmpty(_creationDisciplineError);
    }

    private bool CanProceedToNextStep()
    {
        switch (_currentStep)
        {
            case CreationStep.BasicInformation:
                return !string.IsNullOrWhiteSpace(_newCharacter.Name) && _newCharacter.ClanId.HasValue;
            case CreationStep.Attributes:
                return IsAttributeDistributionValid();
            case CreationStep.Skills:
                return IsSkillDistributionValid();
            case CreationStep.MeritsAndDisciplines:
                return CanLeaveMeritsAndDisciplinesStep();
            case CreationStep.ReviewAndEmbrace:
            default:
                return true;
        }
    }

    private async Task SaveCharacter()
    {
        if (_isSaving) return;
        _isSaving = true;
        try
        {
            await CharacterService.EmbraceCharacterAsync(_newCharacter);
            NavigationManager.NavigateTo("/characters");
        }
        catch (Exception ex)
        {
            ToastService.Show("Creation Failed", ex.Message, ToastType.Error, 5000);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
