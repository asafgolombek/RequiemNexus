@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using RequiemNexus.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@using System.Text.Encodings.Web
@inject IEmailSender<ApplicationUser> EmailSender

<PageTitle>Register - Requiem Nexus</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>Create New User</h2>
            <p>Join Requiem Nexus</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @_errorMessage
            </div>
        }

        @if (_registrationSuccess)
        {
            <div class="alert alert-success mt-4" role="alert">
                Registration successful! Please check your email to verify your account before logging in.
            </div>
            <div class="login-footer">
                <p><a href="/">Return to Sign In</a></p>
            </div>
        }
        else
        {
            <EditForm Model="@_registerModel" OnValidSubmit="HandleRegistration" FormName="registerForm" class="login-form">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <div class="input-container">
                        <InputText id="email" type="email" @bind-Value="_registerModel!.Email" class="form-control" placeholder="Enter your email" />
                    </div>
                    <ValidationMessage For="@(() => _registerModel!.Email)" class="text-danger mt-1 text-sm" />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-container">
                        <InputText id="password" type="password" @bind-Value="_registerModel!.Password" class="form-control" placeholder="Create a password" />
                    </div>
                    <ValidationMessage For="@(() => _registerModel!.Password)" class="text-danger mt-1 text-sm" />
                </div>

                <div class="form-group">
                    <label for="birthday">Birthday <small>(DD/MM/YYYY)</small></label>
                    <div class="input-container">
                        <InputText id="birthday" @bind-Value="_registerModel!.Birthday" class="form-control" placeholder="DD/MM/YYYY" maxlength="10" oninput="this.value=this.value.replace(/\D/g,'').replace(/^(\d{2})(\d)/,'$1/$2').replace(/^(\d{2}\/\d{2})(\d)/,'$1/$2').substring(0,10)" />
                    </div>
                    <ValidationMessage For="@(() => _registerModel!.Birthday)" class="text-danger mt-1 text-sm" />
                </div>

                <button type="submit" class="btn-login mt-4">
                    Register
                </button>
            </EditForm>

            <div class="login-footer">
                <p>Already have an account? <a href="/">Sign In</a></p>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private RegisterModel? _registerModel { get; set; }

    protected override void OnInitialized()
    {
        _registerModel ??= new();
    }

    private string? _errorMessage;
    private bool _registrationSuccess;

    private async Task HandleRegistration()
    {
        _errorMessage = null;
        
        if (_registerModel is null) return;

        // Parse Birthday to DateOnly (DD/MM/YYYY)
        if (!DateOnly.TryParseExact(_registerModel.Birthday, "dd/MM/yyyy", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsedBirthday))
        {
            _errorMessage = "Invalid birthday format. Please use DD/MM/YYYY.";
            return;
        }

        var user = new ApplicationUser
        {
            UserName = _registerModel.Email,
            Email = _registerModel.Email,
            Birthday = parsedBirthday,
            MemberSince = DateOnly.FromDateTime(DateTime.Now)
        };

        var result = await UserManager.CreateAsync(user, _registerModel.Password);

        if (result.Succeeded)
        {
            var userId = await UserManager.GetUserIdAsync(user);
            var code = await UserManager.GenerateEmailConfirmationTokenAsync(user);
            code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
            var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                NavigationManager.ToAbsoluteUri("Account/ConfirmEmail").AbsoluteUri,
                new Dictionary<string, object?> { ["userId"] = userId, ["code"] = code });

            await EmailSender.SendConfirmationLinkAsync(user, _registerModel.Email, HtmlEncoder.Default.Encode(callbackUrl));

            _registrationSuccess = true;
        }
        else
        {
            // If email is duplicate or other issues
            if (result.Errors.Any(e => e.Code == "DuplicateUserName" || e.Code == "DuplicateEmail"))
            {
                _errorMessage = "The account already exists.";
            }
            else
            {
                _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters long.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Birthday is required.")]
        [RegularExpression(@"^(0[1-9]|[12]\d|3[01])/(0[1-9]|1[0-2])/\d{4}$", ErrorMessage = "Format must be DD/MM/YYYY.")]
        public string Birthday { get; set; } = string.Empty;
    }
}
