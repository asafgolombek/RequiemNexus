@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@inject IBloodBondService BloodBondService

<section class="cs-section cs-blood-bonds">
    <h2>Blood Bonds</h2>
    @if (string.IsNullOrEmpty(CurrentUserId))
    {
        <p class="text-muted text-small">Sign in to view Blood Bonds.</p>
    }
    else if (_loading)
    {
        <p class="text-muted text-small"><em>Loading…</em></p>
    }
    else if (_bonds.Count == 0)
    {
        <p class="text-muted text-small">No active Blood Bonds recorded for this character as thrall.</p>
    }
    else
    {
        <ul class="trait-list" style="margin:0.25rem 0 0;padding-left:0;list-style:none;">
            @foreach (var b in _bonds)
            {
                <li class="trait-item" style="margin-bottom:0.65rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border-subtle,#2a2a2a);">
                    <div class="bloodline-detail-row">
                        <span class="trait-subheading">Regnant:</span>
                        <strong>@b.RegnantDisplayName</strong>
                    </div>
                    <div class="bloodline-detail-row" style="margin-top:0.25rem;">
                        <span class="trait-subheading">Stage:</span>
                        <BloodBondStageIndicator Stage="b.Stage" />
                    </div>
                    <div class="bloodline-detail-row" style="margin-top:0.25rem;">
                        <span class="trait-subheading">Last fed:</span>
                        <span>@(b.LastFedAt?.ToLocalTime().ToString("g") ?? "—")</span>
                        @if (b.IsFading)
                        {
                            <span class="text-small" style="margin-left:0.35rem;color:var(--accent-warm,#c90);">(fading)</span>
                        }
                    </div>
                    <div class="bloodline-detail-row" style="margin-top:0.25rem;">
                        <span class="trait-subheading">Condition:</span>
                        <span class="text-small">@b.ActiveConditionName</span>
                    </div>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter]
    public int CharacterId { get; set; }

    [Parameter]
    public string? CurrentUserId { get; set; }

    private List<BloodBondDto> _bonds = [];

    private bool _loading;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(CurrentUserId))
        {
            return;
        }

        _loading = true;
        try
        {
            IReadOnlyList<BloodBondDto> list = await BloodBondService.GetBondsForThrallAsync(CharacterId, CurrentUserId);
            _bonds = list.ToList();
        }
        catch
        {
            _bonds = [];
        }
        finally
        {
            _loading = false;
        }
    }
}
