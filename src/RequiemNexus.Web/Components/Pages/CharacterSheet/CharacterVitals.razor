@using RequiemNexus.Data.Models
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@inject SessionClientService SessionClient
@implements IDisposable

<section class="cs-section cs-vitals">
    <div class="vitals-trackers">
        <HealthTracker Character="Character"
                       OnChanged="OnChanged"
                       PulseTick="_healthPulseTick" />
        <WillpowerTracker Character="Character"
                          OnChanged="OnChanged"
                          PulseTick="_willpowerPulseTick" />
        <VitaeTracker Character="Character"
                      OnChanged="OnChanged"
                      PulseTick="_vitaePulseTick" />
    </div>

    <VitaeFastHealPanel CharacterId="Character.Id"
                        ActingUserId="ActingUserId"
                        CurrentVitae="Character.CurrentVitae"
                        MaxVitae="Character.MaxVitae"
                        HealthDamage="@Character.HealthDamage"
                        TrackLength="Character.CalculatedMaxHealth"
                        OnHealed="OnVitaeHealCompleted" />

    <HuntPanel Character="Character"
               ActingUserId="ActingUserId"
               OnHuntCompleted="OnHuntCompleted" />

    <div class="derived-stats @(_humanityPulse ? "animate-pulse" : "")" style="margin-top: 20px; display: flex; gap: 20px; font-family: 'Cinzel', serif; color: #d0c0b0; border-top: 1px solid #330000; padding-top: 15px;">
        <div class="stat-item" style="text-align: center; flex: 1;">
            <div class="text-muted-rn" style="font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px;">Size</div>
            <div style="font-size: 1.5em;">@Character.Size</div>
        </div>
        <div class="stat-item" style="text-align: center; flex: 1;">
            <div class="text-muted-rn" style="font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px;">Speed</div>
            <div style="font-size: 1.5em;">@Character.Speed</div>
        </div>
        <div class="stat-item" style="text-align: center; flex: 1;">
            <div class="text-muted-rn" style="font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px;">Defense</div>
            <div style="font-size: 1.5em;">@Character.Defense</div>
        </div>
        <div class="stat-item" style="text-align: center; flex: 1;">
            <div class="text-muted-rn" style="font-size: 0.8em; text-transform: uppercase; letter-spacing: 1px;">Armor</div>
            <div style="font-size: 1.5em;">@Character.Armor</div>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public Character Character { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [Parameter]
    public string? ActingUserId { get; set; }

    [Parameter]
    public EventCallback OnVitaeHealCompleted { get; set; }

    [Parameter]
    public EventCallback OnHuntCompleted { get; set; }

    private int _healthPulseTick;
    private int _willpowerPulseTick;
    private int _vitaePulseTick;
    private bool _humanityPulse;

    protected override void OnInitialized()
    {
        SessionClient.CharacterUpdated += HandleCharacterUpdated;
    }

    private async void HandleCharacterUpdated(CharacterUpdateDto patch)
    {
        if (patch.CharacterId != Character.Id)
        {
            return;
        }

        bool healthDirty = false;
        bool willDirty = false;
        bool vitaeDirty = false;
        bool humanityDirty = false;

        if (patch.CurrentHealth.HasValue)
        {
            Character.CurrentHealth = patch.CurrentHealth.Value;
            healthDirty = true;
        }

        if (patch.MaxHealth.HasValue)
        {
            Character.MaxHealth = patch.MaxHealth.Value;
        }

        if (patch.HealthDamage != null)
        {
            Character.HealthDamage = patch.HealthDamage;
            healthDirty = true;
        }

        if (patch.CurrentWillpower.HasValue)
        {
            Character.CurrentWillpower = patch.CurrentWillpower.Value;
            willDirty = true;
        }

        if (patch.MaxWillpower.HasValue)
        {
            Character.MaxWillpower = patch.MaxWillpower.Value;
        }

        if (patch.CurrentVitae.HasValue)
        {
            Character.CurrentVitae = patch.CurrentVitae.Value;
            vitaeDirty = true;
        }

        if (patch.MaxVitae.HasValue)
        {
            Character.MaxVitae = patch.MaxVitae.Value;
        }

        if (patch.Humanity.HasValue)
        {
            Character.Humanity = patch.Humanity.Value;
            humanityDirty = true;
        }

        if (healthDirty)
        {
            _healthPulseTick++;
        }

        if (willDirty)
        {
            _willpowerPulseTick++;
        }

        if (vitaeDirty)
        {
            _vitaePulseTick++;
        }

        await InvokeAsync(StateHasChanged);

        if (humanityDirty)
        {
            await TriggerHumanityPulseAsync();
        }
    }

    private async Task TriggerHumanityPulseAsync()
    {
        _humanityPulse = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(800);
        _humanityPulse = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionClient.CharacterUpdated -= HandleCharacterUpdated;
    }
}
