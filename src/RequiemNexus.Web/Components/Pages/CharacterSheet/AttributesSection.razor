@using RequiemNexus.Data.Models
@using RequiemNexus.Domain
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Helpers

<section class="cs-section cs-attributes">
    <h2>@Title</h2>
    <div class="grid-3-col">
        <div class="stat-col mental">
            <h3>Mental</h3>
            @foreach (var attr in TraitMetadata.MentalAttributes)
            {
                var attrId = attr;
                <DotScale Value="@CharacterTraitHelper.GetTraitValue(Character, attrId)"
                          ValueChanged="@((int val) => HandleValueChanged(attrId.ToString(), val))"
                          Label="@TraitMetadata.GetDisplayName(attrId)"
                          OnLabelClick="@((string label) => OnLabelClick.InvokeAsync(attrId.ToString()))"
                          OnRollClick="@((string label) => OnRollClick.InvokeAsync(attrId.ToString()))" 
                          ShowRollButton="@ShowRollButton" />
            }
        </div>
        <div class="stat-col physical">
            <h3>Physical</h3>
            @foreach (var attr in TraitMetadata.PhysicalAttributes)
            {
                var attrId = attr;
                <DotScale Value="@CharacterTraitHelper.GetTraitValue(Character, attrId)"
                          ValueChanged="@((int val) => HandleValueChanged(attrId.ToString(), val))"
                          Label="@TraitMetadata.GetDisplayName(attrId)"
                          OnLabelClick="@((string label) => OnLabelClick.InvokeAsync(attrId.ToString()))"
                          OnRollClick="@((string label) => OnRollClick.InvokeAsync(attrId.ToString()))"
                          ShowRollButton="@ShowRollButton" />
            }
        </div>
        <div class="stat-col social">
            <h3>Social</h3>
            @foreach (var attr in TraitMetadata.SocialAttributes)
            {
                var attrId = attr;
                <DotScale Value="@CharacterTraitHelper.GetTraitValue(Character, attrId)"
                          ValueChanged="@((int val) => HandleValueChanged(attrId.ToString(), val))"
                          Label="@TraitMetadata.GetDisplayName(attrId)"
                          OnLabelClick="@((string label) => OnLabelClick.InvokeAsync(attrId.ToString()))"
                          OnRollClick="@((string label) => OnRollClick.InvokeAsync(attrId.ToString()))"
                          ShowRollButton="@ShowRollButton" />
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public Character Character { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "Attributes";
    [Parameter] public bool ShowRollButton { get; set; } = true;
    [Parameter] public EventCallback<string> OnLabelClick { get; set; }
    [Parameter] public EventCallback<string> OnRollClick { get; set; }
    [Parameter] public EventCallback<(string TraitName, int NewValue)> OnValueChanged { get; set; }

    private async Task HandleValueChanged(string traitName, int newValue)
    {
        CharacterTraitHelper.SetTraitValue(Character, traitName, newValue);
        if (OnValueChanged.HasDelegate)
            await OnValueChanged.InvokeAsync((traitName, newValue));
    }
}
