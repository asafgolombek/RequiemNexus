@using Microsoft.AspNetCore.Components
@using RequiemNexus.Data.Models

<section class="cs-section cs-devotions">
    <h2>Purchase Devotions</h2>
    @if (EligibleDevotions.Any())
    {
        <div class="equipment-form" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
            <select value="@SelectedDevotionId" @onchange="OnDevotionIdChangeAsync" class="equipment-select" style="min-width: 200px;" aria-label="Devotion to purchase">
                <option value="0">-- Select Devotion --</option>
                @foreach (DevotionDefinition d in EligibleDevotions)
                {
                    <option value="@d.Id">@d.Name (@d.XpCost XP)</option>
                }
            </select>
            <button class="btn-rn-primary" @onclick="OnPurchaseDevotion" disabled="@(SelectedDevotionId == 0)">Purchase</button>
        </div>

        @if (SelectedDevotionId != 0)
        {
            DevotionDefinition selected = EligibleDevotions.First(d => d.Id == SelectedDevotionId);
            <div style="margin-top: 10px; font-size: 0.9em; color: #d0d0d0; background: #1a1a1a; padding: 10px; border-radius: 4px; border-left: 3px solid #550000;">
                <strong>@selected.Name</strong>
                <p style="margin: 5px 0;">@selected.Description</p>
                <div style="font-size: 0.85em; color: #a0a0a0;">
                    Prerequisites:
                    @foreach (var p in selected.Prerequisites.OrderBy(p => p.OrGroupId).ThenBy(p => p.DisciplineId))
                    {
                        <span>@(p.Discipline?.Name ?? "Discipline") @p.MinimumLevel</span>
                        @if (p != selected.Prerequisites.Last())
                        {
                            <span>, </span>
                        }
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted-rn" style="font-size: 0.9em;">No new devotions eligible for purchase at this time.</p>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<DevotionDefinition> EligibleDevotions { get; set; } = [];

    [Parameter]
    public int SelectedDevotionId { get; set; }

    [Parameter]
    public EventCallback<int> SelectedDevotionIdChanged { get; set; }

    [Parameter]
    public EventCallback OnPurchaseDevotion { get; set; }

    private async Task OnDevotionIdChangeAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            await SelectedDevotionIdChanged.InvokeAsync(id);
        }
    }
}
