@using Microsoft.AspNetCore.Components
@using RequiemNexus.Data.Models
@using RequiemNexus.Web.Helpers

<section class="cs-section cs-disciplines">
    <h2>Add New Discipline</h2>
    <div class="equipment-form" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
        <select value="@SelectedDisciplineId" @onchange="OnDisciplineIdChangeAsync" class="equipment-select" style="min-width: 200px;" aria-label="Discipline to add">
            <option value="0">-- Select Discipline --</option>
            @foreach (var d in AvailableDisciplines.Where(ad => !Character.Disciplines.Any(cd => cd.DisciplineId == ad.Id)))
            {
                <option value="@d.Id">@DisciplineUiLabels.FormatAdvancementOption(Character, d)</option>
            }
        </select>

        <div style="display: flex; align-items: center; gap: 5px;">
            <label for="new-discipline-rating">Starting Rating:</label>
            <input id="new-discipline-rating" type="number" min="1" max="5" value="@NewDisciplineRating" @onchange="OnRatingChangeAsync" class="equipment-quantity" style="width: 60px;" />
        </div>

        <button class="btn-rn-primary" @onclick="OnAddDiscipline" disabled="@(SelectedDisciplineId == 0)">Add</button>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public Character Character { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<Discipline> AvailableDisciplines { get; set; } = [];

    [Parameter]
    public int SelectedDisciplineId { get; set; }

    [Parameter]
    public EventCallback<int> SelectedDisciplineIdChanged { get; set; }

    [Parameter]
    public int NewDisciplineRating { get; set; }

    [Parameter]
    public EventCallback<int> NewDisciplineRatingChanged { get; set; }

    [Parameter]
    public EventCallback OnAddDiscipline { get; set; }

    private async Task OnDisciplineIdChangeAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            await SelectedDisciplineIdChanged.InvokeAsync(id);
        }
    }

    private async Task OnRatingChangeAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int r))
        {
            await NewDisciplineRatingChanged.InvokeAsync(r);
        }
    }
}
