@using System.Linq
@using RequiemNexus.Data.Models
@using RequiemNexus.Web.Components.Pages.CharacterSheet.SocialManeuversSectionParts

<section class="cs-section cs-social-maneuvers">
    <h2>Social Maneuvering</h2>
    @if (_loading)
    {
        <SkeletonLoader Variant="panel" Count="4" />
    }
    else if (!_maneuvers.Any())
    {
        <p style="color:var(--text-secondary);font-size:0.9em;">No active Social maneuvers. Your Storyteller creates these from the Glimpse dashboard.</p>
    }
    else
    {
        <ul class="trait-list" style="list-style:none;padding:0;">
            @foreach (SocialManeuver m in _maneuvers)
            {
                <SocialManeuverCard Maneuver="m"
                                    TimingMessage="@SocialManeuverSheetDisplayHelper.GetTimingMessage(m)"
                                    ClueThreshold="@SocialManeuverSheetDisplayHelper.GetClueThreshold(m)"
                                    Busy="_busy"
                                    OpenDoorPools="_openDoorPoolByManeuverId"
                                    ForceDoorPools="_forceDoorPoolByManeuverId"
                                    ForceHardLeverage="_forceHardLeverageByManeuverId"
                                    ForceBpSeverity="_forceBpSeverityByManeuverId"
                                    SpendBenefits="_spendBenefitByClueId"
                                    OnPoolsOrBenefitsChanged="HandlePoolsOrBenefitsChangedAsync"
                                    OnSpendClue="SpendClueAsync"
                                    OnRollOpen="RollOpenAsync"
                                    OnRollForce="RollForceAsync" />
            }
        </ul>
    }
</section>
