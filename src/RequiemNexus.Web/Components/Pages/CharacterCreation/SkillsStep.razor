@using RequiemNexus.Data.Models
@using RequiemNexus.Domain
@using RequiemNexus.Web.Helpers

<div class="step-content">
    <h3>Skills</h3>
    <p style="color: #a0a0a0; margin-bottom: 20px;">Prioritize your Mental, Physical, and Social skills (11/7/4 points to distribute). Every skill starts with 0 dots.</p>
    
    @if (!IsValid)
    {
        <div style="margin-bottom: 20px; padding: 10px; background-color: #330000; border-left: 3px solid #ff3333; color: white; font-size: 0.9em;">
            Warning: You must distribute exactly 11, 7, and 4 points among the three categories. Current: Mental (@MentalSkillsSpent), Physical (@PhysicalSkillsSpent), Social (@SocialSkillsSpent).
        </div>
    }

    <div class="attributes-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        @foreach (var (category, traits, spent, limit) in new[] { 
            ("Mental", TraitMetadata.MentalSkills, MentalSkillsSpent, GetCategoryLimit(PhysicalSkillsSpent, SocialSkillsSpent)),
            ("Physical", TraitMetadata.PhysicalSkills, PhysicalSkillsSpent, GetCategoryLimit(MentalSkillsSpent, SocialSkillsSpent)),
            ("Social", TraitMetadata.SocialSkills, SocialSkillsSpent, GetCategoryLimit(MentalSkillsSpent, PhysicalSkillsSpent))
        })
        {
            <div class="attribute-category">
                <h4 style="color: #990000; border-bottom: 1px solid #330000; padding-bottom: 5px;">@category (@spent)</h4>
                @foreach (var skill in traits)
                {
                    var val = CharacterTraitHelper.GetTraitValue(Character, skill);
                    <div class="attribute-row" style="display: flex; justify-content: space-between; align-items: center; margin-top: 5px;">
                        <span style="font-size: 0.9em;">@TraitMetadata.GetDisplayName(skill)</span>
                        <div>
                            <button class="nav-btn" style="padding: 0px 6px; font-size: 0.8em;" @onclick='() => AdjustAndNotify(skill, -1)' disabled="@(val <= 0)">-</button>
                            <span style="display: inline-block; width: 15px; text-align: center; font-size: 0.9em;">@val</span>
                            <button class="nav-btn" style="padding: 0px 6px; font-size: 0.8em;" @onclick='() => AdjustAndNotify(skill, 1)' disabled="@(val >= 5 || TotalSkillPointsSpent >= 22 || spent >= limit)">+</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Character Character { get; set; } = default!;

    [Parameter] public int MentalSkillsSpent { get; set; }
    [Parameter] public int PhysicalSkillsSpent { get; set; }
    [Parameter] public int SocialSkillsSpent { get; set; }
    [Parameter] public int TotalSkillPointsSpent { get; set; }
    [Parameter] public bool IsValid { get; set; }

    [Parameter] public Action<string, int>? OnAdjustSkill { get; set; }
    [Parameter] public EventCallback OnStateChanged { get; set; }

    // Returns the max points this category can reach, given the other two categories' current points.
    // Ensures a valid {11, 7, 4} distribution remains achievable.
    private static int GetCategoryLimit(int otherA, int otherB)
    {
        int[] targets = { 11, 7, 4 };
        foreach (var v in targets)
        {
            var remaining = targets.Where(t => t != v).OrderBy(x => x).ToArray();
            if ((remaining[0] >= otherA && remaining[1] >= otherB) ||
                (remaining[1] >= otherA && remaining[0] >= otherB))
            {
                return v;
            }
        }
        return 0;
    }

    private async Task AdjustAndNotify(string name, int change)
    {
        OnAdjustSkill?.Invoke(name, change);
        if (OnStateChanged.HasDelegate)
        {
            await OnStateChanged.InvokeAsync();
        }
    }
}
