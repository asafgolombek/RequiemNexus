@page "/character/{Id:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Domain.Models
@using RequiemNexus.Domain.Services
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using RequiemNexus.Web.Helpers
@using Microsoft.JSInterop
@inject ICharacterService CharacterService
@inject ICharacterAssetService CharacterAssetService
@inject IAssetProcurementService AssetProcurementService
@inject IAdvancementService AdvancementService
@inject ICharacterExportService ExportService
@inject ITraitResolver TraitResolver
@inject IHumanityService HumanityService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject ToastService ToastService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ISorceryActivationService SorceryActivationService
@inject IDisciplineActivationService DisciplineActivationService
@inject ICoilService CoilService

<PageTitle>@(_character?.Name ?? "Character Sheet") - Requiem Nexus</PageTitle>

@if (_isSheetLoading)
{
    <SkeletonLoader Variant="sheet" />
}
else if (_sheetLoadError != null)
{
    <div class="page-container fade-in">
        <div class="alert alert-danger" role="alert">
            <strong>Could not load character.</strong> @_sheetLoadError
        </div>
        <a href="/characters" class="btn-rn-primary mt-3">Back to My Characters</a>
    </div>
}
else if (_character == null)
{
    <div class="page-container fade-in">
        <div class="empty-state-rn">
            <p>@(string.IsNullOrEmpty(_currentUserId) ? "You must be signed in to view this character." : "Character not found or you do not have access.")</p>
            <a href="/characters" class="btn-rn-primary">Back to My Characters</a>
        </div>
    </div>
}
else
{
    <div class="character-sheet-layout @(SessionClient.IsConnected ? "with-sidebar" : "")">
        <div class="character-sheet fade-in cs-sheet-root">
            <CharacterDetailsIncapacitatedOverlay IsVisible="IsIncapacitated" />
            <div class="cs-sheet-interactive @(IsIncapacitated ? "cs-sheet-interactive--blocked" : "")">
            <CharacterDetailsSheetHeader Character="_character"
                                         SessionConnected="SessionClient.IsConnected"
                                         IsEditingName="_isEditingName"
                                         IsFreeEditMode="_isFreeEditMode"
                                         IsExporting="_isExporting"
                                         OnBeginEditName="BeginEditingNameAsync"
                                         OnNameBlur="SaveNameOffBlur"
                                         OnNameKeyUp="HandleNameKeyUp"
                                         OnAddBeat="AddBeat"
                                         OnRemoveBeat="RemoveBeat"
                                         OnAddXp="AddXP"
                                         OnRemoveXp="RemoveXP"
                                         OnGoToAdvancement="GoToAdvancement"
                                         OnToggleFreeEditMode="ToggleFreeEditMode"
                                         OnExportJson="ExportJson"
                                         OnExportPdf="ExportPdf" />

        <CharacterDetailsTabBar ActiveTab="_activeTab"
                                OnTabSelected="OnTabBarSelectAsync"
                                OnTabKeydown="HandleTabBarKeydownAsync" />

        @if (_character.CampaignId is int chronicleId)
        {
            <EncounterInitiativeEmbed CampaignId="chronicleId" CharacterId="_character.Id" />
        }

        <CascadingValue Value="@(_isAdvancementMode || _isFreeEditMode)" Name="IsEditable">
            @if (_activeTab == "sheet")
            {
                <div class="cs-grid" id="panel-sheet" role="tabpanel" aria-labelledby="tab-sheet">
                    <!-- VITALS / ADVANTAGES BARS (Top Grid Layer) -->
                    <CharacterVitals Character="_character"
                                       OnChanged="SaveCharacter"
                                       ActingUserId="@_currentUserId"
                                       OnVitaeHealCompleted="ReloadCharacterAfterHealAsync"
                                       OnHuntCompleted="ReloadCharacterAfterHealAsync" />

                    <AttributesSection Character="_character"
                                       UseSectionDivider="true"
                                       SectionDividerLabel="◆ Attributes ◆"
                                       Title="Attributes"
                                       OnLabelClick="OnTraitLabelClick"
                                       OnRollClick="OnTraitRollClick"
                                       OnValueChanged="OnAttributeOrSkillDotsChangedAsync" />
                    <SkillsSection Character="_character"
                                   UseSectionDivider="true"
                                   SectionDividerLabel="◆ Skills ◆"
                                   Title="Skills"
                                   OnLabelClick="OnTraitLabelClick"
                                   OnRollClick="OnTraitRollClick"
                                   OnValueChanged="OnAttributeOrSkillDotsChangedAsync" />

                    <!-- SUPERNATURAL & ADVANTAGES -->
                    <div class="grid-2-col">
                        <section class="cs-section cs-advantages">
                            <h2>Advantages</h2>
                            <DotScale @bind-Value="_character.BloodPotency" Label="Blood Potency" Max="10"
                                OnLabelClick="OpenReference" OnRollClick="OpenRoller" />
                            @{
                                int crucDots = _character.GetDisciplineRating("Crúac");
                                int effectiveMaxHumanity = HumanityService.GetEffectiveMaxHumanity(_character);
                                int humanityDotScaleMax = crucDots > 0 ? effectiveMaxHumanity : 10;
                            }
                            <DotScale @bind-Value="_character.Humanity" Label="Humanity" Max="@humanityDotScaleMax" OnLabelClick="OpenReference"
                                OnRollClick="OpenRoller" />
                            @if (crucDots > 0)
                            {
                                <div class="cruac-humanity-cap @( _character.Humanity >= effectiveMaxHumanity ? "cruac-humanity-cap--warn" : string.Empty)"
                                     title="Crúac permanently caps Humanity">
                                    Max Humanity: @effectiveMaxHumanity (capped by Crúac @(new string('\u2022', crucDots)))
                                </div>
                            }
                            <div class="humanity-stains-block" style="margin-top:0.65rem;">
                                <span class="text-muted-rn" style="font-size:0.85em;">Humanity stains: @_character.HumanityStains</span>
                                @if (_character.HumanityStains >= _character.Humanity)
                                {
                                    <button type="button" class="btn-rn-danger btn-roll-small" style="margin-left:0.5rem;" @onclick="OpenPlayerDegenerationModal">
                                        Roll Degeneration
                                    </button>
                                }
                                else if (_character.HumanityStains > 0 && _character.HumanityStains < _character.Humanity)
                                {
                                    <button type="button" class="btn-rn-ghost btn-roll-small" style="margin-left:0.5rem;border:1px solid var(--border-subtle);" title="@RemorsePoolTooltip" @onclick="RollRemorseFromSheetAsync">
                                        Roll Remorse
                                    </button>
                                }
                            </div>

                            <h3 class="trait-subheading">Merits</h3>
                            <ul class="trait-list">
                                @foreach (var merit in _character.Merits)
                                {
                                    <li class="trait-item merit-item @(_expandedMeritIds.Contains(merit.Id) ? "expanded" : "")"
                                        @onclick="() => ToggleMeritExpanded(merit.Id)"
                                        role="button"
                                        tabindex="0"
                                        @onkeydown="(e) => HandleMeritKeydown(e, merit.Id)">
                                        <div class="merit-header">
                                            <span>@merit.Merit?.Name @(string.IsNullOrEmpty(merit.Specification) || merit.Specification == "N/A" ? "" :
                                                $"({merit.Specification})")</span>
                                            <span class="trait-dots">@(new string('\u2022', merit.Rating))</span>
                                            <span class="merit-chevron">@(_expandedMeritIds.Contains(merit.Id) ? $"{(char)0x25BC}" : $"{(char)0x25B6}")</span>
                                        </div>
                                        @if (_expandedMeritIds.Contains(merit.Id) && merit.Merit != null && !string.IsNullOrEmpty(merit.Merit.Description))
                                        {
                                            <div class="merit-description">@merit.Merit.Description</div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>
                        <section class="cs-section cs-disciplines">
                            <h2>Disciplines (clan triple, bloodline fourth, or out-of-clan)</h2>
                            <p class="text-muted-rn" style="font-size: 0.85em; margin: -6px 0 10px 0;">XP cost uses in-clan (×4) vs out-of-clan (×5) per affinity below.</p>
                            <ul class="trait-list disciplines-list">
                                @foreach (var disc in _character.Disciplines)
                                {
                                    <li class="trait-item discipline-item flex-col-stretch">
                                        <div class="discipline-item-header" @onclick="() => ToggleDiscipline(disc.DisciplineId)">
                                            <span>
                                                @if (_expandedDisciplines.Contains(disc.DisciplineId))
                                                {
                                                    <i class="oi oi-chevron-bottom expand-icon"></i>
                                                }
                                                else
                                                {
                                                    <i class="oi oi-chevron-right expand-icon"></i>
                                                }
                                                @disc.Discipline?.Name
                                                @if (disc.Discipline != null)
                                                {
                                                    <span class="discipline-affinity-badge" style="display: block; font-size: 0.8em; color: #a0a0a0; font-weight: normal; margin-top: 2px;">@DisciplineUiLabels.FormatAffinityBadge(_character, disc.Discipline)</span>
                                                    var defTags = DisciplineUiLabels.FormatDefinitionTags(disc.Discipline);
                                                    if (!string.IsNullOrEmpty(defTags))
                                                    {
                                                        <span style="display: block; font-size: 0.75em; color: #888;">@defTags</span>
                                                    }
                                                }
                                            </span>
                                            <span class="trait-dots">@(new string('\u2022', disc.Rating))</span>
                                        </div>
                                        
                                        @if (_expandedDisciplines.Contains(disc.DisciplineId) && disc.Discipline?.Powers != null)
                                        {
                                            <div class="discipline-powers">
                                                @foreach (var power in disc.Discipline.Powers.Where(p => p.Level <= disc.Rating).OrderBy(p => p.Level))
                                                {
                                                    <div class="power-item">
                                                        <strong>Level @power.Level - @power.Name@if (_disciplinePowerResolvedPools.TryGetValue(power.Id, out int resolvedPool)) { <text> — Pool: @resolvedPool</text> }</strong>
                                                        <p class="power-desc">@power.Description</p>
                                                        @if ((!string.IsNullOrEmpty(power.DicePool) && !_disciplinePowerResolvedPools.ContainsKey(power.Id)) || !string.IsNullOrEmpty(power.Cost))
                                                        {
                                                            <div class="power-meta">
                                                                @if (!string.IsNullOrEmpty(power.DicePool) && !_disciplinePowerResolvedPools.ContainsKey(power.Id))
                                                                {
                                                                    <text>Pool: @power.DicePool</text>
                                                                }
                                                                @if ((!string.IsNullOrEmpty(power.DicePool) && !_disciplinePowerResolvedPools.ContainsKey(power.Id)) && !string.IsNullOrEmpty(power.Cost))
                                                                {
                                                                    <text> | </text>
                                                                }
                                                                @if (!string.IsNullOrEmpty(power.Cost))
                                                                {
                                                                    <text>Cost: @power.Cost</text>
                                                                }
                                                            </div>
                                                        }
                                                        @if (!string.IsNullOrEmpty(power.PoolDefinitionJson))
                                                        {
                                                            <button type="button" class="btn-rn-ghost btn-roll-small"
                                                                    @onclick="() => OpenDisciplinePowerActivateModal(power)">
                                                                Activate
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>

                        <!-- BLOODLINES -->
                        <section class="cs-section cs-bloodlines">
                            <h2>Bloodline</h2>
                            @{
                                var activeBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Active);
                                var pendingBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Pending);
                            }
                            @if (activeBloodline?.BloodlineDefinition != null)
                            {
                                <div class="bloodline-info">
                                    <strong>@activeBloodline.BloodlineDefinition.Name</strong>
                                    <p class="bloodline-desc">@activeBloodline.BloodlineDefinition.Description</p>
                                    <div class="bloodline-detail-row">
                                        <span class="trait-subheading">Lineage:</span> @(_character.Clan?.Name ?? "—") → @activeBloodline.BloodlineDefinition.Name
                                    </div>
                                    @if (_character.Banes?.Any() == true)
                                    {
                                        <div class="bloodline-bane-row">
                                            <span class="trait-subheading">Clan Bane:</span> @_character.Banes.First().Description
                                        </div>
                                    }
                                    <div class="bloodline-bane-row">
                                        <span class="trait-subheading">Bloodline Bane:</span> @activeBloodline.BloodlineDefinition.BaneOverride
                                    </div>
                                    @if (_isFreeEditMode)
                                    {
                                        <button class="btn-rn-ghost btn-roll-small bloodline-detail-row" @onclick="() => RemoveBloodline(activeBloodline.Id)" disabled="@_removingBloodline">
                                            @(_removingBloodline ? "Removing…" : "Remove Bloodline")
                                        </button>
                                    }
                                </div>
                            }
                            else if (pendingBloodline?.BloodlineDefinition != null)
                            {
                                <p class="pending-status">Pending: <strong>@pendingBloodline.BloodlineDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId" class="btn-rn-ghost btn-roll-small bloodline-detail-row">View Campaign</a>
                                }
                            }
                            else if (_character.BloodPotency >= 2 && _character.ClanId.HasValue && _character.CampaignId.HasValue)
                            {
                                <p class="unaligned-note">None. Apply when Blood Potency 2+.</p>
                                <button class="btn-rn-primary text-small" @onclick="OpenApplyBloodlineModal">Apply for Bloodline</button>
                            }
                            else
                            {
                                <p class="none-note">None. Apply for a bloodline when Blood Potency 2+.</p>
                            }
                        </section>

                        <!-- COVENANT -->
                        <section class="cs-section cs-covenant">
                            <h2>Covenant</h2>
                            @if (_character.Covenant != null && _character.CovenantJoinStatus != Data.Models.Enums.CovenantJoinStatus.Pending)
                            {
                                <div class="bloodline-info">
                                    <strong>@_character.Covenant.Name</strong>
                                    <p class="bloodline-desc">@_character.Covenant.Description</p>
                                    @if (_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <p class="pending-status bloodline-detail-row">Leave requested — awaiting Storyteller approval.</p>
                                    }
                                    else if (_character.CampaignId.HasValue && !_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <button class="btn-rn-ghost btn-roll-small bloodline-detail-row" @onclick="RequestLeaveCovenant" disabled="@_requestingLeave">
                                            @(_requestingLeave ? "Requesting…" : "Request to Leave")
                                        </button>
                                    }
                                </div>
                            }
                            else if (_character.CovenantJoinStatus == Data.Models.Enums.CovenantJoinStatus.Pending && _character.Covenant != null)
                            {
                                <p class="pending-status">Pending: <strong>@_character.Covenant.Name</strong> — awaiting Storyteller approval.</p>
                                <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-rn-ghost btn-roll-small bloodline-detail-row">Storyteller Glimpse</a>
                                }
                            }
                            else if (_character.CampaignId.HasValue)
                            {
                                <p class="unaligned-note">Unaligned. Apply to join a covenant.</p>
                                <button class="btn-rn-primary text-small" @onclick="OpenApplyCovenantModal">Apply for Covenant</button>
                            }
                            else
                            {
                                <p class="none-note">Unaligned. Join a campaign to apply for a covenant.</p>
                            }
                        </section>

                        @if (_character.CampaignId.HasValue && !string.IsNullOrEmpty(_currentUserId))
                        {
                            <SocialManeuversSection CharacterId="Id" CurrentUserId="@_currentUserId" />
                            <LineageSection CharacterId="Id" CurrentUserId="@_currentUserId" CampaignId="_character.CampaignId" />
                            <BloodBondsSection CharacterId="Id" CurrentUserId="@_currentUserId" />
                            <GhoulsSection CharacterId="Id" CurrentUserId="@_currentUserId" />
                            <PredatoryAuraSection CharacterId="Id" CurrentUserId="@_currentUserId" CampaignId="_character.CampaignId" />
                        }

                        <!-- DEVOTIONS -->
                        <section class="cs-section cs-devotions">
                            <h2>Devotions</h2>
                            @if (_character.Devotions?.Any() == true)
                            {
                                <ul class="trait-list">
                                    @foreach (var cd in _character.Devotions)
                                    {
                                        @if (cd.DevotionDefinition != null)
                                        {
                                            <li class="trait-item">
                                                <span>@cd.DevotionDefinition.Name</span>
                                                @if (!cd.DevotionDefinition.IsPassive && !string.IsNullOrEmpty(cd.DevotionDefinition.PoolDefinitionJson))
                                                {
                                                    <button class="btn-rn-ghost btn-roll-small" @onclick="async () => await OpenDevotionRollerAsync(cd)">Roll</button>
                                                }
                                            </li>
                                        }
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="none-note">None yet. Purchase devotions via Advancement.</p>
                            }
                        </section>

                        <CharacterSheetWornCard Character="_character" />
                        <CharacterSheetBackpackCard Character="_character" OnManagePack="GoToPackTab" />

                        <!-- BLOOD SORCERY: Crúac/Theban covenants or characters with Necromancy -->
                        @if (ShowBloodSorcerySection)
                        {
                            <section class="cs-section cs-blood-sorcery">
                                <h2>Blood Sorcery</h2>
                                @{
                                    var approvedRites = _character.Rites?.Where(r => r.Status == Data.Models.Enums.RiteLearnStatus.Approved && r.SorceryRiteDefinition != null).ToList();
                                    var pendingRite = _character.Rites?.FirstOrDefault(r => r.Status == Data.Models.Enums.RiteLearnStatus.Pending);
                                }
                                @if (approvedRites?.Any() == true)
                                {
                                    <ul class="trait-list">
                                        @foreach (var cr in approvedRites)
                                        {
                                            @if (cr.SorceryRiteDefinition != null)
                                            {
                                                <li class="trait-item">
                                                    <span>@cr.SorceryRiteDefinition.Name</span>
                                                    <span class="tradition-label">Lv.@cr.SorceryRiteDefinition.Level (@TraditionLabel(cr.SorceryRiteDefinition.SorceryType)), @cr.SorceryRiteDefinition.TargetSuccesses successes</span>
                                                    @if (!string.IsNullOrWhiteSpace(cr.SorceryRiteDefinition.ActivationCostDescription))
                                                    {
                                                        <span class="activation-cost">@cr.SorceryRiteDefinition.ActivationCostDescription</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(cr.SorceryRiteDefinition.PoolDefinitionJson))
                                                    {
                                                        <button class="btn-rn-ghost btn-roll-small" @onclick="() => OpenRiteRoller(cr)">Roll</button>
                                                    }
                                                </li>
                                            }
                                        }
                                    </ul>
                                }
                                else if (pendingRite?.SorceryRiteDefinition != null)
                                {
                                    <p class="pending-status">Pending: <strong>@pendingRite.SorceryRiteDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                    <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                    @if (_character.CampaignId.HasValue)
                                    {
                                        <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-rn-ghost btn-roll-small bloodline-detail-row">Storyteller Glimpse</a>
                                    }
                                }
                                else
                                {
                                    <p class="unaligned-note">No rites yet. Purchase Crúac, Theban Sorcery, or Necromancy dots via Advancement where appropriate, then request to learn rites.</p>
                                    <button class="btn-rn-primary text-small" @onclick="OpenLearnRiteModal" disabled="@_openingRiteModal">Learn Rite</button>
                                }
                            </section>
                        }

                        <!-- MYSTERIES OF THE DRAGON (visible only to Ordo Dracul members) -->
                        @if (IsOrdoDraculMember)
                        {
                            <section class="cs-section cs-coils">
                                <h2>Mysteries of the Dragon</h2>
                                @if (_character.ChosenMysteryScaleId.HasValue)
                                {
                                    <p class="mystery-info">
                                        <strong>Chosen Mystery:</strong> @(_character.ChosenMysteryScale?.Name ?? "Unknown")
                                    </p>
                                }
                                else if (_character.PendingChosenMysteryScaleId.HasValue)
                                {
                                    <p class="pending-status">
                                        Chosen Mystery pending: <strong>@(_character.PendingChosenMysteryScale?.Name ?? "Unknown")</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                else if (_character.CampaignId.HasValue)
                                {
                                    <p class="unaligned-note">No Chosen Mystery selected.</p>
                                    <button class="btn-rn-primary text-small" @onclick="OpenChosenMysteryModal">Select Chosen Mystery</button>
                                }
                                @{
                                    var approvedCoils = _character.Coils?.Where(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Approved && cc.CoilDefinition != null).ToList();
                                    var pendingCoil = _character.Coils?.FirstOrDefault(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Pending);
                                }
                                @if (approvedCoils?.Any() == true)
                                {
                                    <ul class="trait-list coil-list">
                                        @foreach (var cc in approvedCoils.OrderBy(c => c.CoilDefinition!.ScaleId).ThenBy(c => c.CoilDefinition!.Level))
                                        {
                                            <li class="trait-item">
                                                <span>@cc.CoilDefinition!.Name</span>
                                                <span class="coil-tier-label">@cc.CoilDefinition.Scale?.Name — Tier @cc.CoilDefinition.Level</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else if (pendingCoil?.CoilDefinition != null)
                                {
                                    <p class="pending-status bloodline-detail-row">
                                        Pending: <strong>@pendingCoil.CoilDefinition.Name</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                @if (_character.CampaignId.HasValue)
                                {
                                    <button class="btn-rn-ghost btn-roll-small bloodline-detail-row" @onclick="OpenLearnCoilModal">Purchase Coil</button>
                                }
                                @if (_character.HasCrucibleRitualAccess)
                                {
                                    <p class="ritual-active-note">Crucible Ritual active — reduced XP costs apply.</p>
                                }
                            </section>
                        }
                    </div>

                    <div class="cs-conditions-sheet-slot">
                        <ConditionsSection CharacterId="_character.Id"
                                           UserId="@(_currentUserId ?? string.Empty)" />
                    </div>

                </div>
            }
            else if (_activeTab == "pack")
            {
                <CharacterDetailsPackTab Character="_character"
                                         AvailableAssets="_availableAssets"
                                         @bind-SelectedAssetId="_selectedAssetId"
                                         @bind-SelectedAssetQuantity="_selectedAssetQuantity"
                                         IsPurchaseDisabled="IsPurchaseButtonDisabled"
                                         PurchaseButtonTitle="@PurchaseButtonTitle"
                                         OnPurchaseClicked="PurchaseSelectedAssetAsync"
                                         OnAssetEquippedChanged="HandlePackAssetEquippedAsync"
                                         OnStructureChanged="HandlePackStructureChangedAsync"
                                         OnBackpackSlotSelect="HandlePackBackpackSlotSelectAsync"
                                         OnClearBackpackSlot="ClearBackpackSlotAsync"
                                         OnOpenRepairRoller="OpenRepairRoller"
                                         OnOpenForgeModal="OpenForgeModal"
                                         OnRemoveCharacterAsset="RemoveCharacterAsset" />
            }
            else if (_activeTab == "identity")
            {
                <div id="panel-identity" role="tabpanel" aria-labelledby="tab-identity">
                    <CharacterIdentityTab Character="_character" OnChanged="SaveCharacter" />
                </div>
            }
            else if (_activeTab == "history")
            {
                <div id="panel-history" role="tabpanel" aria-labelledby="tab-history">
                    <BeatLedgerSection CharacterId="_character.Id" />
                </div>
            }
        </CascadingValue>
            </div>
        </div>

        <CharacterDetailsSessionSidebar IsConnected="SessionClient.IsConnected" />
    </div>

    <DisciplinePowerActivateModal
        IsOpen="_isDisciplineActivateModalOpen"
        IsOpenChanged="(v) => _isDisciplineActivateModalOpen = v"
        Power="_disciplineActivatePower"
        ResolvedPool="_disciplineActivatePool"
        OnConfirmed="HandleDisciplineActivateConfirmedAsync" />

    <RiteActivationPrepModal IsOpen="_isRitePrepModalOpen"
                             IsOpenChanged="HandleRitePrepModalOpenChanged"
                             RiteName="@(_pendingRiteForPrep?.SorceryRiteDefinition?.Name ?? "Rite")"
                             Tradition="@(_pendingRiteForPrep?.SorceryRiteDefinition?.SorceryType ?? SorceryType.Cruac)"
                             KinTargets="_riteKinTargets"
                             OnContinue="HandleRitePrepContinueAsync" />
    <DiceRollerModal IsVisible="_isRollerOpen"
                     IsVisibleChanged="OnDiceRollerVisibilityChangedAsync"
                     TraitName="@_rollerTraitName"
                     BaseDice="@_rollerBaseDice"
                     Character="_character"
                     FixedDicePool="_rollerFixedDicePool"
                     RiteExtendedMaxRolls="_rollerRiteMaxRolls"
                     RiteExtendedTargetSuccesses="_rollerRiteTargetSuccesses"
                     RiteExtendedMinutesPerRoll="_rollerRiteMinutesPerRoll"
                     RiteOutcomeTradition="_rollerRiteSorceryType" />

    @if (_isForgeModalOpen)
    {
        @* Phase 11 Refinement: Forge Modal Placeholder *@
        <div class="modal-overlay-rn" @onclick="() => _isForgeModalOpen = false">
            <div class="modal-content-rn" @onclick:stopPropagation>
                <h3>Forge: @(_forgeTarget?.Asset?.Name ?? "Item")</h3>
                <p>Modifiers and upgrades for this item will appear here in the next content update.</p>
                <button type="button" class="btn-rn-primary" @onclick="() => _isForgeModalOpen = false">Close</button>
            </div>
        </div>
    }

    <ApplyBloodlineModal IsOpen="_isApplyBloodlineModalOpen"
                         IsOpenChanged="HandleApplyBloodlineModalClosed"
                         EligibleBloodlines="_eligibleBloodlines"
                         OnApplyRequested="HandleApplyBloodlineRequested" />
    <ApplyCovenantModal IsOpen="_isApplyCovenantModalOpen"
                        IsOpenChanged="HandleApplyCovenantModalClosed"
                        EligibleCovenants="_eligibleCovenants"
                        OnApplyRequested="HandleApplyCovenantRequested" />
    <ApplyLearnRiteModal IsOpen="_isApplyLearnRiteModalOpen"
                        IsOpenChanged="HandleApplyLearnRiteModalClosed"
                        EligibleRites="_eligibleRites"
                        OnApplyRequested="HandleApplyLearnRiteRequested" />
    <SelectScaleModal IsOpen="_isChosenMysteryModalOpen"
                      IsOpenChanged="(v) => _isChosenMysteryModalOpen = v"
                      Scales="_eligibleScales"
                      OnScaleSelected="HandleChosenMysteryRequested" />
    <SelectCoilModal IsOpen="_isLearnCoilModalOpen"
                     IsOpenChanged="(v) => _isLearnCoilModalOpen = v"
                     Coils="_eligibleCoils"
                     OnCoilSelected="HandleLearnCoilRequested" />

    <ConfirmModal IsOpen="_degRollPlayerModalOpen"
                  Title="Confirm degeneration roll"
                  Message="@PlayerDegenerationModalMessage"
                  ConfirmLabel="Roll degeneration"
                  OnConfirmClicked="ConfirmPlayerDegenerationRollAsync"
                  OnCancelClicked="ClosePlayerDegenerationModal" />
}

