@page "/character/{Id:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Models
@using RequiemNexus.Domain.Services
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using Microsoft.JSInterop
@inject ICharacterService CharacterService
@inject ICharacterAssetService CharacterAssetService
@inject IAssetProcurementService AssetProcurementService
@inject IAdvancementService AdvancementService
@inject ICharacterExportService ExportService
@inject ITraitResolver TraitResolver
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject ToastService ToastService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ICoilService CoilService

<PageTitle>@(_character?.Name ?? "Character Sheet") - Requiem Nexus</PageTitle>

@if (_isSheetLoading)
{
    <SkeletonLoader Variant="sheet" />
}
else if (_sheetLoadError != null)
{
    <div class="page-container fade-in">
        <div class="alert alert-danger" role="alert">
            <strong>Could not load character.</strong> @_sheetLoadError
        </div>
        <a href="/characters" class="btn-primary-rn mt-3">Back to My Characters</a>
    </div>
}
else if (_character == null)
{
    <div class="page-container fade-in">
        <div class="empty-state-rn">
            <p>@(string.IsNullOrEmpty(_currentUserId) ? "You must be signed in to view this character." : "Character not found or you do not have access.")</p>
            <a href="/characters" class="btn-primary-rn">Back to My Characters</a>
        </div>
    </div>
}
else
{
    <div class="character-sheet-layout @(SessionClient.IsConnected ? "with-sidebar" : "")">
        <div class="character-sheet fade-in">
            <!-- HEADER -->
        <header class="cs-header">
            <div class="char-avatar"></div>
            <div class="char-info">
                @if (_isEditingName)
                {
                    <input type="text" class="char-name-input" @bind="_character.Name" @onblur="SaveNameOffBlur" @onkeyup="HandleNameKeyUp" autofocus />
                }
                else
                {
                    <h1 @onclick="() => _isEditingName = true" class="edit-name-trigger" title="Click to edit name">@_character.Name <i class="edit-icon">✎</i></h1>
                }
                <div class="char-meta">
                    <span><strong>Concept:</strong> @(string.IsNullOrEmpty(_character.Concept) ? "???" : _character.Concept)</span>
                    <span><strong>Clan:</strong> @(_character.Clan?.Name ?? "None")</span>
                    <span><strong>Covenant:</strong> @(_character.Covenant?.Name ?? "Unaligned")</span>
                    <span><strong>Chronicle:</strong> @(_character.Campaign?.Name ?? "None")</span>
                    <span><strong>Mask:</strong> @(string.IsNullOrEmpty(_character.Mask) ? "???" : _character.Mask)</span>
                    <span><strong>Dirge:</strong> @(string.IsNullOrEmpty(_character.Dirge) ? "???" : _character.Dirge)</span>
                    @if (_isFreeEditMode)
                    {
                        <span><strong>Touchstone:</strong> <input type="text" @bind="_character.Touchstone" class="char-meta-input" placeholder="e.g. My sibling" /></span>
                    }
                    else
                    {
                        <span><strong>Touchstone:</strong> @(string.IsNullOrEmpty(_character.Touchstone) ? "???" : _character.Touchstone)</span>
                    }
                </div>
                <div class="char-xp">
                    <div class="char-xp-trackers">
                        <div class="xp-counter">
                            <strong class="xp-counter-label">Beats</strong>
                            <button class="xp-counter-btn" @onclick="RemoveBeat"
                                disabled="@(_character.Beats <= 0)">-</button>
                            <span class="xp-counter-value">@_character.Beats</span>
                            <button class="xp-counter-btn" @onclick="AddBeat">+</button>
                        </div>
                        <div class="xp-counter">
                            <strong class="xp-counter-label">Experiences</strong>
                            <button class="xp-counter-btn" @onclick="RemoveXP"
                                disabled="@(_character.ExperiencePoints <= 0)">-</button>
                            <span class="xp-counter-value">@_character.ExperiencePoints</span>
                            <button class="xp-counter-btn" @onclick="AddXP">+</button>
                        </div>
                        <div class="xp-total">
                            <strong class="xp-counter-label">Total XP</strong>
                            <span class="xp-counter-value">@_character.TotalExperiencePoints</span>
                        </div>
                    </div>
                    <div class="char-xp-actions">
                        <button class="btn-ghost mode-toggle-btn"
                        @onclick="GoToAdvancement">
                            Enter Advancement
                        </button>
                        <button class="btn-ghost mode-toggle-btn @(_isFreeEditMode ? "active" : "")"
                        @onclick="ToggleFreeEditMode">
                            @(_isFreeEditMode ? "Finish Edit" : "Edit Character")
                        </button>
                        <button class="btn-ghost mode-toggle-btn" @onclick="ExportJson" disabled="@_isExporting">
                            @(_isExporting ? "Exporting…" : "Export JSON")
                        </button>
                        <button class="btn-ghost mode-toggle-btn" @onclick="ExportPdf" disabled="@_isExporting">
                            @(_isExporting ? "Exporting…" : "Export PDF")
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <div class="tab-bar" role="tablist" aria-label="Character sheet sections">
            <button type="button" class="tab-btn @(_activeTab == "sheet" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "sheet")" aria-controls="panel-sheet" id="tab-sheet" @onclick='() => SelectTab("sheet")' @onkeydown="HandleTabKeydown">Character Sheet</button>
            <button type="button" class="tab-btn @(_activeTab == "pack" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "pack")" aria-controls="panel-pack" id="tab-pack" @onclick='() => SelectTab("pack")' @onkeydown="HandleTabKeydown">The Pack</button>
            <button type="button" class="tab-btn @(_activeTab == "identity" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "identity")" aria-controls="panel-identity" id="tab-identity" @onclick='() => SelectTab("identity")' @onkeydown="HandleTabKeydown">Identity &amp; Backstory</button>
            <button type="button" class="tab-btn @(_activeTab == "history" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "history")" aria-controls="panel-history" id="tab-history" @onclick='() => SelectTab("history")' @onkeydown="HandleTabKeydown">XP History</button>
        </div>

        @if (_character.CampaignId is int chronicleId)
        {
            <EncounterInitiativeEmbed CampaignId="chronicleId" CharacterId="_character.Id" />
        }

        <CascadingValue Value="@(_isAdvancementMode || _isFreeEditMode)" Name="IsEditable">
            @if (_activeTab == "sheet")
            {
                <div class="cs-grid">
                    <!-- VITALS / ADVANTAGES BARS (Top Grid Layer) -->
                    <CharacterVitals Character="_character" OnChanged="SaveCharacter" />

                    <!-- ATTRIBUTES -->
                    <section class="cs-section cs-attributes">
                        <div class="section-divider">
                            <span class="section-divider-label">◆ Attributes ◆</span>
                        </div>
                        <div class="grid-3-col">
                            @foreach (var (label, category) in new[] {
                                ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                                ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                                ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                            })
                            {
                                <div class="stat-col @label.ToLower()">
                                    <h3>@label</h3>
                                    @foreach (var attr in _character.Attributes.Where(a => a.Category == category))
                                    {
                                        <DotScale @bind-Value="attr.Rating" Label="@RequiemNexus.Domain.TraitMetadata.GetDisplayName(attr.Name)" OnLabelClick="OpenReference"
                                            OnRollClick="OpenRoller" />
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <!-- SKILLS -->
                    <section class="cs-section cs-skills">
                        <div class="section-divider">
                            <span class="section-divider-label">◆ Skills ◆</span>
                        </div>
                        <div class="grid-3-col">
                            @foreach (var (label, category) in new[] {
                                ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                                ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                                ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                            })
                            {
                                <div class="stat-col @label.ToLower()">
                                    <h3>@label</h3>
                                    @foreach (var skill in _character.Skills.Where(s => s.Category == category))
                                    {
                                        <DotScale @bind-Value="skill.Rating" Label="@RequiemNexus.Domain.TraitMetadata.GetDisplayName(skill.Name)" OnLabelClick="OpenReference"
                                            OnRollClick="OpenRoller" />
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <!-- SUPERNATURAL & ADVANTAGES -->
                    <div class="grid-2-col">
                        <section class="cs-section cs-advantages">
                            <h2>Advantages</h2>
                            <DotScale @bind-Value="_character.BloodPotency" Label="Blood Potency" Max="10"
                                OnLabelClick="OpenReference" OnRollClick="OpenRoller" />
                            <DotScale @bind-Value="_character.Humanity" Label="Humanity" Max="10" OnLabelClick="OpenReference"
                                OnRollClick="OpenRoller" />

                            <h3 class="trait-subheading">Merits</h3>
                            <ul class="trait-list">
                                @foreach (var merit in _character.Merits)
                                {
                                    <li class="trait-item merit-item @(_expandedMeritIds.Contains(merit.Id) ? "expanded" : "")"
                                        @onclick="() => ToggleMeritExpanded(merit.Id)"
                                        role="button"
                                        tabindex="0"
                                        @onkeydown="(e) => HandleMeritKeydown(e, merit.Id)">
                                        <div class="merit-header">
                                            <span>@merit.Merit?.Name @(string.IsNullOrEmpty(merit.Specification) || merit.Specification == "N/A" ? "" :
                                                $"({merit.Specification})")</span>
                                            <span class="trait-dots">@(new string('\u2022', merit.Rating))</span>
                                            <span class="merit-chevron">@(_expandedMeritIds.Contains(merit.Id) ? $"{(char)0x25BC}" : $"{(char)0x25B6}")</span>
                                        </div>
                                        @if (_expandedMeritIds.Contains(merit.Id) && merit.Merit != null && !string.IsNullOrEmpty(merit.Merit.Description))
                                        {
                                            <div class="merit-description">@merit.Merit.Description</div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>
                        <section class="cs-section cs-disciplines">
                            <h2>Disciplines</h2>
                            <ul class="trait-list disciplines-list">
                                @foreach (var disc in _character.Disciplines)
                                {
                                    <li class="trait-item discipline-item flex-col-stretch">
                                        <div class="discipline-item-header" @onclick="() => ToggleDiscipline(disc.DisciplineId)">
                                            <span>
                                                @if (_expandedDisciplines.Contains(disc.DisciplineId))
                                                {
                                                    <i class="oi oi-chevron-bottom expand-icon"></i>
                                                }
                                                else
                                                {
                                                    <i class="oi oi-chevron-right expand-icon"></i>
                                                }
                                                @disc.Discipline?.Name
                                            </span>
                                            <span class="trait-dots">@(new string('\u2022', disc.Rating))</span>
                                        </div>
                                        
                                        @if (_expandedDisciplines.Contains(disc.DisciplineId) && disc.Discipline?.Powers != null)
                                        {
                                            <div class="discipline-powers">
                                                @foreach (var power in disc.Discipline.Powers.Where(p => p.Level <= disc.Rating).OrderBy(p => p.Level))
                                                {
                                                    <div class="power-item">
                                                        <strong>Level @power.Level - @power.Name:</strong>
                                                        <p class="power-desc">@power.Description</p>
                                                        @if (!string.IsNullOrEmpty(power.DicePool) || !string.IsNullOrEmpty(power.Cost))
                                                        {
                                                            <div class="power-meta">
                                                                @(string.IsNullOrEmpty(power.DicePool) ? "" : $"Pool: {power.DicePool}")
                                                                @(string.IsNullOrEmpty(power.DicePool) || string.IsNullOrEmpty(power.Cost) ? "" : " | ")
                                                                @(string.IsNullOrEmpty(power.Cost) ? "" : $"Cost: {power.Cost}")
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>

                        <!-- BLOODLINES -->
                        <section class="cs-section cs-bloodlines">
                            <h2>Bloodline</h2>
                            @{
                                var activeBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Active);
                                var pendingBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Pending);
                            }
                            @if (activeBloodline?.BloodlineDefinition != null)
                            {
                                <div class="bloodline-info">
                                    <strong>@activeBloodline.BloodlineDefinition.Name</strong>
                                    <p class="bloodline-desc">@activeBloodline.BloodlineDefinition.Description</p>
                                    <div class="bloodline-detail-row">
                                        <span class="trait-subheading">Lineage:</span> @(_character.Clan?.Name ?? "—") → @activeBloodline.BloodlineDefinition.Name
                                    </div>
                                    @if (_character.Banes?.Any() == true)
                                    {
                                        <div class="bloodline-bane-row">
                                            <span class="trait-subheading">Clan Bane:</span> @_character.Banes.First().Description
                                        </div>
                                    }
                                    <div class="bloodline-bane-row">
                                        <span class="trait-subheading">Bloodline Bane:</span> @activeBloodline.BloodlineDefinition.BaneOverride
                                    </div>
                                    @if (_isFreeEditMode)
                                    {
                                        <button class="btn-ghost btn-roll-small bloodline-detail-row" @onclick="() => RemoveBloodline(activeBloodline.Id)" disabled="@_removingBloodline">
                                            @(_removingBloodline ? "Removing…" : "Remove Bloodline")
                                        </button>
                                    }
                                </div>
                            }
                            else if (pendingBloodline?.BloodlineDefinition != null)
                            {
                                <p class="pending-status">Pending: <strong>@pendingBloodline.BloodlineDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId" class="btn-ghost btn-roll-small bloodline-detail-row">View Campaign</a>
                                }
                            }
                            else if (_character.BloodPotency >= 2 && _character.ClanId.HasValue && _character.CampaignId.HasValue)
                            {
                                <p class="unaligned-note">None. Apply when Blood Potency 2+.</p>
                                <button class="btn-primary-rn text-small" @onclick="OpenApplyBloodlineModal">Apply for Bloodline</button>
                            }
                            else
                            {
                                <p class="none-note">None. Apply for a bloodline when Blood Potency 2+.</p>
                            }
                        </section>

                        <!-- COVENANT -->
                        <section class="cs-section cs-covenant">
                            <h2>Covenant</h2>
                            @if (_character.Covenant != null && _character.CovenantJoinStatus != Data.Models.Enums.CovenantJoinStatus.Pending)
                            {
                                <div class="bloodline-info">
                                    <strong>@_character.Covenant.Name</strong>
                                    <p class="bloodline-desc">@_character.Covenant.Description</p>
                                    @if (_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <p class="pending-status bloodline-detail-row">Leave requested — awaiting Storyteller approval.</p>
                                    }
                                    else if (_character.CampaignId.HasValue && !_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <button class="btn-ghost btn-roll-small bloodline-detail-row" @onclick="RequestLeaveCovenant" disabled="@_requestingLeave">
                                            @(_requestingLeave ? "Requesting…" : "Request to Leave")
                                        </button>
                                    }
                                </div>
                            }
                            else if (_character.CovenantJoinStatus == Data.Models.Enums.CovenantJoinStatus.Pending && _character.Covenant != null)
                            {
                                <p class="pending-status">Pending: <strong>@_character.Covenant.Name</strong> — awaiting Storyteller approval.</p>
                                <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-ghost btn-roll-small bloodline-detail-row">Storyteller Glimpse</a>
                                }
                            }
                            else if (_character.CampaignId.HasValue)
                            {
                                <p class="unaligned-note">Unaligned. Apply to join a covenant.</p>
                                <button class="btn-primary-rn text-small" @onclick="OpenApplyCovenantModal">Apply for Covenant</button>
                            }
                            else
                            {
                                <p class="none-note">Unaligned. Join a campaign to apply for a covenant.</p>
                            }
                        </section>

                        @if (_character.CampaignId.HasValue && !string.IsNullOrEmpty(_currentUserId))
                        {
                            <SocialManeuversSection CharacterId="Id" CurrentUserId="@_currentUserId" />
                            <LineageSection CharacterId="Id" CurrentUserId="@_currentUserId" CampaignId="_character.CampaignId" />
                        }

                        <!-- DEVOTIONS -->
                        <section class="cs-section cs-devotions">
                            <h2>Devotions</h2>
                            @if (_character.Devotions?.Any() == true)
                            {
                                <ul class="trait-list">
                                    @foreach (var cd in _character.Devotions)
                                    {
                                        @if (cd.DevotionDefinition != null)
                                        {
                                            <li class="trait-item">
                                                <span>@cd.DevotionDefinition.Name</span>
                                                @if (!cd.DevotionDefinition.IsPassive && !string.IsNullOrEmpty(cd.DevotionDefinition.PoolDefinitionJson))
                                                {
                                                    <button class="btn-ghost btn-roll-small" @onclick="async () => await OpenDevotionRollerAsync(cd)">Roll</button>
                                                }
                                            </li>
                                        }
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="none-note">None yet. Purchase devotions via Advancement.</p>
                            }
                        </section>

                        <CharacterSheetWornCard Character="_character" />
                        <CharacterSheetBackpackCard Character="_character" OnManagePack="GoToPackTab" />

                        <!-- BLOOD SORCERY: Cr├║ac/Theban covenants, Ordo rituals, or characters with Necromancy -->
                        @if (ShowBloodSorcerySection)
                        {
                            <section class="cs-section cs-blood-sorcery">
                                <h2>Blood Sorcery</h2>
                                @{
                                    var approvedRites = _character.Rites?.Where(r => r.Status == Data.Models.Enums.RiteLearnStatus.Approved && r.SorceryRiteDefinition != null).ToList();
                                    var pendingRite = _character.Rites?.FirstOrDefault(r => r.Status == Data.Models.Enums.RiteLearnStatus.Pending);
                                }
                                @if (approvedRites?.Any() == true)
                                {
                                    <ul class="trait-list">
                                        @foreach (var cr in approvedRites)
                                        {
                                            @if (cr.SorceryRiteDefinition != null)
                                            {
                                                <li class="trait-item">
                                                    <span>@cr.SorceryRiteDefinition.Name</span>
                                                    <span class="tradition-label">Lv.@cr.SorceryRiteDefinition.Level (@TraditionLabel(cr.SorceryRiteDefinition.SorceryType))</span>
                                                    @if (!string.IsNullOrWhiteSpace(cr.SorceryRiteDefinition.ActivationCostDescription))
                                                    {
                                                        <span class="activation-cost">@cr.SorceryRiteDefinition.ActivationCostDescription</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(cr.SorceryRiteDefinition.PoolDefinitionJson))
                                                    {
                                                        <button class="btn-ghost btn-roll-small" @onclick="() => OpenRiteRoller(cr)">Roll</button>
                                                    }
                                                </li>
                                            }
                                        }
                                    </ul>
                                }
                                else if (pendingRite?.SorceryRiteDefinition != null)
                                {
                                    <p class="pending-status">Pending: <strong>@pendingRite.SorceryRiteDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                    <p class="pending-note">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                    @if (_character.CampaignId.HasValue)
                                    {
                                        <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-ghost btn-roll-small bloodline-detail-row">Storyteller Glimpse</a>
                                    }
                                }
                                else
                                {
                                    <p class="unaligned-note">No rites yet. Purchase Cr├║ac, Theban Sorcery, Necromancy, or Ordo Sorcery dots via Advancement where appropriate, then request to learn rites.</p>
                                    <button class="btn-primary-rn text-small" @onclick="OpenLearnRiteModal" disabled="@_openingRiteModal">Learn Rite</button>
                                }
                            </section>
                        }

                        <!-- MYSTERIES OF THE DRAGON (visible only to Ordo Dracul members) -->
                        @if (IsOrdoDraculMember)
                        {
                            <section class="cs-section cs-coils">
                                <h2>Mysteries of the Dragon</h2>
                                @if (_character.ChosenMysteryScaleId.HasValue)
                                {
                                    <p class="mystery-info">
                                        <strong>Chosen Mystery:</strong> @(_character.ChosenMysteryScale?.Name ?? "Unknown")
                                    </p>
                                }
                                else if (_character.PendingChosenMysteryScaleId.HasValue)
                                {
                                    <p class="pending-status">
                                        Chosen Mystery pending: <strong>@(_character.PendingChosenMysteryScale?.Name ?? "Unknown")</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                else if (_character.CampaignId.HasValue)
                                {
                                    <p class="unaligned-note">No Chosen Mystery selected.</p>
                                    <button class="btn-primary-rn text-small" @onclick="OpenChosenMysteryModal">Select Chosen Mystery</button>
                                }
                                @{
                                    var approvedCoils = _character.Coils?.Where(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Approved && cc.CoilDefinition != null).ToList();
                                    var pendingCoil = _character.Coils?.FirstOrDefault(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Pending);
                                }
                                @if (approvedCoils?.Any() == true)
                                {
                                    <ul class="trait-list coil-list">
                                        @foreach (var cc in approvedCoils.OrderBy(c => c.CoilDefinition!.ScaleId).ThenBy(c => c.CoilDefinition!.Level))
                                        {
                                            <li class="trait-item">
                                                <span>@cc.CoilDefinition!.Name</span>
                                                <span class="coil-tier-label">@cc.CoilDefinition.Scale?.Name — Tier @cc.CoilDefinition.Level</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else if (pendingCoil?.CoilDefinition != null)
                                {
                                    <p class="pending-status bloodline-detail-row">
                                        Pending: <strong>@pendingCoil.CoilDefinition.Name</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                @if (_character.CampaignId.HasValue)
                                {
                                    <button class="btn-ghost btn-roll-small bloodline-detail-row" @onclick="OpenLearnCoilModal">Purchase Coil</button>
                                }
                                @if (_character.HasCrucibleRitualAccess)
                                {
                                    <p class="ritual-active-note">Crucible Ritual active — reduced XP costs apply.</p>
                                }
                            </section>
                        }
                    </div>

                    <div class="cs-conditions-sheet-slot">
                        <ConditionsSection CharacterId="_character.Id"
                                           UserId="@(_currentUserId ?? string.Empty)" />
                    </div>

                </div>
            }
            else if (_activeTab == "pack")
            {
                <section class="cs-section cs-equipment" id="panel-pack" role="tabpanel" aria-labelledby="tab-pack">
                    <h2>The Pack</h2>
                    <p class="pack-intro text-muted">Purchase listed gear and services from the catalog: surplus Resources buys outright; at your Availability tier you may use Reach once per chapter (12 hours); further purchases still add to your pack without a table roll. Illicit items require Storyteller approval.</p>

                    <div class="equipment-form">
                        <select @bind="_selectedAssetId" class="equipment-select" aria-label="Asset to purchase">
                            <option value="0">-- Select asset --</option>
                            @foreach (var g in _availableAssets.GroupBy(a => a.Kind).OrderBy(x => x.Key.ToString()))
                            {
                                <optgroup label="@g.Key">
                                    @foreach (var a in g.OrderBy(x => x.Name))
                                    {
                                        <option value="@a.Id">@a.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                        <input type="number" min="1" @bind="_selectedAssetQuantity" class="equipment-quantity" aria-label="Quantity to purchase" />
                        <button class="btn-primary-rn"
                                type="button"
                                id="btn-purchase-asset"
                                disabled="@IsPurchaseButtonDisabled"
                                aria-describedby="@((_availableAssets.Count == 0 || IsPurchaseButtonDisabled) ? "purchase-hint" : null)"
                                title="@PurchaseButtonTitle"
                                @onclick="PurchaseSelectedAssetAsync">Purchase</button>
                    </div>
                    @if (_availableAssets.Count == 0)
                    {
                        <p class="text-muted text-small mt-2" id="purchase-hint" role="status">
                            No listed assets are in the catalog, so Purchase stays disabled.
                        </p>
                    }
                    else if (IsPurchaseButtonDisabled)
                    {
                        <p class="text-muted text-small mt-2" id="purchase-hint" role="note">
                            Select an item from the list and set quantity to at least 1 to enable Purchase.
                        </p>
                    }

                    @{
                        var wornWeapons = _character.CharacterAssets
                            .Where(ca => ca.IsEquipped && ca.Asset is WeaponAsset && CharacterAssetActiveHelper.IsEquippedAndActive(ca))
                            .ToList();
                        int wpUsed = wornWeapons.Sum(ca => ca.Asset is WeaponAsset w ? Math.Max(1, w.WeaponSlotPoints) : 0);
                    }
                    <h3 class="mt-3">Worn</h3>
                    <p class="text-muted text-small">At most one armor. Weapons share @EquipmentCarryRules.MaxWeaponSlotPoints slot points (e.g. two 1-slot sidearms or one 2-slot long gun).</p>
                    <p class="text-small mb-2">Weapon slot points used: <strong>@wpUsed / @EquipmentCarryRules.MaxWeaponSlotPoints</strong></p>

                    <h3 class="mt-3">Backpack (@EquipmentCarryRules.MaxBackpackSlots slots)</h3>
                    <p class="text-muted text-small">Carried on your person but not worn. Assign slots from each inventory row below.</p>
                    <div class="backpack-grid">
                        @for (int i = 0; i < EquipmentCarryRules.MaxBackpackSlots; i++)
                        {
                            int slot = i;
                            var occ = _character.CharacterAssets.FirstOrDefault(ca => ca.BackpackSlotIndex == slot);
                            <div class="backpack-cell">
                                <span class="text-muted text-small">Slot @(slot + 1)</span>
                                @if (occ?.Asset != null)
                                {
                                    <div class="backpack-cell-body">
                                        <span>@occ.Asset.Name</span>
                                        <button type="button" class="btn-ghost text-small" @onclick="() => ClearBackpackSlotAsync(occ.Id)">Clear</button>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Empty</span>
                                }
                            </div>
                        }
                    </div>

                    <h3 class="mt-3">Inventory</h3>
                    <p class="text-muted text-small">Rows not worn and not in a backpack slot are off-person stash (haven, safehouse, etc.).</p>
                    <ul class="equipment-grid">
                        @foreach (var ca in PackInventoryOrder(_character.CharacterAssets))
                        {
                            var broken = ca.CurrentStructure is int st && st <= 0;
                            var isService = ca.Asset?.Kind == AssetKind.Service;
                            <li class="equipment-item @(broken ? "equipment-broken" : "")">
                                <div class="equipment-info">
                                    <strong class="equipment-name">@ca.Asset?.Name (x@ca.Quantity)</strong>
                                    @if (broken)
                                    {
                                        <span class="badge-broken">Broken</span>
                                    }
                                    <div class="equipment-meta">
                                        <span>Kind: @ca.Asset?.Kind</span>
                                        @if (ca.Asset is WeaponAsset w && w.Damage > 0)
                                        {
                                            <span>| Dmg: @w.Damage</span>
                                            <span>| Carry: @(Math.Max(1, w.WeaponSlotPoints)) pt</span>
                                        }
                                        @if (ca.Asset is ArmorAsset ar && ar.ArmorRating > 0)
                                        {
                                            <span>| Arm: @ar.ArmorRating</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(ca.Asset?.Description))
                                    {
                                        <p class="equipment-desc">@ca.Asset.Description</p>
                                    }
                                    @if (isService)
                                    {
                                        <p class="text-muted text-small">Services cannot be worn.</p>
                                    }
                                    else
                                    {
                                        <label class="equipment-equipped-label">
                                            <input type="checkbox" checked="@ca.IsEquipped" disabled="@broken"
                                                   @onchange="e => OnAssetEquippedChanged(ca, e)" />
                                            Equipped (worn)
                                        </label>
                                    }
                                    <div class="pack-row mt-1">
                                        <label class="text-small">Structure <input type="number" class="form-control d-inline-block" style="width:4rem" value="@(ca.CurrentStructure?.ToString() ?? "")" placeholder="—" @onchange="e => OnStructureChanged(ca, e)" /></label>
                                        <label class="text-small ms-2">Backpack
                                            <select class="form-select form-select-sm d-inline-block w-auto ms-1" style="max-width:10rem" disabled="@broken" value="@BackpackSlotSelectValue(ca)" @onchange="e => OnBackpackSlotSelectAsync(ca, e)">
                                                <option value="">—</option>
                                                @for (int bi = 0; bi < EquipmentCarryRules.MaxBackpackSlots; bi++)
                                                {
                                                    <option value="@bi">Slot @(bi + 1)</option>
                                                }
                                            </select>
                                        </label>
                                    </div>
                                    <div class="equipment-actions mt-1">
                                        @if (broken)
                                        {
                                            <button type="button" class="btn-rn-action btn-sm" @onclick="() => OpenRepairRoller(ca)">Repair</button>
                                        }
                                        else if (!isService)
                                        {
                                            <button type="button" class="btn-rn-action btn-sm" @onclick="() => OpenForgeModal(ca)">Forge</button>
                                        }
                                        <button class="equipment-remove-btn ms-2" type="button" @onclick="() => RemoveCharacterAsset(ca.Id)">Remove</button>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </section>
            }
            else if (_activeTab == "identity")
            {
        <CharacterIdentityTab Character="_character" OnChanged="SaveCharacter" />
            }
            else if (_activeTab == "history")
            {
        <BeatLedgerSection CharacterId="_character.Id" />
            }
        </CascadingValue>
        </div>

        @if (SessionClient.IsConnected)
        {
            <div class="character-sidebar">
                <div class="sidebar-header">
                    <h3>≡ƒ⌐╕ Blood Logs</h3>
                </div>
                <div class="sidebar-content">
                    <RollHistoryFeed />
                </div>
            </div>
        }
    </div>

    <DiceRollerModal @bind-IsVisible="_isRollerOpen" TraitName="@_rollerTraitName" BaseDice="@_rollerBaseDice" Character="_character" FixedDicePool="_rollerFixedDicePool" />

    @if (_isForgeModalOpen)
    {
        @* Phase 11 Refinement: Forge Modal Placeholder *@
        <div class="modal-overlay-rn" @onclick="() => _isForgeModalOpen = false">
            <div class="modal-content-rn" @onclick:stopPropagation>
                <h3>Forge: @(_forgeTarget?.Asset?.Name ?? "Item")</h3>
                <p>Modifiers and upgrades for this item will appear here in the next content update.</p>
                <button type="button" class="btn-primary-rn" @onclick="() => _isForgeModalOpen = false">Close</button>
            </div>
        </div>
    }

    <ApplyBloodlineModal IsOpen="_isApplyBloodlineModalOpen"
                         IsOpenChanged="HandleApplyBloodlineModalClosed"
                         EligibleBloodlines="_eligibleBloodlines"
                         OnApplyRequested="HandleApplyBloodlineRequested" />
    <ApplyCovenantModal IsOpen="_isApplyCovenantModalOpen"
                        IsOpenChanged="HandleApplyCovenantModalClosed"
                        EligibleCovenants="_eligibleCovenants"
                        OnApplyRequested="HandleApplyCovenantRequested" />
    <ApplyLearnRiteModal IsOpen="_isApplyLearnRiteModalOpen"
                        IsOpenChanged="HandleApplyLearnRiteModalClosed"
                        EligibleRites="_eligibleRites"
                        OnApplyRequested="HandleApplyLearnRiteRequested" />
    <SelectScaleModal IsOpen="_isChosenMysteryModalOpen"
                      IsOpenChanged="(v) => _isChosenMysteryModalOpen = v"
                      Scales="_eligibleScales"
                      OnScaleSelected="HandleChosenMysteryRequested" />
    <SelectCoilModal IsOpen="_isLearnCoilModalOpen"
                     IsOpenChanged="(v) => _isLearnCoilModalOpen = v"
                     Coils="_eligibleCoils"
                     OnCoilSelected="HandleLearnCoilRequested" />
}

