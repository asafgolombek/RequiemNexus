@page "/character/{Id:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using Microsoft.JSInterop
@inject ICharacterService CharacterService
@inject ICharacterEquipmentService EquipmentService
@inject IAdvancementService AdvancementService
@inject ICharacterExportService ExportService
@inject ITraitResolver TraitResolver
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject ToastService ToastService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ICoilService CoilService

<PageTitle>@(_character?.Name ?? "Character Sheet") - Requiem Nexus</PageTitle>

@if (_character == null)
{
    <SkeletonLoader Variant="sheet" />
}
else
{
    <div class="character-sheet-layout @(SessionClient.IsConnected ? "with-sidebar" : "")">
        <div class="character-sheet fade-in">
            <!-- HEADER -->
        <header class="cs-header">
            <div class="char-avatar"></div>
            <div class="char-info">
                @if (_isEditingName)
                {
                    <input type="text" class="char-name-input" @bind="_character.Name" @onblur="SaveNameOffBlur" @onkeyup="HandleNameKeyUp" autofocus />
                }
                else
                {
                    <h1 @onclick="() => _isEditingName = true" style="cursor: pointer;" title="Click to edit name">@_character.Name <i class="edit-icon">✎</i></h1>
                }
                <div class="char-meta">
                    <span><strong>Concept:</strong> @(string.IsNullOrEmpty(_character.Concept) ? "???" : _character.Concept)</span>
                    <span><strong>Clan:</strong> @(_character.Clan?.Name ?? "None")</span>
                    <span><strong>Covenant:</strong> @(_character.Covenant?.Name ?? "Unaligned")</span>
                    <span><strong>Chronicle:</strong> @(_character.Campaign?.Name ?? "None")</span>
                    <span><strong>Mask:</strong> @(string.IsNullOrEmpty(_character.Mask) ? "???" : _character.Mask)</span>
                    <span><strong>Dirge:</strong> @(string.IsNullOrEmpty(_character.Dirge) ? "???" : _character.Dirge)</span>
                    @if (_isFreeEditMode)
                    {
                        <span><strong>Touchstone:</strong> <input type="text" @bind="_character.Touchstone" class="char-meta-input" placeholder="e.g. My sibling" /></span>
                    }
                    else
                    {
                        <span><strong>Touchstone:</strong> @(string.IsNullOrEmpty(_character.Touchstone) ? "???" : _character.Touchstone)</span>
                    }
                </div>
                <div class="char-xp">
                    <div class="xp-counter">
                        <strong class="xp-counter-label">Beats</strong>
                        <button class="xp-counter-btn" @onclick="RemoveBeat"
                            disabled="@(_character.Beats <= 0)">-</button>
                        <span class="xp-counter-value">@_character.Beats</span>
                        <button class="xp-counter-btn" @onclick="AddBeat">+</button>
                    </div>
                    <div class="xp-counter">
                        <strong class="xp-counter-label">Experiences</strong>
                        <button class="xp-counter-btn" @onclick="RemoveXP"
                            disabled="@(_character.ExperiencePoints <= 0)">-</button>
                        <span class="xp-counter-value">@_character.ExperiencePoints</span>
                        <button class="xp-counter-btn" @onclick="AddXP">+</button>
                    </div>
                    <div class="xp-total">
                        <strong class="xp-counter-label">Total XP</strong>
                        <span class="xp-counter-value">@_character.TotalExperiencePoints</span>
                    </div>

                    <button class="btn-ghost mode-toggle-btn"
                    @onclick="GoToAdvancement">
                        Enter Advancement
                    </button>
                    <button class="btn-ghost mode-toggle-btn @(_isFreeEditMode ? "active" : "")"
                    @onclick="ToggleFreeEditMode">
                        @(_isFreeEditMode ? "Finish Edit" : "Edit Character")
                    </button>
                    <button class="btn-ghost mode-toggle-btn" @onclick="ExportJson" disabled="@_isExporting">
                        @(_isExporting ? "Exporting…" : "Export JSON")
                    </button>
                    <button class="btn-ghost mode-toggle-btn" @onclick="ExportPdf" disabled="@_isExporting">
                        @(_isExporting ? "Exporting…" : "Export PDF")
                    </button>
                </div>
            </div>
        </header>

        <div class="tab-bar" role="tablist" aria-label="Character sheet sections">
            <button type="button" class="tab-btn @(_activeTab == "sheet" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "sheet")" aria-controls="panel-sheet" id="tab-sheet" @onclick='() => SelectTab("sheet")' @onkeydown="HandleTabKeydown">Character Sheet</button>
            <button type="button" class="tab-btn @(_activeTab == "identity" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "identity")" aria-controls="panel-identity" id="tab-identity" @onclick='() => SelectTab("identity")' @onkeydown="HandleTabKeydown">Identity &amp; Backstory</button>
            <button type="button" class="tab-btn @(_activeTab == "history" ? "active" : "")" role="tab" aria-selected="@(_activeTab == "history")" aria-controls="panel-history" id="tab-history" @onclick='() => SelectTab("history")' @onkeydown="HandleTabKeydown">XP History</button>
        </div>

        <CascadingValue Value="@(isAdvancementMode || _isFreeEditMode)" Name="IsEditable">
            @if (_activeTab == "sheet")
            {
                <div class="cs-grid">
                    <!-- VITALS / ADVANTAGES BARS (Top Grid Layer) -->
                    <CharacterVitals Character="_character" OnChanged="SaveCharacter" />

                    <!-- ATTRIBUTES -->
                    <section class="cs-section cs-attributes">
                        <div class="section-divider">
                            <span class="section-divider-label">◆ Attributes ◆</span>
                        </div>
                        <div class="grid-3-col">
                            @foreach (var (label, category) in new[] {
                                ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                                ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                                ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                            })
                            {
                                <div class="stat-col @label.ToLower()">
                                    <h3>@label</h3>
                                    @foreach (var attr in _character.Attributes.Where(a => a.Category == category))
                                    {
                                        <DotScale @bind-Value="attr.Rating" Label="@RequiemNexus.Domain.TraitMetadata.GetDisplayName(attr.Name)" OnLabelClick="OpenReference"
                                            OnRollClick="OpenRoller" />
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <!-- SKILLS -->
                    <section class="cs-section cs-skills">
                        <div class="section-divider">
                            <span class="section-divider-label">◆ Skills ◆</span>
                        </div>
                        <div class="grid-3-col">
                            @foreach (var (label, category) in new[] {
                                ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                                ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                                ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                            })
                            {
                                <div class="stat-col @label.ToLower()">
                                    <h3>@label</h3>
                                    @foreach (var skill in _character.Skills.Where(s => s.Category == category))
                                    {
                                        <DotScale @bind-Value="skill.Rating" Label="@RequiemNexus.Domain.TraitMetadata.GetDisplayName(skill.Name)" OnLabelClick="OpenReference"
                                            OnRollClick="OpenRoller" />
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <!-- SUPERNATURAL & ADVANTAGES -->
                    <div class="grid-2-col">
                        <section class="cs-section cs-advantages">
                            <h2>Advantages</h2>
                            <DotScale @bind-Value="_character.BloodPotency" Label="Blood Potency" Max="10"
                                OnLabelClick="OpenReference" OnRollClick="OpenRoller" />
                            <DotScale @bind-Value="_character.Humanity" Label="Humanity" Max="10" OnLabelClick="OpenReference"
                                OnRollClick="OpenRoller" />

                            <h3 class="trait-subheading">Merits</h3>
                            <ul class="trait-list">
                                @foreach (var merit in _character.Merits)
                                {
                                    <li class="trait-item merit-item @(_expandedMeritIds.Contains(merit.Id) ? "expanded" : "")"
                                        @onclick="() => ToggleMeritExpanded(merit.Id)"
                                        role="button"
                                        tabindex="0"
                                        @onkeydown="(e) => HandleMeritKeydown(e, merit.Id)">
                                        <div class="merit-header">
                                            <span>@merit.Merit?.Name @(string.IsNullOrEmpty(merit.Specification) || merit.Specification == "N/A" ? "" :
                                                $"({merit.Specification})")</span>
                                            <span class="trait-dots">@(new string('•', merit.Rating))</span>
                                            <span class="merit-chevron">@(_expandedMeritIds.Contains(merit.Id) ? "▼" : "▶")</span>
                                        </div>
                                        @if (_expandedMeritIds.Contains(merit.Id) && merit.Merit != null && !string.IsNullOrEmpty(merit.Merit.Description))
                                        {
                                            <div class="merit-description">@merit.Merit.Description</div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>
                        <section class="cs-section cs-disciplines">
                            <h2>Disciplines</h2>
                            <ul class="trait-list disciplines-list">
                                @foreach (var disc in _character.Disciplines)
                                {
                                    <li class="trait-item discipline-item" style="flex-direction: column; align-items: stretch;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; cursor: pointer;" @onclick="() => ToggleDiscipline(disc.DisciplineId)">
                                            <span>
                                                @if (_expandedDisciplines.Contains(disc.DisciplineId))
                                                {
                                                    <i class="oi oi-chevron-bottom" style="font-size: 0.8em; margin-right: 5px;"></i>
                                                }
                                                else
                                                {
                                                    <i class="oi oi-chevron-right" style="font-size: 0.8em; margin-right: 5px;"></i>
                                                }
                                                @disc.Discipline?.Name
                                            </span>
                                            <span class="trait-dots">@(new string('•', disc.Rating))</span>
                                        </div>
                                        
                                        @if (_expandedDisciplines.Contains(disc.DisciplineId) && disc.Discipline?.Powers != null)
                                        {
                                            <div class="discipline-powers" style="margin-top: 10px; padding-left: 15px; border-left: 2px solid #550000; font-size: 0.9em; color: #d0d0d0;">
                                                @foreach (var power in disc.Discipline.Powers.Where(p => p.Level <= disc.Rating).OrderBy(p => p.Level))
                                                {
                                                    <div class="power-item" style="margin-bottom: 8px;">
                                                        <strong>Level @power.Level - @power.Name:</strong>
                                                        <p style="margin: 2px 0 0 0; font-size: 0.85em; color: #a0a0a0;">@power.Description</p>
                                                        @if (!string.IsNullOrEmpty(power.DicePool) || !string.IsNullOrEmpty(power.Cost))
                                                        {
                                                            <div style="font-size: 0.8em; color: #808080; margin-top: 2px;">
                                                                @(string.IsNullOrEmpty(power.DicePool) ? "" : $"Pool: {power.DicePool}")
                                                                @(string.IsNullOrEmpty(power.DicePool) || string.IsNullOrEmpty(power.Cost) ? "" : " | ")
                                                                @(string.IsNullOrEmpty(power.Cost) ? "" : $"Cost: {power.Cost}")
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>

                        <!-- BLOODLINES -->
                        <section class="cs-section cs-bloodlines">
                            <h2>Bloodline</h2>
                            @{
                                var activeBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Active);
                                var pendingBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Pending);
                            }
                            @if (activeBloodline?.BloodlineDefinition != null)
                            {
                                <div class="bloodline-info" style="margin-bottom: 10px;">
                                    <strong>@activeBloodline.BloodlineDefinition.Name</strong>
                                    <p style="font-size: 0.9em; color: #a0a0a0; margin: 4px 0 0 0;">@activeBloodline.BloodlineDefinition.Description</p>
                                    <div style="margin-top: 8px;">
                                        <span class="trait-subheading">Lineage:</span> @(_character.Clan?.Name ?? "—") → @activeBloodline.BloodlineDefinition.Name
                                    </div>
                                    @if (_character.Banes?.Any() == true)
                                    {
                                        <div style="margin-top: 6px;">
                                            <span class="trait-subheading">Clan Bane:</span> @_character.Banes.First().Description
                                        </div>
                                    }
                                    <div style="margin-top: 6px;">
                                        <span class="trait-subheading">Bloodline Bane:</span> @activeBloodline.BloodlineDefinition.BaneOverride
                                    </div>
                                    @if (_isFreeEditMode)
                                    {
                                        <button class="btn-ghost" style="font-size: 0.85em; margin-top: 8px;" @onclick="() => RemoveBloodline(activeBloodline.Id)" disabled="@_removingBloodline">
                                            @(_removingBloodline ? "Removing…" : "Remove Bloodline")
                                        </button>
                                    }
                                </div>
                            }
                            else if (pendingBloodline?.BloodlineDefinition != null)
                            {
                                <p style="color: #a0a0a0; font-size: 0.9em;">Pending: <strong>@pendingBloodline.BloodlineDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                <p style="font-size: 0.85em; color: var(--text-secondary); margin: 4px 0 0 0;">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId" class="btn-ghost" style="font-size: 0.85em; margin-top: 4px;">View Campaign</a>
                                }
                            }
                            else if (_character.BloodPotency >= 2 && _character.ClanId.HasValue && _character.CampaignId.HasValue)
                            {
                                <p style="color: #808080; font-size: 0.9em; margin-bottom: 8px;">None. Apply when Blood Potency 2+.</p>
                                <button class="btn-primary-rn" style="font-size: 0.9em;" @onclick="OpenApplyBloodlineModal">Apply for Bloodline</button>
                            }
                            else
                            {
                                <p style="color: #808080; font-size: 0.9em;">None. Apply for a bloodline when Blood Potency 2+.</p>
                            }
                        </section>

                        <!-- COVENANT -->
                        <section class="cs-section cs-covenant">
                            <h2>Covenant</h2>
                            @if (_character.Covenant != null && _character.CovenantJoinStatus != Data.Models.Enums.CovenantJoinStatus.Pending)
                            {
                                <div class="bloodline-info" style="margin-bottom: 10px;">
                                    <strong>@_character.Covenant.Name</strong>
                                    <p style="font-size: 0.9em; color: #a0a0a0; margin: 4px 0 0 0;">@_character.Covenant.Description</p>
                                    @if (_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <p style="color: #a0a0a0; font-size: 0.85em; margin-top: 6px;">Leave requested — awaiting Storyteller approval.</p>
                                    }
                                    else if (_character.CampaignId.HasValue && !_character.CovenantLeaveRequestedAt.HasValue)
                                    {
                                        <button class="btn-ghost" style="font-size: 0.85em; margin-top: 8px;" @onclick="RequestLeaveCovenant" disabled="@_requestingLeave">
                                            @(_requestingLeave ? "Requesting…" : "Request to Leave")
                                        </button>
                                    }
                                </div>
                            }
                            else if (_character.CovenantJoinStatus == Data.Models.Enums.CovenantJoinStatus.Pending && _character.Covenant != null)
                            {
                                <p style="color: #a0a0a0; font-size: 0.9em;">Pending: <strong>@_character.Covenant.Name</strong> — awaiting Storyteller approval.</p>
                                <p style="font-size: 0.85em; color: var(--text-secondary); margin: 4px 0 0 0;">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                @if (_character.CampaignId.HasValue)
                                {
                                    <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-ghost" style="font-size: 0.85em; margin-top: 4px;">Storyteller Glimpse</a>
                                }
                            }
                            else if (_character.CampaignId.HasValue)
                            {
                                <p style="color: #808080; font-size: 0.9em; margin-bottom: 8px;">Unaligned. Apply to join a covenant.</p>
                                <button class="btn-primary-rn" style="font-size: 0.9em;" @onclick="OpenApplyCovenantModal">Apply for Covenant</button>
                            }
                            else
                            {
                                <p style="color: #808080; font-size: 0.9em;">Unaligned. Join a campaign to apply for a covenant.</p>
                            }
                        </section>

                        <!-- DEVOTIONS -->
                        <section class="cs-section cs-devotions">
                            <h2>Devotions</h2>
                            @if (_character.Devotions?.Any() == true)
                            {
                                <ul class="trait-list">
                                    @foreach (var cd in _character.Devotions)
                                    {
                                        @if (cd.DevotionDefinition != null)
                                        {
                                            <li class="trait-item">
                                                <span>@cd.DevotionDefinition.Name</span>
                                                @if (!cd.DevotionDefinition.IsPassive && !string.IsNullOrEmpty(cd.DevotionDefinition.PoolDefinitionJson))
                                                {
                                                    <button class="btn-ghost" style="padding: 2px 8px; font-size: 0.85em;" @onclick="() => OpenDevotionRoller(cd)">Roll</button>
                                                }
                                            </li>
                                        }
                                    }
                                </ul>
                            }
                            else
                            {
                                <p style="color: #808080; font-size: 0.9em;">None yet. Purchase devotions via Advancement.</p>
                            }
                        </section>

                        <!-- BLOOD SORCERY (visible only when in approved Circle of the Crone or Lancea et Sanctum) -->
                        @if (IsInSorceryCovenant)
                        {
                            <section class="cs-section cs-blood-sorcery">
                                <h2>Blood Sorcery</h2>
                                @{
                                    var approvedRites = _character.Rites?.Where(r => r.Status == Data.Models.Enums.RiteLearnStatus.Approved && r.SorceryRiteDefinition != null).ToList();
                                    var pendingRite = _character.Rites?.FirstOrDefault(r => r.Status == Data.Models.Enums.RiteLearnStatus.Pending);
                                }
                                @if (approvedRites?.Any() == true)
                                {
                                    <ul class="trait-list">
                                        @foreach (var cr in approvedRites)
                                        {
                                            @if (cr.SorceryRiteDefinition != null)
                                            {
                                                <li class="trait-item">
                                                    <span>@cr.SorceryRiteDefinition.Name</span>
                                                    <span style="font-size:0.85em; color:#808080;">Lv.@cr.SorceryRiteDefinition.Level (@(cr.SorceryRiteDefinition.SorceryType == Domain.Enums.SorceryType.Cruac ? "Crúac" : "Theban"))</span>
                                                    @if (!string.IsNullOrEmpty(cr.SorceryRiteDefinition.PoolDefinitionJson))
                                                    {
                                                        <button class="btn-ghost" style="padding: 2px 8px; font-size: 0.85em;" @onclick="() => OpenRiteRoller(cr)">Roll</button>
                                                    }
                                                </li>
                                            }
                                        }
                                    </ul>
                                }
                                else if (pendingRite?.SorceryRiteDefinition != null)
                                {
                                    <p style="color: #a0a0a0; font-size: 0.9em;">Pending: <strong>@pendingRite.SorceryRiteDefinition.Name</strong> — awaiting Storyteller approval.</p>
                                    <p style="font-size: 0.85em; color: var(--text-secondary); margin: 4px 0 0 0;">Your Storyteller will review this. You'll be notified when it's approved.</p>
                                    @if (_character.CampaignId.HasValue)
                                    {
                                        <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-ghost" style="font-size: 0.85em; margin-top: 4px;">Storyteller Glimpse</a>
                                    }
                                }
                                else
                                {
                                    <p style="color: #808080; font-size: 0.9em; margin-bottom: 8px;">No rites yet. Purchase Crúac or Theban Sorcery dots via Advancement, then request to learn rites.</p>
                                    <button class="btn-primary-rn" style="font-size: 0.9em;" @onclick="OpenLearnRiteModal" disabled="@_openingRiteModal">Learn Rite</button>
                                }
                            </section>
                        }

                        <!-- MYSTERIES OF THE DRAGON (visible only to Ordo Dracul members) -->
                        @if (IsOrdoDraculMember)
                        {
                            <section class="cs-section cs-coils">
                                <h2>Mysteries of the Dragon</h2>
                                @if (_character.ChosenMysteryScaleId.HasValue)
                                {
                                    <p style="font-size:0.9em; color:#a0a0a0; margin-bottom:8px;">
                                        <strong>Chosen Mystery:</strong> @(_character.ChosenMysteryScale?.Name ?? "Unknown")
                                    </p>
                                }
                                else if (_character.PendingChosenMysteryScaleId.HasValue)
                                {
                                    <p style="color:#a0a0a0; font-size:0.9em;">
                                        Chosen Mystery pending: <strong>@(_character.PendingChosenMysteryScale?.Name ?? "Unknown")</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                else if (_character.CampaignId.HasValue)
                                {
                                    <p style="color:#808080; font-size:0.9em; margin-bottom:8px;">No Chosen Mystery selected.</p>
                                    <button class="btn-primary-rn" style="font-size:0.9em;" @onclick="OpenChosenMysteryModal">Select Chosen Mystery</button>
                                }
                                @{
                                    var approvedCoils = _character.Coils?.Where(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Approved && cc.CoilDefinition != null).ToList();
                                    var pendingCoil = _character.Coils?.FirstOrDefault(cc => cc.Status == Data.Models.Enums.CoilLearnStatus.Pending);
                                }
                                @if (approvedCoils?.Any() == true)
                                {
                                    <ul class="trait-list" style="margin-top:8px;">
                                        @foreach (var cc in approvedCoils.OrderBy(c => c.CoilDefinition!.ScaleId).ThenBy(c => c.CoilDefinition!.Level))
                                        {
                                            <li class="trait-item">
                                                <span>@cc.CoilDefinition!.Name</span>
                                                <span style="font-size:0.85em; color:#808080;">@cc.CoilDefinition.Scale?.Name — Tier @cc.CoilDefinition.Level</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else if (pendingCoil?.CoilDefinition != null)
                                {
                                    <p style="color:#a0a0a0; font-size:0.9em; margin-top:6px;">
                                        Pending: <strong>@pendingCoil.CoilDefinition.Name</strong> — awaiting Storyteller approval.
                                    </p>
                                }
                                @if (_character.CampaignId.HasValue)
                                {
                                    <button class="btn-ghost" style="font-size:0.9em; margin-top:8px;" @onclick="OpenLearnCoilModal">Purchase Coil</button>
                                }
                                @if (_character.HasCrucibleRitualAccess)
                                {
                                    <p style="font-size:0.8em; color:#808080; margin-top:4px;">Crucible Ritual active — reduced XP costs apply.</p>
                                }
                            </section>
                        }
                    </div>

                    <!-- EQUIPMENT -->
                    <section class="cs-section cs-equipment">
                        <h2>Equipment</h2>

                        <div class="equipment-form">
                            <select @bind="_selectedEquipmentId" class="equipment-select">
                                <option value="0">-- Select Equipment --</option>
                                @foreach (var eq in _availableEquipment)
                                {
                                    <option value="@eq.Id">@eq.Name (@eq.Type)</option>
                                }
                            </select>
                            <input type="number" min="1" @bind="_selectedEquipmentQuantity"
                                class="equipment-quantity" />
                            <button class="btn-primary-rn" @onclick="AddEquipment">Add</button>
                        </div>

                        <ul class="equipment-grid">
                            @foreach (var ce in _character.CharacterEquipments)
                            {
                                <li class="equipment-item">
                                    <div class="equipment-info">
                                        <strong class="equipment-name">@ce.Equipment?.Name (x@ce.Quantity)</strong>
                                        <div class="equipment-meta">
                                            <span>Type: @ce.Equipment?.Type</span>
                                            @if (ce.Equipment?.Damage > 0)
                                            {
                                                <span>| Dmg: @ce.Equipment?.Damage</span>
                                            }
                                            @if (ce.Equipment?.ArmorRating > 0)
                                            {
                                                <span>| Arm: @ce.Equipment?.ArmorRating</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(ce.Equipment?.Description))
                                        {
                                            <p class="equipment-desc">@ce.Equipment?.Description</p>
                                        }
                                    </div>
                                    <button class="equipment-remove-btn" @onclick="() => RemoveEquipment(ce.Id)">Remove</button>
                                </li>
                            }
                        </ul>
                    </section>

                    <ConditionsSection CharacterId="_character.Id"
                                       UserId="@(_currentUserId ?? string.Empty)" />

                </div>
            }
            else if (_activeTab == "identity")
            {
        <CharacterIdentityTab Character="_character" OnChanged="SaveCharacter" />
            }
            else if (_activeTab == "history")
            {
        <BeatLedgerSection CharacterId="_character.Id" />
            }
        </CascadingValue>
        </div>

        @if (SessionClient.IsConnected)
        {
            <div class="character-sidebar">
                <div class="sidebar-header">
                    <h3>🩸 Blood Logs</h3>
                </div>
                <div class="sidebar-content">
                    <RollHistoryFeed />
                </div>
            </div>
        }
    </div>

    <DiceRollerModal @bind-IsVisible="_isRollerOpen" TraitName="@_rollerTraitName" BaseDice="@_rollerBaseDice" Character="_character" />
    <ApplyBloodlineModal IsOpen="_isApplyBloodlineModalOpen"
                         IsOpenChanged="HandleApplyBloodlineModalClosed"
                         EligibleBloodlines="_eligibleBloodlines"
                         OnApplyRequested="HandleApplyBloodlineRequested" />
    <ApplyCovenantModal IsOpen="_isApplyCovenantModalOpen"
                        IsOpenChanged="HandleApplyCovenantModalClosed"
                        EligibleCovenants="_eligibleCovenants"
                        OnApplyRequested="HandleApplyCovenantRequested" />
    <ApplyLearnRiteModal IsOpen="_isApplyLearnRiteModalOpen"
                        IsOpenChanged="HandleApplyLearnRiteModalClosed"
                        EligibleRites="_eligibleRites"
                        OnApplyRequested="HandleApplyLearnRiteRequested" />
    <SelectScaleModal IsOpen="_isChosenMysteryModalOpen"
                      IsOpenChanged="(v) => _isChosenMysteryModalOpen = v"
                      Scales="_eligibleScales"
                      OnScaleSelected="HandleChosenMysteryRequested" />
    <SelectCoilModal IsOpen="_isLearnCoilModalOpen"
                     IsOpenChanged="(v) => _isLearnCoilModalOpen = v"
                     Coils="_eligibleCoils"
                     OnCoilSelected="HandleLearnCoilRequested" />
}

@implements IAsyncDisposable

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    [Parameter]
    public int Id { get; set; }

    private Character? _character;
    private string? _currentUserId;
    private string? _cookieHeader;
    private List<Equipment> _availableEquipment = new List<Equipment>();
    private int _selectedEquipmentId = 0;
    private int _selectedEquipmentQuantity = 1;

    private bool _isRollerOpen = false;
    private string _rollerTraitName = string.Empty;
    private int _rollerBaseDice = 1;
    private bool _isApplyBloodlineModalOpen = false;
    private bool _removingBloodline = false;
    private List<BloodlineSummaryDto> _eligibleBloodlines = [];
    private bool _isApplyCovenantModalOpen = false;
    private bool _isApplyLearnRiteModalOpen = false;
    private bool _openingRiteModal = false;
    private List<SorceryRiteSummaryDto> _eligibleRites = [];
    private bool _isChosenMysteryModalOpen = false;
    private bool _isLearnCoilModalOpen = false;
    private List<ScaleSummaryDto> _eligibleScales = [];
    private List<CoilSummaryDto> _eligibleCoils = [];
    private bool _requestingLeave = false;
    private List<CovenantSummaryDto> _eligibleCovenants = [];
    private HashSet<int> _expandedMeritIds = [];

    private bool isAdvancementMode = false;
    private bool _isFreeEditMode = false;
    private string _activeTab = "sheet";
    private bool _isEditingName = false;
    private bool _isExporting = false;

    private readonly HashSet<int> _expandedDisciplines = new HashSet<int>();

    /// <summary>True when character has joined an approved covenant that supports Blood Sorcery (Crúac or Theban).</summary>
    private bool IsInSorceryCovenant =>
        _character?.Covenant != null
        && _character.CovenantJoinStatus == null
        && _character.Covenant.SupportsBloodSorcery;

    private bool IsOrdoDraculMember =>
        _character?.Covenant?.Name == "The Ordo Dracul"
        && _character.CovenantJoinStatus == null;

    private void ToggleDiscipline(int disciplineId)
    {
        if (_expandedDisciplines.Contains(disciplineId))
        {
            _expandedDisciplines.Remove(disciplineId);
        }
        else
        {
            _expandedDisciplines.Add(disciplineId);
        }
    }

    private void SelectTab(string tab) => _activeTab = tab;

    private void HandleTabKeydown(KeyboardEventArgs e)
    {
        var tabs = new[] { "sheet", "identity", "history" };
        int i = Array.IndexOf(tabs, _activeTab);
        if (i < 0) return;
        if (e.Key == "ArrowRight" || e.Key == "ArrowDown")
        {
            SelectTab(tabs[(i + 1) % tabs.Length]);
        }
        else if (e.Key == "ArrowLeft" || e.Key == "ArrowUp")
        {
            SelectTab(tabs[(i - 1 + tabs.Length) % tabs.Length]);
        }
        else if (e.Key == "Home")
        {
            SelectTab(tabs[0]);
        }
        else if (e.Key == "End")
        {
            SelectTab(tabs[^1]);
        }
    }

    private async Task ExportJson()
    {
        if (_character == null) return;
        _isExporting = true;
        try
        {
            var json = ExportService.ExportCharacterAsJson(_character);
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"{_character.Name}.json", "application/json", base64);
            ToastService.Show("Export complete", "JSON downloaded.", ToastType.Success);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task ExportPdf()
    {
        if (_character == null) return;
        _isExporting = true;
        try
        {
            var pdfBytes = ExportService.ExportCharacterAsPdf(_character);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", $"{_character.Name}.pdf", "application/pdf", base64);
            ToastService.Show("Export complete", "PDF downloaded.", ToastType.Success);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private void GoToAdvancement()
    {
        NavigationManager.NavigateTo($"/character/{Id}/advancement");
    }

    private async Task SaveNameOffBlur()
    {
        _isEditingName = false;
        await SaveCharacter();
    }

    private async Task HandleNameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveNameOffBlur();
        }
    }



    private async Task ToggleFreeEditMode()
    {
        bool wasEditing = _isFreeEditMode;
        _isFreeEditMode = !_isFreeEditMode;
        if (_isFreeEditMode) isAdvancementMode = false;
        // Save when the user finishes editing (transitions from ON → OFF)
        if (!_isFreeEditMode && wasEditing)
        {
            await SaveCharacter();
        }
    }

    private async Task SaveCharacter()
    {
        if (_character != null)
        {
            await CharacterService.SaveAsync(_character);
        }
    }



    protected override async Task OnInitializedAsync()
    {
        _cookieHeader = HttpContextAccessor.HttpContext?.Request.Headers.Cookie.ToString();
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(_currentUserId))
        {
            _character = await CharacterService.GetCharacterByIdAsync(Id, _currentUserId);
            _availableEquipment = await EquipmentService.GetAvailableEquipmentAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _character == null || string.IsNullOrEmpty(_currentUserId))
        {
            return;
        }

        if (_character.CampaignId != null)
        {
            // Auto-join if session is active (uses cache)
            bool isActive = await SessionClient.GetSessionActiveAsync(_character.CampaignId.Value, SessionService);

            // Connect to hub for character updates regardless of live session state
            await SessionClient.StartAsync(_character.CampaignId.Value, _character.Id, _currentUserId, _cookieHeader);

            SessionClient.CharacterUpdated += HandleCharacterUpdated;
            SessionClient.BloodlineApproved += HandleBloodlineApproved;
        }

        // Fallback: show approval toast if character has recently approved bloodline and user hasn't seen it this session
        await TryShowRecentBloodlineApprovalToastAsync();

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        SessionClient.CharacterUpdated -= HandleCharacterUpdated;
        SessionClient.BloodlineApproved -= HandleBloodlineApproved;
        await SessionClient.StopAsync();
    }

    private async void HandleCharacterUpdated(CharacterUpdateDto patch)
    {
        if (patch.CharacterId != Id || _character == null || string.IsNullOrEmpty(_currentUserId))
        {
            return;
        }

        _character = await CharacterService.ReloadCharacterAsync(Id, _currentUserId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TryShowRecentBloodlineApprovalToastAsync()
    {
        if (_character == null)
        {
            return;
        }

        var activeBloodline = _character.Bloodlines?.FirstOrDefault(b => b.Status == Data.Models.Enums.BloodlineStatus.Active);
        if (activeBloodline?.ResolvedAt == null)
        {
            return;
        }

        var hoursSinceApproval = (DateTime.UtcNow - activeBloodline.ResolvedAt.Value).TotalHours;
        if (hoursSinceApproval > 24)
        {
            return;
        }

        var key = $"bloodline-approved-{_character.Id}";
        var alreadyShown = await JS.InvokeAsync<string>("sessionStorageGet", key);
        if (!string.IsNullOrEmpty(alreadyShown))
        {
            return;
        }

        var bloodlineName = activeBloodline.BloodlineDefinition?.Name ?? "Bloodline";
        ToastService.Show("Bloodline approved", $"Your bloodline application for {bloodlineName} has been approved!", ToastType.Success);
        await JS.InvokeVoidAsync("sessionStorageSet", key, "1");
    }

    private async void HandleBloodlineApproved(int characterId, string bloodlineName)
    {
        if (characterId != Id || _character == null || string.IsNullOrEmpty(_currentUserId))
        {
            return;
        }

        // Toast is shown by MainLayout (global subscriber) so player sees it from any page
        _character = await CharacterService.ReloadCharacterAsync(Id, _currentUserId);
        await InvokeAsync(StateHasChanged);
    }

    private static void OpenReference(string traitName)
    {
        Console.WriteLine($"Show Reference for: {traitName}");
    }


    private void OpenRoller(string traitName)
    {
        _rollerTraitName = traitName;
        _rollerBaseDice = GetTraitValue(traitName);
        _isRollerOpen = true;
    }

    private int GetTraitValue(string traitName)
    {
        if (_character == null) return 0;
        var name = traitName.Replace(" ", "");
        if (RequiemNexus.Domain.TraitMetadata.IsAttribute(name))
            return _character.GetAttributeRating(name);
        else
            return _character.GetSkillRating(name);
    }

    private async Task AddBeat()
    {
        if (_character != null)
            await CharacterService.AddBeatAsync(_character);
    }

    private async Task RemoveBeat()
    {
        if (_character != null)
            await CharacterService.RemoveBeatAsync(_character);
    }

    private async Task AddXP()
    {
        if (_character != null)
            await CharacterService.AddXPAsync(_character);
    }

    private async Task RemoveXP()
    {
        if (_character != null)
            await CharacterService.RemoveXPAsync(_character);
    }

    private async Task AddEquipment()
    {
        if (_character != null && !string.IsNullOrEmpty(_currentUserId) && _selectedEquipmentId > 0 && _selectedEquipmentQuantity > 0)
        {
            var ce = await EquipmentService.AddEquipmentAsync(_character.Id, _selectedEquipmentId, _selectedEquipmentQuantity, _currentUserId);
            ce.Equipment = _availableEquipment.FirstOrDefault(e => e.Id == _selectedEquipmentId);
            _character.CharacterEquipments.Add(ce);

            _selectedEquipmentId = 0;
            _selectedEquipmentQuantity = 1;
        }
    }

    private void OpenDevotionRoller(CharacterDevotion cd)
    {
        if (_character == null || cd.DevotionDefinition?.PoolDefinitionJson == null) return;
        try
        {
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            options.Converters.Add(new System.Text.Json.Serialization.JsonStringEnumConverter());
            var pool = System.Text.Json.JsonSerializer.Deserialize<RequiemNexus.Domain.Models.PoolDefinition>(cd.DevotionDefinition.PoolDefinitionJson, options);
            _rollerTraitName = cd.DevotionDefinition.Name;
            _rollerBaseDice = pool != null ? TraitResolver.ResolvePool(_character, pool) : 0;
            _isRollerOpen = true;
        }
        catch
        {
            _rollerTraitName = cd.DevotionDefinition.Name;
            _rollerBaseDice = 0;
            _isRollerOpen = true;
        }
    }

    private async Task RemoveEquipment(int ceId)
    {
        if (_character != null && !string.IsNullOrEmpty(_currentUserId))
        {
            await EquipmentService.RemoveEquipmentAsync(ceId, _currentUserId);
            var ce = _character.CharacterEquipments.FirstOrDefault(e => e.Id == ceId);
            if (ce != null) _character.CharacterEquipments.Remove(ce);
        }
    }

    private void ToggleMeritExpanded(int characterMeritId)
    {
        if (_expandedMeritIds.Contains(characterMeritId))
        {
            _ = _expandedMeritIds.Remove(characterMeritId);
        }
        else
        {
            _expandedMeritIds.Add(characterMeritId);
        }
    }

    private void HandleMeritKeydown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, int characterMeritId)
    {
        if (e.Key is "Enter" or " ")
