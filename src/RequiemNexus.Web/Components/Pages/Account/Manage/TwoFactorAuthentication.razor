@page "/Account/Manage/TwoFactorAuthentication"
@using Microsoft.AspNetCore.Identity
@using RequiemNexus.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Two-Factor Authentication — Requiem Nexus</PageTitle>

<h3>Two-Factor Authentication (2FA)</h3>

@if (isCheckingStatus)
{
    <SkeletonLoader Variant="rows" Count="4" />
}
else if (user is not null)
{
    @if (is2faEnabled)
    {
        <div class="alert alert-success alert-rn" role="alert">
            <strong>2FA is enabled.</strong> Your account is protected.
        </div>
        
        <p>You have @recoveryCodesLeft recovery codes left.</p>
        
        @if (recoveryCodesLeft == 0)
        {
            <div class="alert alert-danger alert-rn" role="alert">
                <strong>You have no recovery codes left.</strong>
                <p>You must <a href="/Account/Manage/GenerateRecoveryCodes">generate a new set of recovery codes</a> before you can log in with a recovery code.</p>
            </div>
        }
        else if (recoveryCodesLeft <= 3)
        {
            <div class="alert alert-warning alert-rn" role="alert">
                <strong>You have @recoveryCodesLeft recovery codes left.</strong>
                <p>You should <a href="/Account/Manage/GenerateRecoveryCodes">generate a new set of recovery codes</a>.</p>
            </div>
        }
        
        <div class="mt-4">
            <a href="/Account/Manage/Disable2fa" class="btn btn-outline-danger me-2">Disable 2FA</a>
            <a href="/Account/Manage/GenerateRecoveryCodes" class="btn btn-outline-warning">Generate Recovery Codes</a>
        </div>
    }
    else
    {
        <div class="alert alert-secondary alert-rn" role="alert">
            <strong>2FA is not enabled.</strong> Add an authenticator app or a security key.
        </div>
    }

    <div class="mt-5">
        <h4>Authenticator App</h4>
        @if (!hasAuthenticator)
        {
            <a href="/Account/Manage/EnableAuthenticator" class="btn btn-outline-primary mt-2">Add authenticator app</a>
        }
        else
        {
            <a href="/Account/Manage/EnableAuthenticator" class="btn btn-outline-primary me-2">Set up new authenticator app</a>
            <a href="/Account/Manage/ResetAuthenticator" class="btn btn-outline-danger">Reset authenticator app</a>
        }
    </div>
}

@code {
    private ApplicationUser? user;
    private bool isCheckingStatus = true;
    private bool hasAuthenticator;
    private int recoveryCodesLeft;
    private bool is2faEnabled;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;
        
        if (principal.Identity?.IsAuthenticated == true)
        {
            user = await UserManager.GetUserAsync(principal);
            if (user is not null)
            {
                hasAuthenticator = await UserManager.GetAuthenticatorKeyAsync(user) is not null;
                is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
                recoveryCodesLeft = await UserManager.CountRecoveryCodesAsync(user);
            }
        }
        
        isCheckingStatus = false;
    }
}
