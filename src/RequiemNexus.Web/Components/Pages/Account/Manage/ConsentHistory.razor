@page "/Account/Manage/ConsentHistory"
@using Microsoft.EntityFrameworkCore
@using RequiemNexus.Data
@using RequiemNexus.Data.Models
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Consent History - Requiem Nexus</PageTitle>

<h3 class="mb-4">Consent History</h3>

<p class="mb-4">This page shows your recorded acceptances of our Terms of Service and Privacy Policy.</p>

@if (consentLogs is null)
{
    <p><em>Loading...</em></p>
}
else if (consentLogs.Count == 0)
{
    <p class="text-muted">No consent records found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Date &amp; Time</th>
                    <th>Consent Type</th>
                    <th>Document Version</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in consentLogs)
                {
                    <tr>
                        <td>@log.ConsentedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.ConsentType</td>
                        <td>@log.DocumentVersion</td>
                        <td>@(string.IsNullOrEmpty(log.IpAddress) ? "Unknown" : log.IpAddress)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ConsentLog>? consentLogs;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (currentUserId is not null)
        {
            consentLogs = (await DbContext.ConsentLogs
                .AsNoTracking()
                .Where(c => c.UserId == currentUserId)
                .ToListAsync())
                .OrderByDescending(c => c.ConsentedAt)
                .ToList();
        }
        else
        {
            consentLogs = [];
        }
    }
}
