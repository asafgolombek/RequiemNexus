@page "/Account/Manage/LinkedAccounts"
@using Microsoft.AspNetCore.Identity
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuditLogService AuditLogService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavigationManager

<PageTitle>Linked Accounts — Requiem Nexus</PageTitle>

<h3 class="mb-4 text-theme-primary">Linked Accounts</h3>

<p class="mb-4">Connect your account to external providers so you can sign in without a password.</p>

@if (_currentLogins is not null && _currentLogins.Count > 0)
{
    <h5 class="mt-3 mb-3">Connected Providers</h5>
    <div class="table-responsive mb-4">
        <table class="table rn-table">
            <thead>
                <tr>
                    <th>Provider</th>
                    <th>Display Name</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (Microsoft.AspNetCore.Identity.UserLoginInfo login in _currentLogins)
                {
                    <tr>
                        <td>@login.LoginProvider</td>
                        <td>@login.ProviderDisplayName</td>
                        <td>
                            @if (_canUnlink)
                            {
                                <form method="post" action="/Account/Manage/LinkedAccounts/Unlink">
                                    <input type="hidden" name="loginProvider" value="@login.LoginProvider" />
                                    <input type="hidden" name="providerKey" value="@login.ProviderKey" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Unlink</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">(Cannot unlink — set a password first)</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-muted mb-4">No external accounts linked.</p>
}

<h5 class="mt-3 mb-3">Connect a Provider</h5>

@if (_availableProviders is not null)
{
    <div class="d-flex gap-3 flex-wrap">
        @foreach (Microsoft.AspNetCore.Authentication.AuthenticationScheme scheme in _availableProviders)
        {
            @if (_currentLogins?.Any(l => l.LoginProvider == scheme.Name) == false)
            {
                <form method="post" action="/Account/ExternalLogin">
                    <input type="hidden" name="provider" value="@scheme.Name" />
                    <input type="hidden" name="returnUrl" value="/Account/Manage/LinkedAccounts" />
                    <button type="submit" class="btn-login btn-outline-primary">
                        Connect @scheme.DisplayName
                    </button>
                </form>
            }
        }
    </div>
}

@code {
    private IList<Microsoft.AspNetCore.Identity.UserLoginInfo>? _currentLogins;
    private IEnumerable<Microsoft.AspNetCore.Authentication.AuthenticationScheme>? _availableProviders;
    private bool _canUnlink;

    protected override async Task OnInitializedAsync()
    {
        Microsoft.AspNetCore.Components.Authorization.AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        System.Security.Claims.ClaimsPrincipal principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        ApplicationUser? user = await UserManager.GetUserAsync(principal);
        if (user is null)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        _currentLogins = await UserManager.GetLoginsAsync(user);
        _availableProviders = await SignInManager.GetExternalAuthenticationSchemesAsync();

        // User can only unlink if they have a password OR more than one external login
        bool hasPassword = await UserManager.HasPasswordAsync(user);
        _canUnlink = hasPassword || _currentLogins.Count > 1;
    }
}
