@page "/Account/Manage/GenerateRecoveryCodes"
@using Microsoft.AspNetCore.Identity
@using RequiemNexus.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<GenerateRecoveryCodes> Logger
@inject NavigationManager NavigationManager

<PageTitle>Generate Recovery Codes - Requiem Nexus</PageTitle>

<h3>Generate Two-Factor Authentication Recovery Codes</h3>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-danger" role="alert">@statusMessage</div>
}

@if (recoveryCodes is not null)
{
    <div class="alert alert-warning mt-4" role="alert">
        <p>
            <span class="fw-bold">Put these codes in a safe place.</span>
        </p>
        <p>
            If you lose your device and don't have the recovery codes you will lose access to your account.
        </p>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card bg-dark text-light border-danger">
                <div class="card-body font-monospace fs-5">
                    @for (var row = 0; row < recoveryCodes.Count; row += 2)
                    {
                        <div class="row mb-2">
                            <code class="col-6">@recoveryCodes[row]</code>
                            @if (row + 1 < recoveryCodes.Count)
                            {
                                <code class="col-6">@recoveryCodes[row + 1]</code>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <a href="/Account/Manage/TwoFactorAuthentication" class="btn btn-primary">Done</a>
}
else if (!isLoading)
{
    <div class="alert alert-warning" role="alert">
        <p>
            <span class="fw-bold">Put these codes in a safe place.</span>
        </p>
        <p>
            Generating new recovery codes does not change the keys used in authenticator apps. 
            If you wish to change the key used in an authenticator app you should 
            <a href="/Account/Manage/ResetAuthenticator">reset your authenticator keys</a>.
        </p>
    </div>

    <button @onclick="GenerateCodes" class="btn btn-danger" disabled="@isGenerating">
        @if (isGenerating)
        {
            <span>Generating...</span>
        }
        else
        {
            <span>Generate Recovery Codes</span>
        }
    </button>
    <a href="/Account/Manage/TwoFactorAuthentication" class="btn btn-outline-secondary ms-2">Back</a>
}
else
{
    <SkeletonLoader Variant="rows" Count="4" />
}

@code {
    private ApplicationUser? user;
    private string? statusMessage;
    private List<string>? recoveryCodes;
    private bool isLoading = true;
    private bool isGenerating;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;
        
        if (principal.Identity?.IsAuthenticated == true)
        {
            user = await UserManager.GetUserAsync(principal);
            if (user is not null)
            {
                var is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
                if (!is2faEnabled)
                {
                    statusMessage = "Cannot generate recovery codes as you do not have 2FA enabled.";
                }
            }
        }
        
        isLoading = false;
    }

    private async Task GenerateCodes()
    {
        if (user is null) return;
        
        isGenerating = true;
        statusMessage = null;

        var is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        if (!is2faEnabled)
        {
            statusMessage = "Cannot generate recovery codes as you do not have 2FA enabled.";
            isGenerating = false;
            return;
        }

        var codes = await UserManager.GenerateNewTwoFactorRecoveryCodesAsync(user, 10);
        recoveryCodes = codes?.ToList();
        
        Logger.LogInformation("User with ID '{UserId}' has generated new 2FA recovery codes.", user.Id);
        
        isGenerating = false;
    }
}
