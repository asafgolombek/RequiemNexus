@page "/Account/ConfirmEmail"
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using RequiemNexus.Data.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Confirm email</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h2>Confirm Email</h2>
            
            @if (_isSuccess)
            {
                <div class="confirm-icon fade-in-up" aria-hidden="true" style="text-align: center; margin: 1.5rem 0;">
                    <svg class="confirm-drop" viewBox="0 0 40 52" style="width: 60px; height: 78px;">
                        <path d="M20 2 C20 2 4 20 4 32 A16 16 0 0 0 36 32 C36 20 20 2 20 2Z"
                              fill="var(--crimson)" />
                    </svg>
                </div>
                <p class="confirm-message" style="font-size: 1.1rem; color: var(--bone-white); text-align: center;">Your covenant is confirmed. Welcome to the night.</p>
            }
            else
            {
                <div class="confirm-icon fade-in-up" aria-hidden="true" style="text-align: center; margin: 1.5rem 0; font-size: 3rem;">
                    <span class="confirm-error-icon">⛓️</span>
                </div>
                <p class="confirm-message confirm-error" style="color: var(--crimson-glow); text-align: center;">@statusMessage</p>
            }
        </div>
        <div class="login-footer mt-4">
            <p><a href="/">Return to Sign In</a></p>
        </div>
    </div>
</div>

@code {
    private string? statusMessage;
    private bool _isSuccess;

    // Automatically maps the "userId" parameter from the URL to this property
    [Parameter]
    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserId { get; set; }

    // Automatically maps the "code" parameter from the URL to this property
    [Parameter]
    [SupplyParameterFromQuery(Name = "code")]
    public string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // 1. Validation check for the mapped parameters
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Code))
        {
            statusMessage = "Error: Invalid email confirmation link. One or more parameters are missing.";
            return;
        }

        // 2. Locate the user
        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            statusMessage = $"Error: Unable to load user with ID '{UserId}'.";
            return;
        }

        try 
        {
            // 3. Decode the Base64Url token
            // The code is usually encoded as Base64Url to be safe for URLs
            var decodedCodeBytes = WebEncoders.Base64UrlDecode(Code);
            var decodedCode = Encoding.UTF8.GetString(decodedCodeBytes);

            // 4. Perform the confirmation
            var result = await UserManager.ConfirmEmailAsync(user, decodedCode);
            _isSuccess = result.Succeeded;
            
            statusMessage = result.Succeeded 
                ? "Thank you for confirming your email." 
                : "Error: Could not confirm your email. The link may have expired.";
        }
        catch (FormatException)
        {
            statusMessage = "Error: The confirmation code is malformed.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: An unexpected error occurred: {ex.Message}";
        }
    }
}