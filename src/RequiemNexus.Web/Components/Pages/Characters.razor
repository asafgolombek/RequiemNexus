@page "/characters"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Application.Contracts
@inject ICharacterService CharacterService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Characters> Logger
@using Microsoft.Extensions.Logging
<PageTitle>My Characters - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    <div class="page-header-rn">
        <h2>My Characters</h2>
        <a href="/character/create" class="btn-primary-rn btn-create">Create New Character</a>
    </div>

    @if (_isLoading)
    {
        <SkeletonLoader Variant="card" Count="3" />
    }
    else if (_loadError != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Could not load characters.</strong> @_loadError
        </div>
    }
    else if (!_characters.Any())
    {
        <div class="empty-state-rn">
            <p>You haven't embraced any characters yet.</p>
            <a href="/character/create" class="btn-primary-rn btn-create btn-large">Create New Character</a>
        </div>
    }
    else
    {
        <div class="character-grid">
            @{ int index = 1; }
            @foreach (Character character in _characters)
            {
                <div class="character-card card-rn fade-in-up stagger-@(Math.Min(index++, 5))">
                    <div class="card-top">
                        <div class="char-avatar">
                            <span>@(character.Name?.Length > 0 ? character.Name[0].ToString().ToUpper() : "?")</span>
                        </div>
                        <div class="card-name-block">
                            <h3>@character.Name</h3>
                            <p class="clan-name">@(character.Clan?.Name ?? "Caitiff")</p>
                        </div>
                    </div>
                    <div class="vitals-bars">
                        @{
                            var bashing = character.HealthDamage?.Count(c => c == '/') ?? 0;
                            var lethal = character.HealthDamage?.Count(c => c == 'X') ?? 0;
                            var agg = character.HealthDamage?.Count(c => c == '*') ?? 0;
                        }
                        <div class="vital-bar">
                            <span class="vital-label">Health</span>
                            <div class="bar-track" style="background: transparent;"></div>
                            <span class="vital-value">@character.MaxHealth</span>
                        </div>
                        @if (bashing > 0)
                        {
                            <div class="vital-bar" style="margin-top: -6px;">
                                <span class="vital-label" style="padding-left: 10px; font-size: 0.7rem; opacity: 0.9;">Bashing</span>
                                <div class="bar-track" style="background: transparent;"></div>
                                <span class="vital-value">@bashing</span>
                            </div>
                        }
                        @if (lethal > 0)
                        {
                            <div class="vital-bar" style="margin-top: -6px;">
                                <span class="vital-label" style="padding-left: 10px; font-size: 0.7rem; color: #ff6b6b;">Lethal</span>
                                <div class="bar-track" style="background: transparent;"></div>
                                <span class="vital-value">@lethal</span>
                            </div>
                        }
                        @if (agg > 0)
                        {
                            <div class="vital-bar" style="margin-top: -6px;">
                                <span class="vital-label" style="padding-left: 10px; font-size: 0.7rem; color: #fa5252; font-weight: bold;">Aggravated</span>
                                <div class="bar-track" style="background: transparent;"></div>
                                <span class="vital-value">@agg</span>
                            </div>
                        }
                        <div class="vital-bar">
                            <span class="vital-label">Will Power</span>
                            <div class="bar-track">
                                <div class="bar-fill wp-fill" style="width: @(character.MaxWillpower > 0 ? (int)(100.0 * character.CurrentWillpower / character.MaxWillpower) : 0)%"></div>
                            </div>
                            <span class="vital-value">@character.CurrentWillpower/@character.MaxWillpower</span>
                        </div>
                        <div class="vital-bar">
                            <span class="vital-label">Vitae</span>
                            <div class="bar-track">
                                <div class="bar-fill vitae-fill" style="width: @(character.MaxVitae > 0 ? (int)(100.0 * character.CurrentVitae / character.MaxVitae) : 0)%"></div>
                            </div>
                            <span class="vital-value">@character.CurrentVitae/@character.MaxVitae</span>
                        </div>
                    </div>
                    <div class="card-stats">
                        <span>🩸 Blood Potency: @character.BloodPotency</span>
                    </div>
                    <div class="card-actions">
                        <a href="/character/@character.Id" class="btn-primary-rn">View Sheet</a>
                        <button @onclick="() => _characterToDelete = character" class="btn-danger-rn">Delete</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<ConfirmModal IsOpen="@(_characterToDelete != null)"
              Title="Delete Character"
              Message="@(_characterToDelete != null ? $"Are you sure you want to delete {_characterToDelete.Name}? This cannot be undone." : "")"
              ConfirmLabel="Delete"
              OnConfirmClicked="ConfirmDeleteCharacter"
              OnCancelClicked="CancelDelete" />

@code {
    private List<Character> _characters = [];
    private string? _currentUserId;
    private Character? _characterToDelete;
    private bool _isLoading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(_currentUserId))
            {
                _characters = await CharacterService.GetCharactersByUserIdAsync(_currentUserId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load characters for user {UserId}", _currentUserId ?? "(anonymous)");
            _loadError = "Please try refreshing the page. If the problem continues, sign out and sign in again.";
            _characters = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmDeleteCharacter()
    {
        if (_characterToDelete != null && !string.IsNullOrEmpty(_currentUserId))
        {
            await CharacterService.DeleteCharacterAsync(_characterToDelete.Id, _currentUserId);
            _characters.Remove(_characterToDelete);
        }
        _characterToDelete = null;
    }

    private void CancelDelete()
    {
        _characterToDelete = null;
    }
}
