@page "/character/{Id:int}/advancement"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Domain
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Web.Helpers
@using RequiemNexus.Web.Enums
@using RequiemNexus.Domain.Enums
@using Microsoft.JSInterop
@inject ICharacterService CharacterService
@inject ISorceryService SorceryService
@inject IAdvancementService AdvancementService
@inject ICharacterMeritService CharacterMeritService
@inject ICharacterDisciplineService CharacterDisciplineService
@inject IDevotionService DevotionService
@inject RequiemNexus.Domain.Contracts.IExperienceCostRules ExperienceCostRules
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ToastService ToastService

<PageTitle>@(_character == null ? "Advancement — Requiem Nexus" : $"Advancement: {_character.Name} — Requiem Nexus")</PageTitle>

@if (_character == null)
{
    <div class="character-sheet fade-in">
        <SkeletonLoader Variant="sheet" Count="4" />
    </div>
}
else
{
    <div class="character-sheet fade-in">
        <header class="cs-header" style="justify-content: space-between;">
            <div>
                <h1>Advancing @_character.Name</h1>
                <p>Spend your Experiences to grow more powerful.</p>
            </div>
            <div class="char-xp" style="flex-direction: column; align-items: flex-end;">
                <div class="xp-counter">
                    <strong class="xp-counter-label">Experiences</strong>
                    <span class="xp-counter-value">@_character.ExperiencePoints</span>
                </div>
                <button class="btn-rn-ghost" @onclick="GoBackToSheet" style="margin-top: 10px;">Return to Character Sheet</button>
            </div>
        </header>

        @if (!string.IsNullOrEmpty(_validationMessage))
        {
            <div @ref="_validationMessageRef" class="advancement-validation-message text-danger mb-3" role="status" aria-live="polite">@_validationMessage</div>
        }

        <CascadingValue Value="true" Name="IsEditable">
            <div class="cs-grid">
                <AttributesAdvancementSection Character="_character"
                                              OnAttributeRatingChange="OnAttributeRatingChangeAsync" />
                <SkillsAdvancementSection Character="_character"
                                          OnSkillRatingChange="OnSkillRatingChangeAsync" />

                @if (_character.Disciplines.Any())
                {
                    <DisciplinesAdvancementListSection Character="_character"
                                                       OnDisciplineRatingChange="OnDisciplineRatingChangeAsync" />
                }

                <MeritsAdvancementSection AvailableMerits="_availableMerits"
                                         SelectedMeritId="_selectedMeritId"
                                         SelectedMeritIdChanged="OnMeritIdChangedAsync"
                                         NewMeritSpecification="_newMeritSpecification"
                                         NewMeritSpecificationChanged="OnMeritSpecificationChangedAsync"
                                         NewMeritRating="_newMeritRating"
                                         NewMeritRatingChanged="OnMeritRatingChangedAsync"
                                         OnAddMerit="AddNewMerit" />

                <NewDisciplineAdvancementSection Character="_character"
                                                 AvailableDisciplines="_availableDisciplines"
                                                 SelectedDisciplineId="_selectedDisciplineId"
                                                 SelectedDisciplineIdChanged="OnDisciplineIdChangedAsync"
                                                 NewDisciplineRating="_newDisciplineRating"
                                                 NewDisciplineRatingChanged="OnNewDisciplineRatingChangedAsync"
                                                 OnAddDiscipline="AddNewDiscipline" />

                <DevotionsAdvancementSection EligibleDevotions="_eligibleDevotions"
                                            SelectedDevotionId="_selectedDevotionId"
                                            SelectedDevotionIdChanged="OnDevotionIdChangedAsync"
                                            OnPurchaseDevotion="AddNewDevotion" />

                @if (ShowBloodSorcerySection)
                {
                    <BloodSorceryAdvancementSection Character="_character"
                                                   IsOpeningLearnRiteModal="IsOpeningModal(nameof(OpenLearnRiteModal))"
                                                   OnOpenLearnRiteModal="OpenLearnRiteModal" />
                }
            </div>
        </CascadingValue>

        <ApplyLearnRiteModal IsOpen="_isApplyLearnRiteModalOpen"
                             IsOpenChanged="HandleApplyLearnRiteModalClosed"
                             EligibleRites="_eligibleRites"
                             OnApplyRequested="HandleApplyLearnRiteRequested" />

        @if (_disciplineGateDialogOpen)
        {
            <div class="modal-backdrop" @onclick="CancelDisciplineGateAckAsync">
                <div class="modal-panel apply-bloodline-modal" @onclick:stopPropagation role="dialog" aria-modal="true" aria-labelledby="disc-gate-title">
                    <div class="modal-header">
                        <h3 id="disc-gate-title">Storyteller acknowledgment</h3>
                        <button type="button" class="close-btn" @onclick="CancelDisciplineGateAckAsync" aria-label="Close">×</button>
                    </div>
                    <div class="modal-body">
                        <p class="apply-bloodline-hint">@_disciplineGateMessage</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-rn-ghost" @onclick="CancelDisciplineGateAckAsync">Cancel</button>
                        <button type="button" class="btn-rn-primary" @onclick="ConfirmDisciplineGateAckAsync">Storyteller acknowledges</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Character? _character;
    private string? _userId;
    private string? _validationMessage;
    private ElementReference _validationMessageRef;
    private int _validationMessageNonce;
    private int _lastScrolledValidationNonce;

    private List<Merit> _availableMerits = new();
    private int _selectedMeritId = 0;
    private int _newMeritRating = 1;
    private string? _newMeritSpecification;

    private List<Discipline> _availableDisciplines = new();
    private int _selectedDisciplineId = 0;
    private int _newDisciplineRating = 1;

    private List<DevotionDefinition> _eligibleDevotions = new();
    private int _selectedDevotionId = 0;

    private bool _isApplyLearnRiteModalOpen;

    /// <summary>When set, matches <c>nameof(OpenLearnRiteModal)</c> while eligible rites are loading.</summary>
    private string? _pendingModal;
    private List<SorceryRiteSummaryDto> _eligibleRites = [];

    private bool _disciplineGateDialogOpen;
    private string? _disciplineGateMessage;
    private DisciplineAcquisitionRequest? _pendingDisciplineRequest;
    private bool _pendingDisciplineIsUpgrade;

    /// <summary>Same visibility as the character sheet Blood Sorcery section.</summary>
    private bool ShowBloodSorcerySection =>
        _character != null
        && _character.CovenantJoinStatus == null
        && (
            (_character.Covenant?.SupportsBloodSorcery == true)
            || _character.GetDisciplineRating("Necromancy") > 0);

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(_userId))
        {
            _character = await CharacterService.GetCharacterByIdAsync(Id, _userId);
            if (_character != null)
            {
                _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
                _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            }

            _availableDisciplines = await CharacterDisciplineService.GetAvailableDisciplinesAsync();
        }
    }

    private void SetValidationMessage(string message)
    {
        _validationMessage = message;
        _validationMessageNonce++;
    }

    private void ShowAdvancementToastError(string message) =>
        ToastService.Show("Advancement", message, ToastType.Error);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_validationMessageNonce > _lastScrolledValidationNonce && !string.IsNullOrEmpty(_validationMessage))
        {
            _lastScrolledValidationNonce = _validationMessageNonce;
            try
            {
                await JSRuntime.InvokeVoidAsync("scrollElementIntoView", _validationMessageRef);
            }
            catch (JSException)
            {
                // Prerender or disconnected circuit — no DOM to scroll.
            }
        }
    }

    private Task OnAttributeRatingChangeAsync((AttributeId Id, int CurrentRating, int NewRating) arg) =>
        TryUpgrade(arg.Id, arg.CurrentRating, arg.NewRating);

    private Task OnSkillRatingChangeAsync((SkillId Id, int CurrentRating, int NewRating) arg) =>
        TryUpgrade(arg.Id, arg.CurrentRating, arg.NewRating);

    private Task OnDisciplineRatingChangeAsync((CharacterDiscipline Discipline, int NewRating) arg) =>
        TryUpgradeDiscipline(arg.Discipline, arg.NewRating);

    private async Task OnMeritIdChangedAsync(int id)
    {
        _selectedMeritId = id;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnMeritSpecificationChangedAsync(string? value)
    {
        _newMeritSpecification = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnMeritRatingChangedAsync(int value)
    {
        _newMeritRating = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDisciplineIdChangedAsync(int id)
    {
        _selectedDisciplineId = id;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnNewDisciplineRatingChangedAsync(int value)
    {
        _newDisciplineRating = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDevotionIdChangedAsync(int id)
    {
        _selectedDevotionId = id;
        await InvokeAsync(StateHasChanged);
    }

    private void GoBackToSheet()
    {
        NavigationManager.NavigateTo($"/character/{Id}");
    }

    private async Task TryUpgrade(AttributeId id, int currentRating, int newRating)
    {
        if (_character == null) return;

        _validationMessage = null;

        if (newRating > currentRating)
        {
            bool success = await AdvancementService.TryUpgradeCoreTrait(_character, id, currentRating, newRating, _userId);
            if (success)
            {
                if (id is AttributeId.Stamina or AttributeId.Resolve or AttributeId.Composure)
                    AdvancementService.RecalculateDerivedStats(_character);
                await CharacterService.SaveAsync(_character);
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                SetValidationMessage("Not enough Experiences to upgrade that attribute.");
            }
        }
    }

    private async Task TryUpgrade(SkillId id, int currentRating, int newRating)
    {
        if (_character == null) return;

        _validationMessage = null;

        if (newRating > currentRating)
        {
            bool success = await AdvancementService.TryUpgradeCoreTrait(_character, id, currentRating, newRating, _userId);
            if (success)
            {
                await CharacterService.SaveAsync(_character);
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                SetValidationMessage("Not enough Experiences to upgrade that skill.");
            }
        }
    }

    private async Task TryUpgradeDiscipline(CharacterDiscipline cd, int newRating)
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || newRating <= cd.Rating)
        {
            return;
        }

        _validationMessage = null;

        var request = new DisciplineAcquisitionRequest(_character.Id, cd.DisciplineId, newRating);
        Result<CharacterDiscipline> result = await CharacterDisciplineService.TryUpgradeDisciplineAsync(request, _userId);
        if (result.IsSuccess)
        {
            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            await CharacterService.SaveAsync(_character);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (DisciplineFailureAllowsStorytellerAck(result.Error))
        {
            _pendingDisciplineRequest = request;
            _pendingDisciplineIsUpgrade = true;
            _disciplineGateMessage = result.Error;
            _disciplineGateDialogOpen = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SetValidationMessage(result.Error ?? "Could not upgrade that Discipline.");
    }

    private async Task AddNewMerit()
    {
        if (_character == null || _selectedMeritId == 0)
        {
            return;
        }

        _validationMessage = null;

        bool meritRequiresSpec = _availableMerits.FirstOrDefault(m => m.Id == _selectedMeritId)?.RequiresSpecification ?? false;
        if (meritRequiresSpec && string.IsNullOrWhiteSpace(_newMeritSpecification))
        {
            SetValidationMessage("This merit requires a specification.");
            return;
        }

        int xpCost = ExperienceCostRules.CalculateMeritCost(0, _newMeritRating);
        if (_character.ExperiencePoints < xpCost)
        {
            SetValidationMessage($"Not enough Experiences to add that merit. Cost is {xpCost} XP.");
            return;
        }

        try
        {
            Merit merit = _availableMerits.First(m => m.Id == _selectedMeritId);
            string? specForPurchase = meritRequiresSpec
                ? (_newMeritSpecification ?? string.Empty).Trim()
                : null;
            CharacterMerit cm = await CharacterMeritService.AddMeritAsync(
                _character,
                _selectedMeritId,
                specForPurchase,
                _newMeritRating,
                xpCost);
            cm.Merit = merit;

            // EF usually fix-ups the tracked Character.Merits collection; avoid duplicate entries.
            if (!_character.Merits.Contains(cm))
            {
                _character.Merits.Add(cm);
            }

            _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
            _selectedMeritId = 0;
            _newMeritRating = 1;
            _newMeritSpecification = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            ShowAdvancementToastError(ex.Message);
        }
    }

    private async Task AddNewDiscipline()
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || _selectedDisciplineId == 0)
        {
            return;
        }

        _validationMessage = null;

        var request = new DisciplineAcquisitionRequest(_character.Id, _selectedDisciplineId, _newDisciplineRating);
        Result<CharacterDiscipline> result = await CharacterDisciplineService.AddDisciplineAsync(request, _userId);
        if (result.IsSuccess && result.Value != null)
        {
            var disc = _availableDisciplines.First(d => d.Id == _selectedDisciplineId);
            CharacterDiscipline cd = result.Value;
            cd.Discipline = disc;
            if (!_character.Disciplines.Contains(cd))
            {
                _character.Disciplines.Add(cd);
            }

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);

            _selectedDisciplineId = 0;
            _newDisciplineRating = 1;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (DisciplineFailureAllowsStorytellerAck(result.Error))
        {
            _pendingDisciplineRequest = request;
            _pendingDisciplineIsUpgrade = false;
            _disciplineGateMessage = result.Error;
            _disciplineGateDialogOpen = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SetValidationMessage(result.Error ?? "Could not add that Discipline.");
    }

    private static bool DisciplineFailureAllowsStorytellerAck(string? error) =>
        !string.IsNullOrEmpty(error)
        && error.Contains("Storyteller", StringComparison.OrdinalIgnoreCase);

    private async Task ConfirmDisciplineGateAckAsync()
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || _pendingDisciplineRequest == null)
        {
            return;
        }

        _disciplineGateDialogOpen = false;
        DisciplineAcquisitionRequest retry = _pendingDisciplineRequest with { AcquisitionAcknowledgedByST = true };
        bool wasUpgrade = _pendingDisciplineIsUpgrade;
        _pendingDisciplineRequest = null;

        Result<CharacterDiscipline> result = wasUpgrade
            ? await CharacterDisciplineService.TryUpgradeDisciplineAsync(retry, _userId)
            : await CharacterDisciplineService.AddDisciplineAsync(retry, _userId);

        if (!result.IsSuccess || result.Value == null)
        {
            ShowAdvancementToastError(result.Error ?? "Discipline purchase failed after Storyteller acknowledgment.");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (wasUpgrade)
        {
            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
        }
        else
        {
            var disc = _availableDisciplines.First(d => d.Id == retry.DisciplineId);
            result.Value.Discipline = disc;
            if (!_character.Disciplines.Contains(result.Value))
            {
                _character.Disciplines.Add(result.Value);
            }

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            _selectedDisciplineId = 0;
            _newDisciplineRating = 1;
        }

        await CharacterService.SaveAsync(_character);
        await InvokeAsync(StateHasChanged);
    }

    private Task CancelDisciplineGateAckAsync()
    {
        _disciplineGateDialogOpen = false;
        _pendingDisciplineRequest = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task AddNewDevotion()
    {
        if (_character == null || _selectedDevotionId == 0) return;

        _validationMessage = null;

        try
        {
            var devotionDef = _eligibleDevotions.First(d => d.Id == _selectedDevotionId);
            var cd = await DevotionService.PurchaseDevotionAsync(_character, _selectedDevotionId, _userId);
            cd.DevotionDefinition = devotionDef;
            _character.Devotions.Add(cd);

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            _selectedDevotionId = 0;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            ShowAdvancementToastError(ex.Message);
        }
    }

    private void HandleApplyLearnRiteModalClosed(bool isOpen)
    {
        _isApplyLearnRiteModalOpen = isOpen;
    }

    private bool IsOpeningModal(string openerName) =>
        string.Equals(_pendingModal, openerName, StringComparison.Ordinal);

    private async Task OpenLearnRiteModal()
    {
        if (_character == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        _validationMessage = null;
        _pendingModal = nameof(OpenLearnRiteModal);
        await InvokeAsync(StateHasChanged);
        try
        {
            _eligibleRites = await SorceryService.GetEligibleRitesAsync(_character.Id, _userId);
            if (_eligibleRites.Count == 0)
            {
                SetValidationMessage("No eligible rites. Raise Crúac, Theban Sorcery, or Necromancy to the required level, meet covenant/clan gates, or you may already have a pending request.");
                return;
            }

            _isApplyLearnRiteModalOpen = true;
        }
        catch (Exception ex)
        {
            ShowAdvancementToastError(ex.Message);
        }
        finally
        {
            _pendingModal = null;
        }
    }

    private async Task HandleApplyLearnRiteRequested(int sorceryRiteDefinitionId)
    {
        if (_character == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        _validationMessage = null;
        try
        {
            await SorceryService.RequestLearnRiteAsync(_character.Id, sorceryRiteDefinitionId, _userId);
            _character = await CharacterService.ReloadCharacterAsync(_character.Id, _userId);
            if (_character != null)
            {
                _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
                _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            ShowAdvancementToastError(ex.Message);
        }
    }
}
