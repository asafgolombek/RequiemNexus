@page "/character/{Id:int}/advancement"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Domain
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Web.Helpers
@using Microsoft.JSInterop
@inject ICharacterService CharacterService
@inject ISorceryService SorceryService
@inject IAdvancementService AdvancementService
@inject IClanService ClanService
@inject IMeritService MeritService
@inject IDisciplineService DisciplineService
@inject ICharacterMeritService CharacterMeritService
@inject ICharacterDisciplineService CharacterDisciplineService
@inject IDevotionService DevotionService
@inject RequiemNexus.Domain.Contracts.IExperienceCostRules ExperienceCostRules
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Advancement: @(_character?.Name ?? "Loading...") - Requiem Nexus</PageTitle>

@if (_character == null)
{
    <p><em>Loading immortal legacy...</em></p>
}
else
{
    <div class="character-sheet fade-in">
        <header class="cs-header" style="justify-content: space-between;">
            <div>
                <h1>Advancing @_character.Name</h1>
                <p>Spend your Experiences to grow more powerful.</p>
            </div>
            <div class="char-xp" style="flex-direction: column; align-items: flex-end;">
                <div class="xp-counter">
                    <strong class="xp-counter-label">Experiences</strong>
                    <span class="xp-counter-value">@_character.ExperiencePoints</span>
                </div>
                <button class="btn-rn-ghost" @onclick="GoBackToSheet" style="margin-top: 10px;">Return to Character Sheet</button>
            </div>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div @ref="_errorAlertRef" class="alert alert-danger mb-3" role="alert" aria-live="polite">@_errorMessage</div>
        }

        <CascadingValue Value="true" Name="IsEditable">
            <div class="cs-grid">
                <!-- ATTRIBUTES -->
                <section class="cs-section cs-attributes">
                    <h2>Attributes (New Dot x 4 XP)</h2>
                    <div class="grid-3-col">
                        @foreach (var (label, category) in new[] {
                            ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                            ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                            ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                        })
                        {
                            <div class="stat-col @label.ToLower()">
                                <h3>@label</h3>
                                @foreach (var attr in _character.Attributes.Where(a => a.Category == category))
                                {
                                    var id = Enum.Parse<AttributeId>(attr.Name);
                                    <DotScale Value="attr.Rating" ValueChanged='(int val) => TryUpgrade(id, attr.Rating, val)' Label="@TraitMetadata.GetDisplayName(id)" ShowRollButton="false" />
                                }
                            </div>
                        }
                    </div>
                </section>

                <!-- SKILLS -->
                <section class="cs-section cs-skills">
                    <h2>Skills (New Dot x 2 XP)</h2>
                    <div class="grid-3-col">
                        @foreach (var (label, category) in new[] {
                            ("Mental", RequiemNexus.Data.Models.Enums.TraitCategory.Mental),
                            ("Physical", RequiemNexus.Data.Models.Enums.TraitCategory.Physical),
                            ("Social", RequiemNexus.Data.Models.Enums.TraitCategory.Social)
                        })
                        {
                            <div class="stat-col @label.ToLower()">
                                <h3>@label</h3>
                                @foreach (var skill in _character.Skills.Where(s => s.Category == category))
                                {
                                    var id = Enum.Parse<SkillId>(skill.Name);
                                    <DotScale Value="skill.Rating" ValueChanged='(int val) => TryUpgrade(id, skill.Rating, val)' Label="@TraitMetadata.GetDisplayName(id)" ShowRollButton="false" />
                                }
                            </div>
                        }
                    </div>
                </section>
                
                @if (_character.Disciplines.Any())
                {
                    <section class="cs-section cs-disciplines">
                        <h2>Disciplines (clan triple, bloodline fourth, out-of-clan)</h2>
                        <ul class="trait-list disciplines-list" style="max-width: 400px;">
                            @foreach (var disc in _character.Disciplines)
                            {
                                <li class="trait-item discipline-item" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                                    <span style="flex-grow: 1;">
                                        @disc.Discipline?.Name
                                        @if (disc.Discipline != null)
                                        {
                                            <span style="display: block; font-size: 0.8em; color: #a0a0a0;">@DisciplineUiLabels.FormatAffinityBadge(_character, disc.Discipline)</span>
                                            var advTags = DisciplineUiLabels.FormatDefinitionTags(disc.Discipline);
                                            if (!string.IsNullOrEmpty(advTags))
                                            {
                                                <span style="display: block; font-size: 0.75em; color: #888;">@advTags</span>
                                            }
                                        }
                                    </span>
                                    <DotScale Value="disc.Rating" ValueChanged='(int val) => TryUpgradeDiscipline(disc, val)' Max="5" ShowRollButton="false" />
                                </li>
                            }
                        </ul>
                    </section>
                }

                <!-- ADD NEW MERIT -->
                <section class="cs-section cs-advantages">
                    <h2>Add New Merit (Rating x 1 XP)</h2>
                    <div class="equipment-form" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                        <select @bind="_selectedMeritId" class="equipment-select" style="min-width: 200px;" aria-label="Merit to purchase">
                            <option value="0">-- Select Merit --</option>
                            @foreach (var m in _availableMerits)
                            {
                                var cat = string.IsNullOrEmpty(m.MeritCategory) ? string.Empty : $" [{m.MeritCategory}]";
                                <option value="@m.Id">@m.Name (@m.ValidRatings)@cat</option>
                            }
                        </select>

                        @if (SelectedMeritRequiresSpec)
                        {
                            <input type="text" @bind="_newMeritSpecification" placeholder="Specification..." class="char-meta-input" style="width: 150px;" aria-label="Merit specification" />
                        }

                        <div style="display: flex; align-items: center; gap: 5px;">
                            <label for="new-merit-rating">Rating:</label>
                            <input id="new-merit-rating" type="number" min="1" max="5" @bind="_newMeritRating" class="equipment-quantity" style="width: 60px;" />
                        </div>

                        <button class="btn-rn-primary" @onclick="AddNewMerit" disabled="@(_selectedMeritId == 0)">Add</button>
                    </div>
                    @if (_selectedMeritId != 0)
                    {
                        var selectedMerit = _availableMerits.FirstOrDefault(m => m.Id == _selectedMeritId);
                        if (selectedMerit != null)
                        {
                            <div style="margin-top: 10px; font-size: 0.9em; color: #d0d0d0; background: #1a1a1a; padding: 10px; border-radius: 4px; border-left: 3px solid #550000;">
                                <strong>@selectedMerit.Name</strong>
                                <p style="margin: 5px 0; white-space: pre-wrap;">@selectedMerit.Description</p>
                            </div>
                        }
                    }
                </section>

                <!-- ADD NEW DISCIPLINE -->
                <section class="cs-section cs-disciplines">
                    <h2>Add New Discipline</h2>
                    <div class="equipment-form" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                        <select @bind="_selectedDisciplineId" class="equipment-select" style="min-width: 200px;" aria-label="Discipline to add">
                            <option value="0">-- Select Discipline --</option>
                            @foreach (var d in _availableDisciplines.Where(ad => !_character.Disciplines.Any(cd => cd.DisciplineId == ad.Id)))
                            {
                                <option value="@d.Id">@DisciplineUiLabels.FormatAdvancementOption(_character, d)</option>
                            }
                        </select>

                        <div style="display: flex; align-items: center; gap: 5px;">
                            <label for="new-discipline-rating">Starting Rating:</label>
                            <input id="new-discipline-rating" type="number" min="1" max="5" @bind="_newDisciplineRating" class="equipment-quantity" style="width: 60px;" />
                        </div>

                        <button class="btn-rn-primary" @onclick="AddNewDiscipline" disabled="@(_selectedDisciplineId == 0)">Add</button>
                    </div>
                </section>

                <!-- ADD NEW DEVOTION -->
                <section class="cs-section cs-devotions">
                    <h2>Purchase Devotions</h2>
                    @if (_eligibleDevotions.Any())
                    {
                        <div class="equipment-form" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                            <select @bind="_selectedDevotionId" class="equipment-select" style="min-width: 200px;" aria-label="Devotion to purchase">
                                <option value="0">-- Select Devotion --</option>
                                @foreach (var d in _eligibleDevotions)
                                {
                                    <option value="@d.Id">@d.Name (@d.XpCost XP)</option>
                                }
                            </select>
                            <button class="btn-rn-primary" @onclick="AddNewDevotion" disabled="@(_selectedDevotionId == 0)">Purchase</button>
                        </div>
                        
                        @if (_selectedDevotionId != 0)
                        {
                            var selected = _eligibleDevotions.First(d => d.Id == _selectedDevotionId);
                            <div style="margin-top: 10px; font-size: 0.9em; color: #d0d0d0; background: #1a1a1a; padding: 10px; border-radius: 4px; border-left: 3px solid #550000;">
                                <strong>@selected.Name</strong>
                                <p style="margin: 5px 0;">@selected.Description</p>
                                <div style="font-size: 0.85em; color: #a0a0a0;">
                                    Prerequisites: 
                                    @foreach (var p in selected.Prerequisites.OrderBy(p => p.OrGroupId).ThenBy(p => p.DisciplineId))
                                    {
                                        <span>@(p.Discipline?.Name ?? "Discipline") @p.MinimumLevel</span>
                                        @if (p != selected.Prerequisites.Last()) { <span>, </span> }
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted-rn" style="font-size: 0.9em;">No new devotions eligible for purchase at this time.</p>
                    }
                </section>

                @if (ShowBloodSorcerySection)
                {
                    <section class="cs-section cs-blood-sorcery">
                        <h2>Blood Sorcery Rites</h2>
                        @{
                            var pendingRiteAdv = _character.Rites?.FirstOrDefault(r => r.Status == RiteLearnStatus.Pending);
                        }
                        @if (pendingRiteAdv?.SorceryRiteDefinition != null)
                        {
                            <p style="color: #a0a0a0; font-size: 0.9em;">Pending: <strong>@pendingRiteAdv.SorceryRiteDefinition.Name</strong> — awaiting Storyteller approval.</p>
                            <p style="font-size: 0.85em; color: var(--text-secondary); margin: 4px 0 0 0;">Your Storyteller will review this. You'll be notified when it's approved.</p>
                            @if (_character.CampaignId.HasValue)
                            {
                                <a href="/campaigns/@_character.CampaignId/glimpse" class="btn-rn-ghost" style="font-size: 0.85em; margin-top: 4px;">Storyteller Glimpse</a>
                            }
                        }
                        else
                        {
                            <p class="text-muted-rn" style="font-size: 0.9em; margin-bottom: 8px;">Request to learn Crúac, Theban, or Necromancy rites you qualify for. Requires matching discipline dots, covenant or clan where applicable, sufficient Experiences, and Storyteller approval.</p>
                            <button class="btn-rn-primary" style="font-size: 0.9em;" @onclick="OpenLearnRiteModal" disabled="@_openingRiteModal">Request rite</button>
                        }
                    </section>
                }
            </div>
        </CascadingValue>

        <ApplyLearnRiteModal IsOpen="_isApplyLearnRiteModalOpen"
                             IsOpenChanged="HandleApplyLearnRiteModalClosed"
                             EligibleRites="_eligibleRites"
                             OnApplyRequested="HandleApplyLearnRiteRequested" />

        @if (_disciplineGateDialogOpen)
        {
            <div class="modal-backdrop" @onclick="CancelDisciplineGateAckAsync">
                <div class="modal-panel apply-bloodline-modal" @onclick:stopPropagation role="dialog" aria-modal="true" aria-labelledby="disc-gate-title">
                    <div class="modal-header">
                        <h3 id="disc-gate-title">Storyteller acknowledgment</h3>
                        <button type="button" class="close-btn" @onclick="CancelDisciplineGateAckAsync" aria-label="Close">×</button>
                    </div>
                    <div class="modal-body">
                        <p class="apply-bloodline-hint">@_disciplineGateMessage</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-rn-ghost" @onclick="CancelDisciplineGateAckAsync">Cancel</button>
                        <button type="button" class="btn-rn-primary" @onclick="ConfirmDisciplineGateAckAsync">Storyteller acknowledges</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Character? _character;
    private string? _userId;
    private string? _errorMessage;
    private ElementReference _errorAlertRef;
    private int _errorAlertNonce;
    private int _lastScrolledErrorNonce;

    private List<Merit> _availableMerits = new();
    private int _selectedMeritId = 0;
    private int _newMeritRating = 1;
    private string? _newMeritSpecification;

    private List<Discipline> _availableDisciplines = new();
    private int _selectedDisciplineId = 0;
    private int _newDisciplineRating = 1;

    private List<DevotionDefinition> _eligibleDevotions = new();
    private int _selectedDevotionId = 0;

    private bool _isApplyLearnRiteModalOpen;
    private bool _openingRiteModal;
    private List<SorceryRiteSummaryDto> _eligibleRites = [];

    private bool _disciplineGateDialogOpen;
    private string? _disciplineGateMessage;
    private DisciplineAcquisitionRequest? _pendingDisciplineRequest;
    private bool _pendingDisciplineIsUpgrade;

    /// <summary>Same visibility as the character sheet Blood Sorcery section.</summary>
    private bool ShowBloodSorcerySection =>
        _character != null
        && _character.CovenantJoinStatus == null
        && (
            (_character.Covenant?.SupportsBloodSorcery == true)
            || _character.GetDisciplineRating("Necromancy") > 0);

    private bool SelectedMeritRequiresSpec => 
        _availableMerits.FirstOrDefault(m => m.Id == _selectedMeritId)?.RequiresSpecification ?? false;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(_userId))
        {
            _character = await CharacterService.GetCharacterByIdAsync(Id, _userId);
            if (_character != null)
            {
                _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
                _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            }

            _availableDisciplines = await CharacterDisciplineService.GetAvailableDisciplinesAsync();
        }
    }

    /// <summary>Sets the visible advancement error and bumps the nonce so <see cref="OnAfterRenderAsync"/> can scroll the alert into view.</summary>
    private void SetAdvancementError(string message)
    {
        _errorMessage = message;
        _errorAlertNonce++;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_errorAlertNonce > _lastScrolledErrorNonce && !string.IsNullOrEmpty(_errorMessage))
        {
            _lastScrolledErrorNonce = _errorAlertNonce;
            try
            {
                await JSRuntime.InvokeVoidAsync("scrollElementIntoView", _errorAlertRef);
            }
            catch (JSException)
            {
                // Prerender or disconnected circuit — no DOM to scroll.
            }
        }
    }

    private void GoBackToSheet()
    {
        NavigationManager.NavigateTo($"/character/{Id}");
    }

    private async Task TryUpgrade(AttributeId id, int currentRating, int newRating)
    {
        if (_character == null) return;
        
        _errorMessage = null;

        if (newRating > currentRating)
        {
            bool success = await AdvancementService.TryUpgradeCoreTrait(_character, id, currentRating, newRating, _userId);
            if (success)
            {
                if (id is AttributeId.Stamina or AttributeId.Resolve or AttributeId.Composure)
                    AdvancementService.RecalculateDerivedStats(_character);
                await CharacterService.SaveAsync(_character);
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                SetAdvancementError("Not enough Experiences to upgrade that attribute.");
            }
        }
    }

    private async Task TryUpgrade(SkillId id, int currentRating, int newRating)
    {
        if (_character == null) return;
        
        _errorMessage = null;

        if (newRating > currentRating)
        {
            bool success = await AdvancementService.TryUpgradeCoreTrait(_character, id, currentRating, newRating, _userId);
            if (success)
            {
                await CharacterService.SaveAsync(_character);
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                SetAdvancementError("Not enough Experiences to upgrade that skill.");
            }
        }
    }

    private async Task TryUpgradeDiscipline(CharacterDiscipline cd, int newRating)
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || newRating <= cd.Rating)
        {
            return;
        }

        _errorMessage = null;

        var request = new DisciplineAcquisitionRequest(_character.Id, cd.DisciplineId, newRating);
        Result<CharacterDiscipline> result = await CharacterDisciplineService.TryUpgradeDisciplineAsync(request, _userId);
        if (result.IsSuccess)
        {
            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            await CharacterService.SaveAsync(_character);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (DisciplineFailureAllowsStorytellerAck(result.Error))
        {
            _pendingDisciplineRequest = request;
            _pendingDisciplineIsUpgrade = true;
            _disciplineGateMessage = result.Error;
            _disciplineGateDialogOpen = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SetAdvancementError(result.Error ?? "Could not upgrade that Discipline.");
    }

    private async Task AddNewMerit()
    {
        if (_character == null || _selectedMeritId == 0)
        {
            return;
        }

        _errorMessage = null;

        if (SelectedMeritRequiresSpec && string.IsNullOrWhiteSpace(_newMeritSpecification))
        {
            SetAdvancementError("This merit requires a specification.");
            return;
        }

        int xpCost = ExperienceCostRules.CalculateMeritCost(0, _newMeritRating);
        if (_character.ExperiencePoints < xpCost)
        {
            SetAdvancementError($"Not enough Experiences to add that merit. Cost is {xpCost} XP.");
            return;
        }

        try
        {
            Merit merit = _availableMerits.First(m => m.Id == _selectedMeritId);
            string? specForPurchase = SelectedMeritRequiresSpec
                ? (_newMeritSpecification ?? string.Empty).Trim()
                : null;
            CharacterMerit cm = await CharacterMeritService.AddMeritAsync(
                _character,
                _selectedMeritId,
                specForPurchase,
                _newMeritRating,
                xpCost);
            cm.Merit = merit;

            // EF usually fix-ups the tracked Character.Merits collection; avoid duplicate entries.
            if (!_character.Merits.Contains(cm))
            {
                _character.Merits.Add(cm);
            }

            _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
            _selectedMeritId = 0;
            _newMeritRating = 1;
            _newMeritSpecification = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            SetAdvancementError(ex.Message);
        }
    }

    private async Task AddNewDiscipline()
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || _selectedDisciplineId == 0)
        {
            return;
        }

        _errorMessage = null;

        var request = new DisciplineAcquisitionRequest(_character.Id, _selectedDisciplineId, _newDisciplineRating);
        Result<CharacterDiscipline> result = await CharacterDisciplineService.AddDisciplineAsync(request, _userId);
        if (result.IsSuccess && result.Value != null)
        {
            var disc = _availableDisciplines.First(d => d.Id == _selectedDisciplineId);
            CharacterDiscipline cd = result.Value;
            cd.Discipline = disc;
            if (!_character.Disciplines.Contains(cd))
            {
                _character.Disciplines.Add(cd);
            }

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);

            _selectedDisciplineId = 0;
            _newDisciplineRating = 1;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (DisciplineFailureAllowsStorytellerAck(result.Error))
        {
            _pendingDisciplineRequest = request;
            _pendingDisciplineIsUpgrade = false;
            _disciplineGateMessage = result.Error;
            _disciplineGateDialogOpen = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        SetAdvancementError(result.Error ?? "Could not add that Discipline.");
    }

    private static bool DisciplineFailureAllowsStorytellerAck(string? error) =>
        !string.IsNullOrEmpty(error)
        && error.Contains("Storyteller", StringComparison.OrdinalIgnoreCase);

    private async Task ConfirmDisciplineGateAckAsync()
    {
        if (_character == null || string.IsNullOrEmpty(_userId) || _pendingDisciplineRequest == null)
        {
            return;
        }

        _disciplineGateDialogOpen = false;
        DisciplineAcquisitionRequest retry = _pendingDisciplineRequest with { AcquisitionAcknowledgedByST = true };
        bool wasUpgrade = _pendingDisciplineIsUpgrade;
        _pendingDisciplineRequest = null;

        Result<CharacterDiscipline> result = wasUpgrade
            ? await CharacterDisciplineService.TryUpgradeDisciplineAsync(retry, _userId)
            : await CharacterDisciplineService.AddDisciplineAsync(retry, _userId);

        if (!result.IsSuccess || result.Value == null)
        {
            SetAdvancementError(result.Error ?? "Discipline purchase failed after Storyteller acknowledgment.");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (wasUpgrade)
        {
            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
        }
        else
        {
            var disc = _availableDisciplines.First(d => d.Id == retry.DisciplineId);
            result.Value.Discipline = disc;
            if (!_character.Disciplines.Contains(result.Value))
            {
                _character.Disciplines.Add(result.Value);
            }

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            _selectedDisciplineId = 0;
            _newDisciplineRating = 1;
        }

        await CharacterService.SaveAsync(_character);
        await InvokeAsync(StateHasChanged);
    }

    private Task CancelDisciplineGateAckAsync()
    {
        _disciplineGateDialogOpen = false;
        _pendingDisciplineRequest = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task AddNewDevotion()
    {
        if (_character == null || _selectedDevotionId == 0) return;

        _errorMessage = null;

        try
        {
            var devotionDef = _eligibleDevotions.First(d => d.Id == _selectedDevotionId);
            var cd = await DevotionService.PurchaseDevotionAsync(_character, _selectedDevotionId, _userId);
            cd.DevotionDefinition = devotionDef;
            _character.Devotions.Add(cd);

            _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            _selectedDevotionId = 0;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            SetAdvancementError(ex.Message);
        }
    }

    private void HandleApplyLearnRiteModalClosed(bool isOpen)
    {
        _isApplyLearnRiteModalOpen = isOpen;
    }

    private async Task OpenLearnRiteModal()
    {
        if (_character == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        _errorMessage = null;
        _openingRiteModal = true;
        try
        {
            _eligibleRites = await SorceryService.GetEligibleRitesAsync(_character.Id, _userId);
            if (_eligibleRites.Count == 0)
            {
                SetAdvancementError("No eligible rites. Raise Crúac, Theban Sorcery, or Necromancy to the required level, meet covenant/clan gates, or you may already have a pending request.");
                return;
            }

            _isApplyLearnRiteModalOpen = true;
        }
        catch (Exception ex)
        {
            SetAdvancementError(ex.Message);
        }
        finally
        {
            _openingRiteModal = false;
        }
    }

    private async Task HandleApplyLearnRiteRequested(int sorceryRiteDefinitionId)
    {
        if (_character == null || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        _errorMessage = null;
        try
        {
            await SorceryService.RequestLearnRiteAsync(_character.Id, sorceryRiteDefinitionId, _userId);
            _character = await CharacterService.ReloadCharacterAsync(_character.Id, _userId);
            if (_character != null)
            {
                _availableMerits = await CharacterMeritService.GetAvailableMeritsAsync(_character);
                _eligibleDevotions = await DevotionService.GetEligibleDevotionsAsync(_character);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            SetAdvancementError(ex.Message);
        }
    }
}
