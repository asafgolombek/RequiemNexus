@page "/home"
@rendermode InteractiveServer

<PageTitle>Home - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    <!-- Main Dashboard Body -->
    <main class="dashboard-content">
        <div class="welcome-banner card-rn stagger-1">
            <h2>Welcome to Requiem Nexus</h2>
            <p>Your portal to darkness and legend awaits. Manage your campaigns, characters, and chronicles.</p>
        </div>

        <div class="dashboard-widgets grid-auto-fill mt-4">
            <a href="/characters" class="widget-card card-rn fade-in-up stagger-2">
                <div class="widget-icon"><Icon Name="@IconName.Users" /></div>
                <h3>My Characters</h3>
                <p>View and manage your vampires.</p>
            </a>
            <a href="/campaigns" class="widget-card card-rn fade-in-up stagger-3">
                <div class="widget-icon"><Icon Name="@IconName.BookOpen" /></div>
                <h3>My Campaigns</h3>
                <p>Access your chronicles and story notes.</p>
            </a>
            <a href="/character/create" class="widget-card card-rn fade-in-up stagger-4">
                <div class="widget-icon"><Icon Name="@IconName.Droplet" /></div>
                <h3>Embrace New</h3>
                <p>Create a new character.</p>
            </a>
        </div>
    </main>
</div>
