@page "/not-found"
@layout MainLayout

<PageTitle>Not Found - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    <div class="empty-state-rn card-rn" style="max-width: 480px; margin: 2rem auto; padding: 2rem; text-align: center;">
        <h2 style="color: var(--bone-white); margin-bottom: 0.5rem;">Not Found</h2>
        <p class="gothic-muted" style="margin-bottom: 1.5rem;">Sorry, the content you are looking for does not exist.</p>
        <a href="/home" class="btn-rn-primary">Return to Dashboard</a>
        <p class="gothic-muted" style="margin-top: 1.5rem; font-size: 0.85em;">Press <kbd>Ctrl+K</kbd> to search</p>
    </div>
</div>