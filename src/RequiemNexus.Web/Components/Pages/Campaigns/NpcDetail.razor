@page "/campaigns/{CampaignId:int}/npcs/{NpcId:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Application.Contracts
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.Pages.Campaigns.NpcDetailParts
@inject IChronicleNpcService NpcService
@inject ICityFactionService FactionService
@inject ICampaignService CampaignService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>@(_npc?.Name is { } npcName ? $"{npcName} — NPC" : "NPC") — Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <p>Access denied. Only the Storyteller may view NPC details.</p>
            <a href="/campaigns/@CampaignId/danse-macabre" class="btn-rn-ghost">Back</a>
        </div>
    }
    else if (_npc == null)
    {
        <SkeletonLoader Variant="card" Count="3" />
    }
    else
    {
        <NpcDetailPageHeader CampaignId="CampaignId" Npc="_npc" />

        @if (!string.IsNullOrEmpty(_feedbackMessage))
        {
            <p class="feedback-ok">@_feedbackMessage</p>
        }

        <div class="card-rn" style="margin-bottom:1.5rem;">
            <h3>Edit NPC</h3>
            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="_editName" />
            </div>
            <div class="form-group">
                <label>Title</label>
                <input class="form-control" placeholder="e.g. Prince, Harpy..." @bind="_editTitle" />
            </div>
            <div class="form-group">
                <label>Type</label>
                <div style="display:flex;gap:1.5rem;align-items:center;margin-top:0.25rem;">
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <input type="radio" name="npcType" checked="@(_editCreatureType == CreatureType.Mortal)" @onchange="() => _editCreatureType = CreatureType.Mortal" />
                        👤 Mortal
                    </label>
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <input type="radio" name="npcType" checked="@(_editCreatureType == CreatureType.Vampire)" @onchange="() => _editCreatureType = CreatureType.Vampire" />
                        🧛 Vampire
                    </label>
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <input type="radio" name="npcType" checked="@(_editCreatureType == CreatureType.Ghoul)" @onchange="() => _editCreatureType = CreatureType.Ghoul" />
                        🩸 Ghoul
                    </label>
                </div>
            </div>
            <div class="form-group">
                <label>Faction</label>
                <select class="form-control" @bind="_editFactionId">
                    <option value="0">— No faction —</option>
                    @foreach (CityFaction faction in _allFactions)
                    {
                        <option value="@faction.Id">@faction.Name</option>
                    }
                </select>
                @if (_editFactionId > 0)
                {
                    <a href="/campaigns/@CampaignId/factions/@_editFactionId" class="btn-rn-ghost" style="font-size:0.8em;margin-top:0.25rem;display:inline-block;">
                        👑 View Faction
                    </a>
                }
            </div>
            <div class="form-group">
                <label>Role in Faction</label>
                <input class="form-control" placeholder="e.g. Lieutenant, Spy..." @bind="_editRole" />
            </div>
            <div class="form-group">
                <label>Public Description</label>
                <textarea class="form-control" rows="3" @bind="_editPublicDesc"></textarea>
            </div>
            <div class="form-group">
                <label>Storyteller Notes (ST-only)</label>
                <textarea class="form-control" rows="3" @bind="_editStNotes"></textarea>
            </div>
            <div class="form-group" style="display:flex;align-items:center;gap:1rem;">
                <label>Status:</label>
                <label>
                    <input type="checkbox" checked="@_npc.IsAlive" @onchange="ToggleAlive" />
                    @(_npc.IsAlive ? "Alive" : "Deceased")
                </label>
            </div>
            <button type="button" class="btn-rn-primary" disabled="@_busy" @onclick="SaveNpc">Save Changes</button>
        </div>

        <NpcDetailAttributesCard Categories="_attributeCategories"
                                 EditAttributes="_editAttributes"
                                 OnChanged="HandleStatsEditedAsync" />

        <NpcDetailSkillsCard Categories="_skillCategories"
                             EditSkills="_editSkills"
                             OnChanged="HandleStatsEditedAsync" />

        <NpcDetailStatBlockCard Npc="_npc"
                                @bind-EditStatBlockId="_editStatBlockId"
                                Busy="_busy"
                                OnSaveLink="SaveStatBlockLink" />

        <NpcDetailDangerZone NpcName="_npc.Name"
                             @bind-ShowConfirmDelete="_showConfirmDelete"
                             Busy="_busy"
                             OnConfirmDelete="ConfirmDelete" />
    }
</div>
