@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums

<a href="/campaigns/@CampaignId/danse-macabre" class="btn-rn-ghost" style="margin-bottom:1rem;display:inline-block;">← Back to Danse Macabre</a>

<div class="campaign-header">
    <h2>@Npc.Name
        @if (!string.IsNullOrEmpty(Npc.Title))
        {
            <span class="text-muted" style="font-size:0.7em;"> — @Npc.Title</span>
        }
        @if (!Npc.IsAlive)
        {
            <span class="badge-rn" style="font-size:0.6em;">☠ Deceased</span>
        }
        @switch (Npc.CreatureType)
        {
            case CreatureType.Vampire:
                <span class="badge-rn" style="font-size:0.6em;margin-left:0.5rem;">🧛 Vampire</span>
                break;
            case CreatureType.Ghoul:
                <span class="badge-rn" style="font-size:0.6em;margin-left:0.5rem;background:var(--color-surface-2,#444);">🩸 Ghoul</span>
                break;
            default:
                <span class="badge-rn" style="font-size:0.6em;margin-left:0.5rem;background:var(--color-surface-2,#444);">👤 Mortal</span>
                break;
        }
    </h2>
</div>

@code {
    [Parameter, EditorRequired]
    public int CampaignId { get; set; }

    [Parameter, EditorRequired]
    public ChronicleNpc Npc { get; set; } = default!;
}
