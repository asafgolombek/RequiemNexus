@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Data.Models
@using RequiemNexus.Domain.Models
@using RequiemNexus.Web.Services
@inject IGhoulManagementService GhoulService
@inject ToastService ToastService

@if (IsOpen)
{
    <div class="rn-modal-backdrop" @onclick="CloseAsync">
        <div class="rn-modal-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="ghoul-create-title">
            <div class="rn-modal-header">
                <h2 id="ghoul-create-title" class="rn-modal-title">Add ghoul</h2>
                <button type="button" class="rn-modal-close" @onclick="CloseAsync" aria-label="Close">×</button>
            </div>
            <div class="rn-modal-body">
                <label class="text-small" for="ghoul-name">Name</label>
                <input id="ghoul-name" type="text" class="form-control" maxlength="150" @bind="_name" style="margin:0.35rem 0 0.75rem;" />

                <div class="lineage-mode-row" style="display:flex;flex-wrap:wrap;gap:0.35rem;margin-bottom:0.75rem;">
                    <button type="button" class="@ModeClass("pc")" @onclick='() => _regnantMode = "pc"'>PC regnant</button>
                    <button type="button" class="@ModeClass("npc")" @onclick='() => _regnantMode = "npc"'>NPC regnant</button>
                    <button type="button" class="@ModeClass("name")" @onclick='() => _regnantMode = "name"'>Name only</button>
                </div>

                @if (_regnantMode == "pc")
                {
                    <label class="text-small" for="ghoul-pc">Regnant (PC)</label>
                    <select id="ghoul-pc" class="form-control" style="width:100%;margin:0.35rem 0 0.75rem;" @bind="_regnantPcId">
                        <option value="0">— Select —</option>
                        @foreach (var v in Vitals)
                        {
                            <option value="@v.CharacterId">@v.Name</option>
                        }
                    </select>
                }
                else if (_regnantMode == "npc")
                {
                    <label class="text-small" for="ghoul-npc">Regnant (NPC)</label>
                    <select id="ghoul-npc" class="form-control" style="width:100%;margin:0.35rem 0 0.75rem;" @bind="_regnantNpcId">
                        <option value="0">— Select —</option>
                        @foreach (var n in Npcs)
                        {
                            <option value="@n.Id">@n.Name</option>
                        }
                    </select>
                }
                else
                {
                    <label class="text-small" for="ghoul-rname">Regnant display name</label>
                    <input id="ghoul-rname" type="text" class="form-control" maxlength="150" @bind="_regnantName" style="margin:0.35rem 0 0.75rem;" />
                }

                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
                    <div style="flex:1;min-width:120px;">
                        <label class="text-small" for="ghoul-apparent">Apparent age (optional)</label>
                        <input id="ghoul-apparent" type="number" class="form-control" min="0" max="200" @bind="_apparentStr" style="margin:0.35rem 0 0;" />
                    </div>
                    <div style="flex:1;min-width:120px;">
                        <label class="text-small" for="ghoul-actual">Actual age (optional)</label>
                        <input id="ghoul-actual" type="number" class="form-control" min="0" max="200" @bind="_actualStr" style="margin:0.35rem 0 0;" />
                    </div>
                </div>

                <label class="text-small" for="ghoul-notes" style="display:block;margin-top:0.75rem;">Notes (optional)</label>
                <textarea id="ghoul-notes" class="form-control" rows="2" maxlength="2000" @bind="_notes" style="margin:0.35rem 0 0;"></textarea>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-small" style="color:var(--accent-warm);margin-top:0.5rem;">@_error</p>
                }
            </div>
            <div class="edit-lineage-footer">
                <button type="button" class="btn-ghost" @onclick="CloseAsync" disabled="@_busy">Cancel</button>
                <button type="button" class="btn-primary-rn" disabled="@(_busy || !CanSubmit)" @onclick="SubmitAsync">
                    @(_busy ? "Saving…" : "Create ghoul")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public int CampaignId { get; set; }

    [Parameter]
    public string StorytellerUserId { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<CharacterVitalsDto> Vitals { get; set; } = [];

    [Parameter]
    public IReadOnlyList<ChronicleNpc> Npcs { get; set; } = [];

    [Parameter]
    public EventCallback OnCreated { get; set; }

    private string _name = string.Empty;

    private string _regnantMode = "pc";

    private int _regnantPcId;

    private int _regnantNpcId;

    private string _regnantName = string.Empty;

    private string _notes = string.Empty;

    private string _apparentStr = string.Empty;

    private string _actualStr = string.Empty;

    private string _error = string.Empty;

    private bool _busy;

    private bool CanSubmit => !string.IsNullOrWhiteSpace(_name) && (_regnantMode switch
    {
        "pc" => _regnantPcId != 0,
        "npc" => _regnantNpcId != 0,
        _ => !string.IsNullOrWhiteSpace(_regnantName),
    });

    private string ModeClass(string mode) =>
        $"btn-ghost lineage-mode-btn {(_regnantMode == mode ? "lineage-mode-active" : string.Empty)}";

    private static int? ParseOptionalInt(string s) =>
        int.TryParse(s, out int v) ? v : null;

    private async Task CloseAsync()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        _error = string.Empty;
        _name = string.Empty;
        _regnantPcId = 0;
        _regnantNpcId = 0;
        _regnantName = string.Empty;
        _notes = string.Empty;
        _apparentStr = string.Empty;
        _actualStr = string.Empty;
        _regnantMode = "pc";
    }

    private async Task SubmitAsync()
    {
        _error = string.Empty;
        _busy = true;
        try
        {
            var request = new CreateGhoulRequest(
                CampaignId,
                _name.Trim(),
                _regnantMode == "pc" ? _regnantPcId : null,
                _regnantMode == "npc" ? _regnantNpcId : null,
                _regnantMode == "name" ? _regnantName : null,
                ParseOptionalInt(_apparentStr),
                ParseOptionalInt(_actualStr),
                string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim());

            Result<GhoulDto> result = await GhoulService.CreateGhoulAsync(request, StorytellerUserId);
            if (!result.IsSuccess)
            {
                _error = result.Error ?? "Could not create ghoul.";
                return;
            }

            ToastService.Show("Ghouls", $"Created {result.Value!.Name}.", ToastType.Success);
            await OnCreated.InvokeAsync();
            await CloseAsync();
        }
        finally
        {
            _busy = false;
        }
    }
}
