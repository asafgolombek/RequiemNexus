@page "/campaigns/{Id:int}/glimpse"
@rendermode InteractiveServer
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IStorytellerGlimpseService GlimpseService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ICoilService CoilService
@inject ICampaignService CampaignService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject RequiemNexus.Web.Services.ToastService ToastService

<PageTitle>Storyteller Glimpse - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <p><em>Loading campaign vitals...</em></p>
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — only the campaign Storyteller may view this dashboard.
        </div>
    }
    else
    {
        <div class="campaign-header">
            <h2>Storyteller Glimpse</h2>
            <a href="/campaigns/@Id" class="btn-ghost">← Back to Campaign</a>
        </div>

        @* ── Coterie Beat Award ──────────────────────────────────────────────── *@
        <div class="card-rn" style="margin-bottom:1.5rem;">
            <h3 style="margin-bottom:0.75rem;">Award Beat to Coterie</h3>
            <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap;">
                <input class="form-control"
                       style="flex:1;min-width:200px;"
                       placeholder="Reason for coterie Beat…"
                       @bind="_coteReason" />
                <button class="btn-primary-rn"
                        disabled="@(string.IsNullOrWhiteSpace(_coteReason) || _awarding)"
                        @onclick="AwardCoterieBeat">
                    Award to All
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_coteMessage))
            {
                <p class="feedback-ok" style="margin-top:0.5rem;">@_coteMessage</p>
            }
        </div>

        @* ── Pending Bloodline Requests ──────────────────────────────────────── *@
        @if (_pendingBloodlines.Count > 0)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Pending Bloodline Requests</h3>
                <ul style="list-style:none;padding:0;margin:0;">
                    @foreach (var app in _pendingBloodlines)
                    {
                        <li style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);">
                            <span><strong>@app.CharacterName</strong> → @app.BloodlineName</span>
                            <span style="color:var(--text-secondary);font-size:0.85em;">@app.AppliedAt.ToString("yyyy-MM-dd HH:mm")</span>
                            <div style="display:flex;gap:0.5rem;margin-left:auto;">
                                @if (_rejectingId == app.CharacterBloodlineId)
                                {
                                    <input type="text"
                                           class="form-control"
                                           style="width:160px;font-size:0.85em;"
                                           placeholder="Optional note…"
                                           @bind="_rejectNote" />
                                }
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(_awarding)"
                                        @onclick="() => ApproveBloodline(app.CharacterBloodlineId)">
                                    Approve
                                </button>
                                @if (_rejectingId == app.CharacterBloodlineId)
                                {
                                    <button class="btn-danger-rn"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => ConfirmRejectBloodline(app.CharacterBloodlineId)">
                                        Confirm Reject
                                    </button>
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="CancelReject">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => StartReject(app.CharacterBloodlineId)">
                                        Reject
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        @* ── Pending Covenant Requests ───────────────────────────────────────── *@
        @if (_pendingCovenants.Count > 0)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Pending Covenant Requests</h3>
                <ul style="list-style:none;padding:0;margin:0;">
                    @foreach (var app in _pendingCovenants)
                    {
                        <li style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);">
                            <span><strong>@app.CharacterName</strong> → @app.CovenantName</span>
                            <span style="color:var(--text-secondary);font-size:0.85em;">@app.AppliedAt.ToString("yyyy-MM-dd HH:mm")</span>
                            <div style="display:flex;gap:0.5rem;margin-left:auto;">
                                @if (_rejectingCovenantCharacterId == app.CharacterId)
                                {
                                    <input type="text"
                                           class="form-control"
                                           style="width:160px;font-size:0.85em;"
                                           placeholder="Optional note…"
                                           @bind="_covenantRejectNote" />
                                }
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(_awarding)"
                                        @onclick="() => ApproveCovenant(app.CharacterId)">
                                    Approve
                                </button>
                                @if (_rejectingCovenantCharacterId == app.CharacterId)
                                {
                                    <button class="btn-danger-rn"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => ConfirmRejectCovenant(app.CharacterId)">
                                        Confirm Reject
                                    </button>
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="CancelRejectCovenant">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => StartRejectCovenant(app.CharacterId)">
                                        Reject
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        @* ── Pending Rite Learning Requests ───────────────────────────────────── *@
        @if (_pendingRites.Count > 0)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Pending Rite Learning Requests</h3>
                <ul style="list-style:none;padding:0;margin:0;">
                    @foreach (var app in _pendingRites)
                    {
                        <li style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);">
                            <span><strong>@app.CharacterName</strong> → @app.RiteName</span>
                            <span style="color:var(--text-secondary);font-size:0.85em;">@app.SorceryType Lv.@app.Level — @app.XpCost XP @app.AppliedAt.ToString("yyyy-MM-dd HH:mm")</span>
                            <div style="display:flex;gap:0.5rem;margin-left:auto;">
                                @if (_rejectingRiteId == app.CharacterRiteId)
                                {
                                    <input type="text"
                                           class="form-control"
                                           style="width:160px;font-size:0.85em;"
                                           placeholder="Optional note…"
                                           @bind="_riteRejectNote" />
                                }
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(_awarding)"
                                        @onclick="() => ApproveRite(app.CharacterRiteId)">
                                    Approve
                                </button>
                                @if (_rejectingRiteId == app.CharacterRiteId)
                                {
                                    <button class="btn-danger-rn"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => ConfirmRejectRite(app.CharacterRiteId)">
                                        Confirm Reject
                                    </button>
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="CancelRejectRite">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => StartRejectRite(app.CharacterRiteId)">
                                        Reject
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        @* ── Pending Chosen Mystery (Ordo Dracul) ─────────────────────────────── *@
        @if (_pendingChosenMysteries.Count > 0)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Pending Chosen Mystery Requests</h3>
                <ul style="list-style:none;padding:0;margin:0;">
                    @foreach (var app in _pendingChosenMysteries)
                    {
                        <li style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);">
                            <span><strong>@app.CharacterName</strong> → @app.ScaleName</span>
                            <div style="display:flex;gap:0.5rem;margin-left:auto;">
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(_awarding)"
                                        @onclick="() => ApproveChosenMystery(app.CharacterId)">
                                    Approve
                                </button>
                                @if (_rejectingChosenMysteryCharacterId == app.CharacterId)
                                {
                                    <button class="btn-danger-rn"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => ConfirmRejectChosenMystery(app.CharacterId)">
                                        Confirm Reject
                                    </button>
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="CancelRejectChosenMystery">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => StartRejectChosenMystery(app.CharacterId)">
                                        Reject
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        @* ── Pending Coil Purchase Requests (Ordo Dracul) ─────────────────────── *@
        @if (_pendingCoils.Count > 0)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Pending Coil Purchase Requests</h3>
                <ul style="list-style:none;padding:0;margin:0;">
                    @foreach (var app in _pendingCoils)
                    {
                        <li style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.1);">
                            <span><strong>@app.CharacterName</strong> → @app.CoilName (@app.ScaleName, dot @app.Level)</span>
                            <span style="color:var(--text-secondary);font-size:0.85em;">@app.XpCost XP @app.AppliedAt.ToString("yyyy-MM-dd HH:mm")</span>
                            <div style="display:flex;gap:0.5rem;margin-left:auto;">
                                @if (_rejectingCoilId == app.CharacterCoilId)
                                {
                                    <input type="text"
                                           class="form-control"
                                           style="width:160px;font-size:0.85em;"
                                           placeholder="Optional note…"
                                           @bind="_coilRejectNote" />
                                }
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(_awarding)"
                                        @onclick="() => ApproveCoil(app.CharacterCoilId)">
                                    Approve
                                </button>
                                @if (_rejectingCoilId == app.CharacterCoilId)
                                {
                                    <button class="btn-danger-rn"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => ConfirmRejectCoil(app.CharacterCoilId)">
                                        Confirm Reject
                                    </button>
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="CancelRejectCoil">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-ghost"
                                            style="font-size:0.85em;"
                                            disabled="@(_awarding)"
                                            @onclick="() => StartRejectCoil(app.CharacterCoilId)">
                                        Reject
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        @* ── Character Cards ─────────────────────────────────────────────────── *@
        @if (!_vitals.Any())
        {
            <div class="empty-state-rn">
                <p>No characters have joined this campaign yet.</p>
            </div>
        }
        else
        {
            <div class="character-grid">
                @foreach (CharacterVitalsDto v in _vitals)
                {
                    <div class="card-rn glimpse-card">
                        <div class="glimpse-card-header">
                            <h4>@v.Name</h4>
                            <a href="/campaigns/@Id/characters/@v.CharacterId" class="btn-ghost" style="font-size:0.8em;">👁 View Sheet</a>
                        </div>

                        <div class="vitals-grid">
                            <div class="vital-row">
                                <span class="vital-label">❤️ Health</span>
                                <div class="vital-bar-wrap">
                                    <div class="vital-bar health-bar" style="width:@BarPct(v.CurrentHealth, v.MaxHealth)%"></div>
                                </div>
                                <span class="vital-value">@v.CurrentHealth / @v.MaxHealth</span>
                            </div>
                            <div class="vital-row">
                                <span class="vital-label">🛡️ Willpower</span>
                                <div class="vital-bar-wrap">
                                    <div class="vital-bar willpower-bar" style="width:@BarPct(v.CurrentWillpower, v.MaxWillpower)%"></div>
                                </div>
                                <span class="vital-value">@v.CurrentWillpower / @v.MaxWillpower</span>
                            </div>
                            <div class="vital-row">
                                <span class="vital-label">🍷 Vitae</span>
                                <div class="vital-bar-wrap">
                                    <div class="vital-bar vitae-bar" style="width:@BarPct(v.CurrentVitae, v.MaxVitae)%"></div>
                                </div>
                                <span class="vital-value">@v.CurrentVitae / @v.MaxVitae</span>
                            </div>
                        </div>

                        <div class="glimpse-stats">
                            <span>🕊️ Humanity: @v.Humanity</span>
                            <span>⚫ Beats: @v.Beats</span>
                            <span>✨ XP: @v.ExperiencePoints</span>
                            @if (v.ActiveConditionCount > 0)
                            {
                                <span class="condition-badge">⚠️ @v.ActiveConditionCount Condition@(v.ActiveConditionCount > 1 ? "s" : "")</span>
                            }
                        </div>

                        @* Beat award *@
                        <div class="award-panel">
                            <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
                                <input class="form-control"
                                       style="flex:1;min-width:140px;font-size:0.85em;"
                                       placeholder="Beat reason…"
                                       @bind="_beatReasons[v.CharacterId]" />
                                <button class="btn-primary-rn"
                                        style="font-size:0.85em;"
                                        disabled="@(string.IsNullOrWhiteSpace(_beatReasons.GetValueOrDefault(v.CharacterId)) || _awarding)"
                                        @onclick="() => AwardBeat(v.CharacterId)">
                                    + Beat
                                </button>
                            </div>
                        </div>

                        @* XP award *@
                        <div class="award-panel" style="margin-top:0.5rem;">
                            <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
                                <input type="number"
                                       class="form-control"
                                       style="width:70px;font-size:0.85em;"
                                       min="1"
                                       @bind="_xpAmounts[v.CharacterId]" />
                                <input class="form-control"
                                       style="flex:1;min-width:140px;font-size:0.85em;"
                                       placeholder="XP reason…"
                                       @bind="_xpReasons[v.CharacterId]" />
                                <button class="btn-ghost"
                                        style="font-size:0.85em;"
                                        disabled="@(_xpAmounts.GetValueOrDefault(v.CharacterId) <= 0 || string.IsNullOrWhiteSpace(_xpReasons.GetValueOrDefault(v.CharacterId)) || _awarding)"
                                        @onclick="() => AwardXp(v.CharacterId)">
                                    + XP
                                </button>
                            </div>
                        </div>

                        @if (_feedbackMessages.TryGetValue(v.CharacterId, out string? msg) && !string.IsNullOrEmpty(msg))
                        {
                            <p class="feedback-ok" style="font-size:0.8em;margin-top:0.4rem;">@msg</p>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

