@page "/campaigns/{Id:int}/glimpse"
@rendermode InteractiveServer
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IStorytellerGlimpseService GlimpseService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ICoilService CoilService
@inject IAssetProcurementService AssetProcurementService
@inject ICampaignService CampaignService
@inject ISocialManeuverQueryService SocialManeuveringService
@inject IChronicleNpcService ChronicleNpcService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject RequiemNexus.Web.Services.ToastService ToastService
@inject IJSRuntime JSRuntime
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Web.Components.Pages.CharacterSheet
@using RequiemNexus.Web.Components.UI
@using Microsoft.JSInterop
@using System.Linq

<PageTitle>Storyteller Glimpse - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <p><em>Loading campaign vitals...</em></p>
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — only the campaign Storyteller may view this dashboard.
        </div>
    }
    else
    {
        <div class="campaign-header">
            <h2>Storyteller Glimpse</h2>
            <StorytellerChronicleNav CampaignId="Id" />
        </div>

        <div class="tab-bar glimpse-tab-bar" role="tablist" aria-label="Storyteller Glimpse sections">
            <button type="button"
                    class="tab-btn @(_glimpseTab == "overview" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "overview" ? "true" : "false")"
                    id="tab-glimpse-overview"
                    @onclick='() => SelectGlimpseTab("overview")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Overview
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "social" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "social" ? "true" : "false")"
                    id="tab-glimpse-social"
                    @onclick='() => SelectGlimpseTab("social")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Social
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "approvals" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "approvals" ? "true" : "false")"
                    id="tab-glimpse-approvals"
                    @onclick='() => SelectGlimpseTab("approvals")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Approvals
                @if (PendingApprovalCount > 0)
                {
                    <span class="glimpse-tab-badge" aria-label="@($"{PendingApprovalCount} pending approvals")">@PendingApprovalCount</span>
                }
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "chronicle" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "chronicle" ? "true" : "false")"
                    id="tab-glimpse-chronicle"
                    @onclick='() => SelectGlimpseTab("chronicle")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Chronicle
            </button>
        </div>

        @if (_glimpseTab == "overview")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-overview" role="tabpanel" aria-labelledby="tab-glimpse-overview">
                @if (_degAlerts.Count > 0)
                {
                    <div class="degeneration-glimpse-banners" role="region" aria-label="Pending degeneration checks">
                        @foreach (KeyValuePair<int, (string Name, int Humanity, int Resolve)> kv in _degAlerts.OrderBy(x => x.Value.Name))
                        {
                            <div class="degeneration-glimpse-banner card-rn alert-rn alert-warning"
                                 role="button"
                                 tabindex="0"
                                 @onclick="() => OpenDegenerationRollModal(kv.Key)"
                                 @onkeydown="e => HandleDegBannerKeydown(e, kv.Key)">
                                <strong>@kv.Value.Name</strong> must roll degeneration (@DegenerationPoolHint(kv.Value.Humanity, kv.Value.Resolve)). Open the roll confirmation (Storyteller cannot dismiss without rolling).
                            </div>
                        }
                    </div>
                }

                <div class="card-rn glimpse-card">
                    <h3 class="section-header">Passive Predatory Aura</h3>
                    <p class="text-small text-muted-rn mb-sm">
                        Manual Blood Potency contest between two PCs (chronicle-wide). Results appear in the session dice feed. When Kindred join the same encounter, passive contests also fire automatically once per pair.
                    </p>
                    <div class="form-row" style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:flex-end;">
                        <label class="text-small">
                            Kindred A
                            <select class="form-control form-select-medium" @bind="_passiveAuraCharacterA">
                                <option value="0">—</option>
                                @foreach (CharacterVitalsDto v in _vitals.Where(x => x.CreatureType == CreatureType.Vampire))
                                {
                                    <option value="@v.CharacterId">@v.Name</option>
                                }
                            </select>
                        </label>
                        <label class="text-small">
                            Kindred B
                            <select class="form-control form-select-medium" @bind="_passiveAuraCharacterB">
                                <option value="0">—</option>
                                @foreach (CharacterVitalsDto v in _vitals.Where(x => x.CreatureType == CreatureType.Vampire))
                                {
                                    <option value="@v.CharacterId">@v.Name</option>
                                }
                            </select>
                        </label>
                        <button type="button"
                                class="btn-rn-primary"
                                disabled="@(_passiveAuraBusy || _passiveAuraCharacterA == 0 || _passiveAuraCharacterB == 0 || _passiveAuraCharacterA == _passiveAuraCharacterB || string.IsNullOrEmpty(_currentUserId))"
                                @onclick="TriggerPassivePredatoryAuraAsync">
                            Trigger contest
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_passiveAuraMessage))
                    {
                        <p class="text-small mt-sm @(_passiveAuraError ? "feedback-error" : "feedback-ok")">@_passiveAuraMessage</p>
                    }
                </div>

                @* ── Coterie Beat Award ──────────────────────────────────────────────── *@
                <div class="card-rn glimpse-card">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <h3 class="section-header">Award Beat to Coterie</h3>
                        <div class="draggable-beat" draggable="true" @ondragstart="HandleDragStart" title="Drag this to a character card to award a Beat instantly">
                            ⚫
                        </div>
                    </div>
                    <div class="coterie-beat-award">
                        <input class="form-control coterie-reason-input"
                               placeholder="Reason for coterie Beat…"
                               aria-label="Reason for coterie-wide Beat award"
                               @bind="_coteReason" />
                        <button class="btn-rn-primary"
                                disabled="@(string.IsNullOrWhiteSpace(_coteReason) || _awarding)"
                                @onclick="AwardCoterieBeat">
                            Award to All
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_coteMessage))
                    {
                        <p class="feedback-ok">@_coteMessage</p>
                    }
                </div>

                @* ── Pinned NPCs ────────────────────────────────────────────────────── *@
                @if (_pinnedNpcIds.Any())
                {
                    <h3 class="section-header">Pinned NPCs</h3>
                    <div class="character-grid mb-lg">
                        @foreach (var npcId in _pinnedNpcIds)
                        {
                            var npc = _npcs.FirstOrDefault(n => n.Id == npcId);
                            if (npc != null)
                            {
                                <div class="card-rn glimpse-card active">
                                    <div class="glimpse-card-header">
                                        <h4>📌 @npc.Name</h4>
                                        <button class="btn-rn-ghost" style="font-size:0.8em;" @onclick="() => TogglePinNpc(npc.Id)">📍 Unpin</button>
                                    </div>

                                    @if (!string.IsNullOrEmpty(npc.Title))
                                    {
                                        <p class="text-small text-muted-rn mb-sm">@npc.Title</p>
                                    }

                                    <div class="glimpse-stats">
                                        <span>🎭 @npc.CreatureType</span>
                                        @if (npc.PrimaryFaction != null)
                                        {
                                            <span>⚔️ @npc.PrimaryFaction.Name</span>
                                        }
                                    </div>

                                    <p class="text-xsmall text-muted-rn">
                                        <em>NPC Vitals (Damage tracking deferred to Phase 11)</em>
                                    </p>
                                </div>
                            }
                        }
                    </div>
                }

                @* ── Character Cards ─────────────────────────────────────────────────── *@
                @if (!_vitals.Any())
                {
                    <div class="empty-state-rn">
                        <p>No characters have joined this campaign yet.</p>
                    </div>
                }
                else
                {
                    <div class="character-grid">
                        @foreach (CharacterVitalsDto v in _vitals)
                        {
                            <div class="card-rn glimpse-card drop-zone @(_activeDropTargetId == v.CharacterId ? "drop-zone-active" : "")"
                                 ondragover="event.preventDefault();"
                                 @ondragenter="() => HandleDragEnter(v.CharacterId)"
                                 @ondragleave="HandleDragLeave"
                                 @ondrop="() => HandleDrop(v.CharacterId)">
                                <div class="glimpse-card-header">
                                    <h4>@v.Name</h4>
                                    <div style="display:flex;flex-wrap:wrap;gap:0.35rem;align-items:center;">
                                        <a href="/campaigns/@Id/characters/@v.CharacterId" class="btn-rn-ghost" style="font-size:0.8em;">👁 View Sheet</a>
                                        <button type="button" class="btn-rn-ghost" style="font-size:0.8em;" @onclick="() => OpenLineageEditor(v.CharacterId)">Lineage</button>
                                    </div>
                                </div>

                                <div class="vitals-grid">
                                    <div class="vital-row">
                                        <span class="vital-label">❤️ Health</span>
                                        <div class="vital-bar-wrap">
                                            <div class="vital-bar health-bar" style="width:@BarPct(v.CurrentHealth, v.MaxHealth)%"></div>
                                        </div>
                                        <span class="vital-value">@v.CurrentHealth / @v.MaxHealth</span>
                                    </div>
                                    <div class="vital-row">
                                        <span class="vital-label">🛡️ Willpower</span>
                                        <div class="vital-bar-wrap">
                                            <div class="vital-bar willpower-bar" style="width:@BarPct(v.CurrentWillpower, v.MaxWillpower)%"></div>
                                        </div>
                                        <span class="vital-value">@v.CurrentWillpower / @v.MaxWillpower</span>
                                    </div>
                                    <div class="vital-row">
                                        <span class="vital-label">🍷 Vitae</span>
                                        <div class="vital-bar-wrap">
                                            <div class="vital-bar vitae-bar" style="width:@BarPct(v.CurrentVitae, v.MaxVitae)%"></div>
                                        </div>
                                        <span class="vital-value">@v.CurrentVitae / @v.MaxVitae</span>
                                    </div>
                                </div>

                                @if (v.MaxVitae > 0)
                                {
                                    <VitaeFastHealPanel CharacterId="v.CharacterId"
                                                        ActingUserId="@_currentUserId"
                                                        CurrentVitae="v.CurrentVitae"
                                                        MaxVitae="v.MaxVitae"
                                                        HealthDamage="@v.HealthDamage"
                                                        TrackLength="v.MaxHealth"
                                                        OnHealed="LoadVitals" />
                                }

                                <div class="glimpse-stats">
                                    <span>🕊️ Humanity: @v.Humanity</span>
                                    <span>🩸 Stains: @v.HumanityStains</span>
                                    <span>⚫ Beats: @v.Beats</span>
                                    <span>✨ XP: @v.ExperiencePoints</span>
                                    @if (v.ActiveConditionCount > 0)
                                    {
                                        <span class="condition-badge">⚠️ @v.ActiveConditionCount Condition@(v.ActiveConditionCount > 1 ? "s" : "")</span>
                                    }
                                </div>

                                <div class="glimpse-humanity-actions" style="display:flex;flex-wrap:wrap;gap:0.35rem;margin:0.5rem 0;">
                                    @if (v.HumanityStains >= v.Humanity)
                                    {
                                        <button type="button"
                                                class="btn-rn-danger"
                                                style="font-size:0.8em;"
                                                @onclick="() => OpenDegenerationRollModal(v.CharacterId)">
                                            Roll Degeneration
                                        </button>
                                    }
                                    else if (v.HumanityStains > 0 && v.HumanityStains < v.Humanity)
                                    {
                                        <button type="button"
                                                class="btn-rn-ghost"
                                                style="font-size:0.8em;border:1px solid var(--border-subtle);"
                                                title="@(v.Humanity <= 0 ? "Pool: chance die (1 die)" : $"Pool: {v.Humanity + (v.HasTouchstoneAnchor ? 1 : 0)} dice (Humanity{(v.HasTouchstoneAnchor ? " + Touchstone" : "")})")"
                                                @onclick="() => RollRemorseForCharacterAsync(v.CharacterId)">
                                            Roll Remorse
                                        </button>
                                    }
                                </div>

                                @* Beat award *@
                                <div class="award-panel">
                                    <div class="award-row">
                                        <input class="form-control award-input"
                                               placeholder="Beat reason…"
                                               aria-label="@($"Beat reason for {v.Name}")"
                                               @bind="_beatReasons[v.CharacterId]" />
                                        <button class="btn-rn-primary"
                                                style="font-size:0.85em;"
                                                disabled="@(string.IsNullOrWhiteSpace(_beatReasons.GetValueOrDefault(v.CharacterId)) || _awarding)"
                                                @onclick="() => AwardBeat(v.CharacterId)">
                                            + Beat
                                        </button>
                                    </div>
                                </div>

                                @* XP award *@
                                <div class="award-panel" style="margin-top:0.5rem;">
                                    <div class="award-row">
                                        <input type="number"
                                               class="form-control xp-amount-input"
                                               min="1"
                                               aria-label="@($"Experience points to award to {v.Name}")"
                                               @bind="_xpAmounts[v.CharacterId]" />
                                        <input class="form-control award-input"
                                               placeholder="XP reason…"
                                               aria-label="@($"Experience point reason for {v.Name}")"
                                               @bind="_xpReasons[v.CharacterId]" />
                                        <button class="btn-rn-ghost"
                                                style="font-size:0.85em;"
                                                disabled="@(_xpAmounts.GetValueOrDefault(v.CharacterId) <= 0 || string.IsNullOrWhiteSpace(_xpReasons.GetValueOrDefault(v.CharacterId)) || _awarding)"
                                                @onclick="() => AwardXp(v.CharacterId)">
                                            + XP
                                        </button>
                                    </div>
                                </div>

                                @if (_feedbackMessages.TryGetValue(v.CharacterId, out string? msg) && !string.IsNullOrEmpty(msg))
                                {
                                    <p class="feedback-ok feedback-small">@msg</p>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (_glimpseTab == "social")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-social" role="tabpanel" aria-labelledby="tab-glimpse-social">
                <GlimpseSocialManeuvers
                    CampaignId="Id"
                    StorytellerId="@_currentUserId"
                    Maneuvers="_socialManeuvers"
                    Vitals="_vitals"
                    Npcs="_npcs"
                    InitialClueThreshold="@_campaign.SocialManeuverInvestigationSuccessesPerClue"
                    PinnedNpcIds="_pinnedNpcIds"
                    OnChanged="LoadSocialManeuvers" />
            </div>
        }
        else if (_glimpseTab == "approvals")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-approvals" role="tabpanel" aria-labelledby="tab-glimpse-approvals">
                @if (PendingApprovalCount == 0)
                {
                    <div class="empty-state-rn">
                        <p>No pending player requests. Bloodline, covenant, rite, coil, chosen mystery, and illicit procurement approvals appear here.</p>
                    </div>
                }
                else
                {
                    <GlimpsePendingRequests
                        StorytellerId="@_currentUserId"
                        Bloodlines="_pendingBloodlines"
                        Covenants="_pendingCovenants"
                        Rites="_pendingRites"
                        ChosenMysteries="_pendingChosenMysteries"
                        Coils="_pendingCoils"
                        AssetProcurements="_pendingAssetProcurements"
                        OnChanged="LoadVitals" />
                }
            </div>
        }
        else if (_glimpseTab == "chronicle")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-chronicle" role="tabpanel" aria-labelledby="tab-glimpse-chronicle">
                <BloodBondsPanel CampaignId="Id"
                                 StorytellerUserId="@(_currentUserId ?? string.Empty)"
                                 Vitals="_vitals"
                                 Npcs="_npcs" />

                <PredatoryAuraHistoryPanel CampaignId="Id"
                                           StorytellerUserId="@(_currentUserId ?? string.Empty)" />

                <GhoulsTab CampaignId="Id"
                           StorytellerUserId="@(_currentUserId ?? string.Empty)"
                           Vitals="_vitals"
                           Npcs="_npcs" />
            </div>
        }
    }
</div>

<EditLineageModal @bind-IsOpen="_lineageModalOpen"
                  CampaignId="Id"
                  CharacterId="_lineageEditCharacterId"
                  StorytellerUserId="@(_currentUserId ?? string.Empty)"
                  OnSaved="OnLineageSavedAsync" />

<ConfirmModal IsOpen="_degRollModalOpen"
              Title="Confirm degeneration roll"
              Message="@(DegenerationModalMessage ?? string.Empty)"
              ConfirmLabel="Roll degeneration"
              OnConfirmClicked="ConfirmDegenerationRollAsync"
              OnCancelClicked="CloseDegenerationRollModal" />
