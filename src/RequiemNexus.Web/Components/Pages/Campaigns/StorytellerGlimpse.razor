@page "/campaigns/{Id:int}/glimpse"
@rendermode InteractiveServer
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IStorytellerGlimpseService GlimpseService
@inject IBloodlineService BloodlineService
@inject ICovenantService CovenantService
@inject ISorceryService SorceryService
@inject ICoilService CoilService
@inject IAssetProcurementService AssetProcurementService
@inject ICampaignService CampaignService
@inject ISocialManeuverQueryService SocialManeuveringService
@inject IChronicleNpcService ChronicleNpcService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject RequiemNexus.Web.Services.ToastService ToastService
@inject IJSRuntime JSRuntime
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Web.Components.UI
@using Microsoft.JSInterop
@using System.Linq
@using RequiemNexus.Web.Components.Pages.Campaigns.StorytellerGlimpseOverviewParts

<PageTitle>Storyteller Glimpse — Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <SkeletonLoader Variant="sheet" Count="4" />
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — only the campaign Storyteller may view this dashboard.
        </div>
    }
    else
    {
        <div class="campaign-header">
            <h2>Storyteller Glimpse</h2>
            <StorytellerChronicleNav CampaignId="Id" />
        </div>

        <div class="tab-bar glimpse-tab-bar" role="tablist" aria-label="Storyteller Glimpse sections">
            <button type="button"
                    class="tab-btn @(_glimpseTab == "overview" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "overview" ? "true" : "false")"
                    id="tab-glimpse-overview"
                    @onclick='() => SelectGlimpseTab("overview")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Overview
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "social" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "social" ? "true" : "false")"
                    id="tab-glimpse-social"
                    @onclick='() => SelectGlimpseTab("social")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Social
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "approvals" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "approvals" ? "true" : "false")"
                    id="tab-glimpse-approvals"
                    @onclick='() => SelectGlimpseTab("approvals")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Approvals
                @if (PendingApprovalCount > 0)
                {
                    <span class="glimpse-tab-badge" aria-label="@($"{PendingApprovalCount} pending approvals")">@PendingApprovalCount</span>
                }
            </button>
            <button type="button"
                    class="tab-btn @(_glimpseTab == "chronicle" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_glimpseTab == "chronicle" ? "true" : "false")"
                    id="tab-glimpse-chronicle"
                    @onclick='() => SelectGlimpseTab("chronicle")'
                    @onkeydown="HandleGlimpseTabKeydown">
                Chronicle
            </button>
        </div>

        @if (_glimpseTab == "overview")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-overview" role="tabpanel" aria-labelledby="tab-glimpse-overview">
                <StorytellerGlimpseOverview>
                <StorytellerGlimpseDegenerationBanners Alerts="_degAlerts" OnOpenRoll="OpenDegenerationRollModal" />

                <StorytellerGlimpsePassivePredatoryAuraCard Vampires="@(_vitals.Where(x => x.CreatureType == CreatureType.Vampire).ToList())"
                                                            CharacterA="_passiveAuraCharacterA"
                                                            CharacterAChanged="OnPassiveAuraCharacterAChangedAsync"
                                                            CharacterB="_passiveAuraCharacterB"
                                                            CharacterBChanged="OnPassiveAuraCharacterBChangedAsync"
                                                            CurrentUserId="@_currentUserId"
                                                            Busy="_passiveAuraBusy"
                                                            Message="@_passiveAuraMessage"
                                                            IsError="_passiveAuraError"
                                                            OnTriggerContest="TriggerPassivePredatoryAuraAsync" />

                <StorytellerGlimpseCoterieBeatAwardCard @bind-Reason="_coteReason"
                                                        Awarding="_awarding"
                                                        Message="@_coteMessage"
                                                        OnDragStart="HandleDragStart"
                                                        OnAward="AwardCoterieBeat" />

                <StorytellerGlimpsePinnedNpcsSection PinnedNpcIds="_pinnedNpcIds"
                                                     Npcs="_npcs"
                                                     OnTogglePin="TogglePinNpc" />

                <StorytellerGlimpseCharacterVitalsGrid CampaignId="Id"
                                                       CurrentUserId="@_currentUserId"
                                                       Vitals="_vitals"
                                                       ActiveDropTargetId="_activeDropTargetId"
                                                       Awarding="_awarding"
                                                       BeatReasons="_beatReasons"
                                                       XpReasons="_xpReasons"
                                                       XpAmounts="_xpAmounts"
                                                       FeedbackMessages="_feedbackMessages"
                                                       OnDragEnter="HandleDragEnter"
                                                       OnDragLeave="HandleDragLeave"
                                                       OnDrop="HandleDrop"
                                                       OnOpenLineage="OpenLineageEditor"
                                                       OnOpenDegenerationRoll="OpenDegenerationRollModal"
                                                       OnRollRemorse="RollRemorseForCharacterAsync"
                                                       OnAwardBeat="AwardBeat"
                                                       OnAwardXp="AwardXp"
                                                       OnHealed="LoadVitals" />
                </StorytellerGlimpseOverview>
            </div>
        }
        else if (_glimpseTab == "social")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-social" role="tabpanel" aria-labelledby="tab-glimpse-social">
                <GlimpseSocialManeuvers
                    CampaignId="Id"
                    StorytellerId="@_currentUserId"
                    Maneuvers="_socialManeuvers"
                    Vitals="_vitals"
                    Npcs="_npcs"
                    InitialClueThreshold="@_campaign.SocialManeuverInvestigationSuccessesPerClue"
                    PinnedNpcIds="_pinnedNpcIds"
                    OnChanged="LoadSocialManeuvers" />
            </div>
        }
        else if (_glimpseTab == "approvals")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-approvals" role="tabpanel" aria-labelledby="tab-glimpse-approvals">
                @if (PendingApprovalCount == 0)
                {
                    <div class="empty-state-rn">
                        <p>No pending player requests. Bloodline, covenant, rite, coil, chosen mystery, and illicit procurement approvals appear here.</p>
                    </div>
                }
                else
                {
                    <GlimpsePendingRequests
                        StorytellerId="@_currentUserId"
                        Bloodlines="_pendingBloodlines"
                        Covenants="_pendingCovenants"
                        Rites="_pendingRites"
                        ChosenMysteries="_pendingChosenMysteries"
                        Coils="_pendingCoils"
                        AssetProcurements="_pendingAssetProcurements"
                        OnChanged="LoadVitals" />
                }
            </div>
        }
        else if (_glimpseTab == "chronicle")
        {
            <div class="glimpse-tab-panel" id="panel-glimpse-chronicle" role="tabpanel" aria-labelledby="tab-glimpse-chronicle">
                <BloodBondsPanel CampaignId="Id"
                                 StorytellerUserId="@(_currentUserId ?? string.Empty)"
                                 Vitals="_vitals"
                                 Npcs="_npcs" />

                <PredatoryAuraHistoryPanel CampaignId="Id"
                                           StorytellerUserId="@(_currentUserId ?? string.Empty)" />

                <GhoulsTab CampaignId="Id"
                           StorytellerUserId="@(_currentUserId ?? string.Empty)"
                           Vitals="_vitals"
                           Npcs="_npcs" />
            </div>
        }
    }
</div>

<EditLineageModal @bind-IsOpen="_lineageModalOpen"
                  CampaignId="Id"
                  CharacterId="_lineageEditCharacterId"
                  StorytellerUserId="@(_currentUserId ?? string.Empty)"
                  OnSaved="OnLineageSavedAsync" />

<ConfirmModal IsOpen="_degRollModalOpen"
              Title="Confirm degeneration roll"
              Message="@(DegenerationModalMessage ?? string.Empty)"
              ConfirmLabel="Roll degeneration"
              OnConfirmClicked="ConfirmDegenerationRollAsync"
              OnCancelClicked="CloseDegenerationRollModal" />
