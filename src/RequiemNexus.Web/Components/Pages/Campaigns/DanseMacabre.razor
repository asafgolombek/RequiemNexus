@page "/campaigns/{CampaignId:int}/danse-macabre"
@rendermode InteractiveServer
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Web.Components.Pages.Campaigns.DanseMacabreTabs
@inject ICityFactionService FactionService
@inject IChronicleNpcService NpcService
@inject IFeedingTerritoryService TerritoryService
@inject ICampaignService CampaignService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Danse Macabre - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <p>Access denied. Only the Storyteller may view the Danse Macabre.</p>
            <a href="/campaigns/@CampaignId" class="btn-rn-ghost">Back to Campaign</a>
        </div>
    }
    else if (_loading)
    {
        <SkeletonLoader Variant="rows" Count="8" />
    }
    else
    {
        <div class="campaign-header">
            <h2>🌹 Danse Macabre</h2>
            <StorytellerChronicleNav CampaignId="CampaignId" />
        </div>

        <div class="tabs" style="margin-bottom:1.5rem;">
            <button class="@TabClass(0)" @onclick="() => _activeTab = 0">🏛 Territories</button>
            <button class="@TabClass(1)" @onclick="() => _activeTab = 1">👑 Power Structure</button>
            <button class="@TabClass(2)" @onclick="() => _activeTab = 2">🧛 NPCs</button>
        </div>

        @if (_activeTab == 0)
        {
            <DanseTerritoriesTab CampaignId="CampaignId"
                                 Territories="_territories"
                                 FeedbackMessage="_feedbackMessage"
                                 Busy="_busy"
                                 OnOpenCreateModal="OpenTerritoryModal"
                                 OnDeleteTerritory="DeleteTerritory" />
        }

        @if (_activeTab == 1)
        {
            <DansePowerStructureTab CampaignId="CampaignId"
                                    Factions="_factions"
                                    FeedbackMessage="_feedbackMessage"
                                    OnOpenCreateModal="OpenFactionModal" />
        }

        @if (_activeTab == 2)
        {
            <DanseNpcsTab CampaignId="CampaignId"
                          Npcs="_npcs"
                          ShowDeceased="_showDeceased"
                          FeedbackMessage="_feedbackMessage"
                          Busy="_busy"
                          OnOpenCreateModal="OpenNpcModal"
                          OnDeleteNpc="DeleteNpc"
                          ShowDeceasedChanged="OnShowDeceasedChangedAsync" />
        }

        <CreateFeedingTerritoryModal @bind-IsOpen="_territoryModalOpen"
                                     CampaignId="CampaignId"
                                     StorytellerUserId="@(_currentUserId ?? string.Empty)"
                                     OnCreated="OnTerritoryCreatedAsync" />
        <CreateCityFactionModal @bind-IsOpen="_factionModalOpen"
                                CampaignId="CampaignId"
                                StorytellerUserId="@(_currentUserId ?? string.Empty)"
                                OnCreated="OnFactionCreatedAsync" />
        <CreateChronicleNpcModal @bind-IsOpen="_npcModalOpen"
                                 CampaignId="CampaignId"
                                 StorytellerUserId="@(_currentUserId ?? string.Empty)"
                                 OnCreated="OnNpcCreatedAsync" />
    }
</div>
