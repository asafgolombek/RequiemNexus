@page "/campaigns/{CampaignId:int}/factions/{FactionId:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using RequiemNexus.Web.Components.Pages.Campaigns.FactionDetailParts
@inject ICityFactionService FactionService
@inject IChronicleNpcService NpcService
@inject IFactionRelationshipService RelationshipService
@inject ICampaignService CampaignService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>@(_faction?.Name is { } factionName ? $"{factionName} — Faction" : "Faction") — Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <p>Access denied. Only the Storyteller may edit factions.</p>
            <a href="/campaigns/@CampaignId/danse-macabre" class="btn-rn-ghost">Back</a>
        </div>
    }
    else if (_faction == null)
    {
        <SkeletonLoader Variant="card" Count="3" />
    }
    else
    {
        <FactionDetailPageHeader CampaignId="CampaignId" Faction="_faction" />

        @if (!string.IsNullOrEmpty(_feedbackMessage))
        {
            <p class="feedback-ok">@_feedbackMessage</p>
        }

        <div class="card-rn" style="margin-bottom:1.5rem;">
            <h3>Edit Faction</h3>
            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="_editName" />
            </div>
            <div class="form-group">
                <label>Type</label>
                <select class="form-control" @bind="_editType">
                    @foreach (FactionType ft in Enum.GetValues<FactionType>())
                    {
                        <option value="@ft">@ft</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Influence Rating (1–5)</label>
                <input class="form-control" type="number" min="1" max="5" @bind="_editInfluence" />
            </div>
            <div class="form-group">
                <label>Agenda</label>
                <textarea class="form-control" rows="2" @bind="_editAgenda"></textarea>
            </div>
            <div class="form-group">
                <label>Public Description</label>
                <textarea class="form-control" rows="3" @bind="_editPublicDesc"></textarea>
            </div>
            <div class="form-group">
                <label>Storyteller Notes (ST-only)</label>
                <textarea class="form-control" rows="3" @bind="_editStNotes"></textarea>
            </div>
            <div class="form-group">
                <label>Leader NPC</label>
                <select class="form-control" @bind="_editLeaderNpcId">
                    <option value="0">— No leader —</option>
                    @foreach (ChronicleNpc npc in _allNpcs)
                    {
                        <option value="@npc.Id">@npc.Name</option>
                    }
                </select>
                @if (_editLeaderNpcId > 0)
                {
                    <a href="/campaigns/@CampaignId/npcs/@_editLeaderNpcId" class="btn-rn-ghost" style="font-size:0.8em;margin-top:0.25rem;display:inline-block;">
                        👤 View Leader NPC
                    </a>
                }
            </div>
            <button type="button" class="btn-rn-primary" disabled="@_busy" @onclick="SaveFaction">Save Changes</button>
        </div>

        <FactionDetailMembersCard CampaignId="CampaignId" Faction="_faction" />

        <FactionDetailTerritoriesCard Faction="_faction" />

        <FactionDetailRelationsCard CampaignId="CampaignId"
                                    FactionId="FactionId"
                                    Relationships="_relationships"
                                    OtherFactions="_otherFactions"
                                    @bind-RelOtherFactionId="_relOtherFactionId"
                                    @bind-RelStance="_relStance"
                                    @bind-RelNotes="_relNotes"
                                    Busy="_busy"
                                    OnSaveRelationship="SaveRelationship" />

        <FactionDetailDangerZone FactionName="_faction.Name"
                                   @bind-ShowConfirmDelete="_showConfirmDelete"
                                   Busy="_busy"
                                   OnConfirmDelete="ConfirmDelete" />
    }
</div>
