@using RequiemNexus.Data.Models

<div class="card-rn">
    <h4>@Encounter.Name</h4>
    <p style="font-size:0.85em;color:var(--gothic-muted);">
        Round @Encounter.CurrentRound · Paused — resume to continue combat
    </p>
    <div class="card-actions" style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.5rem;">
        <button type="button" class="btn-rn-primary" style="font-size:0.85em;" disabled="@Busy" @onclick="ResumeClickAsync">▶ Resume</button>
        <a href="/campaigns/@CampaignId/encounter/@Encounter.Id" class="btn-rn-ghost" style="font-size:0.85em;">👁️ View tracker</a>
        <button type="button" class="btn-rn-ghost" style="font-size:0.85em;" disabled="@Busy" @onclick="ResolveClickAsync">✓ Resolve</button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CombatEncounter Encounter { get; set; } = null!;

    [Parameter, EditorRequired]
    public int CampaignId { get; set; }

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public EventCallback<int> OnResume { get; set; }

    [Parameter]
    public EventCallback<int> OnResolve { get; set; }

    private Task ResumeClickAsync() => OnResume.InvokeAsync(Encounter.Id);

    private Task ResolveClickAsync() => OnResolve.InvokeAsync(Encounter.Id);
}
