@using RequiemNexus.Data.Models

<div class="card-rn" style="margin-top:0.75rem;padding:0.75rem;border:1px solid var(--gothic-border, rgba(255,255,255,0.12));">
    <h4 style="margin:0 0 0.35rem 0;font-size:1rem;">@Title</h4>
    <p style="font-size:0.9em;margin:0 0 0.5rem 0;">@LeadText</p>
    <p style="font-size:0.85em;color:var(--gothic-muted);">Checked characters must be online in the session and not already in this encounter.</p>
    @if (CampaignCharacters.Count == 0)
    {
        <p style="font-size:0.85em;color:var(--gothic-muted);">No characters in this campaign — only NPC lines will be in initiative.</p>
    }
    @foreach (Character ch in CampaignCharacters)
    {
        <label style="display:flex;align-items:center;gap:0.5rem;margin:0.35rem 0;">
            <input type="checkbox"
                   checked="@IsSelected(ch.Id)"
                   @onchange="e => OnCheckboxAsync(ch.Id, e)" />
            <span>@ch.Name</span>
        </label>
    }
    <div style="display:flex;gap:0.75rem;margin-top:0.75rem;flex-wrap:wrap;">
        <button type="button" class="btn-rn-primary" disabled="@Busy" @onclick="ConfirmClickAsync">@ConfirmButtonText</button>
        <button type="button" class="btn-rn-ghost" @onclick="CancelClickAsync">Cancel</button>
    </div>
</div>

@code {
    /// <summary>Panel heading (e.g. ready to begin vs add PCs).</summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>Explains prep-start vs join-active behavior.</summary>
    [Parameter]
    public string LeadText { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<Character> CampaignCharacters { get; set; } = [];

    /// <summary>Returns whether <paramref name="characterId"/> is included in the smart launch selection.</summary>
    [Parameter]
    public Func<int, bool> IsSelected { get; set; } = static _ => true;

    [Parameter]
    public EventCallback<(int CharacterId, bool Selected)> SelectionChanged { get; set; }

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public string ConfirmButtonText { get; set; } = "Confirm";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private Task OnCheckboxAsync(int characterId, ChangeEventArgs e)
    {
        bool v = e.Value is bool b && b;
        return SelectionChanged.InvokeAsync((characterId, v));
    }

    private Task ConfirmClickAsync() => OnConfirm.InvokeAsync();

    private Task CancelClickAsync() => OnCancel.InvokeAsync();
}
