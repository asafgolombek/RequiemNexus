@page "/campaigns/{Id:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.Campaigns.CampaignDetailsParts
@using RequiemNexus.Web.Services
@using System.Security.Claims
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject ICampaignService CampaignService
@inject IJSRuntime JSRuntime
@inject IPerceptionRollService PerceptionRollService
@inject ICharacterReader CharacterReader
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject ToastService ToastService
@implements IDisposable

<PageTitle>@(_campaign == null || !_campaignLoadComplete ? "Campaign — Requiem Nexus" : $"{_campaign.Name} — Requiem Nexus")</PageTitle>

<div class="page-container fade-in">
    @if (!_campaignLoadComplete)
    {
        <SkeletonLoader Variant="card" Count="3" />
    }
    else if (string.IsNullOrEmpty(_currentUserId))
    {
        <p><em>Sign in to view this campaign.</em></p>
    }
    else if (_campaign == null)
    {
        <div class="alert-rn alert-danger">
            This campaign does not exist, or your account is not part of it. You must be the Storyteller or own a character in the saga (same rules as joining a live session). Ask your Storyteller for an invite link to join with your first character.
        </div>
    }
    else
    {
        <CampaignSessionHeader Campaign="_campaign"
                               IsStoryteller="CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)"
                               SessionActive="_sessionActive"
                               SessionClientConnected="SessionClient.IsConnected"
                               SessionHubMessage="_sessionHubMessage"
                               InviteModalOpen="_inviteModalOpen"
                               InviteBusy="_inviteBusy"
                               LastGeneratedJoinUrl="_lastGeneratedJoinUrl"
                               DiscordWebhookModalOpen="_discordWebhookModalOpen"
                               DiscordWebhookBusy="_discordWebhookBusy"
                               OnStartSession="StartSession"
                               OnEndSession="EndSession"
                               OnJoinSession="JoinSession"
                               OnLeaveSession="LeaveSession"
                               OnOpenInviteModal="OpenInviteModal"
                               OnCloseInviteModal="CloseInviteModal"
                               OnRegenerateInvite="RegenerateJoinInvite"
                               OnClearInvite="ClearJoinInvite"
                               OnCopyJoinUrl="CopyJoinUrl"
                               OnOpenDiscordWebhookModal="OpenDiscordWebhookModal"
                               OnCloseDiscordWebhookModal="CloseDiscordWebhookModal"
                               OnSaveDiscordWebhook="SaveDiscordWebhookAsync" />

        <CampaignRosterTabBar ActiveTab="_rosterTab"
                              IsStoryteller="CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)"
                              ActiveTabChanged="OnRosterTabChangedAsync"
                              OnTabKeydown="HandleRosterTabKeydownAsync" />

        <div style="display: grid; grid-template-columns: 1fr 300px; gap: 2rem;">
            <div class="main-content-area">
                @if (_rosterTab == "players")
                {
                    <CampaignPlayersSection Campaign="_campaign"
                                            CurrentUserId="_currentUserId"
                                            IsStoryteller="CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)"
                                            ShowAddCharacter="_showAddCharacter"
                                            AddModel="_addModel"
                                            AvailableCharacters="_availableCharacters"
                                            PerceptionOpenId="_perceptionOpenId"
                                            PerceptionBusy="_perceptionBusy"
                                            PerceptionResults="_perceptionResults"
                                            PerceptionUseAwareness="PerceptionUseAwareness"
                                            PerceptionUseAwarenessChanged="OnPerceptionUseAwarenessChanged"
                                            PerceptionPenalty="PerceptionPenalty"
                                            PerceptionPenaltyChanged="OnPerceptionPenaltyChanged"
                                            ConfirmRemoveCharacterId="_confirmRemoveCharacterId"
                                            OnToggleAddCharacter="ToggleAddCharacter"
                                            OnAddCharacterSubmit="AddCharacterSubmit"
                                            OnNavigateToCharacter="OnNavigateToCharacterAsync"
                                            OnTogglePerception="OnTogglePerceptionAsync"
                                            OnRollPerception="RollPerception"
                                            OnAskRemoveCharacter="OnAskRemoveCharacterAsync"
                                            OnConfirmRemoveCharacter="ConfirmRemoveCharacter"
                                            OnCancelConfirm="CancelConfirmAsync" />
                }

                @if (_rosterTab == "lore")
                {
                    <CampaignLoreSection Entries="_loreEntries"
                                         CurrentUserId="_currentUserId"
                                         IsStoryteller="CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)"
                                         ShowAddForm="_showAddLoreForm"
                                         NewTitle="_newLoreTitle"
                                         NewBody="_newLoreBody"
                                         OnOpenAddForm="OpenLoreAddFormAsync"
                                         NewTitleChanged="SetNewLoreTitleAsync"
                                         NewBodyChanged="SetNewLoreBodyAsync"
                                         OnSave="CreateLore"
                                         OnDiscard="DiscardAddLore"
                                         OnDelete="DeleteLore" />
                }

                @if (_rosterTab == "prep" && CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                {
                    <CampaignSessionPrepSection Entries="_sessionPrepNotes"
                                                ShowAddForm="_showAddPrepForm"
                                                NewTitle="_newPrepTitle"
                                                NewBody="_newPrepBody"
                                                OnOpenAddForm="OpenPrepAddFormAsync"
                                                NewTitleChanged="SetNewPrepTitleAsync"
                                                NewBodyChanged="SetNewPrepBodyAsync"
                                                OnSave="CreateSessionPrepNote"
                                                OnDiscard="DiscardAddPrep"
                                                OnDelete="DeleteSessionPrepNote" />
                }
            </div>

            <div class="realtime-sidebar">
                <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem; color: var(--brand-crimson);">🩸 Blood Logs</h3>
                <RollHistoryFeed />
            </div>
        </div>

        @if (_rosterTab == "players")
        {
            <CampaignDangerZoneSection Campaign="_campaign"
                                       CurrentUserId="_currentUserId"
                                       IsStoryteller="CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)"
                                       ShowConfirmLeave="_showConfirmLeave"
                                       ShowConfirmDelete="_showConfirmDelete"
                                       Busy="_busy"
                                       OnRequestLeave="RequestLeaveCampaignAsync"
                                       OnConfirmLeave="ConfirmLeaveCampaign"
                                       OnRequestDelete="RequestDeleteCampaignAsync"
                                       OnConfirmDelete="ConfirmDeleteCampaign"
                                       OnCancelConfirm="CancelConfirmAsync" />
        }
    }
</div>
