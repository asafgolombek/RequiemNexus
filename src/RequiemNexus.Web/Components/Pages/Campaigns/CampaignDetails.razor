@page "/campaigns/{Id:int}"
@rendermode InteractiveServer
@using RequiemNexus.Data.Models
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Services
@using System.Security.Claims
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject ICampaignService CampaignService
@inject IJSRuntime JSRuntime
@inject IPerceptionRollService PerceptionRollService
@inject ICharacterService CharacterService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@implements IDisposable

<PageTitle>Campaign Details - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (!_campaignLoadComplete)
    {
        <SkeletonLoader Variant="card" Count="3" />
    }
    else if (string.IsNullOrEmpty(_currentUserId))
    {
        <p><em>Sign in to view this campaign.</em></p>
    }
    else if (_campaign == null)
    {
        <div class="alert-rn alert-danger">
            This campaign does not exist, or your account is not part of it. You must be the Storyteller or own a character in the saga (same rules as joining a live session). Ask your Storyteller for an invite link to join with your first character.
        </div>
    }
    else
    {
        <div class="campaign-header">
            <div style="display:flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                <div>
                    <h2>@_campaign.Name</h2>
                    <div class="storyteller-badge">
                        <span>👑 Story Teller:</span> @(_campaign.StoryTeller?.UserName ?? _campaign.StoryTeller?.Email ?? "Unknown")
                    </div>
                </div>
                <div style="display: flex; gap: 0.5rem; flex-direction: column; align-items: flex-end;">
                    @if (CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                    {
                        @if (!_sessionActive)
                        {
                            <button class="btn-rn-primary" @onclick="StartSession">🔴 Start Live Session</button>
                        }
                        else
                        {
                            <button class="btn-rn-danger" @onclick="EndSession">🛑 End Session</button>
                        }
                    }
                    else if (_sessionActive)
                    {
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <span class="badge-live">🔴 LIVE SESSION ACTIVE</span>
                            @if (!CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                            {
                                @if (!SessionClient.IsConnected)
                                {
                                    <button class="btn-rn-primary" style="font-size: 0.8rem; padding: 0.25rem 0.75rem;" @onclick="JoinSession">Join Session</button>
                                }
                                else
                                {
                                    <span style="font-size: 0.8rem; color: var(--text-muted); border: 1px solid var(--border-subtle); padding: 0.25rem 0.75rem; border-radius: 4px;">Status: Presence Active</span>
                                    <button class="btn-rn-ghost" style="font-size: 0.8rem; padding: 0.25rem 0.75rem; border: 1px solid var(--brand-crimson); margin-left: 0.5rem;" @onclick="LeaveSession">Leave Session</button>
                                }
                            }
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_sessionHubMessage))
            {
                <div class="alert-rn alert-warning" style="margin-top:0.75rem;font-size:0.9rem;" role="status">
                    @_sessionHubMessage
                </div>
            }
            
            <SessionPresenceBar SessionActive="_sessionActive" />

            @if (CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
            {
                <StorytellerChronicleNav CampaignId="_campaign.Id" />
                <div class="flex-row flex-wrap items-center gap-sm" style="margin-top: 0.5rem;">
                    <button type="button" class="btn-rn-ghost" @onclick="() => _inviteModalOpen = true">Player invite</button>
                    @if (!string.IsNullOrEmpty(_campaign.InviteTokenHash))
                    {
                        <span class="badge-live" style="font-size:0.75rem;">Invite on</span>
                    }
                </div>
                <PlayerInviteModal IsOpen="_inviteModalOpen"
                                   InviteActive="@(!string.IsNullOrEmpty(_campaign.InviteTokenHash))"
                                   InviteError="@_inviteError"
                                   LastGeneratedJoinUrl="@_lastGeneratedJoinUrl"
                                   Busy="_inviteBusy"
                                   OnClose="CloseInviteModal"
                                   OnRegenerate="RegenerateJoinInvite"
                                   OnClear="ClearJoinInvite"
                                   OnCopy="CopyJoinUrl" />
            }
        </div>

        <div class="tab-bar campaign-roster-tab-bar" role="tablist" aria-label="Campaign roster sections">
            <button type="button" class="tab-btn @RosterTabClass("players")" role="tab" aria-selected="@(_rosterTab == "players")" id="roster-tab-players" @onclick='() => SelectRosterTab("players")' @onkeydown="HandleRosterTabKeydown">Players</button>
            <button type="button" class="tab-btn @RosterTabClass("lore")" role="tab" aria-selected="@(_rosterTab == "lore")" id="roster-tab-lore" @onclick='() => SelectRosterTab("lore")' @onkeydown="HandleRosterTabKeydown">Lore</button>
            @if (CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
            {
                <button type="button" class="tab-btn @RosterTabClass("prep")" role="tab" aria-selected="@(_rosterTab == "prep")" id="roster-tab-prep" @onclick='() => SelectRosterTab("prep")' @onkeydown="HandleRosterTabKeydown">Session prep</button>
            }
        </div>

        <div style="display: grid; grid-template-columns: 1fr 300px; gap: 2rem;">
            <div class="main-content-area">
                @if (_rosterTab == "players")
                {
                <div class="characters-section">
                    <div class="section-header">
                        <h3>Players in this Campaign</h3>
                        @if (!CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                        {
                            <button class="btn-rn-primary" @onclick="ToggleAddCharacter">Add Character</button>
                        }
                    </div>

                    @if (_showAddCharacter && !CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                    {
                        <div class="add-character-panel">
                            <h4>Add Character to Campaign</h4>
                            <EditForm Model="_addModel" OnValidSubmit="AddCharacterSubmit">
                                <div class="add-character-row">
                                    <div class="add-character-select">
                                        <InputSelect @bind-Value="_addModel.CharacterId" class="form-control">
                                            <option value="0">-- Select an available character --</option>
                                            @foreach (var c in _availableCharacters)
                                            {
                                                <option value="@c.Id">@c.Name (@c.User?.Email)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="add-character-actions">
                                        <button type="submit" class="btn-rn-primary" disabled="@(_addModel.CharacterId == 0)">Add</button>
                                        <button type="button" class="btn-rn-ghost" @onclick="ToggleAddCharacter">Cancel</button>
                                    </div>
                                </div>
                            </EditForm>
                        </div>
                    }

                    @if (!_campaign.Characters.Any())
                    {
                        <div class="empty-state-rn">
                            <p>No characters have joined this saga yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="character-grid">
                            @foreach (var character in _campaign.Characters)
                            {
                                bool isOwn = character.ApplicationUserId == _currentUserId;
                                <div class="character-card card-rn clickable-card" @onclick="() => NavigateToCharacter(character.Id, isOwn)">
                                    <h4 class="char-name">@character.Name</h4>
                                    <div class="char-clan">🦇 Clan: @(character.Clan?.Name ?? "Unknown")</div>
                                    <div class="player-info">
                                        <span>👤 Player:</span> @(character.User?.UserName ?? character.User?.Email ?? "Unknown")
                                    </div>
                                    <div class="stats">
                                        <span>❤️ HP: @character.CurrentHealth / @character.MaxHealth</span>
                                        <span>🛡️ WP: @character.CurrentWillpower / @character.MaxWillpower</span>
                                        <span>🩸 BP: @character.BloodPotency</span>
                                        <span>🍷 Vitae: @character.CurrentVitae / @character.MaxVitae</span>
                                    </div>
                                    @if (CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                                    {
                                        <div @onclick:stopPropagation="true" style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border-subtle);">
                                            <button type="button" class="btn-rn-ghost" style="font-size:0.75em;" @onclick="() => TogglePerception(character.Id)">👁️ Hidden perception</button>
                                            @if (_perceptionOpenId == character.Id)
                                            {
                                                <div style="margin-top:0.35rem;display:flex;flex-direction:column;gap:0.35rem;max-width:280px;">
                                                    <label style="font-size:0.8em;display:flex;align-items:center;gap:0.35rem;">
                                                        <input type="checkbox" @bind="PerceptionUseAwareness" /> Wits + Awareness (else Composure)
                                                    </label>
                                                    <label style="font-size:0.8em;">Penalty dice
                                                        <input type="number" class="form-control" style="width:80px;display:inline-block;" @bind="PerceptionPenalty" min="0" max="20" />
                                                    </label>
                                                    <button type="button" class="btn-rn-primary" style="font-size:0.8em;align-self:flex-start;" disabled="@_perceptionBusy" @onclick="() => RollPerception(character.Id)">Roll</button>
                                                    @if (_perceptionBusy)
                                                    {
                                                        <span style="font-size:0.75em;color:var(--gothic-muted);">Rolling…</span>
                                                    }
                                                    @if (_perceptionResults.TryGetValue(character.Id, out string? pr))
                                                    {
                                                        <p style="font-size:0.8em;margin:0;color:var(--gothic-muted);white-space:pre-wrap;">@pr</p>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    <div class="card-actions" style="margin-top:10px;">
                                        @if (isOwn)
                                        {
                                            @if (_confirmRemoveCharacterId == character.Id)
                                            {
                                                <span style="font-size:0.8em;" @onclick:stopPropagation="true">Remove from campaign?
                                                    <button class="btn-rn-primary" style="font-size:0.8em;" @onclick="() => ConfirmRemoveCharacter(character.Id)">Yes</button>
                                                    <button class="btn-rn-ghost" style="font-size:0.8em;" @onclick="CancelConfirm">No</button>
                                                </span>
                                            }
                                            else
                                            {
                                                <button class="btn-rn-ghost" style="font-size:0.8em;" @onclick="() => AskRemoveCharacter(character.Id)" @onclick:stopPropagation="true">Remove from Campaign</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                }

                @if (_rosterTab == "lore")
                {
                <div class="card-rn" style="margin-top:0;">
                    @if (!_showAddLoreForm)
                    {
                        <div class="flex-row flex-wrap items-center gap-sm" style="margin-bottom:0.75rem; justify-content:flex-end;">
                            <button type="button" class="btn-rn-primary" @onclick="() => _showAddLoreForm = true">Add lore entry</button>
                        </div>
                    }
                    @if (_showAddLoreForm)
                    {
                        <div class="card-rn" style="margin-bottom:1rem;">
                            <div style="display:flex;flex-direction:column;gap:0.5rem;">
                                <label class="font-sm" for="new-lore-title">Title</label>
                                <input id="new-lore-title" class="form-control" @bind="_newLoreTitle" placeholder="Title" autocomplete="off" />
                                <label class="font-sm" for="new-lore-body">Body</label>
                                <textarea id="new-lore-body" class="form-control" rows="4" @bind="_newLoreBody" placeholder="Body"></textarea>
                                <div class="flex-row flex-wrap gap-sm" style="margin-top:0.25rem;">
                                    <button type="button" class="btn-rn-primary" disabled="@(string.IsNullOrWhiteSpace(_newLoreTitle))" @onclick="CreateLore">Save</button>
                                    <button type="button" class="btn-rn-ghost" @onclick="DiscardAddLore">Discard</button>
                                </div>
                            </div>
                        </div>
                    }
                    @if (_loreEntries.Count == 0)
                    {
                        <p style="color:var(--gothic-muted);font-size:0.9em;">No lore entries yet.</p>
                    }
                    else
                    {
                        @foreach (CampaignLore lore in _loreEntries)
                        {
                            <div class="card-rn" style="margin-bottom:0.75rem;">
                                <strong>@lore.Title</strong>
                                <p style="margin:0.25rem 0 0;font-size:0.9em;white-space:pre-wrap;">@lore.Body</p>
                                @if (lore.AuthorUserId == _currentUserId || CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                                {
                                    <button class="btn-rn-danger" style="font-size:0.75em;margin-top:0.35rem;" @onclick="() => DeleteLore(lore.Id)">Remove</button>
                                }
                            </div>
                        }
                    }
                </div>
                }

                @if (_rosterTab == "prep" && CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
                {
                <div class="card-rn" style="margin-top:0;">
                    @if (!_showAddPrepForm)
                    {
                        <div class="flex-row flex-wrap items-center gap-sm" style="margin-bottom:0.75rem; justify-content:flex-end;">
                            <button type="button" class="btn-rn-primary" @onclick="() => _showAddPrepForm = true">Add prep note</button>
                        </div>
                    }
                    @if (_showAddPrepForm)
                    {
                        <div class="card-rn" style="margin-bottom:1rem;">
                            <div style="display:flex;flex-direction:column;gap:0.5rem;">
                                <label class="font-sm" for="new-prep-title">Title</label>
                                <input id="new-prep-title" class="form-control" @bind="_newPrepTitle" placeholder="Title" autocomplete="off" />
                                <label class="font-sm" for="new-prep-body">Body</label>
                                <textarea id="new-prep-body" class="form-control" rows="4" @bind="_newPrepBody" placeholder="Body"></textarea>
                                <div class="flex-row flex-wrap gap-sm" style="margin-top:0.25rem;">
                                    <button type="button" class="btn-rn-primary" disabled="@(string.IsNullOrWhiteSpace(_newPrepTitle))" @onclick="CreateSessionPrepNote">Save</button>
                                    <button type="button" class="btn-rn-ghost" @onclick="DiscardAddPrep">Discard</button>
                                </div>
                            </div>
                        </div>
                    }
                    @if (_sessionPrepNotes.Count == 0)
                    {
                        <p style="color:var(--gothic-muted);font-size:0.9em;">No prep notes yet.</p>
                    }
                    else
                    {
                        @foreach (SessionPrepNote prepNote in _sessionPrepNotes)
                        {
                            <div class="card-rn" style="margin-bottom:0.75rem;border-left:3px solid var(--blood-red);">
                                <strong>@prepNote.Title</strong>
                                <p style="margin:0.25rem 0 0;font-size:0.9em;white-space:pre-wrap;">@prepNote.Body</p>
                                <button class="btn-rn-danger" style="font-size:0.75em;margin-top:0.35rem;" @onclick="() => DeleteSessionPrepNote(prepNote.Id)">Remove</button>
                            </div>
                        }
                    }
                </div>
                }
            </div>

            <div class="realtime-sidebar">
                <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem; color: var(--brand-crimson);">🩸 Blood Logs</h3>
                <RollHistoryFeed />
            </div>
        </div>

        @* --- Danger Zone (Players tab only) --- *@
        @if (_rosterTab == "players")
        {
        <div class="danger-zone" style="margin-top:2rem;">
            @if (!CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty)
                 && _campaign.Characters.Any(c => c.ApplicationUserId == _currentUserId))
            {
                @if (_showConfirmLeave)
                {
                    <div class="confirm-card card-rn">
                        <p>Leave this campaign? Your character will return to your unassigned pool.</p>
                        <button class="btn-rn-primary" disabled="@_busy" @onclick="ConfirmLeaveCampaign">Yes, Leave</button>
                        <button class="btn-rn-ghost" @onclick="CancelConfirm">Cancel</button>
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <p class="feedback-error">@_errorMessage</p>
                        }
                    </div>
                }
                else
                {
                    <button class="btn-rn-ghost" @onclick="() => _showConfirmLeave = true">Leave Campaign</button>
                }
            }

            @if (CampaignService.IsStoryteller(_campaign, _currentUserId ?? string.Empty))
            {
                @if (_showConfirmDelete)
                {
                    <div class="confirm-card card-rn">
                        <p>⚠️ Delete campaign <strong>@_campaign.Name</strong>? This cannot be undone. All enrolled characters will be returned to their players.</p>
                        <button class="btn-rn-primary" disabled="@_busy" @onclick="ConfirmDeleteCampaign">Yes, Delete</button>
                        <button class="btn-rn-ghost" @onclick="CancelConfirm">Cancel</button>
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <p class="feedback-error">@_errorMessage</p>
                        }
                    </div>
                }
                else
                {
                    <button class="btn-rn-ghost" style="margin-top: 1rem;" @onclick="() => _showConfirmDelete = true">Delete Campaign</button>
                }
            }
        </div>
        }
    }
</div>
