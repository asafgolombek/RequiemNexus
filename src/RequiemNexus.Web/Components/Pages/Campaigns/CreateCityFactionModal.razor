@using RequiemNexus.Application.Contracts
@using RequiemNexus.Domain.Enums
@inject ICityFactionService FactionService

@if (IsOpen)
{
    <div class="rn-modal-backdrop" @onclick="CloseAsync">
        <div class="rn-modal-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="create-faction-title">
            <div class="rn-modal-header">
                <h2 id="create-faction-title" class="rn-modal-title">Create faction</h2>
                <button type="button" class="rn-modal-close" @onclick="CloseAsync" aria-label="Close">×</button>
            </div>
            <div class="rn-modal-body">
                <label class="text-small" for="create-faction-name">Faction name</label>
                <input id="create-faction-name" type="text" class="form-control" @bind="_name" style="margin:0.35rem 0 0.75rem;" />

                <label class="text-small" for="create-faction-type">Type</label>
                <select id="create-faction-type" class="form-control" style="margin:0.35rem 0 0.75rem;" @bind="_factionType">
                    @foreach (FactionType ft in Enum.GetValues<FactionType>())
                    {
                        <option value="@ft">@ft</option>
                    }
                </select>

                <label class="text-small" for="create-faction-influence">Influence (1–5)</label>
                <input id="create-faction-influence" type="number" class="form-control" min="1" max="5" style="max-width:8rem;margin:0.35rem 0 0;" @bind="_influence" />
            </div>
            <div class="edit-lineage-footer">
                <button type="button" class="btn-rn-ghost" @onclick="CloseAsync" disabled="@_busy">Discard</button>
                <button type="button" class="btn-rn-primary" disabled="@(_busy || !CanSubmit)" @onclick="SubmitAsync">
                    @(_busy ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public int CampaignId { get; set; }

    [Parameter]
    public string StorytellerUserId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnCreated { get; set; }

    private string _name = string.Empty;

    private FactionType _factionType = FactionType.Other;

    private int _influence = 1;

    private bool _busy;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_name) && !string.IsNullOrEmpty(StorytellerUserId);

    private async Task CloseAsync()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        ResetForm();
    }

    private void ResetForm()
    {
        _name = string.Empty;
        _factionType = FactionType.Other;
        _influence = 1;
    }

    private async Task SubmitAsync()
    {
        if (!CanSubmit)
        {
            return;
        }

        int influence = Math.Clamp(_influence, 1, 5);
        _busy = true;
        try
        {
            await FactionService.CreateFactionAsync(
                CampaignId,
                _name.Trim(),
                _factionType,
                influence,
                string.Empty,
                StorytellerUserId);
            await OnCreated.InvokeAsync();
            await CloseAsync();
        }
        finally
        {
            _busy = false;
        }
    }
}
