@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Data.Models
@using RequiemNexus.Domain.Models
@using RequiemNexus.Web.Services
@inject IGhoulManagementService GhoulService
@inject IDisciplineService DisciplineService
@inject ToastService ToastService

@if (IsOpen && Ghoul != null)
{
    <div class="rn-modal-backdrop" @onclick="CloseAsync">
        <div class="rn-modal-panel ghoul-disc-editor-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="ghoul-disc-title">
            <div class="rn-modal-header">
                <h2 id="ghoul-disc-title" class="rn-modal-title">Discipline access — @Ghoul.Name</h2>
                <button type="button" class="rn-modal-close" @onclick="CloseAsync" aria-label="Close">×</button>
            </div>
            <div class="rn-modal-body">
                @if (Ghoul.DisciplineAccessEnforced)
                {
                    <p class="text-small text-muted-rn" style="margin-bottom:0.75rem;">
                        In-clan only, at most <strong>@Ghoul.DisciplineAccessMaxCount</strong> (regnant Blood Potency).
                    </p>
                }
                else
                {
                    <p class="text-small text-muted-rn" style="margin-bottom:0.75rem;">
                        NPC or name-only regnant — pick any disciplines; caps are ST-trusted at the table.
                    </p>
                }

                @if (_loading)
                {
                    <p class="text-small"><em>Loading disciplines…</em></p>
                }
                else
                {
                    <ul class="ghoul-disc-checklist">
                        @foreach (var d in _visibleDisciplines)
                        {
                            bool sel = _selected.Contains(d.Id);
                            bool disabled = Ghoul.DisciplineAccessEnforced && !Ghoul.RegnantAllowedDisciplineIds.Contains(d.Id);
                            <li class="ghoul-disc-check-item">
                                <label class="@(disabled ? "text-muted-rn" : null)">
                                    <input type="checkbox"
                                           checked="@sel"
                                           disabled="@disabled"
                                           @onchange="e => ToggleSelection(d.Id, e.Value is true)" />
                                    <span>@d.Name</span>
                                </label>
                            </li>
                        }
                    </ul>
                }

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-small" style="color:var(--accent-warm);margin-top:0.5rem;">@_error</p>
                }
            </div>
            <div class="edit-lineage-footer">
                <button type="button" class="btn-rn-ghost" @onclick="CloseAsync" disabled="@_busy">Cancel</button>
                <button type="button" class="btn-rn-primary" disabled="@_busy" @onclick="SaveAsync">
                    @(_busy ? "Saving…" : "Save access")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public GhoulDto? Ghoul { get; set; }

    [Parameter]
    public string StorytellerUserId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnSaved { get; set; }

    private readonly HashSet<int> _selected = [];

    private List<Discipline> _visibleDisciplines = [];

    private bool _loading;

    private string _error = string.Empty;

    private bool _busy;

    private int? _lastGhoulId;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || Ghoul == null)
        {
            return;
        }

        if (_lastGhoulId == Ghoul.Id)
        {
            return;
        }

        _lastGhoulId = Ghoul.Id;
        _error = string.Empty;
        _selected.Clear();
        foreach (int id in Ghoul.AccessibleDisciplineIds)
        {
            _selected.Add(id);
        }

        _loading = true;
        try
        {
            List<Discipline> all = await DisciplineService.GetAllDisciplinesAsync();
            if (Ghoul.DisciplineAccessEnforced && Ghoul.RegnantAllowedDisciplineIds.Count > 0)
            {
                var allow = Ghoul.RegnantAllowedDisciplineIds.ToHashSet();
                _visibleDisciplines = all.Where(d => allow.Contains(d.Id)).OrderBy(d => d.Name).ToList();
            }
            else
            {
                _visibleDisciplines = all.OrderBy(d => d.Name).ToList();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleSelection(int disciplineId, bool on)
    {
        if (Ghoul == null)
        {
            return;
        }

        if (Ghoul.DisciplineAccessEnforced && !Ghoul.RegnantAllowedDisciplineIds.Contains(disciplineId))
        {
            return;
        }

        if (on)
        {
            if (Ghoul.DisciplineAccessEnforced && _selected.Count >= Ghoul.DisciplineAccessMaxCount && !_selected.Contains(disciplineId))
            {
                _error = $"At most {Ghoul.DisciplineAccessMaxCount} Disciplines.";
                StateHasChanged();
                return;
            }

            _selected.Add(disciplineId);
        }
        else
        {
            _selected.Remove(disciplineId);
        }

        _error = string.Empty;
    }

    private async Task CloseAsync()
    {
        IsOpen = false;
        _lastGhoulId = null;
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task SaveAsync()
    {
        if (Ghoul == null)
        {
            return;
        }

        _busy = true;
        _error = string.Empty;
        try
        {
            Result<Unit> result = await GhoulService.SetDisciplineAccessAsync(
                Ghoul.Id,
                _selected.OrderBy(i => i).ToList(),
                StorytellerUserId);

            if (!result.IsSuccess)
            {
                _error = result.Error ?? "Could not save.";
                return;
            }

            ToastService.Show("Ghouls", "Discipline access updated.", ToastType.Success);
            await OnSaved.InvokeAsync();
            await CloseAsync();
        }
        finally
        {
            _busy = false;
        }
    }
}
