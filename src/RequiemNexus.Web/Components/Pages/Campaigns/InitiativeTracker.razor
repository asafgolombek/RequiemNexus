@page "/campaigns/{CampaignId:int}/encounter/{EncounterId:int}"
@rendermode InteractiveServer
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Web.Services
@using System.Security.Claims
@using System.Threading
@using Microsoft.AspNetCore.Components.Authorization
@inject IEncounterService EncounterService
@inject IEncounterQueryService EncounterQueryService
@inject IEncounterParticipantService EncounterParticipantService
@inject IEncounterPrepService EncounterPrepService
@inject INpcCombatService NpcCombatService
@inject IChronicleNpcService ChronicleNpcService
@inject ICampaignService CampaignService
@inject IConditionService ConditionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject ScreenReaderAnnouncer Announcer
@inject IInitiativeTrackerDragState InitiativeTrackerDragState
@using RequiemNexus.Web.Components.UI
@using RequiemNexus.Web.Components.Pages.Campaigns.InitiativeParts
@implements IAsyncDisposable

<PageTitle>Initiative Tracker - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <SkeletonLoader Variant="tracker" Count="2" />
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — you are not a member of this campaign.
        </div>
        <a href="/campaigns/@CampaignId" class="btn-rn-ghost">← Back to Campaign</a>
    }
    else if (_encounter == null)
    {
        <div class="empty-state-rn">
            <p>Encounter not found.</p>
            <a href="/campaigns/@CampaignId/encounters" class="btn-rn-ghost">← Back to Encounters</a>
        </div>
    }
    else
    {
        <div class="initiative-page-grid">
        <div class="initiative-page-main">
        <div class="campaign-header">
            <div>
                <h2>⚔️ @_encounter.Name</h2>
                <span style="font-size:0.85em;color:var(--gothic-muted);">
                    @if (_encounter.IsActive && !_encounter.IsDraft)
                    {
                        <text>Round @_encounter.CurrentRound · Active</text>
                    }
                    else if (_encounter.IsDraft)
                    {
                        <text>Draft — start from Encounter Manager to begin combat</text>
                    }
                    else if (_encounter.IsPaused)
                    {
                        <text>Paused — resume from Encounter Manager to continue combat</text>
                    }
                    else if (_encounter.ResolvedAt != null)
                    {
                        <text>Resolved @_encounter.ResolvedAt?.ToLocalTime():g</text>
                    }
                    else
                    {
                        <text>Inactive</text>
                    }
                </span>
            </div>
            <a href="/campaigns/@CampaignId/encounters" class="btn-rn-ghost">← Encounters</a>
        </div>

        <InitiativeAddParticipantPanel Visible="@(_isSt && _encounter.ResolvedAt == null && !_encounter.IsPaused)"
                                       CampaignId="CampaignId"
                                       @bind-AddType="_addType"
                                       @bind-AddCharacterId="_addCharacterId"
                                       @bind-AddNpcName="_addNpcName"
                                       @bind-AddChronicleNpcId="_addChronicleNpcId"
                                       @bind-AddInitMod="_addInitMod"
                                       @bind-AddRoll="_addRoll"
                                       @bind-AddNpcHealthBoxes="_addNpcHealthBoxes"
                                       @bind-AddNpcMaxWillpower="_addNpcMaxWillpower"
                                       @bind-AddNpcMaxVitae="_addNpcMaxVitae"
                                       @bind-AddChronicleTracksVitae="_addChronicleTracksVitae"
                                       CampaignCharacters="_campaignCharacters"
                                       ChronicleNpcsAvailableForEncounter="ChronicleNpcsAvailableForEncounter"
                                       ChronicleNpcTotalCount="_chronicleNpcs.Count"
                                       CanAdd="CanAddParticipant()"
                                       AddError="_addError"
                                       Busy="_busy"
                                       OnAddTypeAfterChanged="OnAddTypeChanged"
                                       OnChronicleSelectChanged="OnTrackerChronicleSelectChanged"
                                       OnAdd="AddParticipant" />

        <InitiativeOrderList Entries="SortedEntries"
                             CurrentActor="CurrentActor"
                             IsStoryteller="_isSt"
                             EncounterIsActive="_encounter.IsActive"
                             EncounterIsDraft="_encounter.IsDraft"
                             Busy="_busy"
                             PlayerOwnedCharacterId="PlayerOwnedCharacterId"
                             ActionFeedback="_actionFeedback"
                             ShowTurnToolbar="@(_isSt && _encounter.IsActive && !_encounter.IsDraft)"
                             ActiveTilts="_activeTilts"
                             TiltSelections="_tiltSelections"
                             DefeatConfirmEntryId="_defeatConfirmEntryId"
                             NpcRollEntryId="_npcRollEntryId"
                             CanStEditLaunchedNpcEncounter="CanStEditLaunchedNpcEncounter()"
                             ShowPlayerHealth="ShowPlayerHealth"
                             DamageBoxClass="GetDamageClass"
                             OnAdvanceTurn="AdvanceTurn"
                             OnHoldTurn="HoldTurn"
                             OnResolveEncounter="ResolveEncounter"
                             OnDragStart="OnDragStart"
                             OnDrop="OnDrop"
                             OnNpcHealthTrackChanged="OnNpcHealthTrackFromListAsync"
                             OnNpcSpendWill="NpcSpendWill"
                             OnNpcRestoreWill="NpcRestoreWill"
                             OnNpcSpendVitae="NpcSpendVitae"
                             OnNpcRestoreVitae="NpcRestoreVitae"
                             OnOpenPlayerWeaponDamage="OpenPlayerWeaponDamageFromListAsync"
                             OnRemoveTilt="RemoveTilt"
                             OnApplyTilt="ApplyTilt"
                             OnToggleNpcReveal="ToggleNpcReveal"
                             OnToggleNpcRoll="ToggleNpcRoll"
                             OnReleaseHeld="ReleaseHeld"
                             OnConfirmDefeatNpc="ConfirmDefeatNpc"
                             OnCancelDefeatConfirm="CancelDefeatConfirm"
                             OnRequestDefeatConfirm="RequestDefeatConfirmAsync"
                             OnOpenMeleeAttack="OpenMeleeAttackFromListAsync"
                             OnRemoveEntry="RemoveEntry"
                             OnNpcRollClosed="CloseNpcRollPanelAsync"
                             OnTiltSelectionChanged="OnTiltSelectionFromListAsync" />
        </div>
        @if (_isSt)
        {
            <InitiativeBloodLogSidebar />
        }
        </div>
    }
</div>

<MeleeAttackResolveModal IsOpen="_meleeAttackModalOpen"
                         IsOpenChanged="OnMeleeAttackModalOpenChanged"
                         CampaignId="CampaignId"
                         EncounterId="EncounterId"
                         AttackerCharacterId="_meleeAttackAttackerCharacterId"
                         StorytellerUserId="@(_currentUserId ?? string.Empty)"
                         InitiativeEntries="SortedEntries" />

<PlayerWeaponDamageRollModal IsOpen="_playerWeaponDamageModalOpen"
                             IsOpenChanged="OnPlayerWeaponDamageModalOpenChanged"
                             CampaignId="CampaignId"
                             EncounterId="EncounterId"
                             CharacterId="_playerWeaponDamageCharacterId"
                             UserId="@(_currentUserId ?? string.Empty)" />
