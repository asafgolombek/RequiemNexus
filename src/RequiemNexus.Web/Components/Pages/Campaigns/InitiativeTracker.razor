@page "/campaigns/{CampaignId:int}/encounter/{EncounterId:int}"
@rendermode InteractiveServer
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Web.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IEncounterService EncounterService
@inject ICampaignService CampaignService
@inject IConditionService ConditionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject SessionClientService SessionClient
@inject ISessionService SessionService
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@implements IAsyncDisposable

<PageTitle>Initiative Tracker - Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <p><em>Loading encounter...</em></p>
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — you are not a member of this campaign.
        </div>
        <a href="/campaigns/@CampaignId" class="btn-ghost">← Back to Campaign</a>
    }
    else if (_encounter == null)
    {
        <div class="empty-state-rn">
            <p>Encounter not found.</p>
            <a href="/campaigns/@CampaignId/encounters" class="btn-ghost">← Back to Encounters</a>
        </div>
    }
    else
    {
        <div class="campaign-header">
            <div>
                <h2>⚔️ @_encounter.Name</h2>
                <span style="font-size:0.85em;color:var(--gothic-muted);">
                    @if (_encounter.IsActive && !_encounter.IsDraft)
                    {
                        <text>Round @_encounter.CurrentRound · Active</text>
                    }
                    else if (_encounter.IsDraft)
                    {
                        <text>Draft — start from Encounter Manager to begin combat</text>
                    }
                    else if (_encounter.IsPaused)
                    {
                        <text>Paused — resume from Encounter Manager to continue combat</text>
                    }
                    else if (_encounter.ResolvedAt != null)
                    {
                        <text>Resolved @_encounter.ResolvedAt?.ToLocalTime():g</text>
                    }
                    else
                    {
                        <text>Inactive</text>
                    }
                </span>
            </div>
            <a href="/campaigns/@CampaignId/encounters" class="btn-ghost">← Encounters</a>
        </div>

        @if (_isSt && _encounter.ResolvedAt == null && !_encounter.IsPaused)
        {
            <div class="card-rn" style="margin-bottom:1.5rem;">
                <h3 style="margin-bottom:0.75rem;">Add Participant</h3>
                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:flex-end;">
                    <div>
                        <label style="font-size:0.8em;color:var(--gothic-muted);">Type</label>
                        <select class="form-control" @bind="_addType" style="min-width:110px;">
                            <option value="character">Character</option>
                            <option value="npc">NPC</option>
                        </select>
                    </div>

                    @if (_addType == "character")
                    {
                        <div style="flex:1;min-width:160px;">
                            <label style="font-size:0.8em;color:var(--gothic-muted);">Character</label>
                            <select class="form-control" @bind="_addCharacterId">
                                <option value="0">-- Select character --</option>
                                @foreach (Character c in _campaignCharacters)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div style="flex:1;min-width:160px;">
                            <label style="font-size:0.8em;color:var(--gothic-muted);">NPC Name</label>
                            <input class="form-control" placeholder="NPC name…" @bind="_addNpcName" />
                        </div>
                    }

                    <div>
                        <label style="font-size:0.8em;color:var(--gothic-muted);">Init Mod</label>
                        <input type="number" class="form-control" style="width:80px;" @bind="_addInitMod" />
                    </div>
                    <div>
                        <label style="font-size:0.8em;color:var(--gothic-muted);">Roll (1–10)</label>
                        <input type="number" class="form-control" style="width:80px;" min="1" max="10" @bind="_addRoll" />
                    </div>
                    <button class="btn-primary-rn"
                            disabled="@(!CanAddParticipant() || _busy)"
                            @onclick="AddParticipant">
                        Add
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_addError))
                {
                    <p class="text-danger" style="margin-top:0.5rem;">@_addError</p>
                }
            </div>
        }

        @if (!SortedEntries.Any())
        {
            <div class="empty-state-rn">
                <p>No participants yet. Add characters or NPCs above.</p>
            </div>
        }
        else
        {
            <div style="margin-bottom:1rem;display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
                @if (_isSt && _encounter.IsActive && !_encounter.IsDraft)
                {
                    <button class="btn-primary-rn"
                            disabled="@_busy"
                            @onclick="AdvanceTurn">
                        ▶ Advance Turn
                    </button>
                    <button class="btn-ghost"
                            disabled="@_busy"
                            @onclick="HoldTurn">
                        ⏸ Hold action
                    </button>
                    <button class="btn-ghost"
                            disabled="@_busy"
                            @onclick="ResolveEncounter">
                        ✓ Resolve Encounter
                    </button>
                }
                @if (!string.IsNullOrEmpty(_actionFeedback))
                {
                    <span style="font-size:0.85em;color:var(--gothic-muted);">@_actionFeedback</span>
                }
            </div>

            <div class="initiative-list">
                @foreach (InitiativeEntry entry in SortedEntries)
                {
                    bool isCurrent = CurrentActor?.Id == entry.Id;
                    string displayName = entry.Character?.Name ?? entry.NpcName ?? "Unknown";
                    bool isNpc = entry.CharacterId == null;

                    <div class="initiative-row @(isCurrent ? "initiative-current" : "") @(entry.HasActed ? "initiative-acted" : "") @(_isSt && _encounter.IsActive && !_encounter.IsDraft ? "draggable-row" : "")"
                         draggable="@(_isSt && _encounter.IsActive && !_encounter.IsDraft ? "true" : "false")"
                         @ondragstart="() => OnDragStart(entry)"
                         @ondragover:preventDefault="true"
                         @ondrop="() => OnDrop(entry)">
                        
                        <div class="initiative-order">@entry.Order</div>

                        <div class="initiative-info">
                            <span class="initiative-name">
                                @if (isCurrent)
                                {
                                    <strong>▶ @displayName</strong>
                                }
                                else
                                {
                                    @displayName
                                }
                                @if (isNpc)
                                {
                                    <span class="badge-npc">NPC</span>
                                }
                            </span>
                            
                            @if (entry.Character != null && ShowPlayerHealth(entry))
                            {
                                <div class="mini-health-track">
                                    @for (int i = 0; i < entry.Character.CalculatedMaxHealth; i++)
                                    {
                                        <span class="health-box-mini @GetDamageClass(entry.Character, i)"></span>
                                    }
                                </div>
                            }
                            @if (isNpc && _isSt)
                            {
                                <div class="mini-health-track">
                                    @for (int i = 0; i < entry.NpcHealthBoxes; i++)
                                    {
                                        <span class="health-box-mini @GetNpcDamageClass(entry.NpcHealthDamage, i)"></span>
                                    }
                                </div>
                                <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.25rem;">
                                    <button type="button" class="btn-ghost" style="font-size:0.7em;" disabled="@_busy" @onclick="() => NpcDamage(entry.Id, '/')">+B</button>
                                    <button type="button" class="btn-ghost" style="font-size:0.7em;" disabled="@_busy" @onclick="() => NpcDamage(entry.Id, 'X')">+L</button>
                                    <button type="button" class="btn-ghost" style="font-size:0.7em;" disabled="@_busy" @onclick="() => NpcDamage(entry.Id, '*')">+A</button>
                                    <button type="button" class="btn-ghost" style="font-size:0.7em;" disabled="@_busy" @onclick="() => NpcHeal(entry.Id)">Heal</button>
                                </div>
                            }

                            <span class="initiative-total">
                                Initiative: <strong>@entry.Total</strong>
                                <span style="font-size:0.8em;color:var(--gothic-muted);">(@entry.InitiativeMod + @entry.RollResult)</span>
                            </span>
                        </div>

                        <div style="display: flex; align-items: center; gap: 1.5rem;">
                            @if (_isSt && _encounter.IsActive && !_encounter.IsDraft && entry.CharacterId.HasValue)
                            {
                                <div class="initiative-tilts">
                                    @if (_activeTilts.TryGetValue(entry.CharacterId.Value, out List<CharacterTilt>? tilts) && tilts.Any())
                                    {
                                        @foreach (CharacterTilt tilt in tilts)
                                        {
                                            <span class="tilt-badge">
                                                @(tilt.CustomName ?? tilt.TiltType.ToString())
                                                <button class="tilt-remove-btn"
                                                        disabled="@_busy"
                                                        @onclick="() => RemoveTilt(tilt.Id)">
                                                    ×
                                                </button>
                                            </span>
                                        }
                                    }

                                    <div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;margin-top:0.3rem;">
                                        <select class="form-control"
                                                style="font-size:0.8em;"
                                                @bind="_tiltSelections[entry.CharacterId.Value]">
                                            @foreach (TiltType t in Enum.GetValues<TiltType>())
                                            {
                                                <option value="@t">@t</option>
                                            }
                                        </select>
                                        <button class="btn-ghost"
                                                style="font-size:0.8em;"
                                                disabled="@_busy"
                                                @onclick="() => ApplyTilt(entry.CharacterId.Value)">
                                            + Tilt
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (_isSt && _encounter.IsActive && !_encounter.IsDraft)
                            {
                                @if (isNpc)
                                {
                                    <button type="button" class="btn-ghost" style="font-size:0.7em;" disabled="@_busy" @onclick="() => ToggleNpcReveal(entry)">
                                        @(entry.IsRevealed ? "🙈 Hide" : "👁 Reveal")
                                    </button>
                                }
                                @if (entry.IsHeld)
                                {
                                    <button type="button" class="btn-primary-rn" style="font-size:0.7em;" disabled="@_busy" @onclick="() => ReleaseHeld(entry.Id)">Release</button>
                                }
                                <button class="btn-ghost"
                                        style="font-size:0.75em;align-self:flex-start;"
                                        disabled="@_busy"
                                        @onclick="() => RemoveEntry(entry.Id)">
                                    Remove
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public int CampaignId { get; set; }
    [Parameter] public int EncounterId { get; set; }

    private CombatEncounter? _encounter;
    private bool _accessDenied;
    private List<Character> _campaignCharacters = [];
    private Dictionary<int, List<CharacterTilt>> _activeTilts = [];
    private Dictionary<int, TiltType> _tiltSelections = [];
    private bool _loading = true;
    private bool _isSt;
    private bool _busy;
    private string? _currentUserId;
    private InitiativeEntry? _draggedItem;

    private List<InitiativeEntry> SortedEntries =>
        _encounter?.InitiativeEntries.OrderBy(i => i.Order).ToList() ?? [];

    private InitiativeEntry? CurrentActor =>
        _encounter is { ResolvedAt: null } ? SortedEntries.FirstOrDefault(i => !i.HasActed) : null;

    private string _addType = "character";
    private int _addCharacterId;
    private string _addNpcName = string.Empty;
    private int _addInitMod;
    private int _addRoll = 1;
    private string _addError = string.Empty;
    private string _actionFeedback = string.Empty;
    private string? _cookieHeader;
    private PersistingComponentStateSubscription _persistingSubscription;
    private int _lastLoadedEncounterId = int.MinValue;
    private int _lastLoadedCampaignId = int.MinValue;
    private int? _hubConnectedCampaignId;

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistCookieHeader);

        if (!ApplicationState.TryTakeFromJson<string>("rnCookieHeader", out _cookieHeader))
        {
            _cookieHeader = HttpContextAccessor.HttpContext?.Request.Headers.Cookie.ToString();
        }

        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(_currentUserId))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        SessionClient.InitiativeUpdated += HandleInitiativeUpdated;
        SessionClient.CharacterUpdated += HandleCharacterUpdated;

        await LoadEncounter();
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (string.IsNullOrEmpty(_currentUserId))
        {
            return;
        }

        if (EncounterId == _lastLoadedEncounterId && CampaignId == _lastLoadedCampaignId)
        {
            return;
        }

        await LoadEncounter();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrEmpty(_currentUserId))
        {
            return;
        }

        if (!firstRender && _hubConnectedCampaignId == CampaignId)
        {
            return;
        }

        _hubConnectedCampaignId = CampaignId;
        _ = await SessionClient.GetSessionActiveAsync(CampaignId, SessionService);
        await SessionClient.StartAsync(CampaignId, null, _currentUserId, _cookieHeader);
    }

    private Task PersistCookieHeader()
    {
        ApplicationState.PersistAsJson("rnCookieHeader", _cookieHeader);
        return Task.CompletedTask;
    }

    private void HandleInitiativeUpdated(IEnumerable<InitiativeEntryDto> entries)
    {
        InvokeAsync(LoadEncounter);
    }

    private void HandleCharacterUpdated(CharacterUpdateDto patch)
    {
        // Vitals might have changed, reload to see mini-health-track updates
        InvokeAsync(LoadEncounter);
    }

    private async Task LoadEncounter()
    {
        _loading = true;
        try
        {
            _accessDenied = false;
            try
            {
                _encounter = await EncounterService.GetEncounterAsync(EncounterId, _currentUserId!);
            }
            catch (UnauthorizedAccessException)
            {
                _encounter = null;
                _accessDenied = true;
                return;
            }

            if (_encounter == null)
            {
                return;
            }

            Campaign? campaign = await CampaignService.GetCampaignByIdAsync(CampaignId, _currentUserId!);
            _isSt = campaign != null && CampaignService.IsStoryteller(campaign, _currentUserId!);

            if (_isSt && campaign != null)
            {
                _campaignCharacters = campaign.Characters.ToList();
            }

            await LoadActiveTiltsAsync();
            StateHasChanged();
        }
        finally
        {
            _loading = false;
            _lastLoadedEncounterId = EncounterId;
            _lastLoadedCampaignId = CampaignId;
        }
    }

    private async Task LoadActiveTiltsAsync()
    {
        if (_encounter == null) return;

        _activeTilts = [];
        _tiltSelections = [];

        foreach (InitiativeEntry entry in _encounter.InitiativeEntries)
        {
            if (!entry.CharacterId.HasValue) continue;

            int charId = entry.CharacterId.Value;
            List<CharacterTilt> tilts = await ConditionService.GetActiveTiltsAsync(charId);
            _activeTilts[charId] = tilts;
            _tiltSelections.TryAdd(charId, TiltType.KnockedDown);
        }
    }

    private bool CanAddParticipant() => _addType == "character" ? _addCharacterId > 0 : !string.IsNullOrWhiteSpace(_addNpcName);

    private async Task AddParticipant()
    {
        if (!CanAddParticipant() || _busy) return;

        _busy = true;
        _addError = string.Empty;
        try
        {
            if (_addType == "character")
            {
                await EncounterService.AddCharacterToEncounterAsync(EncounterId, _addCharacterId, _addInitMod, _addRoll, _currentUserId!);
            }
            else
            {
                await EncounterService.AddNpcToEncounterAsync(EncounterId, _addNpcName.Trim(), _addInitMod, _addRoll, _currentUserId!);
            }

            _addCharacterId = 0;
            _addNpcName = string.Empty;
            _addInitMod = 0;
            _addRoll = 1;

            await LoadEncounter();
        }
        catch (Exception ex)
        {
            _addError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AdvanceTurn()
    {
        if (_busy) return;

        _busy = true;
        _actionFeedback = string.Empty;
        try
        {
            await EncounterService.AdvanceTurnAsync(EncounterId, _currentUserId!);
            await LoadEncounter();

            if (SortedEntries.All(i => !i.HasActed))
            {
                _actionFeedback = $"Round {_encounter?.CurrentRound ?? 1}";
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HoldTurn()
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.HoldActionAsync(EncounterId, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReleaseHeld(int entryId)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.ReleaseHeldActionAsync(EncounterId, entryId, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task NpcDamage(int entryId, char type)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.ApplyNpcDamageAsync(entryId, type, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task NpcHeal(int entryId)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.HealNpcDamageAsync(entryId, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ToggleNpcReveal(InitiativeEntry entry)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.SetNpcEntryRevealAsync(entry.Id, !entry.IsRevealed, entry.MaskedDisplayName, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ResolveEncounter()
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.ResolveEncounterAsync(EncounterId, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveEntry(int entryId)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await EncounterService.RemoveEntryAsync(entryId, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ApplyTilt(int characterId)
    {
        if (_busy || !_tiltSelections.TryGetValue(characterId, out TiltType tiltType)) return;

        _busy = true;
        try
        {
            await ConditionService.ApplyTiltAsync(characterId, tiltType, null, EncounterId, _currentUserId!);
            await LoadActiveTiltsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RemoveTilt(int tiltId)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await ConditionService.RemoveTiltAsync(tiltId, _currentUserId!);
            await LoadActiveTiltsAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnDragStart(InitiativeEntry item) => _draggedItem = item;

    private async Task OnDrop(InitiativeEntry target)
    {
        if (_draggedItem is null || _draggedItem == target || _encounter == null)
        {
            return;
        }

        List<InitiativeEntry> list = _encounter.InitiativeEntries.OrderBy(i => i.Order).ToList();
        int oldIdx = list.IndexOf(_draggedItem);
        int newIdx = list.IndexOf(target);

        list.RemoveAt(oldIdx);
        list.Insert(newIdx, _draggedItem);

        List<int> orderIds = list.Select(e => e.Id).ToList();
        _draggedItem = null;

        _busy = true;
        try
        {
            await EncounterService.ReorderInitiativeAsync(EncounterId, orderIds, _currentUserId!);
            await LoadEncounter();
        }
        finally
        {
            _busy = false;
        }
    }

    private bool ShowPlayerHealth(InitiativeEntry entry) =>
        entry.Character != null && (_isSt || entry.Character.ApplicationUserId == _currentUserId);

    private string GetNpcDamageClass(string damage, int index)
    {
        if (string.IsNullOrEmpty(damage) || index >= damage.Length)
        {
            return string.Empty;
        }

        return damage[index] switch
        {
            '/' => "bashing",
            'X' => "lethal",
            '*' => "aggravated",
            _ => string.Empty,
        };
    }

    private string GetDamageClass(Character character, int index)
    {
        if (string.IsNullOrEmpty(character.HealthDamage) || index >= character.HealthDamage.Length)
            return string.Empty;
        
        return character.HealthDamage[index] switch
        {
            '/' => "bashing",
            'X' => "lethal",
            '*' => "aggravated",
            _ => string.Empty
        };
    }

    public async ValueTask DisposeAsync()
    {
        _persistingSubscription.Dispose();
        SessionClient.InitiativeUpdated -= HandleInitiativeUpdated;
        SessionClient.CharacterUpdated -= HandleCharacterUpdated;
        await SessionClient.StopAsync();
    }
}
