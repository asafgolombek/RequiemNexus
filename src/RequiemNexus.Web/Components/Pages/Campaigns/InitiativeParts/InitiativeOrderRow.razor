@using Microsoft.AspNetCore.Components.Web
@using RequiemNexus.Data.Models
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Domain.Models
@using RequiemNexus.Web.Components.UI

<div class="initiative-row @(IsCurrent ? "initiative-current" : "") @(Entry.HasActed ? "initiative-acted" : "") @(Draggable ? "draggable-row" : "")"
     draggable="@(Draggable ? "true" : "false")"
     @ondragstart="HandleDragStartAsync"
     @ondragover:preventDefault="true"
     @ondrop="HandleDropAsync">

    <div class="initiative-order">@Entry.Order</div>

    <div class="initiative-info">
        <span class="initiative-name">
            @if (IsCurrent)
            {
                <strong>▶ @DisplayName</strong>
            }
            else
            {
                @DisplayName
            }
            @if (IsNpc)
            {
                <span class="badge-npc">NPC</span>
            }
        </span>

        @if (Entry.Character != null && ShowPlayerHealth)
        {
            <div class="mini-health-track">
                @for (int i = 0; i < Entry.Character.CalculatedMaxHealth; i++)
                {
                    <span class="health-box-mini @DamageBoxClass(Entry.Character, i)"></span>
                }
            </div>
        }
        @if (IsNpc && IsStoryteller)
        {
            <div class="initiative-npc-health">
                <span class="initiative-npc-health-label">Health</span>
                <HealthDamageTrackBoxes BoxCount="Entry.NpcHealthBoxes"
                                        DamageTrack="@Entry.NpcHealthDamage"
                                        ReadOnly="@(!CanStEditLaunchedNpcEncounter)"
                                        DamageTrackChanged="NpcHealthDamageTrackChanged" />
            </div>
            @if (CanStEditLaunchedNpcEncounter)
            {
                @if (Entry.NpcMaxWillpower > 0)
                {
                    <div style="margin-top:0.35rem;font-size:0.78em;color:var(--gothic-muted);">
                        Willpower: <strong>@Entry.NpcCurrentWillpower</strong> / @Entry.NpcMaxWillpower
                    </div>
                    <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.2rem;">
                        <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnNpcSpendWill">Spend</button>
                        <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnNpcRestoreWill">Restore</button>
                    </div>
                }
                @if (Entry.NpcMaxVitae > 0)
                {
                    <div style="margin-top:0.35rem;font-size:0.78em;color:var(--gothic-muted);">
                        Vitae: <strong>@Entry.NpcCurrentVitae</strong> / @Entry.NpcMaxVitae
                    </div>
                    <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.2rem;">
                        <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnNpcSpendVitae">Spend vitae</button>
                        <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnNpcRestoreVitae">Restore vitae</button>
                    </div>
                }
            }
        }

        <span class="initiative-total">
            Initiative: <strong>@Entry.Total</strong>
            <span style="font-size:0.8em;color:var(--gothic-muted);">(@Entry.InitiativeMod + @Entry.RollResult)</span>
        </span>

        @if (ShowPlayerWeaponDamage)
        {
            <div style="margin-top:0.35rem;">
                <button type="button"
                        class="btn-rn-ghost"
                        style="font-size:0.75em;"
                        disabled="@Busy"
                        @onclick="OnOpenPlayerWeaponDamage">
                    Weapon damage
                </button>
            </div>
        }
    </div>

    <div style="display: flex; align-items: center; gap: 1.5rem;">
        @if (ShowTiltColumn)
        {
            <div class="initiative-tilts">
                @if (ActiveTiltsForCharacter is { Count: > 0 })
                {
                    @foreach (CharacterTilt tilt in ActiveTiltsForCharacter)
                    {
                        <span class="tilt-badge">
                            @(tilt.CustomName ?? tilt.TiltType.ToString())
                            <button class="tilt-remove-btn"
                                    disabled="@Busy"
                                    @onclick="@(() => RemoveTiltAsync(tilt.Id))">
                                ×
                            </button>
                        </span>
                    }
                }

                @if (TiltCharacterId.HasValue)
                {
                    <div style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap;margin-top:0.3rem;">
                        <select class="form-control"
                                style="font-size:0.8em;"
                                value="@SelectedTilt"
                                @onchange="OnTiltSelectChangedAsync">
                            @foreach (TiltType t in Enum.GetValues<TiltType>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                        <button class="btn-rn-ghost"
                                style="font-size:0.8em;"
                                disabled="@Busy"
                                @onclick="OnApplyTilt">
                            + Tilt
                        </button>
                    </div>
                }
            </div>
        }

        @if (ShowStCombatActions)
        {
            @if (IsNpc)
            {
                <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnToggleNpcReveal">
                    @(Entry.IsRevealed ? "🙈 Hide" : "👁️ Reveal")
                </button>
                <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnToggleNpcRoll">
                    @(NpcRollOpen ? "Hide roll" : "Roll")
                </button>
            }
            @if (Entry.IsHeld)
            {
                <button type="button" class="btn-rn-primary" style="font-size:0.7em;" disabled="@Busy" @onclick="OnReleaseHeld">Release</button>
            }
            @if (IsNpc)
            {
                @if (DefeatConfirmOpen)
                {
                    <div style="display:flex;flex-direction:column;gap:0.35rem;align-items:flex-start;max-width:18rem;">
                        <span style="font-size:0.72em;color:var(--gothic-muted);">Remove from initiative only. This does not remove the NPC from the chronicle (Danse Macabre).</span>
                        <div style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                            <button type="button" class="btn-rn-primary" style="font-size:0.7em;" disabled="@Busy" @onclick="OnConfirmDefeatNpc">Confirm</button>
                            <button type="button" class="btn-rn-ghost" style="font-size:0.7em;" disabled="@Busy" @onclick="OnCancelDefeatConfirm">Cancel</button>
                        </div>
                    </div>
                }
                else
                {
                    <button type="button" class="btn-rn-ghost" style="font-size:0.75em;" disabled="@Busy" @onclick="OnRequestDefeatConfirm">Defeated / out of fight</button>
                }
            }
            else
            {
                @if (ShowMeleeAttack)
                {
                    <button type="button"
                            class="btn-rn-ghost"
                            style="font-size:0.75em;align-self:flex-start;"
                            disabled="@Busy"
                            @onclick="OnOpenMeleeAttack">
                        Attack
                    </button>
                }
                <button type="button" class="btn-rn-ghost"
                        style="font-size:0.75em;align-self:flex-start;"
                        disabled="@Busy"
                        @onclick="OnRemoveEntry">
                    Remove
                </button>
            }
        }
    </div>
</div>
@if (ShowNpcRollPanel)
{
    <NpcEncounterRollPanel InitiativeEntryId="Entry.Id"
                           HasChronicleNpc="Entry.ChronicleNpcId.HasValue"
                           AttributesJson="@(Entry.ChronicleNpc?.AttributesJson ?? "{}")"
                           SkillsJson="@(Entry.ChronicleNpc?.SkillsJson ?? "{}")"
                           OnClosed="OnNpcRollClosed" />
}

@code {
    [Parameter]
    public InitiativeEntry Entry { get; set; } = null!;

    [Parameter]
    public bool IsCurrent { get; set; }

    [Parameter]
    public bool IsStoryteller { get; set; }

    [Parameter]
    public bool Draggable { get; set; }

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public bool ShowPlayerHealth { get; set; }

    [Parameter]
    public bool ShowPlayerWeaponDamage { get; set; }

    [Parameter]
    public bool CanStEditLaunchedNpcEncounter { get; set; }

    [Parameter]
    public bool ShowTiltColumn { get; set; }

    [Parameter]
    public int? TiltCharacterId { get; set; }

    [Parameter]
    public IReadOnlyList<CharacterTilt>? ActiveTiltsForCharacter { get; set; }

    [Parameter]
    public TiltType SelectedTilt { get; set; }

    [Parameter]
    public EventCallback<TiltType> SelectedTiltChanged { get; set; }

    [Parameter]
    public bool ShowStCombatActions { get; set; }

    [Parameter]
    public bool ShowMeleeAttack { get; set; }

    [Parameter]
    public bool DefeatConfirmOpen { get; set; }

    [Parameter]
    public bool NpcRollOpen { get; set; }

    [Parameter]
    public bool ShowNpcRollPanel { get; set; }

    [Parameter]
    public Func<Character, int, string> DamageBoxClass { get; set; } = (_, _) => string.Empty;

    [Parameter]
    public EventCallback OnDragStart { get; set; }

    [Parameter]
    public EventCallback OnDrop { get; set; }

    [Parameter]
    public EventCallback<string> NpcHealthDamageTrackChanged { get; set; }

    [Parameter]
    public EventCallback OnNpcSpendWill { get; set; }

    [Parameter]
    public EventCallback OnNpcRestoreWill { get; set; }

    [Parameter]
    public EventCallback OnNpcSpendVitae { get; set; }

    [Parameter]
    public EventCallback OnNpcRestoreVitae { get; set; }

    [Parameter]
    public EventCallback OnOpenPlayerWeaponDamage { get; set; }

    [Parameter]
    public EventCallback<int> OnRemoveTilt { get; set; }

    [Parameter]
    public EventCallback OnApplyTilt { get; set; }

    [Parameter]
    public EventCallback OnToggleNpcReveal { get; set; }

    [Parameter]
    public EventCallback OnToggleNpcRoll { get; set; }

    [Parameter]
    public EventCallback OnReleaseHeld { get; set; }

    [Parameter]
    public EventCallback OnConfirmDefeatNpc { get; set; }

    [Parameter]
    public EventCallback OnCancelDefeatConfirm { get; set; }

    [Parameter]
    public EventCallback OnRequestDefeatConfirm { get; set; }

    [Parameter]
    public EventCallback OnOpenMeleeAttack { get; set; }

    [Parameter]
    public EventCallback OnRemoveEntry { get; set; }

    [Parameter]
    public EventCallback OnNpcRollClosed { get; set; }

    private string DisplayName => Entry.Character?.Name ?? Entry.NpcName ?? "Unknown";

    private bool IsNpc => Entry.CharacterId == null;

    private Task HandleDragStartAsync() => OnDragStart.InvokeAsync();

    private Task HandleDropAsync() => OnDrop.InvokeAsync();

    private async Task OnTiltSelectChangedAsync(ChangeEventArgs e)
    {
        string? raw = e.Value?.ToString();
        if (Enum.TryParse(raw, ignoreCase: true, out TiltType next))
        {
            await SelectedTiltChanged.InvokeAsync(next);
        }
    }

    private Task RemoveTiltAsync(int tiltId) => OnRemoveTilt.InvokeAsync(tiltId);
}
