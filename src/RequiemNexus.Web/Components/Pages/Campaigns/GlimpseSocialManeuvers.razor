@using RequiemNexus.Application.Contracts
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Web.Services
@inject ISocialManeuveringService SocialService
@inject ToastService ToastService

<div class="card-rn glimpse-card">
    <h3 class="section-header">Social Maneuvering</h3>
    <p class="social-description">
        Targets must be chronicle NPCs only. On <strong>Force Doors</strong>, failure marks the relationship <strong>Burnt</strong> — no further Social maneuvering against that NPC by this PC.
    </p>

    <div class="social-config-row">
        <label class="config-label">
            Investigation successes per clue (chronicle)
            <input type="number" class="form-control config-input-small" min="1" max="50"
                   @bind="_thresholdDraft" />
        </label>
        <button type="button" class="btn-rn-ghost btn-align-small" disabled="@_busy"
                @onclick="SaveThreshold">Save threshold</button>
    </div>

    <div class="new-maneuver-form">
        <strong class="text-small">New maneuver</strong>
        <div class="form-row">
            <label class="form-label">
                Initiator (PC)
                <select class="form-control form-select-medium" @bind="_newInitiatorId">
                    <option value="0">— Select —</option>
                    @foreach (var v in Vitals)
                    {
                        <option value="@v.CharacterId">@v.Name</option>
                    }
                </select>
            </label>
            <label class="form-label">
                Target (NPC)
                <select class="form-control form-select-medium" @bind="_newTargetNpcId">
                    <option value="0">— Select —</option>
                    @foreach (var n in Npcs)
                    {
                        <option value="@n.Id">@(_pinnedNpcIds.Contains(n.Id) ? "📌 " : "")@n.Name</option>
                    }
                </select>
            </label>
        </div>
        <textarea class="form-control" rows="2" placeholder="Goal description…" @bind="_newGoal"></textarea>
        <div class="checkbox-group">
            <label><input type="checkbox" @bind="_newBreakingPoint" /> Goal would be a breaking point (+2 Doors)</label>
            <label><input type="checkbox" @bind="_newAspiration" /> Prevents victim Aspiration (+1)</label>
            <label><input type="checkbox" @bind="_newVirtueMask" /> Against Virtue / Mask (+1)</label>
        </div>
        <button class="btn-rn-primary btn-align-start"
                disabled="@(_busy || _newInitiatorId == 0 || _newTargetNpcId == 0 || string.IsNullOrWhiteSpace(_newGoal))"
                @onclick="CreateManeuver">
            Create maneuver
        </button>
    </div>

    @if (!Maneuvers.Any())
    {
        <p class="empty-maneuvers">No maneuvers yet.</p>
    }
    else
    {
        <ul class="maneuver-list">
            @foreach (var m in Maneuvers)
            {
                <li class="maneuver-item">
                    <div class="maneuver-header">
                        <strong>@m.InitiatorCharacter?.Name</strong>
                        <span class="text-muted-rn">→</span>
                        <strong>@m.TargetNpc?.Name</strong>
                        <span class="condition-badge text-xsmall">@m.Status</span>
                    </div>
                    <p class="maneuver-goal">@(m.GoalDescription.Length > 120 ? m.GoalDescription[..120] + "…" : m.GoalDescription)</p>
                    <div class="maneuver-meta">
                        <span><strong>Doors:</strong> @m.RemainingDoors / @m.InitialDoors</span>
                        <span><strong>Impression:</strong> @m.CurrentImpression</span>
                        <span><strong>Penalty dice:</strong> @m.CumulativePenaltyDice</span>
                        @if (m.LastRollAt.HasValue)
                        {
                            <span><strong>Last roll:</strong> @m.LastRollAt.Value.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</span>
                        }
                    </div>
                    
                    @* Clues Section (Bank/Add/List) *@
                    <div class="clues-section">
                        <strong>Clues</strong>
                        <span class="clues-progress">Progress @m.InvestigationProgressTowardNextClue / @GetClueThreshold(m)</span>
                        @if (m.Status == ManeuverStatus.Active)
                        {
                            <div class="clues-bank-row">
                                <input type="number" class="form-control input-mini" min="1" max="30"
                                       @bind="_bankSuccesses[m.Id]" />
                                <button type="button" class="btn-rn-ghost btn-small" disabled="@_busy"
                                        @onclick="() => BankInvestigation(m.Id)">Bank Investigation</button>
                            </div>
                        }
                        <div class="manual-clue-form">
                            <label class="clue-source-label">
                                Manual clue (ST)
                                <input class="form-control mt-small input-xsmall-text"
                                       placeholder="Source / discovery…"
                                       @bind="_manualClueSource[m.Id]" />
                            </label>
                            <label class="text-small">
                                Leverage
                                <select class="form-control mt-small form-select-medium" style="min-width:100px;"
                                        @bind="_manualClueLeverage[m.Id]">
                                    <option value="@ClueLeverageKind.Soft">Soft</option>
                                    <option value="@ClueLeverageKind.Hard">Hard</option>
                                </select>
                            </label>
                            <button type="button" class="btn-rn-ghost btn-small" disabled="@_busy"
                                    @onclick="() => AddClue(m.Id)">Add clue</button>
                        </div>
                        @if (m.Clues.Any())
                        {
                            <ul class="clue-list">
                                @foreach (var clue in m.Clues.OrderByDescending(c => c.Id))
                                {
                                    <li class="clue-item">
                                        @if (clue.IsSpent)
                                        {
                                            <span class="text-muted-rn">Spent:</span>
                                            <span>@clue.SourceDescription — @clue.Benefit</span>
                                        }
                                        else
                                        {
                                            <div><strong>Unspent</strong> · @clue.SourceDescription <span class="text-muted-rn">(@clue.LeverageKind)</span></div>
                                            <div class="clue-spend-row">
                                                <input class="form-control flex-1 input-xsmall-text" style="min-width:120px;"
                                                       placeholder="Recorded benefit…"
                                                       @bind="_spendBenefit[clue.Id]" />
                                                <button type="button" class="btn-rn-primary btn-xsmall" disabled="@_busy"
                                                        @onclick="() => SpendClue(clue.Id)">Spend</button>
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="impression-config-row">
                        <label class="text-small">Impression
                            <select class="form-control impression-select"
                                    value="@((int)m.CurrentImpression)"
                                    @onchange="e => SetImpression(m.Id, e)">
                                @foreach (ImpressionLevel il in Enum.GetValues<ImpressionLevel>())
                                {
                                    <option value="@((int)il)">@il</option>
                                }
                            </select>
                        </label>
                        <label class="text-small">Narrative doors
                            <input type="number" class="form-control doors-input"
                                   min="0" max="@m.InitialDoors"
                                   @bind="_narrativeDoorsDraft[m.Id]" />
                            <button type="button" class="btn-rn-ghost btn-small ml-small" disabled="@_busy"
                                    @onclick="() => ApplyNarrativeDoors(m.Id)">Apply</button>
                        </label>
                    </div>

                    @if (m.Status == ManeuverStatus.Active)
                    {
                        <div class="maneuver-actions-row">
                            <span class="text-small"><strong>Open Door</strong></span>
                            <input type="number" class="form-control pool-input" min="0" max="50"
                                   @bind="_openPool[m.Id]" />
                            <span class="btn-align-small text-muted-rn">pool</span>
                            <button type="button" class="btn-rn-primary btn-align-small" disabled="@_busy"
                                    @onclick="() => RollOpen(m.Id)">Roll open</button>
                            
                            <span class="text-small ml-small"><strong>Force Doors</strong></span>
                            <input type="number" class="form-control pool-input" min="0" max="50"
                                   @bind="_forcePool[m.Id]" />
                            <label class="btn-small">
                                <input type="checkbox" @bind="_forceHard[m.Id]" /> Hard leverage
                            </label>
                            @if (_forceHard.GetValueOrDefault(m.Id))
                            {
                                <label class="btn-small">BP severity
                                    <input type="number" class="form-control bp-severity-input" min="0" max="10"
                                           @bind="_forceBp[m.Id]" />
                                </label>
                            }
                            <button type="button" class="btn-rn-danger btn-align-small" disabled="@_busy"
                                    @onclick="() => RollForce(m.Id)">Roll force</button>
                        </div>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public int CampaignId { get; set; }
    [Parameter, EditorRequired] public string StorytellerId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IReadOnlyList<SocialManeuver> Maneuvers { get; set; } = [];
    [Parameter, EditorRequired] public List<CharacterVitalsDto> Vitals { get; set; } = [];
    [Parameter, EditorRequired] public List<ChronicleNpc> Npcs { get; set; } = [];
    [Parameter, EditorRequired] public int InitialClueThreshold { get; set; }
    [Parameter] public HashSet<int> PinnedNpcIds { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _busy;
    private int _thresholdDraft;
    private HashSet<int> _pinnedNpcIds => PinnedNpcIds;

    // New Maneuver Draft
    private int _newInitiatorId;
    private int _newTargetNpcId;
    private string _newGoal = string.Empty;
    private bool _newBreakingPoint;
    private bool _newAspiration;
    private bool _newVirtueMask;

    // State Dictionaries
    private Dictionary<int, int> _bankSuccesses = [];
    private Dictionary<int, string> _manualClueSource = [];
    private Dictionary<int, ClueLeverageKind> _manualClueLeverage = [];
    private Dictionary<int, string> _spendBenefit = [];
    private Dictionary<int, int> _narrativeDoorsDraft = [];
    private Dictionary<int, int> _openPool = [];
    private Dictionary<int, int> _forcePool = [];
    private Dictionary<int, bool> _forceHard = [];
    private Dictionary<int, int> _forceBp = [];

    protected override void OnParametersSet()
    {
        _thresholdDraft = InitialClueThreshold;
        foreach (var m in Maneuvers)
        {
            _bankSuccesses.TryAdd(m.Id, 1);
            _manualClueSource.TryAdd(m.Id, string.Empty);
            _manualClueLeverage.TryAdd(m.Id, ClueLeverageKind.Soft);
            _narrativeDoorsDraft.TryAdd(m.Id, m.RemainingDoors);
            _openPool.TryAdd(m.Id, 5);
            _forcePool.TryAdd(m.Id, 5);
            _forceHard.TryAdd(m.Id, false);
            _forceBp.TryAdd(m.Id, 2);
        }
    }

    private int GetClueThreshold(SocialManeuver m) => m.Campaign?.SocialManeuverInvestigationSuccessesPerClue ?? InitialClueThreshold;

    private async Task SaveThreshold()
    {
        _busy = true;
        try {
            await SocialService.SetInvestigationSuccessesPerClueAsync(CampaignId, _thresholdDraft, StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task CreateManeuver()
    {
        _busy = true;
        try {
            await SocialService.CreateAsync(CampaignId, _newInitiatorId, _newTargetNpcId, _newGoal, _newBreakingPoint, _newAspiration, _newVirtueMask, StorytellerId);
            _newGoal = "";
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task BankInvestigation(int mId)
    {
        _busy = true;
        try {
            await SocialService.BankInvestigationSuccessesAsync(mId, _bankSuccesses[mId], StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task AddClue(int mId)
    {
        _busy = true;
        try {
            await SocialService.AddManeuverClueAsync(mId, _manualClueSource[mId], _manualClueLeverage[mId], StorytellerId);
            _manualClueSource[mId] = "";
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task SpendClue(int clueId)
    {
        _busy = true;
        try {
            await SocialService.SpendManeuverClueAsync(clueId, _spendBenefit[clueId], StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task SetImpression(int mId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            await SocialService.SetImpressionAsync(mId, (ImpressionLevel)val, StorytellerId);
            await OnChanged.InvokeAsync();
        }
    }

    private async Task ApplyNarrativeDoors(int mId)
    {
        await SocialService.SetRemainingDoorsNarrativeAsync(mId, _narrativeDoorsDraft[mId], StorytellerId);
        await OnChanged.InvokeAsync();
    }

    private async Task RollOpen(int mId)
    {
        await SocialService.RollOpenDoorAsync(mId, _openPool[mId], StorytellerId);
        await OnChanged.InvokeAsync();
    }

    private async Task RollForce(int mId)
    {
        await SocialService.RollForceDoorsAsync(mId, _forcePool[mId], _forceHard[mId], _forceBp[mId], StorytellerId);
        await OnChanged.InvokeAsync();
    }
}
