@using RequiemNexus.Application.Contracts
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.Models.Enums
@using RequiemNexus.Application.DTOs
@using RequiemNexus.Domain.Enums
@using System.Globalization
@using System.Linq
@using RequiemNexus.Web.Services
@using RequiemNexus.Web.Components.Pages.Campaigns.GlimpseSocialManeuverParts
@inject ISocialManeuveringService SocialService
@inject ISocialManeuverRollService SocialRollService
@inject ToastService ToastService

<div class="glimpse-social-root card-rn glimpse-card">
    <h3 class="section-header">Social Maneuvering</h3>
    <p class="social-description">
        Targets must be chronicle NPCs only. On <strong>Force Doors</strong>, failure marks the relationship <strong>Burnt</strong> — no further Social maneuvering against that NPC by this PC.
    </p>

    <GlimpseSocialManeuverThresholdPanel @bind-ThresholdDraft="_thresholdDraft"
                                         Busy="_busy"
                                         OnSave="SaveThreshold" />

    <GlimpseSocialManeuverNewForm Vitals="Vitals"
                                  Npcs="Npcs"
                                  PinnedNpcIds="_pinnedNpcIds"
                                  @bind-InitiatorId="_newInitiatorId"
                                  @bind-TargetNpcId="_newTargetNpcId"
                                  @bind-Goal="_newGoal"
                                  @bind-BreakingPoint="_newBreakingPoint"
                                  @bind-Aspiration="_newAspiration"
                                  @bind-VirtueMask="_newVirtueMask"
                                  Busy="_busy"
                                  OnCreate="CreateManeuver" />

    @if (!Maneuvers.Any())
    {
        <p class="empty-maneuvers">No maneuvers yet.</p>
    }
    else
    {
        <ul class="maneuver-list">
            @foreach (SocialManeuver m in Maneuvers)
            {
                <GlimpseSocialManeuverCard M="m"
                                            Vitals="Vitals"
                                            InitialClueThreshold="InitialClueThreshold"
                                            Busy="_busy"
                                            BankSuccesses="_bankSuccesses"
                                            ManualClueSource="_manualClueSource"
                                            ManualClueLeverage="_manualClueLeverage"
                                            SpendBenefit="_spendBenefit"
                                            NarrativeDoorsDraft="_narrativeDoorsDraft"
                                            OpenPool="_openPool"
                                            ForcePool="_forcePool"
                                            ForceHard="_forceHard"
                                            ForceBp="_forceBp"
                                            AddInterceptorCharacterId="_addInterceptorCharacterId"
                                            InterceptorSuccessDraft="_interceptorSuccessDraft"
                                            OnBankInvestigation="BankInvestigation"
                                            OnAddClue="AddClue"
                                            OnSpendClue="SpendClue"
                                            OnSetImpression="SetImpressionAsync"
                                            OnApplyNarrativeDoors="ApplyNarrativeDoors"
                                            OnRollOpen="RollOpen"
                                            OnRollForce="RollForce"
                                            OnAddInterceptor="AddInterceptorToManeuver"
                                            OnRecordInterceptorOpposition="RecordInterceptorOpposition" />
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public int CampaignId { get; set; }
    [Parameter, EditorRequired] public string StorytellerId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IReadOnlyList<SocialManeuver> Maneuvers { get; set; } = [];
    [Parameter, EditorRequired] public List<CharacterVitalsDto> Vitals { get; set; } = [];
    [Parameter, EditorRequired] public List<ChronicleNpc> Npcs { get; set; } = [];
    [Parameter, EditorRequired] public int InitialClueThreshold { get; set; }
    [Parameter] public HashSet<int> PinnedNpcIds { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _busy;
    private int _thresholdDraft;
    private HashSet<int> _pinnedNpcIds => PinnedNpcIds;

    // New Maneuver Draft
    private int _newInitiatorId;
    private int _newTargetNpcId;
    private string _newGoal = string.Empty;
    private bool _newBreakingPoint;
    private bool _newAspiration;
    private bool _newVirtueMask;

    // State Dictionaries
    private Dictionary<int, int> _bankSuccesses = [];
    private Dictionary<int, string> _manualClueSource = [];
    private Dictionary<int, ClueLeverageKind> _manualClueLeverage = [];
    private Dictionary<int, string> _spendBenefit = [];
    private Dictionary<int, int> _narrativeDoorsDraft = [];
    private Dictionary<int, int> _openPool = [];
    private Dictionary<int, int> _forcePool = [];
    private Dictionary<int, bool> _forceHard = [];
    private Dictionary<int, int> _forceBp = [];

    private Dictionary<int, int> _addInterceptorCharacterId = [];

    private Dictionary<int, int> _interceptorSuccessDraft = [];

    protected override void OnParametersSet()
    {
        _thresholdDraft = InitialClueThreshold;
        foreach (var m in Maneuvers)
        {
            _bankSuccesses.TryAdd(m.Id, 1);
            _manualClueSource.TryAdd(m.Id, string.Empty);
            _manualClueLeverage.TryAdd(m.Id, ClueLeverageKind.Soft);
            _narrativeDoorsDraft.TryAdd(m.Id, m.RemainingDoors);
            _openPool.TryAdd(m.Id, 5);
            _forcePool.TryAdd(m.Id, 5);
            _forceHard.TryAdd(m.Id, false);
            _forceBp.TryAdd(m.Id, 2);
            _addInterceptorCharacterId.TryAdd(m.Id, 0);
            foreach (ManeuverInterceptor intr in m.Interceptors)
            {
                _interceptorSuccessDraft.TryAdd(intr.Id, intr.Successes);
            }
        }
    }

    private async Task SaveThreshold()
    {
        _busy = true;
        try {
            await SocialService.SetInvestigationSuccessesPerClueAsync(CampaignId, _thresholdDraft, StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task CreateManeuver()
    {
        _busy = true;
        try {
            await SocialService.CreateAsync(CampaignId, _newInitiatorId, _newTargetNpcId, _newGoal, _newBreakingPoint, _newAspiration, _newVirtueMask, StorytellerId);
            _newGoal = "";
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task BankInvestigation(int mId)
    {
        _busy = true;
        try {
            await SocialService.BankInvestigationSuccessesAsync(mId, _bankSuccesses[mId], StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task AddClue(int mId)
    {
        _busy = true;
        try {
            await SocialService.AddManeuverClueAsync(mId, _manualClueSource[mId], _manualClueLeverage[mId], StorytellerId);
            _manualClueSource[mId] = "";
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task SpendClue(int clueId)
    {
        _busy = true;
        try {
            await SocialService.SpendManeuverClueAsync(clueId, _spendBenefit[clueId], StorytellerId);
            await OnChanged.InvokeAsync();
        } finally { _busy = false; }
    }

    private async Task SetImpressionAsync((int ManeuverId, ImpressionLevel Level) args)
    {
        await SocialService.SetImpressionAsync(args.ManeuverId, args.Level, StorytellerId);
        await OnChanged.InvokeAsync();
    }

    private async Task ApplyNarrativeDoors(int mId)
    {
        await SocialService.SetRemainingDoorsNarrativeAsync(mId, _narrativeDoorsDraft[mId], StorytellerId);
        await OnChanged.InvokeAsync();
    }

    private async Task RollOpen(int mId)
    {
        var result = await SocialRollService.RollOpenDoorAsync(mId, _openPool[mId], StorytellerId);
        if (!result.IsSuccess)
        {
            ToastService.Show("Open Door", result.Error ?? "Roll failed.", ToastType.Error);
            return;
        }

        await OnChanged.InvokeAsync();
    }

    private async Task RollForce(int mId)
    {
        var result = await SocialRollService.RollForceDoorsAsync(mId, _forcePool[mId], _forceHard[mId], _forceBp[mId], StorytellerId);
        if (!result.IsSuccess)
        {
            ToastService.Show("Force Doors", result.Error ?? "Roll failed.", ToastType.Error);
            return;
        }

        await OnChanged.InvokeAsync();
    }

    private async Task AddInterceptorToManeuver(int maneuverId)
    {
        int pick = _addInterceptorCharacterId.GetValueOrDefault(maneuverId);
        if (pick == 0)
        {
            ToastService.Show("Interceptor", "Select a chronicle character first.", ToastType.Warning);
            return;
        }

        _busy = true;
        try
        {
            await SocialService.AddInterceptorAsync(maneuverId, pick, StorytellerId);
            _addInterceptorCharacterId[maneuverId] = 0;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            ToastService.Show("Interceptor", ex.Message, ToastType.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RecordInterceptorOpposition(int interceptorRowId)
    {
        if (!_interceptorSuccessDraft.TryGetValue(interceptorRowId, out int successes))
        {
            ToastService.Show("Interceptor", "Enter a success count.", ToastType.Warning);
            return;
        }

        _busy = true;
        try
        {
            await SocialService.RecordInterceptorRollAsync(interceptorRowId, successes, StorytellerId);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            ToastService.Show("Interceptor", ex.Message, ToastType.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
