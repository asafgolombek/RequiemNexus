@using RequiemNexus.Data.Models
@using RequiemNexus.Web.Components.UI

<div class="campaign-header">
    <div style="display:flex; justify-content: space-between; align-items: flex-start; width: 100%;">
        <div>
            <h2>@Campaign.Name</h2>
            <div class="storyteller-badge">
                <span>👑 Story Teller:</span> @(Campaign.StoryTeller?.UserName ?? Campaign.StoryTeller?.Email ?? "Unknown")
            </div>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-direction: column; align-items: flex-end;">
            @if (IsStoryteller)
            {
                @if (!SessionActive)
                {
                    <button class="btn-rn-primary" @onclick="OnStartSession">🔴 Start Live Session</button>
                }
                else
                {
                    <button class="btn-rn-danger" @onclick="OnEndSession">🛑 End Session</button>
                }
            }
            else if (SessionActive)
            {
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <span class="badge-live">🔴 LIVE SESSION ACTIVE</span>
                    @if (!IsStoryteller)
                    {
                        @if (!SessionClientConnected)
                        {
                            <button class="btn-rn-primary" style="font-size: 0.8rem; padding: 0.25rem 0.75rem;" @onclick="OnJoinSession">Join Session</button>
                        }
                        else
                        {
                            <span style="font-size: 0.8rem; color: var(--text-muted); border: 1px solid var(--border-subtle); padding: 0.25rem 0.75rem; border-radius: 4px;">Status: Presence Active</span>
                            <button class="btn-rn-ghost" style="font-size: 0.8rem; padding: 0.25rem 0.75rem; border: 1px solid var(--brand-crimson); margin-left: 0.5rem;" @onclick="OnLeaveSession">Leave Session</button>
                        }
                    }
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(SessionHubMessage))
    {
        <div class="alert-rn alert-warning" style="margin-top:0.75rem;font-size:0.9rem;" role="status">
            @SessionHubMessage
        </div>
    }

    <SessionPresenceBar SessionActive="SessionActive" />

    @if (IsStoryteller)
    {
        <StorytellerChronicleNav CampaignId="Campaign.Id" />
        <div class="flex-row flex-wrap items-center gap-sm" style="margin-top: 0.5rem;">
            <button type="button" class="btn-rn-ghost" @onclick="OnOpenInviteModal">Player invite</button>
            @if (!string.IsNullOrEmpty(Campaign.InviteTokenHash))
            {
                <span class="badge-live" style="font-size:0.75rem;">Invite on</span>
            }
            <button type="button" class="btn-rn-ghost" @onclick="OnOpenDiscordWebhookModal">Discord session updates</button>
            @if (!string.IsNullOrEmpty(Campaign.DiscordWebhookUrl))
            {
                <span class="badge-live" style="font-size:0.75rem;">Discord on</span>
            }
        </div>
        <PlayerInviteModal IsOpen="@InviteModalOpen"
                           InviteActive="@(!string.IsNullOrEmpty(Campaign.InviteTokenHash))"
                           LastGeneratedJoinUrl="@LastGeneratedJoinUrl"
                           Busy="@InviteBusy"
                           OnClose="OnCloseInviteModal"
                           OnRegenerate="OnRegenerateInvite"
                           OnClear="OnClearInvite"
                           OnCopy="OnCopyJoinUrl" />
        <DiscordWebhookModal IsOpen="@DiscordWebhookModalOpen"
                             InitialWebhookUrl="@Campaign.DiscordWebhookUrl"
                             Busy="@DiscordWebhookBusy"
                             OnClose="OnCloseDiscordWebhookModal"
                             OnSave="OnSaveDiscordWebhook" />
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Campaign Campaign { get; set; } = default!;

    [Parameter]
    public bool IsStoryteller { get; set; }

    [Parameter]
    public bool SessionActive { get; set; }

    [Parameter]
    public bool SessionClientConnected { get; set; }

    [Parameter]
    public string? SessionHubMessage { get; set; }

    [Parameter]
    public bool InviteModalOpen { get; set; }

    [Parameter]
    public bool InviteBusy { get; set; }

    [Parameter]
    public string? LastGeneratedJoinUrl { get; set; }

    [Parameter]
    public EventCallback OnStartSession { get; set; }

    [Parameter]
    public EventCallback OnEndSession { get; set; }

    [Parameter]
    public EventCallback OnJoinSession { get; set; }

    [Parameter]
    public EventCallback OnLeaveSession { get; set; }

    [Parameter]
    public EventCallback OnOpenInviteModal { get; set; }

    [Parameter]
    public EventCallback OnCloseInviteModal { get; set; }

    [Parameter]
    public EventCallback OnRegenerateInvite { get; set; }

    [Parameter]
    public EventCallback OnClearInvite { get; set; }

    [Parameter]
    public EventCallback OnCopyJoinUrl { get; set; }

    [Parameter]
    public bool DiscordWebhookModalOpen { get; set; }

    [Parameter]
    public bool DiscordWebhookBusy { get; set; }

    [Parameter]
    public EventCallback OnOpenDiscordWebhookModal { get; set; }

    [Parameter]
    public EventCallback OnCloseDiscordWebhookModal { get; set; }

    [Parameter]
    public EventCallback<string?> OnSaveDiscordWebhook { get; set; }
}
