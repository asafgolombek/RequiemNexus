@page "/campaigns/{Id:int}/encounters"
@rendermode InteractiveServer
@using System.Globalization
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Application.RealTime
@using RequiemNexus.Data.Models
@using RequiemNexus.Data.RealTime
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using RequiemNexus.Web.Enums
@using RequiemNexus.Web.Components.Pages.Campaigns.EncounterParts
@inject IEncounterService EncounterService
@inject IEncounterQueryService EncounterQueryService
@inject IEncounterParticipantService EncounterParticipantService
@inject IEncounterPrepService EncounterPrepService
@inject IEncounterTemplateService EncounterTemplateService
@inject IChronicleNpcService ChronicleNpcService
@inject ICampaignService CampaignService
@inject INpcStatBlockService NpcStatBlockService
@inject ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Encounters — Requiem Nexus</PageTitle>

<div class="page-container fade-in">
    @if (_loading)
    {
        <SkeletonLoader Variant="encounter-list" Count="7" />
    }
    else if (_accessDenied)
    {
        <div class="alert-rn alert-danger">
            <strong>Access Denied</strong> — only the campaign Storyteller may manage encounters.
        </div>
    }
    else
    {
        <div class="campaign-header">
            <h2>Encounter Manager</h2>
            <StorytellerChronicleNav CampaignId="Id" />
        </div>

        @* Create encounter (prep) *@
        @if (!_showCreateEncounterForm)
        {
            <div class="flex-row flex-wrap items-center gap-sm" style="margin-bottom:1.5rem; justify-content:flex-end;">
                <button type="button" class="btn-rn-primary" @onclick="OpenCreateEncounterForm">Create encounter</button>
            </div>
        }
        else
        {
            <EncounterCreateFormPanel @bind-Name="_formEncounterName"
                                      @bind-Notes="_formEncounterNotes"
                                      FormDraftEncounter="FormDraftEncounter"
                                      CreateError="@_createError"
                                      Busy="_busy"
                                      OnStartNow="CreateFormStartNowAsync"
                                      OnSaveForLater="CreateFormSaveForLaterAsync"
                                      OnDiscard="DiscardCreateEncounterFormAsync"
                                      OnAddNpc="OpenAddNpcForCreateFormAsync"
                                      OnRemoveTemplate="RemoveTemplateRow" />
        }

        @if (_templates.Count > 0)
        {
            <EncounterFromTemplatePanel Templates="_templates"
                                        @bind-SelectedTemplateId="_selectedTemplateId"
                                        @bind-EncounterName="_fromTemplateEncounterName"
                                        Busy="_busy"
                                        OnCreate="CreateFromTemplate" />
        }

        <EncounterDraftPrepListSection DraftEncounters="DraftEncountersForList"
                                       PrepFeedback="@_prepFeedback"
                                       CreateError="@_createError"
                                       ShowCreateEncounterForm="_showCreateEncounterForm"
                                       Busy="_busy"
                                       RenamingEncounterId="_renamingEncounterId"
                                       @bind-RenameBuffer="_renameEncounterBuffer"
                                       SmartLaunchEncounterId="_smartLaunchEncounterId"
                                       SmartLaunchIsPrepStart="_smartLaunchIsPrepStart"
                                       CampaignCharacters="_campaignCharacters"
                                       SmartLaunchIsSelected="GetSmartCheck"
                                       OnSmartLaunchSelectionChanged="OnSmartLaunchSelectionChangedAsync"
                                       OnSmartLaunchConfirm="ConfirmSmartLaunch"
                                       OnSmartLaunchCancel="CancelSmartLaunchAsync"
                                       OnStartRename="OnDraftPrepStartRenameAsync"
                                       OnCancelRename="CancelEncounterRenameAsync"
                                       OnSaveRename="SaveEncounterRename"
                                       OnAddNpc="OpenNpcPickerForDraftAsync"
                                       OnStartPrep="OpenSmartLaunchPrepAsync"
                                       OnAckSaveForLater="AckSaveForLaterAsync"
                                       OnRemoveTemplate="RemoveTemplateRow" />

        <EncounterLaunchedAndPausedSection CampaignId="Id"
                                           LaunchedEncounters="LaunchedEncounters"
                                           PausedEncounters="PausedEncounters"
                                           Busy="_busy"
                                           SmartLaunchEncounterId="_smartLaunchEncounterId"
                                           SmartLaunchIsPrepStart="_smartLaunchIsPrepStart"
                                           CampaignCharacters="_campaignCharacters"
                                           SmartLaunchIsSelected="GetSmartCheck"
                                           OnSmartLaunchSelectionChanged="OnSmartLaunchSelectionChangedAsync"
                                           OnSmartLaunchConfirm="ConfirmSmartLaunch"
                                           OnSmartLaunchCancel="CancelSmartLaunchAsync"
                                           OnOnlinePlayers="OpenSmartLaunchForActiveAsync"
                                           OnAddNpcActive="OpenNpcPickerForActiveAsync"
                                           OnPause="PauseEncounter"
                                           OnResume="ResumeEncounter"
                                           OnResolve="ResolveEncounter" />

        @if (!DraftEncountersForList.Any() && !LaunchedEncounters.Any() && !PausedEncounters.Any() && !_showCreateEncounterForm)
        {
            <div class="empty-state-rn" style="margin-bottom:1.5rem;">
                <p>No encounters yet. Use <strong>Create encounter</strong>, add NPCs (stat block, Danse Macabre, or improvised), then <strong>Start now</strong> or <strong>Save for later</strong>.</p>
            </div>
        }

        <EncounterPastEncountersSection CampaignId="Id" PastEncounters="PastEncounters" />

        @if (_activeEncounterForNpc.HasValue && _npcPickerMode is not null)
        {
            <EncounterNpcPickerModal Title="@GetNpcModalTitle()"
                                     Busy="_busy"
                                     IsDraft="_npcPickerIsDraft"
                                     SourceMode="@_sourcePicker"
                                     StatMode="@_statPicker"
                                     ChronicleMode="@_chroniclePicker"
                                     ImprovMode="@_improvisedPicker"
                                     @bind-PickerMode="_npcPickerMode"
                                     AvailableBlocks="_availableBlocks"
                                     @bind-SelectedBlockId="_selectedBlockId"
                                     @bind-NpcInitMod="_npcInitMod"
                                     @bind-NpcRoll="_npcRoll"
                                     ChronicleNpcs="_chronicleNpcs"
                                     ExcludedChronicleNpcIds="_excludedChronicleNpcIds"
                                     SelectedChronicleNpcId="_selectedChronicleNpcId"
                                     OnChronicleNpcSelect="OnChronicleNpcSelectChanged"
                                     @bind-ChronicleHealthBoxes="_chronicleHealthBoxes"
                                     @bind-ChronicleMaxWillpower="_chronicleMaxWillpower"
                                     @bind-ChronicleMaxVitae="_chronicleMaxVitae"
                                     ChronicleTracksVitae="_chronicleTracksVitae"
                                     ChronicleAddError="@_chronicleAddError"
                                     ChroniclePrepHint="@_chroniclePrepHint"
                                     CampaignId="Id"
                                     @bind-ImprovName="_improvName"
                                     @bind-ImprovHealthBoxes="_improvHealthBoxes"
                                     @bind-ImprovMaxWillpower="_improvMaxWillpower"
                                     ImprovError="@_improvError"
                                     OnClose="CloseNpcPickerAsync"
                                     OnKeyDown="OnNpcModalKeyDownAsync"
                                     OnAddFromStatBlock="AddNpcFromStatBlock"
                                     OnAddFromChronicle="AddNpcFromChronicle"
                                     OnAddImprovised="AddImprovisedNpc" />
        }
    }
</div>
