@using RequiemNexus.Application.DTOs

@if (IsOpen)
{
<div class="rn-modal-backdrop" @onclick="CloseModal">
    <div class="rn-modal-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="scale-modal-title">
        <div class="rn-modal-header">
            <h2 id="scale-modal-title" class="rn-modal-title">Select Chosen Mystery</h2>
            <button type="button" class="rn-modal-close" @onclick="CloseModal" aria-label="Close">×</button>
        </div>
        <div class="rn-modal-body">
            @if (Scales.Count == 0)
            {
                <p class="rn-modal-empty">No Scales available.</p>
            }
            else
            {
                <ul class="rn-selection-list" role="list">
                    @foreach (var scale in Scales)
                    {
                        <li class="rn-selection-item" role="listitem">
                            <div class="rn-selection-info">
                                <strong class="rn-selection-name">@scale.Name</strong>
                                <span class="rn-selection-meta">@scale.MysteryName</span>
                                @if (!string.IsNullOrEmpty(scale.Description))
                                {
                                    <p class="rn-selection-desc">@scale.Description</p>
                                }
                            </div>
                            <button type="button" class="btn-primary-rn rn-selection-action" @onclick="() => SelectScale(scale.Id)">Select</button>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public List<ScaleSummaryDto> Scales { get; set; } = [];
    [Parameter] public EventCallback<int> OnScaleSelected { get; set; }

    private async Task SelectScale(int scaleId)
    {
        await OnScaleSelected.InvokeAsync(scaleId);
        await CloseModal();
    }

    private async Task CloseModal()
    {
        await IsOpenChanged.InvokeAsync(false);
    }
}
