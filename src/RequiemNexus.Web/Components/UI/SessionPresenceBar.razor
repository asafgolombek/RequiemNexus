@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@inject SessionClientService SessionService
@inject ScreenReaderAnnouncer Announcer
@implements IDisposable

@if (_players.Any() || SessionActive)
{
    <div class="presence-bar-container">
        <div class="presence-header" title="@(SessionActive ? "Players in the live session." : "Players who have this campaign or a campaign character open.")">@(SessionActive ? "🩸 In Session" : "Who's Here")</div>
        @if (_players.Any())
        {
            <div class="presence-bar">
                @foreach (var player in _players)
                {
                    <div class="player-chip" title="@player.UserName @(player.IsOnline ? "(Online)" : "(Offline)")">
                        <div class="avatar @(player.IsOnline ? "online" : "offline")">
                            @GetInitials(player.UserName)
                        </div>
                        <span class="player-name">@player.UserName</span>
                    </div>
                }
            </div>
        }
        else if (SessionActive)
        {
            <p class="presence-empty-hint" style="margin: 0.35rem 0 0; font-size: 0.85rem; color: var(--text-muted);">No one listed in session yet—use Join Session if you are not connected.</p>
        }
    </div>
}

@code {
    /// <summary>
    /// When true, a live session is active (ST has started it). When false, this shows lobby presence only.
    /// </summary>
    [Parameter]
    public bool SessionActive { get; set; }

    private List<PlayerPresenceDto> _players = new();

    private readonly Dictionary<string, string> _userDisplayNames = new();

    private HashSet<string> _previousUserIds = new();

    private IDisposable? _presenceSubscription;

    protected override void OnInitialized()
    {
        _presenceSubscription = SessionService.SubscribePresenceUpdated(HandlePresenceUpdated);
    }

    private void HandlePresenceUpdated(IEnumerable<PlayerPresenceDto> players)
    {
        List<PlayerPresenceDto> next = players.OrderBy(p => p.UserName).ToList();
        HashSet<string> nextIds = next.Select(p => p.UserId).ToHashSet(StringComparer.Ordinal);

        foreach (PlayerPresenceDto p in next)
        {
            _userDisplayNames[p.UserId] = p.UserName;
        }

        _ = InvokeAsync(async () =>
        {
            bool hadPriorSnapshot = _previousUserIds.Count > 0;

            if (hadPriorSnapshot)
            {
                foreach (PlayerPresenceDto p in next)
                {
                    if (!_previousUserIds.Contains(p.UserId))
                    {
                        await Announcer.AnnounceAsync($"{p.UserName} joined the session");
                    }
                }

                foreach (string id in _previousUserIds)
                {
                    if (!nextIds.Contains(id) && _userDisplayNames.TryGetValue(id, out string? name))
                    {
                        await Announcer.AnnounceAsync($"{name} left the session");
                    }
                }
            }

            _players = next;
            _previousUserIds = nextIds;
            StateHasChanged();
        });
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    public void Dispose()
    {
        _presenceSubscription?.Dispose();
    }
}
