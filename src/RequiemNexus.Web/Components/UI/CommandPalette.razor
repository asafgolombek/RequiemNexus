@using RequiemNexus.Web.Services
@using RequiemNexus.Application.Contracts
@using RequiemNexus.Data.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject CommandPaletteService PaletteService
@inject ICharacterService CharacterService
@inject ICampaignService CampaignService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

@if (PaletteService.IsOpen)
{
    <div class="palette-overlay" @onclick="Close" role="dialog" aria-modal="true" aria-label="Command palette">
        <div class="palette-card" @onclick:stopPropagation>
            <input @ref="_inputRef" class="palette-input" placeholder="Search characters, campaigns, pages..."
                   @bind-value="_query" @bind-value:event="oninput" @onkeydown="OnKeyDown" autofocus />
            <div class="palette-results">
                @foreach (var group in FilteredResults())
                {
                    <div class="palette-section">
                        <span class="palette-section-label">@group.Label</span>
                        @foreach (var item in group.Items)
                        {
                            <div class="palette-item @(item == _activeItem ? "active" : "")"
                                 @onclick="() => Navigate(item.Href)">
                                <span class="palette-item-icon">@item.Icon</span>
                                <span class="palette-item-label">@item.Name</span>
                            </div>
                        }
                    </div>
                }
                @if (!FilteredResults().Any())
                {
                    <div class="palette-no-results">No results found for "@_query"</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private ElementReference _inputRef;
    private string _query = string.Empty;
    private List<PaletteItem> _characters = new();
    private List<PaletteItem> _campaigns = new();
    private List<PaletteItem> _staticPages = new()
    {
        new PaletteItem("Dashboard", "/home", "🏠"),
        new PaletteItem("My Characters", "/characters", "🦇"),
        new PaletteItem("My Campaigns", "/campaigns", "⚔️"),
        new PaletteItem("Profile Settings", "/Account/Manage", "⚙️")
    };

    private PaletteItem? _activeItem;
    private string? _userId;
    private bool _paletteIndexLoaded;
    private bool _paletteIndexLoading;

    protected override async Task OnInitializedAsync()
    {
        PaletteService.OnStateChanged += HandleStateChanged;

        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private void HandleStateChanged()
    {
        if (PaletteService.IsOpen)
        {
            _query = string.Empty;
            _ = OnPaletteOpenedAsync();
        }
        else
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Loads character/campaign index only when the palette opens so every page navigation
    /// does not run duplicate DB queries alongside page-level loads (same scoped services/circuit).
    /// </summary>
    private async Task OnPaletteOpenedAsync()
    {
        await EnsurePaletteIndexAsync();
        _activeItem = FilteredResults().FirstOrDefault()?.Items.FirstOrDefault();
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnsurePaletteIndexAsync()
    {
        if (_paletteIndexLoaded || _paletteIndexLoading || string.IsNullOrEmpty(_userId))
        {
            return;
        }

        _paletteIndexLoading = true;
        try
        {
            List<Character> chars = await CharacterService.GetCharactersByUserIdAsync(_userId);
            _characters = chars.Select(c => new PaletteItem(c.Name, $"/character/{c.Id}", "🩸")).ToList();

            List<Campaign> camps = await CampaignService.GetCampaignsByUserIdAsync(_userId);
            _campaigns = camps.Select(c => new PaletteItem(c.Name, $"/campaigns/{c.Id}", "📜")).ToList();
            _paletteIndexLoaded = true;
        }
        finally
        {
            _paletteIndexLoading = false;
        }
    }

    private IEnumerable<PaletteSection> FilteredResults()
    {
        var results = new List<PaletteSection>();

        if (_query.StartsWith("/"))
        {
            var commands = new List<PaletteItem>();
            if ("/roll".StartsWith(_query, StringComparison.OrdinalIgnoreCase))
                commands.Add(new PaletteItem("Roll Dice", "command:roll", "🎲"));
            if ("/goto".StartsWith(_query, StringComparison.OrdinalIgnoreCase))
                commands.Add(new PaletteItem("Go to section...", "command:goto", "📍"));
            
            if (commands.Any())
            {
                results.Add(new PaletteSection("Commands", commands));
                return results;
            }
        }

        var filteredPages = _staticPages.Where(i => i.Name.Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();
        if (filteredPages.Any()) results.Add(new PaletteSection("Pages", filteredPages));

        var filteredChars = _characters.Where(i => i.Name.Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();
        if (filteredChars.Any()) results.Add(new PaletteSection("Characters", filteredChars));

        var filteredCamps = _campaigns.Where(i => i.Name.Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();
        if (filteredCamps.Any()) results.Add(new PaletteSection("Campaigns", filteredCamps));

        return results;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        var allItems = FilteredResults().SelectMany(s => s.Items).ToList();
        
        if (e.Key == "Enter")
        {
            if (_activeItem != null)
            {
                ExecuteItem(_activeItem);
            }
            else if (_query.StartsWith("/roll "))
            {
                ExecuteRollCommand(_query[6..]);
            }
            return;
        }

        if (!allItems.Any()) return;

        int index = _activeItem == null ? -1 : allItems.IndexOf(_activeItem);

        if (e.Key == "ArrowDown")
        {
            index = (index + 1) % allItems.Count;
            _activeItem = allItems[index];
        }
        else if (e.Key == "ArrowUp")
        {
            index = (index - 1 + allItems.Count) % allItems.Count;
            _activeItem = allItems[index];
        }
        else if (e.Key == "Escape")
        {
            Close();
        }
    }

    private void ExecuteItem(PaletteItem item)
    {
        if (item.Href.StartsWith("command:"))
        {
            HandleInternalCommand(item.Href);
        }
        else
        {
            Navigate(item.Href);
        }
    }

    private void HandleInternalCommand(string command)
    {
        switch (command)
        {
            case "command:roll":
                _query = "/roll ";
                _activeItem = null;
                break;
            case "command:goto":
                _query = "/goto ";
                _activeItem = null;
                break;
        }
    }

    private void ExecuteRollCommand(string args)
    {
        // For now, we'll just show a toast or navigate to a specialized roll page if it existed.
        // In a real implementation, this could trigger the DiceRollerModal via a service.
        PaletteService.Close();
        // Placeholder for triggering roll logic
    }

    private void Navigate(string href)
    {
        PaletteService.Close();
        NavigationManager.NavigateTo(href);
    }

    private void Close() => PaletteService.Close();

    public void Dispose()
    {
        PaletteService.OnStateChanged -= HandleStateChanged;
    }

    private record PaletteItem(string Name, string Href, string Icon);
    private record PaletteSection(string Label, List<PaletteItem> Items);
}
