@using RequiemNexus.Data.Models
@using RequiemNexus.Domain.Models

@if (IsOpen && Power != null)
{
    <div class="rn-modal-backdrop" @onclick="CloseAsync">
        <div class="rn-modal-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="discipline-activate-modal-title">
            <div class="rn-modal-header">
                <h2 id="discipline-activate-modal-title" class="rn-modal-title">Activate discipline power</h2>
                <button type="button" class="rn-modal-close" @onclick="CloseAsync" aria-label="Close">×</button>
            </div>
            <div class="rn-modal-body">
                <p class="rn-modal-empty" style="margin-bottom: 0.75rem;">
                    <strong>@Power.Name</strong>
                    <span class="text-muted-rn"> — Level @Power.Level</span>
                </p>
                <p>
                    <span class="trait-subheading">Pool (preview):</span>
                    @(ResolvedPool <= 0 ? "Chance die" : ResolvedPool.ToString())
                </p>
                @if (!string.IsNullOrWhiteSpace(Power.Cost))
                {
                    <p>
                        <span class="trait-subheading">Cost:</span>
                        @Power.Cost
                    </p>
                }
                @if (ParsedCost.IsPlayerChoiceVitaeOrWillpower)
                {
                    <fieldset class="rn-fieldset-plain" style="margin-top: 0.75rem; border: 0; padding: 0;">
                        <legend class="trait-subheading" style="margin-bottom: 0.35rem;">Spend</legend>
                        <label class="rn-radio-row" style="display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.25rem;">
                            <input type="radio" name="discipline-cost-choice" checked="@(_playerChoiceSelection == DisciplineActivationResourceChoice.Vitae)"
                                   @onchange="@(() => _playerChoiceSelection = DisciplineActivationResourceChoice.Vitae)" />
                            <span>Vitae (@ParsedCost.Amount)</span>
                        </label>
                        <label class="rn-radio-row" style="display: flex; align-items: center; gap: 0.35rem;">
                            <input type="radio" name="discipline-cost-choice" checked="@(_playerChoiceSelection == DisciplineActivationResourceChoice.Willpower)"
                                   @onchange="@(() => _playerChoiceSelection = DisciplineActivationResourceChoice.Willpower)" />
                            <span>Willpower (@ParsedCost.PlayerChoiceWillpowerAmount)</span>
                        </label>
                    </fieldset>
                }
                else if (!IsFreeCost(Power.Cost))
                {
                    <p class="text-muted-rn" style="font-size: 0.9em;">
                        Confirming spends Vitae or Willpower before you roll, as shown above.
                    </p>
                }
            </div>
            <div class="rn-modal-footer" style="display: flex; gap: 0.5rem; justify-content: flex-end; flex-wrap: wrap;">
                <button type="button" class="btn-rn-ghost" @onclick="CloseAsync">Cancel</button>
                <button type="button" class="btn-rn-primary" @onclick="ConfirmAsync">Confirm &amp; Roll</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public DisciplinePower? Power { get; set; }

    [Parameter]
    public int ResolvedPool { get; set; }

    [Parameter]
    public EventCallback<DisciplineActivationResourceChoice?> OnConfirmed { get; set; }

    private DisciplineActivationResourceChoice _playerChoiceSelection = DisciplineActivationResourceChoice.Vitae;

    private int? _lastPowerIdForChoiceReset;

    private ActivationCost ParsedCost => Power != null ? ActivationCost.Parse(Power.Cost) : ActivationCost.None;

    protected override void OnParametersSet()
    {
        if (IsOpen && Power != null && _lastPowerIdForChoiceReset != Power.Id)
        {
            _lastPowerIdForChoiceReset = Power.Id;
            _playerChoiceSelection = DisciplineActivationResourceChoice.Vitae;
        }

        if (!IsOpen)
        {
            _lastPowerIdForChoiceReset = null;
        }
    }

    private static bool IsFreeCost(string? cost)
    {
        return ActivationCost.Parse(cost).IsNone;
    }

    private async Task CloseAsync()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task ConfirmAsync()
    {
        if (Power == null)
        {
            return;
        }

        ActivationCost parsed = ActivationCost.Parse(Power.Cost);
        if (parsed.IsPlayerChoiceVitaeOrWillpower)
        {
            await OnConfirmed.InvokeAsync(_playerChoiceSelection);
        }
        else
        {
            await OnConfirmed.InvokeAsync(null);
        }
    }
}
