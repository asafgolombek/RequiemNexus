@* SVG paths derived from Lucide (MIT): https://lucide.dev *@
<svg xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round"
     class="@Class"
     aria-hidden="@(Title == null ? "true" : "false")"
     focusable="false"
     @attributes="AdditionalAttributes">
    @if (Title is not null)
    {
        <title>@Title</title>
    }
    @switch (Name)
    {
        case IconName.Users:
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            break;
        case IconName.BookOpen:
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            break;
        case IconName.Droplet:
            <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z" />
            break;
        case IconName.Search:
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
            break;
        case IconName.Menu:
            <path d="M4 5h16" />
            <path d="M4 12h16" />
            <path d="M4 19h16" />
            break;
        case IconName.ChevronRight:
            <path d="m9 18 6-6-6-6" />
            break;
        case IconName.CircleCheck:
            <circle cx="12" cy="12" r="10" />
            <path d="m9 12 2 2 4-4" />
            break;
        case IconName.CircleX:
            <circle cx="12" cy="12" r="10" />
            <path d="m15 9-6 6" />
            <path d="m9 9 6 6" />
            break;
        case IconName.TriangleAlert:
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
            <path d="M12 9v4" />
            <path d="M12 17h.01" />
            break;
        case IconName.Info:
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4" />
            <path d="M12 8h.01" />
            break;
    }
</svg>

@code {
    /// <summary>Which built-in glyph to render.</summary>
    [Parameter]
    public IconName Name { get; set; }

    /// <summary>Optional CSS classes (e.g. sizing via w-100 h-100 from parent).</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>When set, the icon is exposed to assistive tech with this label; otherwise it is decorative (<c>aria-hidden</c>).</summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>Additional attributes merged onto the root <c>svg</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
