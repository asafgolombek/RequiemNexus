@using RequiemNexus.Domain.Services
@using RequiemNexus.Domain.Contracts
@using RequiemNexus.Domain.Models
@inject IDiceService DiceService

@if (IsVisible)
{
    <div class="modal-backdrop @(_isRolling ? "backdrop-surge" : "")" @onclick="Close">
        <div class="modal-panel" @onclick:stopPropagation>
            @if (_showBurst)
            {
                <div class="particle-burst" aria-hidden="true">
                    @for (int a = 0; a < 8; a++)
                    {
                        <span class="burst-particle" style="--angle: @(a * 45)deg"></span>
                    }
                </div>
            }

            <div class="modal-header">
                <h3>Roll: @TraitName</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            
            <div class="modal-body">
                <div class="roller-form-group">
                    <label>Base Trait (@TraitName)</label>
                    <input type="number" value="@BaseDice" readonly class="roller-input" style="background: rgba(0,0,0,0.5);" />
                </div>
                
                @if (Character != null)
                {
                    <div class="roller-form-group">
                        <label>Associated Trait</label>
                        <select @bind="_associatedTraitName" class="roller-input" style="width: 100%; padding: 8px;">
                            <option value="">-- None --</option>
                            <optgroup label="Attributes">
                                @foreach (var attr in _attributes.Where(a => a != TraitName))
                                {
                                    <option value="@attr">@attr</option>
                                }
                            </optgroup>

                            <optgroup label="Skills">
                                @foreach (var skill in _skills.Where(s => s != TraitName))
                                {
                                    <option value="@skill">@skill</option>
                                }
                            </optgroup>

                        </select>
                    </div>
                }

                <div class="roller-form-group">
                    <label>Modifiers (Bonus / Penalty)</label>
                    <input type="number" @bind="_modifier" class="roller-input" />
                </div>
                
                <div class="roller-form-group">
                    <label>Total Pool</label>
                    <strong class="pool-total">@(TotalPool <= 0 ? "Chance Die" : TotalPool.ToString())</strong>
                </div>

                <div class="options-group">
                    <label class="option-label"><input type="checkbox" @bind="_tenAgain" /> 10-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_nineAgain" /> 9-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_eightAgain" /> 8-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_isRote" /> Rote Action</label>
                </div>
                
                <div class="roller-actions">
                    <button class="btn-primary-rn roll-action-btn" @onclick="RollDice">Roll the Dice</button>
                    @if (_showTools)
                    {
                        <div class="debug-tools">
                            <label>Seed (Deterministic Mode)</label>
                            <input type="number" @bind="_seed" class="roller-input" placeholder="Optional" />
                        </div>
                    }
                    <button class="btn-ghost debug-toggle" @onclick="() => _showTools = !_showTools">
                        @(_showTools ? "Hide" : "Show") Debug Tools
                    </button>
                </div>
                
                @if (_lastResult != null)
                {
                    <div class="result-box @(_lastResult.IsExceptionalSuccess ? "exceptional" : "") @(_lastResult.IsDramaticFailure ? "dramatic-failure" : "") @(_shakeClass)">
                        <h4 class="result-title">
                            <span id="@_successCountId">0</span> Success@(_lastResult.Successes != 1 ? "es" : "")
                        </h4>
                        @if (_lastResult.IsExceptionalSuccess)
                        {
                            <span class="result-badge exceptional-badge">✨ Exceptional Success!</span>
                        }
                        @if (_lastResult.IsDramaticFailure)
                        {
                            <span class="result-badge failure-badge">💀 Dramatic Failure!</span>
                        }
                        
                        <div class="dice-results">
                            @{ int dieIndex = 0; }
                            @foreach (var die in _lastResult.DiceRolled)
                            {
                                <span class="die-result @(die >= 8 ? "success-die" : "fail-die")"
                                      style="--die-index: @dieIndex">@die</span>
                                dieIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string TraitName { get; set; } = string.Empty;
    [Parameter] public int BaseDice { get; set; } = 1;
    [Parameter] public RequiemNexus.Data.Models.Character? Character { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string _associatedTraitName { get; set; } = string.Empty;
    private int _modifier { get; set; } = 0;
    private bool _tenAgain { get; set; } = true;
    private bool _nineAgain { get; set; } = false;
    private bool _eightAgain { get; set; } = false;
    private bool _isRote { get; set; } = false;
    private int? _seed { get; set; } = null;
    private RollResult? _lastResult;
    private bool _showTools = false;

    private string _successCountId = $"success-count-{Guid.NewGuid():N}";
    private string _shakeClass = string.Empty;
    private bool _showBurst = false;
    private bool _isRolling = false;

    private readonly string[] _attributes = RequiemNexus.Domain.TraitMetadata.AllAttributes.Select(a => a.ToString()).ToArray();
    private readonly string[] _skills = RequiemNexus.Domain.TraitMetadata.AllSkills.Select(s => s.ToString()).ToArray();

    private int AssociatedTraitDice
    {
        get
        {
            if (string.IsNullOrEmpty(_associatedTraitName) || Character == null) return 0;
            var propName = _associatedTraitName.Replace(" ", "");
            if (RequiemNexus.Domain.TraitMetadata.IsAttribute(propName))
                return Character.GetAttributeRating(propName);
            else
                return Character.GetSkillRating(propName);
        }
    }

    private int TotalPool => BaseDice + AssociatedTraitDice + _modifier;

    private async Task Close()
    {
        IsVisible = false;
        _lastResult = null;
        _associatedTraitName = string.Empty;
        _modifier = 0;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task RollDice()
    {
        _isRolling = true;
        _lastResult = DiceService.Roll(TotalPool, _tenAgain, _nineAgain, _eightAgain, _isRote, _seed);
        
        // Reset effects
        _shakeClass = string.Empty;
        _showBurst = false;

        await InvokeAsync(StateHasChanged);

        // Success counter odometer
        await JS.InvokeVoidAsync("countUp", _successCountId, _lastResult.Successes, 600);

        // Dramatic Failure Screen Shake
        if (_lastResult.IsDramaticFailure)
        {
            _shakeClass = "shake";
        }

        // Exceptional Success Particle Burst
        if (_lastResult.IsExceptionalSuccess)
        {
            _showBurst = true;
        }

        await Task.Delay(400); // Wait for surge animation to complete roughly
        _isRolling = false;
        
        await InvokeAsync(StateHasChanged);
        
        if (_showBurst)
        {
            await Task.Delay(700);
            _showBurst = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
