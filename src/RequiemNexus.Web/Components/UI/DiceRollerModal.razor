@using RequiemNexus.Domain.Services
@using RequiemNexus.Domain.Contracts
@using RequiemNexus.Domain.Models
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using RequiemNexus.Application.Contracts
@using System.Security.Claims
@using Microsoft.JSInterop
@inject ToastService ToastService
@inject IDiceService DiceService
@inject SessionClientService SessionClient
@inject IPublicRollService PublicRollService
@inject ITraitResolver TraitResolver
@inject IRiteRollOutcomeService RiteRollOutcomeService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal-backdrop @(_isRolling ? "backdrop-surge" : "")" @onclick="Close">
        <div class="modal-panel dice-roller-modal" @onclick:stopPropagation role="dialog" aria-modal="true" aria-labelledby="dice-roller-title">
            @if (_showBurst)
            {
                <div class="particle-burst" aria-hidden="true">
                    @for (int a = 0; a < 8; a++)
                    {
                        <span class="burst-particle" style="--angle: @(a * 45)deg"></span>
                    }
                </div>
            }

            <div class="modal-header">
                <h3 id="dice-roller-title">@(IsRiteExtendedMode ? $"Rite: {TraitName}" : $"Roll: {TraitName}")</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            
            <div class="modal-body">
                @if (IsRiteExtendedMode)
                {
                    <RiteExtendedRollPanel AccumulatedSuccesses="_riteAccumulatedSuccesses"
                                           TargetSuccesses="RiteExtendedTargetSuccesses!.Value"
                                           RollsRemaining="RiteRollsRemaining"
                                           MaxRolls="RiteExtendedMaxRolls!.Value"
                                           MinutesPerRoll="RiteExtendedMinutesPerRoll"
                                           ShowCompletedBanner="ShowRiteCompletedBanner"
                                           ShowFailedNoRollsBanner="ShowRiteFailedNoRollsBanner"
                                           HadExceptionalSuccess="_riteHadExceptionalSuccess"
                                           AddDisciplineDotsToPotency="_addRiteDisciplineDotsToPotency"
                                           AddDisciplineDotsToPotencyChanged="OnAddRiteDisciplineDotsToPotencyChanged"
                                           RitualDisciplineDots="RiteExtendedRitualDisciplineDots"
                                           OutcomeTradition="RiteOutcomeTradition" />
                }
                <DiceRollerStandardPanel TraitName="TraitName"
                                         BaseDice="BaseDice"
                                         Character="Character"
                                         FixedDicePool="FixedDicePool"
                                         IsRiteExtendedMode="IsRiteExtendedMode"
                                         IsChanceDiePool="IsChanceDiePool"
                                         TotalPool="TotalPool"
                                         AttributeNames="_attributes"
                                         SkillNames="_skills"
                                         AssociatedTraitName="@_associatedTraitName"
                                         AssociatedTraitNameChanged="OnAssociatedTraitFromPanelAsync"
                                         Modifier="_modifier"
                                         ModifierChanged="OnModifierFromPanelAsync"
                                         TenAgain="_tenAgain"
                                         TenAgainChanged="OnTenAgainFromPanelAsync"
                                         NineAgain="_nineAgain"
                                         NineAgainChanged="OnNineAgainFromPanelAsync"
                                         EightAgain="_eightAgain"
                                         EightAgainChanged="OnEightAgainFromPanelAsync"
                                         IsRote="_isRote"
                                         IsRoteChanged="OnIsRoteFromPanelAsync" />
                
                @if (IsRiteExtendedMode && _riteFailureNeedsChoice)
                {
                    <div class="roller-form-group" style="border: 1px solid rgba(255,200,200,0.3); padding: 0.75rem; border-radius: 6px;">
                        <p style="margin: 0 0 0.5rem 0;">This roll scored no successes. Continue to take the Stumbled Condition and keep casting, or abandon (costs stay spent).</p>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <button type="button" class="btn-rn-primary" @onclick="ContinueAfterRiteFailureAsync">Continue ritual</button>
                            <button type="button" class="btn-rn-ghost" @onclick="AbandonRite">Abandon (costs already spent)</button>
                        </div>
                    </div>
                }
                <div class="roller-actions">
                    <button class="btn-rn-primary roll-action-btn" @onclick="RollDice" disabled="@RiteRollButtonDisabled">Roll the Dice</button>
                    @if (_showTools)
                    {
                        <div class="debug-tools">
                            <label>Seed (Deterministic Mode)</label>
                            <input type="number" @bind="_seed" class="roller-input" placeholder="Optional" />
                        </div>
                    }
                    <button class="btn-rn-ghost debug-toggle" @onclick="() => _showTools = !_showTools">
                        @(_showTools ? "Hide" : "Show") Debug Tools
                    </button>
                </div>
                
                @if (_lastResultDto != null)
                {
                    <div class="result-box @(_lastResultDto.IsExceptionalSuccess ? "exceptional" : "") @(_lastResultDto.IsDramaticFailure ? "dramatic-failure" : "") @(_shakeClass) @(_isRolling ? "results-rolling" : "")"
                         aria-live="polite">
                        <h4 class="result-title">
                            @if (_isRolling)
                            {
                                <span>Rolling...</span>
                            }
                            else
                            {
                                <span id="@_successCountId" aria-label="@_lastResultDto.Successes Successes @(_lastResultDto.IsExceptionalSuccess ? "Exceptional!" : "") @(_lastResultDto.IsDramaticFailure ? "Dramatic Failure!" : "")">
                                    @_lastResultDto.Successes
                                </span> @("Success" + (_lastResultDto.Successes != 1 ? "es" : ""))
                            }
                        </h4>
                        @if (!_isRolling)
                        {
                            @if (_lastResultDto.IsExceptionalSuccess)
                            {
                                <span class="result-badge exceptional-badge">✨ Exceptional Success!</span>
                            }
                            @if (_lastResultDto.IsDramaticFailure)
                            {
                                <span class="result-badge failure-badge">💀 Dramatic Failure!</span>
                            }
                            
                            <div style="margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                                @if (_shareSlug == null)
                                {
                                    <button class="btn-rn-ghost" style="font-size: 0.85em;" @onclick="ShareRoll" disabled="@_sharing">
                                        @(_sharing ? "Generating Link..." : "🔗 Share Public Link")
                                    </button>
                                }
                                else
                                {
                                    <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                        <span class="share-url" style="font-size: 0.8em; color: var(--gold); word-break: break-all;">Link: @GetShareUrl()</span>
                                        <button type="button" class="btn-rn-ghost" style="font-size: 0.85em; white-space: nowrap;" @onclick="CopyShareUrl" disabled="@_copying">
                                            @(_copying ? "Copied!" : "📋 Copy")
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        
                        <div class="dice-results">
                            @{ int dieIndex = 0; }
                            @foreach (var die in _lastResultDto.DiceRolled)
                            {
                                <span class="die-result @(_isRolling ? "rolling-die" : (IsDieShownAsSuccess(die, _lastResultDto.IsChanceDie) ? "success-die" : "fail-die"))"
                                      style="--die-index: @dieIndex">@(_isRolling ? "" : die.ToString())</span>
                                dieIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
