@using RequiemNexus.Domain.Services
@using RequiemNexus.Domain.Contracts
@using RequiemNexus.Domain.Models
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using RequiemNexus.Application.Contracts
@using System.Security.Claims
@inject ToastService ToastService
@inject IDiceService DiceService
@inject SessionClientService SessionClient
@inject IPublicRollService PublicRollService
@inject ITraitResolver TraitResolver
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider
@inject NavigationManager NavigationManager
@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop @(_isRolling ? "backdrop-surge" : "")" @onclick="Close">
        <div class="modal-panel dice-roller-modal" @onclick:stopPropagation role="dialog" aria-modal="true" aria-labelledby="dice-roller-title">
            @if (_showBurst)
            {
                <div class="particle-burst" aria-hidden="true">
                    @for (int a = 0; a < 8; a++)
                    {
                        <span class="burst-particle" style="--angle: @(a * 45)deg"></span>
                    }
                </div>
            }

            <div class="modal-header">
                <h3 id="dice-roller-title">Roll: @TraitName</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            
            <div class="modal-body">
                <div class="roller-form-group">
                    <label>@(FixedDicePool.HasValue ? "Pool (with modifiers)" : $"Base trait ({TraitName})")</label>
                    <input type="number" value="@(FixedDicePool ?? BaseDice)" readonly class="roller-input" style="background: rgba(0,0,0,0.5);" />
                </div>
                
                @if (Character != null && !FixedDicePool.HasValue)
                {
                    <div class="roller-form-group">
                        <label>Associated Trait</label>
                        <select value="@_associatedTraitName" @onchange="OnAssociatedTraitChanged" class="roller-input" style="width: 100%; padding: 8px;">
                            <option value="">-- None --</option>
                            <optgroup label="Attributes">
                                @foreach (var attr in _attributes.Where(a => a != TraitName))
                                {
                                    <option value="@attr">@attr</option>
                                }
                            </optgroup>

                            <optgroup label="Skills">
                                @foreach (var skill in _skills.Where(s => s != TraitName))
                                {
                                    <option value="@skill">@skill</option>
                                }
                            </optgroup>

                        </select>
                    </div>
                }

                <div class="roller-form-group">
                    <label>Modifiers (Bonus / Penalty)</label>
                    <input type="number" @bind="_modifier" class="roller-input" />
                </div>
                
                <div class="roller-form-group">
                    <label>Total Pool</label>
                    <strong class="pool-total">@(TotalPool <= 0 ? "Chance Die" : TotalPool.ToString())</strong>
                </div>

                <div class="options-group">
                    <label class="option-label"><input type="checkbox" @bind="_tenAgain" /> 10-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_nineAgain" /> 9-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_eightAgain" /> 8-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_isRote" /> Rote Action</label>
                </div>
                
                <div class="roller-actions">
                    <button class="btn-rn-primary roll-action-btn" @onclick="RollDice">Roll the Dice</button>
                    @if (_showTools)
                    {
                        <div class="debug-tools">
                            <label>Seed (Deterministic Mode)</label>
                            <input type="number" @bind="_seed" class="roller-input" placeholder="Optional" />
                        </div>
                    }
                    <button class="btn-rn-ghost debug-toggle" @onclick="() => _showTools = !_showTools">
                        @(_showTools ? "Hide" : "Show") Debug Tools
                    </button>
                </div>
                
                @if (_lastResultDto != null)
                {
                    <div class="result-box @(_lastResultDto.IsExceptionalSuccess ? "exceptional" : "") @(_lastResultDto.IsDramaticFailure ? "dramatic-failure" : "") @(_shakeClass) @(_isRolling ? "results-rolling" : "")"
                         aria-live="polite">
                        <h4 class="result-title">
                            @if (_isRolling)
                            {
                                <span>Rolling...</span>
                            }
                            else
                            {
                                <span id="@_successCountId" aria-label="@_lastResultDto.Successes Successes @(_lastResultDto.IsExceptionalSuccess ? "Exceptional!" : "") @(_lastResultDto.IsDramaticFailure ? "Dramatic Failure!" : "")">
                                    @_lastResultDto.Successes
                                </span> @("Success" + (_lastResultDto.Successes != 1 ? "es" : ""))
                            }
                        </h4>
                        @if (!_isRolling)
                        {
                            @if (_lastResultDto.IsExceptionalSuccess)
                            {
                                <span class="result-badge exceptional-badge">✨ Exceptional Success!</span>
                            }
                            @if (_lastResultDto.IsDramaticFailure)
                            {
                                <span class="result-badge failure-badge">💀 Dramatic Failure!</span>
                            }
                            
                            <div style="margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                                @if (_shareSlug == null)
                                {
                                    <button class="btn-rn-ghost" style="font-size: 0.85em;" @onclick="ShareRoll" disabled="@_sharing">
                                        @(_sharing ? "Generating Link..." : "🔗 Share Public Link")
                                    </button>
                                }
                                else
                                {
                                    <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                        <span class="share-url" style="font-size: 0.8em; color: var(--gold); word-break: break-all;">Link: @GetShareUrl()</span>
                                        <button type="button" class="btn-rn-ghost" style="font-size: 0.85em; white-space: nowrap;" @onclick="CopyShareUrl" disabled="@_copying">
                                            @(_copying ? "Copied!" : "📋 Copy")
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        
                        <div class="dice-results">
                            @{ int dieIndex = 0; }
                            @foreach (var die in _lastResultDto.DiceRolled)
                            {
                                <span class="die-result @(_isRolling ? "rolling-die" : (die >= 8 ? "success-die" : "fail-die"))"
                                      style="--die-index: @dieIndex">@(_isRolling ? "" : die.ToString())</span>
                                dieIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string TraitName { get; set; } = string.Empty;
    [Parameter] public int BaseDice { get; set; } = 1;
    [Parameter] public RequiemNexus.Data.Models.Character? Character { get; set; }

    /// <summary>When set, pool size is fixed (e.g. devotion) and associated trait UI is hidden.</summary>
    [Parameter] public int? FixedDicePool { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string _associatedTraitName { get; set; } = string.Empty;
    private int _modifier { get; set; } = 0;
    private bool _tenAgain { get; set; } = true;
    private bool _nineAgain { get; set; } = false;
    private bool _eightAgain { get; set; } = false;
    private bool _isRote { get; set; } = false;
    private int? _seed { get; set; } = null;
    private DiceRollResultDto? _lastResultDto;
    private bool _showTools = false;

    private string _successCountId = $"success-count-{Guid.NewGuid():N}";
    private string _shakeClass = string.Empty;
    private bool _showBurst = false;
    private bool _isRolling = false;
    private bool _sharing = false;
    private bool _copying = false;
    private string? _shareSlug;

    private readonly string[] _attributes = RequiemNexus.Domain.TraitMetadata.AllAttributes.Select(a => a.ToString()).ToArray();
    private readonly string[] _skills = RequiemNexus.Domain.TraitMetadata.AllSkills.Select(s => s.ToString()).ToArray();

    protected override void OnInitialized()
    {
        SessionClient.DiceRollReceived += HandleDiceRollReceived;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        await RefreshResolverTotalAsync();
    }

    private async Task OnAssociatedTraitChanged(ChangeEventArgs e)
    {
        _associatedTraitName = e.Value?.ToString() ?? string.Empty;
        await RefreshResolverTotalAsync();
    }

    private async Task RefreshResolverTotalAsync()
    {
        _resolverTotal = null;
        if (Character == null || !IsVisible || FixedDicePool.HasValue)
        {
            return;
        }

        RequiemNexus.Domain.Models.PoolDefinition? pool = RequiemNexus.Domain.SheetPoolBuilder.TryCreate(TraitName, _associatedTraitName);
        if (pool != null)
        {
            _resolverTotal = await TraitResolver.ResolvePoolAsync(Character, pool);
        }
    }

    private int AssociatedTraitDice
    {
        get
        {
            if (string.IsNullOrEmpty(_associatedTraitName) || Character == null) return 0;
            var propName = _associatedTraitName.Replace(" ", "");
            if (RequiemNexus.Domain.TraitMetadata.IsAttribute(propName))
                return Character.GetAttributeRating(propName);
            else
                return Character.GetSkillRating(propName);
        }
    }

    private int? _resolverTotal;

    private int TotalPool
    {
        get
        {
            int basePart = FixedDicePool ?? _resolverTotal ?? (BaseDice + AssociatedTraitDice);
            return Math.Max(0, basePart + _modifier);
        }
    }

    private async Task Close()
    {
        IsVisible = false;
        _lastResultDto = null;
        _shareSlug = null;
        _associatedTraitName = string.Empty;
        _modifier = 0;
        _resolverTotal = null;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private string GetShareUrl() => $"{NavigationManager.BaseUri}rolls/{_shareSlug}";

    private async Task CopyShareUrl()
    {
        if (_shareSlug == null || _copying) return;
        var url = GetShareUrl();
        _copying = true;
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", url);
            ToastService.Show("Copied", "Link copied to clipboard.", ToastType.Success, 2000);
        }
        finally
        {
            _copying = false;
        }
    }

    private async Task ShareRoll()
    {
        if (_lastResultDto == null || _sharing) return;

        _sharing = true;
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (userId != null)
            {
                var description = string.IsNullOrEmpty(_associatedTraitName)
                    ? TraitName
                    : $"{TraitName} + {_associatedTraitName}";

                if (_modifier != 0)
                {
                    description += $" ({(_modifier > 0 ? "+" : "")}{_modifier})";
                }

                _shareSlug = await PublicRollService.ShareRollAsync(userId, Character?.CampaignId, description, _lastResultDto);
            }
        }
        finally
        {
            _sharing = false;
        }
    }

    private async Task RollDice()
    {
        _isRolling = true;
        _showBurst = false;
        _shakeClass = string.Empty;
        _shareSlug = null;

        var description = string.IsNullOrEmpty(_associatedTraitName)
            ? TraitName
            : $"{TraitName} + {_associatedTraitName}";

        if (_modifier != 0)
        {
            description += $" ({(_modifier > 0 ? "+" : "")}{_modifier})";
        }

        if (SessionClient.IsConnected && Character?.CampaignId != null)
        {
            // Server-Side Roll (The Masquerade Audit - Step 4)
            await SessionClient.RollDiceAsync(
                Character.CampaignId.Value,
                Character.Id,
                TotalPool,
                description,
                _tenAgain,
                _nineAgain,
                _eightAgain,
                _isRote);
                
            // The result will come back via HandleDiceRollReceived
        }
        else
        {
            // Fallback: Local Client-Side Roll (Solo/Offline)
            var result = DiceService.Roll(TotalPool, _tenAgain, _nineAgain, _eightAgain, _isRote, _seed);
            
            var userName = Character?.Name ?? "Player";
            var rollDto = new DiceRollResultDto(
                userName,
                "offline",
                Character?.Id,
                description,
                result.Successes,
                result.IsExceptionalSuccess,
                result.IsDramaticFailure,
                result.DiceRolled,
                DateTimeOffset.UtcNow);

            await ProcessRollResult(rollDto);
        }
    }

    private void HandleDiceRollReceived(DiceRollResultDto roll)
    {
        // Only react to our own roll to avoid modal popping for others (though only the roller has the modal open)
        // If the modal is open, we assume we might be waiting for this result.
        if (!IsVisible) return;

        // Verify it was us (the character ID should match if provided)
        if (Character != null && roll.CharacterId.HasValue && roll.CharacterId != Character.Id) return;

        _ = InvokeAsync(() => ProcessRollResult(roll));
    }

    private async Task ProcessRollResult(DiceRollResultDto result)
    {
        _lastResultDto = result;
        
        // Simulate "rolling" time for suspense and animation
        await Task.Delay(800); 
        
        _isRolling = false;

        // Dramatic Failure Screen Shake
        if (_lastResultDto.IsDramaticFailure)
        {
            _shakeClass = "shake";
        }

        // Exceptional Success Particle Burst
        if (_lastResultDto.IsExceptionalSuccess)
        {
            _showBurst = true;
        }
        
        StateHasChanged();
        
        if (_showBurst)
        {
            await Task.Delay(1500);
            _showBurst = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        SessionClient.DiceRollReceived -= HandleDiceRollReceived;
    }
}
