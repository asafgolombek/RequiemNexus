@using RequiemNexus.Domain.Services
@using RequiemNexus.Domain.Contracts
@using RequiemNexus.Domain.Models
@using RequiemNexus.Domain.Enums
@using RequiemNexus.Data.RealTime
@using RequiemNexus.Web.Services
@using RequiemNexus.Application.Contracts
@using System.Security.Claims
@inject ToastService ToastService
@inject IDiceService DiceService
@inject SessionClientService SessionClient
@inject IPublicRollService PublicRollService
@inject ITraitResolver TraitResolver
@inject IRiteRollOutcomeService RiteRollOutcomeService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider
@inject NavigationManager NavigationManager
@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop @(_isRolling ? "backdrop-surge" : "")" @onclick="Close">
        <div class="modal-panel dice-roller-modal" @onclick:stopPropagation role="dialog" aria-modal="true" aria-labelledby="dice-roller-title">
            @if (_showBurst)
            {
                <div class="particle-burst" aria-hidden="true">
                    @for (int a = 0; a < 8; a++)
                    {
                        <span class="burst-particle" style="--angle: @(a * 45)deg"></span>
                    }
                </div>
            }

            <div class="modal-header">
                <h3 id="dice-roller-title">@(IsRiteExtendedMode ? $"Rite: {TraitName}" : $"Roll: {TraitName}")</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            
            <div class="modal-body">
                @if (IsRiteExtendedMode)
                {
                    <div class="rite-extended-summary" style="margin-bottom: 1rem; padding: 0.75rem 1rem; background: rgba(139, 0, 0, 0.15); border: 1px solid rgba(255, 200, 200, 0.25); border-radius: 6px;">
                        <p style="margin: 0 0 0.35rem 0;"><strong>Extended ritual</strong> — V:tR 2e p. 152</p>
                        <ul style="margin: 0; padding-left: 1.2rem;">
                            <li>Successes accumulated: <strong>@_riteAccumulatedSuccesses</strong> / @RiteExtendedTargetSuccesses</li>
                            <li>Rolls remaining: <strong>@RiteRollsRemaining</strong> (max @RiteExtendedMaxRolls unmodified pool)</li>
                            <li>Interval per roll: <strong>@(RiteExtendedMinutesPerRoll ?? 30)</strong> min</li>
                        </ul>
                        @if (RiteExtendedMaxRolls is 0)
                        {
                            <p class="chance-die-hint" style="margin-top: 0.5rem;">No unmodified pool — this rite cannot be rolled as an extended action.</p>
                        }
                        @if (ShowRiteCompletedBanner)
                        {
                            <p style="margin: 0.5rem 0 0 0; color: var(--gold, #c9a227);"><strong>Rite completed</strong> — apply the effect at the table.</p>
                        }
                        else if (ShowRiteFailedNoRollsBanner)
                        {
                            <p style="margin: 0.5rem 0 0 0; color: #f88;"><strong>Ritual failed</strong> — no rolls remain; costs were already spent when you began.</p>
                        }
                    </div>
                }
                <div class="roller-form-group">
                    <label>@(FixedDicePool.HasValue ? "Pool (with modifiers)" : $"Base trait ({TraitName})")</label>
                    <input type="number" value="@(FixedDicePool ?? BaseDice)" readonly class="roller-input" style="background: rgba(0,0,0,0.5);" />
                </div>
                
                @if (Character != null && !FixedDicePool.HasValue)
                {
                    <div class="roller-form-group">
                        <label>Associated Trait</label>
                        <select value="@_associatedTraitName" @onchange="OnAssociatedTraitChanged" class="roller-input" style="width: 100%; padding: 8px;">
                            <option value="">-- None --</option>
                            <optgroup label="Attributes">
                                @foreach (var attr in _attributes.Where(a => a != TraitName))
                                {
                                    <option value="@attr">@attr</option>
                                }
                            </optgroup>

                            <optgroup label="Skills">
                                @foreach (var skill in _skills.Where(s => s != TraitName))
                                {
                                    <option value="@skill">@skill</option>
                                }
                            </optgroup>

                        </select>
                    </div>
                }

                @if (!IsRiteExtendedMode)
                {
                    <div class="roller-form-group">
                        <label>Modifiers (Bonus / Penalty)</label>
                        <input type="number" @bind="_modifier" class="roller-input" />
                    </div>
                }
                
                <div class="roller-form-group">
                    <label>Total Pool</label>
                    <strong class="pool-total">@(IsChanceDiePool ? "Chance Die" : TotalPool.ToString())</strong>
                </div>

                @if (IsChanceDiePool)
                {
                    <p class="chance-die-hint">Chance die: only a 10 counts as a success. 10-again, 9-again, 8-again, and rote do not apply.</p>
                }

                <div class="options-group">
                    <label class="option-label"><input type="checkbox" @bind="_tenAgain" disabled="@IsChanceDiePool" /> 10-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_nineAgain" disabled="@IsChanceDiePool" /> 9-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_eightAgain" disabled="@IsChanceDiePool" /> 8-Again</label>
                    <label class="option-label"><input type="checkbox" @bind="_isRote" disabled="@IsChanceDiePool" /> Rote Action</label>
                </div>
                
                @if (IsRiteExtendedMode && _riteFailureNeedsChoice)
                {
                    <div class="roller-form-group" style="border: 1px solid rgba(255,200,200,0.3); padding: 0.75rem; border-radius: 6px;">
                        <p style="margin: 0 0 0.5rem 0;">This roll scored no successes. Continue to take the Stumbled Condition and keep casting, or abandon (costs stay spent).</p>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <button type="button" class="btn-rn-primary" @onclick="ContinueAfterRiteFailureAsync">Continue ritual</button>
                            <button type="button" class="btn-rn-ghost" @onclick="AbandonRite">Abandon (costs already spent)</button>
                        </div>
                    </div>
                }
                <div class="roller-actions">
                    <button class="btn-rn-primary roll-action-btn" @onclick="RollDice" disabled="@RiteRollButtonDisabled">Roll the Dice</button>
                    @if (_showTools)
                    {
                        <div class="debug-tools">
                            <label>Seed (Deterministic Mode)</label>
                            <input type="number" @bind="_seed" class="roller-input" placeholder="Optional" />
                        </div>
                    }
                    <button class="btn-rn-ghost debug-toggle" @onclick="() => _showTools = !_showTools">
                        @(_showTools ? "Hide" : "Show") Debug Tools
                    </button>
                </div>
                
                @if (_lastResultDto != null)
                {
                    <div class="result-box @(_lastResultDto.IsExceptionalSuccess ? "exceptional" : "") @(_lastResultDto.IsDramaticFailure ? "dramatic-failure" : "") @(_shakeClass) @(_isRolling ? "results-rolling" : "")"
                         aria-live="polite">
                        <h4 class="result-title">
                            @if (_isRolling)
                            {
                                <span>Rolling...</span>
                            }
                            else
                            {
                                <span id="@_successCountId" aria-label="@_lastResultDto.Successes Successes @(_lastResultDto.IsExceptionalSuccess ? "Exceptional!" : "") @(_lastResultDto.IsDramaticFailure ? "Dramatic Failure!" : "")">
                                    @_lastResultDto.Successes
                                </span> @("Success" + (_lastResultDto.Successes != 1 ? "es" : ""))
                            }
                        </h4>
                        @if (!_isRolling)
                        {
                            @if (_lastResultDto.IsExceptionalSuccess)
                            {
                                <span class="result-badge exceptional-badge">✨ Exceptional Success!</span>
                            }
                            @if (_lastResultDto.IsDramaticFailure)
                            {
                                <span class="result-badge failure-badge">💀 Dramatic Failure!</span>
                            }
                            
                            <div style="margin-top: 15px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                                @if (_shareSlug == null)
                                {
                                    <button class="btn-rn-ghost" style="font-size: 0.85em;" @onclick="ShareRoll" disabled="@_sharing">
                                        @(_sharing ? "Generating Link..." : "🔗 Share Public Link")
                                    </button>
                                }
                                else
                                {
                                    <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                        <span class="share-url" style="font-size: 0.8em; color: var(--gold); word-break: break-all;">Link: @GetShareUrl()</span>
                                        <button type="button" class="btn-rn-ghost" style="font-size: 0.85em; white-space: nowrap;" @onclick="CopyShareUrl" disabled="@_copying">
                                            @(_copying ? "Copied!" : "📋 Copy")
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        
                        <div class="dice-results">
                            @{ int dieIndex = 0; }
                            @foreach (var die in _lastResultDto.DiceRolled)
                            {
                                <span class="die-result @(_isRolling ? "rolling-die" : (IsDieShownAsSuccess(die, _lastResultDto.IsChanceDie) ? "success-die" : "fail-die"))"
                                      style="--die-index: @dieIndex">@(_isRolling ? "" : die.ToString())</span>
                                dieIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string TraitName { get; set; } = string.Empty;
    [Parameter] public int BaseDice { get; set; } = 1;
    [Parameter] public RequiemNexus.Data.Models.Character? Character { get; set; }

    /// <summary>When set, pool size is fixed (e.g. devotion) and associated trait UI is hidden.</summary>
    [Parameter] public int? FixedDicePool { get; set; }

    /// <summary>Optional blood rite extended-action cap (unmodified pool). Requires <see cref="FixedDicePool"/> and <see cref="RiteExtendedTargetSuccesses"/>.</summary>
    [Parameter] public int? RiteExtendedMaxRolls { get; set; }

    /// <summary>Successes required to complete the rite (shown in the roller).</summary>
    [Parameter] public int? RiteExtendedTargetSuccesses { get; set; }

    /// <summary>Minutes per extended roll (30 or 15 per V:tR 2e).</summary>
    [Parameter] public int? RiteExtendedMinutesPerRoll { get; set; }

    /// <summary>Tradition for ritual outcome Conditions (Crúac / Theban / Necromancy). Set with extended rite parameters.</summary>
    [Parameter] public SorceryType? RiteOutcomeTradition { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private const string RiteExtendedDescriptionMarker = "extended rite";

    private string _associatedTraitName { get; set; } = string.Empty;
    private int _modifier { get; set; } = 0;
    private bool _tenAgain { get; set; } = true;
    private bool _nineAgain { get; set; } = false;
    private bool _eightAgain { get; set; } = false;
    private bool _isRote { get; set; } = false;
    private int? _seed { get; set; } = null;
    private DiceRollResultDto? _lastResultDto;
    private bool _showTools = false;

    private string _successCountId = $"success-count-{Guid.NewGuid():N}";
    private string _shakeClass = string.Empty;
    private bool _showBurst = false;
    private bool _isRolling = false;
    private bool _sharing = false;
    private bool _copying = false;
    private string? _shareSlug;

    private int _riteRollsUsed;
    private int _riteAccumulatedSuccesses;
    private bool _riteFailureNeedsChoice;
    private bool _riteRollInFlight;
    private bool _rollerWasVisible;

    private readonly string[] _attributes = RequiemNexus.Domain.Services.TraitMetadata.AllAttributes.Select(a => a.ToString()).ToArray();
    private readonly string[] _skills = RequiemNexus.Domain.Services.TraitMetadata.AllSkills.Select(s => s.ToString()).ToArray();

    protected override void OnInitialized()
    {
        SessionClient.DiceRollReceived += HandleDiceRollReceived;
    }

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (IsVisible && !_rollerWasVisible && IsRiteExtendedMode)
        {
            _riteRollsUsed = 0;
            _riteAccumulatedSuccesses = 0;
            _riteFailureNeedsChoice = false;
            _riteRollInFlight = false;
        }

        _rollerWasVisible = IsVisible;
        await RefreshResolverTotalAsync();
    }

    private async Task OnAssociatedTraitChanged(ChangeEventArgs e)
    {
        _associatedTraitName = e.Value?.ToString() ?? string.Empty;
        await RefreshResolverTotalAsync();
    }

    private async Task RefreshResolverTotalAsync()
    {
        _resolverTotal = null;
        if (Character == null || !IsVisible || FixedDicePool.HasValue)
        {
            return;
        }

        RequiemNexus.Domain.Models.PoolDefinition? pool = RequiemNexus.Domain.Services.SheetPoolBuilder.TryCreate(TraitName, _associatedTraitName);
        if (pool != null)
        {
            _resolverTotal = await TraitResolver.ResolvePoolAsync(Character, pool);
        }
    }

    private int AssociatedTraitDice
    {
        get
        {
            if (string.IsNullOrEmpty(_associatedTraitName) || Character == null) return 0;
            var propName = _associatedTraitName.Replace(" ", "");
            if (RequiemNexus.Domain.Services.TraitMetadata.IsAttribute(propName))
                return Character.GetAttributeRating(propName);
            else
                return Character.GetSkillRating(propName);
        }
    }

    private int? _resolverTotal;

    private bool IsRiteExtendedMode =>
        FixedDicePool.HasValue
        && RiteExtendedMaxRolls.HasValue
        && RiteExtendedTargetSuccesses.HasValue;

    private int RiteRollsRemaining =>
        !RiteExtendedMaxRolls.HasValue ? 0 : Math.Max(0, RiteExtendedMaxRolls.Value - _riteRollsUsed);

    private bool ShowRiteCompletedBanner =>
        IsRiteExtendedMode
        && _riteAccumulatedSuccesses >= RiteExtendedTargetSuccesses!.Value;

    private bool ShowRiteFailedNoRollsBanner =>
        IsRiteExtendedMode
        && _lastResultDto != null
        && !_isRolling
        && _riteRollsUsed >= RiteExtendedMaxRolls!.Value
        && _riteAccumulatedSuccesses < RiteExtendedTargetSuccesses!.Value;

    private bool RiteRollBlocked =>
        IsRiteExtendedMode
        && (
            _riteFailureNeedsChoice
            || _riteAccumulatedSuccesses >= RiteExtendedTargetSuccesses!.Value
            || _riteRollsUsed >= RiteExtendedMaxRolls!.Value
            || RiteExtendedMaxRolls!.Value <= 0);

    private bool RiteRollButtonDisabled => _isRolling || RiteRollBlocked;

    private int TotalPool
    {
        get
        {
            if (IsRiteExtendedMode)
            {
                return Math.Max(0, FixedDicePool ?? 0);
            }

            int basePart = FixedDicePool ?? _resolverTotal ?? (BaseDice + AssociatedTraitDice);
            return Math.Max(0, basePart + _modifier);
        }
    }

    private bool IsChanceDiePool => TotalPool <= 0;

    private static bool IsDieShownAsSuccess(int dieFace, bool isChanceDie) =>
        isChanceDie ? dieFace == 10 : dieFace >= 8;

    private async Task Close()
    {
        IsVisible = false;
        _lastResultDto = null;
        _shareSlug = null;
        _associatedTraitName = string.Empty;
        _modifier = 0;
        _resolverTotal = null;
        _riteRollsUsed = 0;
        _riteAccumulatedSuccesses = 0;
        _riteFailureNeedsChoice = false;
        _riteRollInFlight = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task ContinueAfterRiteFailureAsync()
    {
        if (Character != null && RiteOutcomeTradition.HasValue)
        {
            string? userId = await TryGetCurrentUserIdAsync();
            if (userId != null)
            {
                try
                {
                    await RiteRollOutcomeService.ApplyRiteRollOutcomeAsync(
                        Character.Id,
                        userId,
                        RiteOutcomeTradition.Value,
                        RiteRollOutcomeTrigger.ContinueAfterZeroSuccesses);
                }
                catch (Exception ex)
                {
                    ToastService.Show("Rite", ex.Message, ToastType.Error);
                    return;
                }
            }
        }

        _riteFailureNeedsChoice = false;
    }

    private async Task AbandonRite()
    {
        await Close();
    }

    private string GetShareUrl() => $"{NavigationManager.BaseUri}rolls/{_shareSlug}";

    private async Task CopyShareUrl()
    {
        if (_shareSlug == null || _copying) return;
        var url = GetShareUrl();
        _copying = true;
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", url);
            ToastService.Show("Copied", "Link copied to clipboard.", ToastType.Success, 2000);
        }
        finally
        {
            _copying = false;
        }
    }

    private async Task ShareRoll()
    {
        if (_lastResultDto == null || _sharing) return;

        _sharing = true;
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (userId != null)
            {
                var description = string.IsNullOrEmpty(_associatedTraitName)
                    ? TraitName
                    : $"{TraitName} + {_associatedTraitName}";

                if (_modifier != 0)
                {
                    description += $" ({(_modifier > 0 ? "+" : "")}{_modifier})";
                }

                _shareSlug = await PublicRollService.ShareRollAsync(userId, Character?.CampaignId, description, _lastResultDto);
            }
        }
        finally
        {
            _sharing = false;
        }
    }

    private async Task RollDice()
    {
        if (RiteRollButtonDisabled)
        {
            return;
        }

        if (IsRiteExtendedMode && RiteExtendedMaxRolls.GetValueOrDefault() <= 0)
        {
            ToastService.Show("Rite", "This rite has no unmodified pool for extended rolls.", ToastType.Warning);
            return;
        }

        _isRolling = true;
        _showBurst = false;
        _shakeClass = string.Empty;
        _shareSlug = null;

        string description;
        if (IsRiteExtendedMode)
        {
            int nextRoll = _riteRollsUsed + 1;
            description = $"{TraitName} — {RiteExtendedDescriptionMarker} (roll {nextRoll} of {RiteExtendedMaxRolls!.Value})";
            _riteRollInFlight = true;
        }
        else
        {
            description = string.IsNullOrEmpty(_associatedTraitName)
                ? TraitName
                : $"{TraitName} + {_associatedTraitName}";

            if (_modifier != 0)
            {
                description += $" ({(_modifier > 0 ? "+" : "")}{_modifier})";
            }
        }

        bool chanceDie = IsChanceDiePool;
        bool tenAgain = chanceDie ? false : _tenAgain;
        bool nineAgain = chanceDie ? false : _nineAgain;
        bool eightAgain = chanceDie ? false : _eightAgain;
        bool isRote = chanceDie ? false : _isRote;

        try
        {
            if (SessionClient.IsConnected && Character?.CampaignId != null)
            {
                await SessionClient.RollDiceAsync(
                    Character.CampaignId.Value,
                    Character.Id,
                    TotalPool,
                    description,
                    tenAgain,
                    nineAgain,
                    eightAgain,
                    isRote);
            }
            else
            {
                var result = DiceService.Roll(TotalPool, tenAgain, nineAgain, eightAgain, isRote, _seed);

                var userName = Character?.Name ?? "Player";
                var rollDto = new DiceRollResultDto(
                    userName,
                    "offline",
                    Character?.Id,
                    description,
                    result.Successes,
                    result.IsExceptionalSuccess,
                    result.IsDramaticFailure,
                    result.DiceRolled,
                    DateTimeOffset.UtcNow,
                    result.IsChanceDie);

                await ProcessRollResult(rollDto);
            }
        }
        catch (Exception)
        {
            _isRolling = false;
            _riteRollInFlight = false;
            throw;
        }
    }

    private void HandleDiceRollReceived(DiceRollResultDto roll)
    {
        if (!IsVisible)
        {
            return;
        }

        if (Character != null && roll.CharacterId.HasValue && roll.CharacterId != Character.Id)
        {
            return;
        }

        if (IsRiteExtendedMode && _riteRollInFlight
            && !roll.PoolDescription.Contains(RiteExtendedDescriptionMarker, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _ = InvokeAsync(() => ProcessRollResult(roll));
    }

    private async Task ProcessRollResult(DiceRollResultDto result)
    {
        _lastResultDto = result;
        
        // Simulate "rolling" time for suspense and animation
        await Task.Delay(800); 
        
        _isRolling = false;

        // Dramatic Failure Screen Shake
        if (_lastResultDto.IsDramaticFailure)
        {
            _shakeClass = "shake";
        }

        // Exceptional Success Particle Burst
        if (_lastResultDto.IsExceptionalSuccess)
        {
            _showBurst = true;
        }

        bool riteRollCounted = ApplyRiteExtendedRollAccounting(result);

        if (riteRollCounted && Character != null && RiteOutcomeTradition.HasValue)
        {
            string? userId = await TryGetCurrentUserIdAsync();
            if (userId != null)
            {
                try
                {
                    if (result.IsDramaticFailure)
                    {
                        await RiteRollOutcomeService.ApplyRiteRollOutcomeAsync(
                            Character.Id,
                            userId,
                            RiteOutcomeTradition.Value,
                            RiteRollOutcomeTrigger.DramaticFailure);
                    }
                    else if (result.IsExceptionalSuccess)
                    {
                        await RiteRollOutcomeService.ApplyRiteRollOutcomeAsync(
                            Character.Id,
                            userId,
                            RiteOutcomeTradition.Value,
                            RiteRollOutcomeTrigger.ExceptionalSuccess);
                    }
                }
                catch (Exception ex)
                {
                    ToastService.Show("Rite", ex.Message, ToastType.Error);
                }
            }
        }

        StateHasChanged();
        
        if (_showBurst)
        {
            await Task.Delay(1500);
            _showBurst = false;
            StateHasChanged();
        }
    }

    private async Task<string?> TryGetCurrentUserIdAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private bool ApplyRiteExtendedRollAccounting(DiceRollResultDto rollResult)
    {
        if (!IsRiteExtendedMode || !_riteRollInFlight)
        {
            return false;
        }

        if (!rollResult.PoolDescription.Contains(RiteExtendedDescriptionMarker, StringComparison.OrdinalIgnoreCase))
        {
            _riteRollInFlight = false;
            return false;
        }

        int max = RiteExtendedMaxRolls!.Value;
        int target = RiteExtendedTargetSuccesses!.Value;

        _riteRollsUsed++;
        _riteAccumulatedSuccesses += rollResult.Successes;
        _riteRollInFlight = false;

        _riteFailureNeedsChoice = rollResult.Successes == 0
            && _riteRollsUsed < max
            && _riteAccumulatedSuccesses < target;
        return true;
    }

    public void Dispose()
    {
        SessionClient.DiceRollReceived -= HandleDiceRollReceived;
    }
}
