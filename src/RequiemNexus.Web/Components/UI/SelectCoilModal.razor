@using RequiemNexus.Application.DTOs

@if (IsOpen)
{
<div class="rn-modal-backdrop" @onclick="CloseModal">
    <div class="rn-modal-panel rn-modal-panel--wide" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="coil-modal-title">
        <div class="rn-modal-header">
            <h2 id="coil-modal-title" class="rn-modal-title">Purchase Coil</h2>
            <button type="button" class="rn-modal-close" @onclick="CloseModal" aria-label="Close">×</button>
        </div>
        <div class="rn-modal-body">
            @if (Coils.Count == 0)
            {
                <p class="rn-modal-empty">No eligible Coils.</p>
            }
            else
            {
                <ul class="rn-selection-list" role="list">
                    @foreach (var coil in Coils.OrderBy(c => c.ScaleName).ThenBy(c => c.Level))
                    {
                        <li class="rn-selection-item" role="listitem">
                            <div class="rn-selection-info">
                                <strong class="rn-selection-name">@coil.Name</strong>
                                <span class="rn-selection-meta">
                                    @coil.ScaleName — Tier @coil.Level
                                    @if (coil.IsChosenMystery)
                                    {
                                        <span class="rn-selection-badge">★ Chosen</span>
                                    }
                                </span>
                                <span class="rn-selection-cost">Cost: @coil.XpCost XP</span>
                                @if (!string.IsNullOrEmpty(coil.Description))
                                {
                                    <p class="rn-selection-desc">@coil.Description</p>
                                }
                            </div>
                            <button type="button" class="btn-primary-rn rn-selection-action" @onclick="() => SelectCoil(coil.Id)">Purchase</button>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public List<CoilSummaryDto> Coils { get; set; } = [];
    [Parameter] public EventCallback<int> OnCoilSelected { get; set; }

    private async Task SelectCoil(int coilId)
    {
        await OnCoilSelected.InvokeAsync(coilId);
        await CloseModal();
    }

    private async Task CloseModal()
    {
        await IsOpenChanged.InvokeAsync(false);
    }
}
